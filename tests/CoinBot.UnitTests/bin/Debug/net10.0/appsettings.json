{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Enrichers.Environment"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithEnvironmentName"
    ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=CoinBotDb;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=True"
  },
  "HealthMonitoring": {
    "Market": {
      "ValidationFreshnessMinutes": 15
    }
  },
  "ExecutionSafety": {
    "DataLatencyGuard": {
      "StaleDataThresholdSeconds": 3,
      "StopDataThresholdSeconds": 6,
      "ClockDriftThresholdSeconds": 2
    },
    "DemoSession": {
      "DefaultSeedAsset": "USDT",
      "DefaultSeedAmount": 10000,
      "ConsistencyTolerance": 0.00000001
    }
  },
  "Caching": {
    "InMemory": {
      "SizeLimit": 2048,
      "SymbolMetadataTtlMinutes": 60,
      "LatestPriceTtlSeconds": 15
    }
  },
  "MarketData": {
    "Binance": {
      "Enabled": false,
      "RestBaseUrl": "https://fapi.binance.com",
      "WebSocketBaseUrl": "wss://fstream.binance.com",
      "KlineInterval": "1m",
      "ExchangeInfoRefreshIntervalMinutes": 60,
      "ReconnectDelaySeconds": 5,
      "HeartbeatPersistenceIntervalSeconds": 1,
      "SeedSymbols": [
        "BTCUSDT",
        "ETHUSDT",
        "SOLUSDT"
      ]
    },
    "HistoricalGapFiller": {
      "Enabled": false,
      "ScanIntervalMinutes": 5,
      "LookbackCandles": 1440,
      "MaxCandlesPerRequest": 500,
      "MaxRetryAttempts": 3,
      "RetryDelaySeconds": 2,
      "Symbols": []
    },
    "Scanner": {
      "Enabled": true,
      "ScanIntervalSeconds": 30,
      "MaxUniverseSymbols": 100,
      "TopCandidateCount": 10,
      "VolumeLookbackHours": 24,
      "MaxDataAgeSeconds": 120,
      "Min24hQuoteVolume": 1000000,
      "MinPrice": 0.00000001,
      "MaxPrice": 1000000,
      "HandoffEnabled": true,
      "AllowedQuoteAssets": [
        "USDT"
      ]
    },
    "Indicators": {
      "RsiPeriod": 14,
      "MacdFastPeriod": 12,
      "MacdSlowPeriod": 26,
      "MacdSignalPeriod": 9,
      "BollingerPeriod": 20,
      "BollingerStandardDeviationMultiplier": 2.0
    }
  },
  "ExchangeSync": {
    "Binance": {
      "Enabled": false,
      "RestBaseUrl": "https://fapi.binance.com",
      "WebSocketBaseUrl": "wss://fstream.binance.com",
      "SessionScanIntervalSeconds": 15,
      "ReconnectDelaySeconds": 5,
      "ListenKeyRenewalIntervalMinutes": 30,
      "ReconciliationIntervalMinutes": 5,
      "RecvWindowMilliseconds": 5000
    }
  },
  "CredentialValidation": {
    "Binance": {
      "SpotProbeBaseUrl": "https://api.binance.com"
    }
  },
  "Alerting": {
    "ApplicationName": "CoinBot",
    "Slack": {
      "Enabled": false,
      "WebhookUrl": "SLACK_WEBHOOK_URL"
    },
    "Telegram": {
      "Enabled": false,
      "BotToken": "TELEGRAM_BOT_TOKEN",
      "ChatId": "TELEGRAM_CHAT_ID"
    }
  },
  "Mfa": {
    "EmailOtpCodeLength": 6,
    "EmailOtpLifetimeMinutes": 10,
    "EmailOtpMaxFailedAttempts": 5,
    "TotpCodeLength": 6,
    "TotpTimeStepSeconds": 30,
    "TotpAllowedTimeDriftSteps": 1,
    "TotpSecretSizeBytes": 20
  },
  "CredentialSecurity": {
    "Provider": "Environment",
    "KeyVersion": "credential-v1",
    "EnvironmentVariableName": "COINBOT_CREDENTIAL_ENCRYPTION_KEY_BASE64",
    "VaultKeyConfigurationPath": "CredentialSecurity:Vault:ResolvedKey",
    "RevalidationIntervalDays": 30,
    "RotationIntervalDays": 90
  },
  "IdentitySeed": {
    "SuperAdminEmail": "",
    "SuperAdminPassword": "",
    "SuperAdminFullName": "Super Admin"
  },
  "AllowedHosts": "*"
}



