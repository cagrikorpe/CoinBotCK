@{
    Layout = "_AdminAuthLayout";
    ViewData["Title"] = "Admin Login";
    ViewData["AuthTitle"] = "Super Admin erişimi";
    ViewData["AuthDescription"] = "Kullanıcı girişinden ayrı, daha kontrollü ve MFA zorunlu admin erişim foundation ekranı.";
    ViewData["AuthEyebrow"] = "Privileged Access";
    ViewData["AuthStage"] = "Admin Login";
    ViewData["AuthProgress"] = "1 / 2";
    ViewData["AuthBackHref"] = Url.Action("Overview", "Admin", new { area = "Admin" });
    ViewData["AuthHighlights"] = new[]
    {
        "Admin giriş kartı kullanıcı auth ekranından görsel olarak ayrışır",
        "MFA zorunluluğu ve genel hata alanı ilk bakışta görünür",
        "Loading, validation ve show/hide password aynı foundation ile taşınır"
    };
}

<div class="cb-auth-panel cb-auth-panel-compact cb-admin-auth-panel">
    <div class="cb-auth-panel-header">
        <div>
            <div class="cb-page-eyebrow">Privileged Access</div>
            <h2 class="cb-page-title">Admin paneline giriş yapın</h2>
            <p class="cb-page-description">Bu ekran gerçek auth enforcement içermez; ancak admin alanı için ayrı erişim dili, doğrulama alanları ve güvenlik notları hazırdır.</p>
        </div>
        @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = "MFA Required", Tone = "warning", IconText = "2F" })
    </div>

    <div class="cb-auth-alert cb-auth-alert-warning">
        Admin alanı için MFA zorunludur. Giriş başarılı olsa bile ikinci doğrulama adımı atlanmaz.
    </div>

    <form class="cb-auth-form-grid" action="#" method="post" novalidate>
        <div class="form-group mb-0">
            <label class="cb-form-label">E-posta veya kullanıcı adı</label>
            <input type="text" class="form-control cb-form-control" placeholder="Admin e-posta veya kullanıcı adı" autocomplete="username" />
            <div class="cb-field-feedback">Admin identity provider bağlandığında bu alan aynı kalıp ile gerçek backend’e bağlanacaktır.</div>
        </div>

        <div class="form-group mb-0">
            <div class="d-flex align-items-center justify-content-between">
                <label class="cb-form-label mb-0">Parola</label>
                <a href="#" class="cb-auth-inline-link">Erişim yardımı</a>
            </div>
            <div class="cb-auth-password-wrap">
                <input type="password" id="admin_login_password" class="form-control cb-form-control cb-form-control-with-action" placeholder="Parola" autocomplete="current-password" />
                <button type="button" class="cb-auth-field-action" data-cb-password-toggle data-cb-password-target="#admin_login_password">Göster</button>
            </div>
            <div class="cb-field-feedback">Show / hide password kullanıcı auth desenini yeniden kullanır; admin dilinde daha kontrollü helper text ile sunulur.</div>
        </div>

        <div class="cb-auth-row-between">
            <label class="checkbox checkbox-outline checkbox-outline-2x checkbox-primary mb-0 cb-auth-check-inline">
                <input type="checkbox" />
                <span></span>
                Bu cihazı düşük riskli olarak işaretle placeholder
            </label>
            <span class="cb-auth-meta">Gerçek remember-device backend’i bu fazda yoktur.</span>
        </div>

        <div class="cb-validation-summary cb-validation-summary-danger">
            Invalid credential, geçici erişim kilidi veya genel auth hataları bu bölgede gösterilir. Secret, token veya hassas içerik yazılmaz.
        </div>

        <div class="cb-auth-action-row">
            <button type="submit" class="btn btn-primary font-weight-bolder px-10" data-cb-button-loading>
                <span class="cb-btn-label">Admin giriş</span>
                <span class="cb-btn-spinner"></span>
            </button>
            <a asp-area="Admin" asp-controller="Admin" asp-action="Mfa" class="btn btn-clean text-muted font-weight-bold">MFA ekranını gör</a>
        </div>
    </form>

    <div class="cb-auth-footnote">
        Güvenlik notu: Admin erişimi ayrı shell, ayrı route ve ayrı session uyarı dili ile ele alınır. Brute-force, lockout ve gerçek rate-limit backend katmanında bağlanacaktır.
    </div>
</div>

<div class="row mt-6">
    <div class="col-xl-6">
        @await Html.PartialAsync("Foundation/_AdminSecurityHelpCard", new AdminSecurityHelpCardViewModel
        {
            Eyebrow = "Why protected?",
            Title = "Admin alanı neden ayrı korunuyor",
            Description = "Platform seviyesinde değişiklik yapabilen yüzeyler daha sert giriş ve daha görünür güvenlik sinyalleri gerektirir.",
            BadgeLabel = "Security",
            BadgeTone = "info",
            Items = new[]
            {
                "Kullanıcı panelinden ayrı erişim akışı",
                "MFA ve step-up security zemini",
                "Kritik aksiyonlarda audit reason beklentisi"
            }
        })
    </div>
    <div class="col-xl-6">
        @await Html.PartialAsync("Foundation/_AdminSecurityHelpCard", new AdminSecurityHelpCardViewModel
        {
            Eyebrow = "Operator notes",
            Title = "Erişim reddi durumunda ne yapılmalı",
            Description = "Yanlış role, eksik MFA veya süresi dolan oturum için çıkmaz oluşturmayan yönlendirme zemini hazırlanmıştır.",
            BadgeLabel = "Access",
            BadgeTone = "warning",
            Items = new[]
            {
                "Access denied ve insufficient permission ekranları ayrı tutulur",
                "Session expired ekranı yeniden doğrulamaya yönlendirir",
                "Role matrix görünümü beklenen kapsamı açıklar"
            },
            ActionText = "Role matrix görünümü",
            ActionHref = Url.Action("RoleMatrix", "Admin", new { area = "Admin" })
        })
    </div>
</div>
