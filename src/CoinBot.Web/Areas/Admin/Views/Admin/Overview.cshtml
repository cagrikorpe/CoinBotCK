@model AdminOperationsCenterViewModel
@using System.Linq
@using CoinBot.Web.ViewModels.Admin
@using CoinBot.Web.ViewModels.Foundation
@{
    var setup = Model.PrimaryFlow.Setup;
    var activation = Model.PrimaryFlow.Activation;
    var monitoring = Model.PrimaryFlow.Monitoring;
    var advanced = Model.PrimaryFlow.Advanced;
    var activationModel = ViewData["AdminActivationControlCenter"] as AdminActivationControlCenterViewModel;
    var executionSuccess = TempData["AdminExecutionSwitchSuccess"]?.ToString();
    var executionError = TempData["AdminExecutionSwitchError"]?.ToString();
    var clockDriftSuccess = TempData["AdminClockDriftSuccess"]?.ToString();
    var clockDriftError = TempData["AdminClockDriftError"]?.ToString();
    var currentModeIsDemo = string.Equals(setup.Items.FirstOrDefault(item => item.Key == "environment")?.Value, "Demo", StringComparison.OrdinalIgnoreCase);
    var setupConnectionTestAction = setup.Actions.FirstOrDefault(item => item.Key == "connection-test") ?? new AdminSuperAdminFlowActionViewModel("connection-test", "Baglantiyi Test Et", true, string.Empty, string.Empty);
    var activationPrepareAction = activation.Actions.FirstOrDefault(item => item.Key == "prepare") ?? new AdminSuperAdminFlowActionViewModel("prepare", "Sistemi Hazirla", true, string.Empty, string.Empty);
    var activateAction = activation.Actions.FirstOrDefault(item => item.Key == "activate") ?? new AdminSuperAdminFlowActionViewModel("activate", "Sistemi Aktif Et", true, string.Empty, string.Empty);
    var deactivateAction = activation.Actions.FirstOrDefault(item => item.Key == "deactivate") ?? new AdminSuperAdminFlowActionViewModel("deactivate", "Sistemi Kapat", true, string.Empty, string.Empty);
    var monitoringRefreshAction = monitoring.Actions.FirstOrDefault(item => item.Key == "refresh") ?? new AdminSuperAdminFlowActionViewModel("refresh", "Yenile", true, string.Empty, string.Empty);
    var headerModel = new AdminPageHeaderViewModel
    {
        Eyebrow = "Super Admin",
        Title = "Sistem Akisi",
        Description = "Kurulumu kontrol et, sistemi aktiflestir, calismayi izle ve teknik detaylara yalnizca gerektiginde gir.",
        StatusBadge = new AdminBadgeViewModel { Label = Model.IsAccessible ? "Super Admin" : "Blocked", Tone = Model.IsAccessible ? "role" : "critical", IconText = Model.IsAccessible ? "SA" : "BL" },
        MetaBadges = new[]
        {
            new AdminBadgeViewModel { Label = "Fail-closed", Tone = "critical", IconText = "FC" },
            new AdminBadgeViewModel { Label = "Guarded", Tone = "warning", IconText = "GD" },
            new AdminBadgeViewModel { Label = "Audit aware", Tone = "info", IconText = "AU" }
        },
        SecondaryActionText = "Audit",
        SecondaryActionHref = Url.Action("Audit", "Admin", new { area = "Admin" }),
        PrimaryActionText = "Global Ayarlar",
        PrimaryActionHref = Url.Action("Settings", "Admin", new { area = "Admin" })
    };

    AdminBadgeViewModel Badge(string label, string tone, string iconText) => new() { Label = label, Tone = tone, IconText = iconText };
    string StripTone(string tone) => tone.ToLowerInvariant() switch { "healthy" => "success", "warning" => "warning", "critical" => "critical", _ => "info" };
    string ShortIcon(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "NA";
        }

        var tokens = value.Split(new[] { ' ', '/', '-', '_' }, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Take(2)
            .Select(item => item[..1].ToUpperInvariant())
            .ToArray();

        return tokens.Length == 0 ? value[..Math.Min(2, value.Length)].ToUpperInvariant() : string.Concat(tokens);
    }
    string ActionReason(string? blockedReason, string fallbackReason)
    {
        return string.IsNullOrWhiteSpace(blockedReason) ? fallbackReason : blockedReason!;
    }
}

<div class="row" data-cb-super-admin-simple-flow="true">
    <div class="col-12">
        <div class="card card-custom gutter-b cb-card cb-admin-card">
            <div class="card-body">
                @await Html.PartialAsync("Foundation/_AdminPageHeader", headerModel)
                @await Html.PartialAsync("Foundation/_AdminInfoStrip", new AdminInfoStripViewModel { Tone = Model.IsAccessible ? "info" : "critical", Title = Model.IsAccessible ? "Once kurulumu tamamlayin" : Model.AccessTitle, Message = Model.IsAccessible ? "Ilk kez gelen kullanici once Sistem Kurulumu sekmesinden ilerler, sonra Aktivasyon ve Izleme adimlarina gecer." : Model.AccessSummary, Meta = $"Refreshed {Model.RefreshedAtUtcLabel}" })

                @if (!string.IsNullOrWhiteSpace(executionSuccess))
                {
                    @await Html.PartialAsync("Foundation/_AdminInfoStrip", new AdminInfoStripViewModel { Tone = "success", Title = "Komut sonucu", Message = executionSuccess!, Meta = "Guarded action" })
                }

                @if (!string.IsNullOrWhiteSpace(clockDriftSuccess))
                {
                    @await Html.PartialAsync("Foundation/_AdminInfoStrip", new AdminInfoStripViewModel { Tone = "success", Title = "Baglanti testi", Message = clockDriftSuccess!, Meta = "Server time sync" })
                }

                @if (!string.IsNullOrWhiteSpace(executionError))
                {
                    @await Html.PartialAsync("Foundation/_AdminInfoStrip", new AdminInfoStripViewModel { Tone = "critical", Title = "Blocked", Message = executionError!, Meta = "Fail-closed" })
                }

                @if (!string.IsNullOrWhiteSpace(clockDriftError))
                {
                    @await Html.PartialAsync("Foundation/_AdminInfoStrip", new AdminInfoStripViewModel { Tone = "warning", Title = "Baglanti testi", Message = clockDriftError!, Meta = "Sync refresh" })
                }

                <div class="cb-admin-summary-grid mt-6" data-cb-super-admin-flow-summary>
                    @foreach (var flowSection in new[] { setup, activation, monitoring, advanced })
                    {
                        <div class="cb-admin-summary-card" data-cb-super-admin-flow-card="@flowSection.Key">
                            <span class="cb-admin-summary-label">@flowSection.Label</span>
                            <strong>@flowSection.StatusLabel</strong>
                            <small>@flowSection.PrimaryMessage</small>
                            <div class="cb-admin-page-meta mt-4">
                                @await Html.PartialAsync("Foundation/_AdminBadge", Badge(flowSection.StatusLabel, flowSection.Tone, ShortIcon(flowSection.Label)))
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (!Model.IsAccessible)
    {
        <div class="col-12">
            @await Html.PartialAsync("Foundation/_AdminInfoStrip", new AdminInfoStripViewModel { Tone = "critical", Title = "Super Admin gerekli", Message = "Bu sade ana akis yalnizca super admin rolu ile acilir. Teknik read-model ve kritik aksiyonlar fail-closed gizlendi.", Meta = "Access blocked" })
        </div>
    }
    else
    {
        <div class="col-12">
            <div class="card card-custom gutter-b cb-card cb-admin-card">
                <div class="card-body">
                    <div class="cb-admin-section-kicker">Ana Akis</div>
                    <div class="cb-admin-section-title">Super admin icin 4 adimli sade kullanim</div>
                    <p class="cb-admin-section-description">Teknik detaylar Gelismis sekmesine tasindi. Ana yuzeyde yalnizca kurulum, aktivasyon, izleme ve kritik cikis aksiyonlari gorunur.</p>
                    <ul class="nav nav-pills cb-admin-settings-nav mt-6" id="cb_super_admin_flow_tab_nav" role="tablist" data-cb-super-admin-flow-nav>
                        <li class="nav-item mr-3 mb-3"><a class="nav-link cb-admin-settings-nav-link active" id="cb_super_admin_flow_tab_link_setup" data-toggle="tab" href="#cb_super_admin_flow_tab_setup" role="tab" aria-selected="true" data-cb-super-admin-flow-tab-link="setup">Sistem Kurulumu</a></li>
                        <li class="nav-item mr-3 mb-3"><a class="nav-link cb-admin-settings-nav-link" id="cb_super_admin_flow_tab_link_activation" data-toggle="tab" href="#cb_super_admin_flow_tab_activation" role="tab" aria-selected="false" data-cb-super-admin-flow-tab-link="activation">Sistemi Aktiflestir</a></li>
                        <li class="nav-item mr-3 mb-3"><a class="nav-link cb-admin-settings-nav-link" id="cb_super_admin_flow_tab_link_monitoring" data-toggle="tab" href="#cb_super_admin_flow_tab_monitoring" role="tab" aria-selected="false" data-cb-super-admin-flow-tab-link="monitoring">Sistemi Izle</a></li>
                        <li class="nav-item mb-3"><a class="nav-link cb-admin-settings-nav-link" id="cb_super_admin_flow_tab_link_advanced" data-toggle="tab" href="#cb_super_admin_flow_tab_advanced" role="tab" aria-selected="false" data-cb-super-admin-flow-tab-link="advanced">Gelismis</a></li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="tab-content" id="cb_super_admin_flow_tab_content">
                <div class="tab-pane fade show active" id="cb_super_admin_flow_tab_setup" role="tabpanel" data-cb-super-admin-flow-section="setup" data-cb-super-admin-flow-visible="@setup.IsVisible.ToString().ToLowerInvariant()" data-cb-super-admin-flow-accessible="@setup.IsAccessible.ToString().ToLowerInvariant()">
                    <section class="card card-custom gutter-b cb-card cb-admin-card">
                        <div class="card-body">
                            <div class="cb-admin-section-kicker">1. Sistem Kurulumu</div>
                            <div class="cb-admin-section-title">Ortam, baglanti ve temel hazirlik</div>
                            <p class="cb-admin-section-description">Bu adimda yalnizca ortam secimi, exchange hazirligi, worker durumu ve baglanti testi gorunur.</p>
                            @await Html.PartialAsync("Foundation/_AdminInfoStrip", new AdminInfoStripViewModel { Tone = StripTone(setup.Tone), Title = setup.StatusLabel, Message = setup.PrimaryMessage, Meta = setup.Summary })
                            <div class="cb-admin-summary-grid mt-6">
                                @foreach (var item in setup.Items)
                                {
                                    <div class="cb-admin-summary-card">
                                        <span class="cb-admin-summary-label">@item.Label</span>
                                        <strong>@item.Value</strong>
                                        <small>@item.Summary</small>
                                        <div class="cb-admin-page-meta mt-4">@await Html.PartialAsync("Foundation/_AdminBadge", Badge(item.Value, item.Tone, ShortIcon(item.Label)))</div>
                                    </div>
                                }
                            </div>
                        </div>
                    </section>

                    <div class="row">
                        <div class="col-xl-7">
                            <section class="card card-custom gutter-b cb-card cb-admin-card" data-cb-super-admin-setup-form>
                                <div class="card-body">
                                    <div class="cb-admin-section-kicker">Ortam secimi</div>
                                    <div class="cb-admin-section-title">Demo / Live secimini kaydet</div>
                                    <p class="cb-admin-section-description">Demo/Live secimi yalnizca super admin tarafinda kalir. Live acilisi icin approval reference zorunludur.</p>
                                    <form asp-area="Admin" asp-controller="Admin" asp-action="SetDemoMode" method="post" class="mt-5">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="returnTarget" value="Overview" />
                                        <div class="form-group">
                                            <label class="font-weight-bold d-block">Ortam</label>
                                            <div class="d-flex flex-wrap gap-4">
                                                <label class="radio radio-outline radio-outline-2x radio-primary mr-6">
                                                    <input type="radio" name="isEnabled" value="true" @(currentModeIsDemo ? "checked" : null) />
                                                    <span></span>
                                                    Demo / Testnet
                                                </label>
                                                <label class="radio radio-outline radio-outline-2x radio-warning">
                                                    <input type="radio" name="isEnabled" value="false" @(!currentModeIsDemo ? "checked" : null) />
                                                    <span></span>
                                                    Live
                                                </label>
                                            </div>
                                        </div>
                                        <div class="form-group">
                                            <label class="font-weight-bold">Audit reason</label>
                                            <input type="text" name="reason" class="form-control" maxlength="256" placeholder="Ortam degisikligi nedeni" />
                                        </div>
                                        <div class="form-group">
                                            <label class="font-weight-bold">Live izin referansi</label>
                                            <input type="text" name="liveApprovalReference" class="form-control" maxlength="128" placeholder="Live seciliyorsa zorunlu" />
                                            <small class="form-text text-muted">Live seciliyse approval reference olmadan server-side block uygulanir.</small>
                                        </div>
                                        <div class="form-group mb-6">
                                            <label class="font-weight-bold">Onay ibaresi</label>
                                            <input type="text" name="reauthToken" class="form-control" maxlength="32" placeholder="ONAYLA" />
                                        </div>
                                        <div class="cb-admin-inline-actions">
                                            <button type="submit" class="btn btn-primary font-weight-bolder">Kaydet ve Devam Et</button>
                                            <a asp-area="Admin" asp-controller="Admin" asp-action="ExchangeAccounts" class="btn btn-light-primary font-weight-bold">Exchange Hesaplari</a>
                                        </div>
                                    </form>
                                </div>
                            </section>
                        </div>
                        <div class="col-xl-5">
                            <section class="card card-custom gutter-b cb-card cb-admin-card" data-cb-super-admin-connection-test-form>
                                <div class="card-body">
                                    <div class="cb-admin-section-kicker">Baglanti testi</div>
                                    <div class="cb-admin-section-title">Server time ve worker gorunurlugunu yenile</div>
                                    <p class="cb-admin-section-description">Bu buton yalnizca read-model ozetini yeniler. Aktivasyon karari hala server-side gate ile verilir.</p>
                                    <form asp-area="Admin" asp-controller="Admin" asp-action="RefreshClockDrift" method="post" class="mt-5">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="returnTarget" value="Overview" />
                                        <button type="submit" class="btn btn-light-warning font-weight-bolder" data-cb-super-admin-action-enabled="@setupConnectionTestAction.IsEnabled.ToString().ToLowerInvariant()" @(!setupConnectionTestAction.IsEnabled ? "disabled" : null)>Baglantiyi Test Et</button>
                                    </form>
                                    <div class="cb-helper-text mt-6" data-cb-super-admin-action-reason="connection-test">@(setupConnectionTestAction.IsEnabled ? "Exchange bagli degil veya worker calismiyor ise ana blocker tek satir mesaj olarak bu ekranda kalir." : ActionReason(setupConnectionTestAction.BlockedReason, "Bu rolde baglanti testi acik degil"))</div>
                                </div>
                            </section>
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade" id="cb_super_admin_flow_tab_activation" role="tabpanel" data-cb-super-admin-flow-section="activation" data-cb-super-admin-flow-visible="@activation.IsVisible.ToString().ToLowerInvariant()" data-cb-super-admin-flow-accessible="@activation.IsAccessible.ToString().ToLowerInvariant()">
                    <section class="card card-custom gutter-b cb-card cb-admin-card" data-cb-super-admin-activation-panel>
                        <div class="card-body">
                            <div class="cb-admin-section-kicker">2. Sistemi Aktiflestir</div>
                            <div class="cb-admin-section-title">Hazirla, aktif et, kapat veya acil durdur</div>
                            <p class="cb-admin-section-description">Bu adimda teknik checklist yerine tek satir operasyon mesaji ve guarded aksiyonlar gorunur.</p>
                            @await Html.PartialAsync("Foundation/_AdminInfoStrip", new AdminInfoStripViewModel { Tone = StripTone(activation.Tone), Title = activation.StatusLabel, Message = activation.PrimaryMessage, Meta = activation.Summary })
                            <div class="cb-admin-summary-grid mt-6">
                                @foreach (var item in activation.Items)
                                {
                                    <div class="cb-admin-summary-card">
                                        <span class="cb-admin-summary-label">@item.Label</span>
                                        <strong>@item.Value</strong>
                                        <small>@item.Summary</small>
                                        <div class="cb-admin-page-meta mt-4">@await Html.PartialAsync("Foundation/_AdminBadge", Badge(item.Value, item.Tone, ShortIcon(item.Label)))</div>
                                    </div>
                                }
                            </div>
                        </div>
                    </section>

                    <div class="row">
                        <div class="col-xl-4">
                            <section class="card card-custom gutter-b cb-card cb-admin-card" data-cb-super-admin-prepare-card>
                                <div class="card-body">
                                    <div class="cb-admin-section-kicker">Hazirlik</div>
                                    <div class="cb-admin-section-title">Sistemi Hazirla</div>
                                    <p class="cb-admin-section-description">Readiness ozetini yenileyin; blocker kalmadiysa aktivasyon komutuna gecin.</p>
                                    <form asp-area="Admin" asp-controller="Admin" asp-action="RefreshClockDrift" method="post" class="mt-5">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="returnTarget" value="Overview" />
                                        <button type="submit" class="btn btn-light-warning font-weight-bolder" data-cb-super-admin-action-enabled="@activationPrepareAction.IsEnabled.ToString().ToLowerInvariant()" @(!activationPrepareAction.IsEnabled ? "disabled" : null)>Sistemi Hazirla</button>
                                    </form>
                                    <div class="cb-helper-text mt-4" data-cb-super-admin-action-reason="prepare">@(activationPrepareAction.IsEnabled ? activationPrepareAction.Summary : ActionReason(activationPrepareAction.BlockedReason, "Bu rolde hazirlik yenilemesi acik degil"))</div>
                                </div>
                            </section>
                        </div>
                        <div class="col-xl-4">
                            <section class="card card-custom gutter-b cb-card cb-admin-card" data-cb-super-admin-activation-action="activate">
                                <div class="card-body">
                                    <div class="cb-admin-section-kicker">Aktivasyon</div>
                                    <div class="cb-admin-section-title">Sistemi Aktif Et</div>
                                    <p class="cb-admin-section-description">Readiness fail veya blocker varsa buton disabled kalir; backend yine fail-closed koruma uygular.</p>
                                    <form asp-area="Admin" asp-controller="Admin" asp-action="ActivateSystem" method="post" class="mt-5">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="returnTarget" value="Overview" />
                                        <div class="form-group">
                                            <label class="font-weight-bold">Audit reason</label>
                                            <input type="text" name="reason" class="form-control" maxlength="256" placeholder="Aktivasyon nedeni" />
                                        </div>
                                        <div class="form-group mb-6">
                                            <label class="font-weight-bold">Onay ibaresi</label>
                                            <input type="text" name="reauthToken" class="form-control" maxlength="32" placeholder="ONAYLA" />
                                        </div>
                                        <button type="submit" class="btn btn-primary font-weight-bolder" data-cb-super-admin-action-enabled="@activateAction.IsEnabled.ToString().ToLowerInvariant()" @(!activateAction.IsEnabled ? "disabled" : null)>Sistemi Aktif Et</button>
                                    </form>
                                    <div class="cb-helper-text mt-4" data-cb-super-admin-action-reason="activate">@(activateAction.IsEnabled ? activateAction.Summary : ActionReason(activateAction.BlockedReason, "Sistem aktive edilmeye hazir degil"))</div>
                                </div>
                            </section>
                        </div>
                        <div class="col-xl-4">
                            <section class="card card-custom gutter-b cb-card cb-admin-card" data-cb-super-admin-activation-action="deactivate">
                                <div class="card-body">
                                    <div class="cb-admin-section-kicker">Guvenli kapatma</div>
                                    <div class="cb-admin-section-title">Sistemi Kapat</div>
                                    <p class="cb-admin-section-description">Normal stop icin guarded kapatma komutunu kullanin. Acil durum icin ayri emergency linki asagidadir.</p>
                                    <form asp-area="Admin" asp-controller="Admin" asp-action="DeactivateSystem" method="post" class="mt-5">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="returnTarget" value="Overview" />
                                        <div class="form-group">
                                            <label class="font-weight-bold">Audit reason</label>
                                            <input type="text" name="reason" class="form-control" maxlength="256" placeholder="Kapatma nedeni" />
                                        </div>
                                        <div class="form-group mb-6">
                                            <label class="font-weight-bold">Onay ibaresi</label>
                                            <input type="text" name="reauthToken" class="form-control" maxlength="32" placeholder="ONAYLA" />
                                        </div>
                                        <button type="submit" class="btn btn-light-danger font-weight-bolder" data-cb-super-admin-action-enabled="@deactivateAction.IsEnabled.ToString().ToLowerInvariant()" @(!deactivateAction.IsEnabled ? "disabled" : null)>Sistemi Kapat</button>
                                    </form>
                                    <div class="cb-helper-text mt-4" data-cb-super-admin-action-reason="deactivate">@(deactivateAction.IsEnabled ? deactivateAction.Summary : ActionReason(deactivateAction.BlockedReason, "Sistem zaten kapali"))</div>
                                </div>
                            </section>
                        </div>
                    </div>

                    <section class="card card-custom gutter-b cb-card cb-admin-card" data-cb-super-admin-emergency-panel>
                        <div class="card-body d-flex flex-wrap align-items-start justify-content-between gap-4">
                            <div>
                                <div class="cb-admin-section-kicker">Acil durum</div>
                                <div class="cb-admin-section-title">Acil durdur görünur ve ayrik kalir</div>
                                <p class="cb-admin-section-description mb-0">Panik aninda mevcut crisis escalation yuzeyini kullanin. Emergency stop aktifse aktivasyon tekrar verilmez.</p>
                            </div>
                            <div class="cb-admin-inline-actions">
                                <a asp-area="Admin" asp-controller="Admin" asp-action="Settings" asp-fragment="cb_admin_settings_crisis_panel" class="btn btn-danger font-weight-bolder">Acil Durdur</a>
                                <a asp-area="Admin" asp-controller="Admin" asp-action="Settings" asp-fragment="cb_admin_settings_tab_activation" class="btn btn-light-warning font-weight-bold">Detayli aktivasyon</a>
                            </div>
                        </div>
                    </section>
                </div>

                <div class="tab-pane fade" id="cb_super_admin_flow_tab_monitoring" role="tabpanel" data-cb-super-admin-flow-section="monitoring" data-cb-super-admin-flow-visible="@monitoring.IsVisible.ToString().ToLowerInvariant()" data-cb-super-admin-flow-accessible="@monitoring.IsAccessible.ToString().ToLowerInvariant()">
                    <section class="card card-custom gutter-b cb-card cb-admin-card" data-cb-super-admin-monitoring-panel>
                        <div class="card-body">
                            <div class="cb-admin-section-kicker">3. Sistemi Izle</div>
                            <div class="cb-admin-section-title">Kisa operasyon ozeti</div>
                            <p class="cb-admin-section-description">Bu adim yalnizca sistem acik mi, ortam ne, son hata ne ve son durdurma nedeni ne sorularina cevap verir.</p>
                            @await Html.PartialAsync("Foundation/_AdminInfoStrip", new AdminInfoStripViewModel { Tone = StripTone(monitoring.Tone), Title = monitoring.StatusLabel, Message = monitoring.PrimaryMessage, Meta = monitoring.Summary })
                            <div class="cb-admin-summary-grid mt-6">
                                @foreach (var item in monitoring.Items)
                                {
                                    <div class="cb-admin-summary-card">
                                        <span class="cb-admin-summary-label">@item.Label</span>
                                        <strong>@item.Value</strong>
                                        <small>@item.Summary</small>
                                        <div class="cb-admin-page-meta mt-4">@await Html.PartialAsync("Foundation/_AdminBadge", Badge(item.Value, item.Tone, ShortIcon(item.Label)))</div>
                                    </div>
                                }
                            </div>
                            <div class="cb-admin-inline-actions mt-6">
                                <form asp-area="Admin" asp-controller="Admin" asp-action="RefreshClockDrift" method="post" class="d-inline-block mr-3">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="returnTarget" value="Overview" />
                                    <button type="submit" class="btn btn-light-warning font-weight-bolder" data-cb-super-admin-action-enabled="@monitoringRefreshAction.IsEnabled.ToString().ToLowerInvariant()" @(!monitoringRefreshAction.IsEnabled ? "disabled" : null)>Yenile</button>
                                </form>
                                <span class="cb-helper-text mr-4" data-cb-super-admin-action-reason="refresh">@(monitoringRefreshAction.IsEnabled ? monitoringRefreshAction.Summary : ActionReason(monitoringRefreshAction.BlockedReason, "Bu rolde izleme yenilemesi acik degil"))</span>
                                <a asp-area="Admin" asp-controller="Admin" asp-action="Settings" asp-fragment="cb_admin_settings_crisis_panel" class="btn btn-danger font-weight-bolder">Acil Durdur</a>
                                <a href="#cb_super_admin_flow_tab_activation" class="btn btn-light-primary font-weight-bold" data-toggle="tab">Sistemi Kapat</a>
                            </div>
                        </div>
                    </section>
                </div>

                <div class="tab-pane fade" id="cb_super_admin_flow_tab_advanced" role="tabpanel" data-cb-super-admin-flow-section="advanced" data-cb-super-admin-flow-visible="@advanced.IsVisible.ToString().ToLowerInvariant()" data-cb-super-admin-flow-accessible="@advanced.IsAccessible.ToString().ToLowerInvariant()">
                    <section class="card card-custom gutter-b cb-card cb-admin-card" data-cb-super-admin-advanced-links>
                        <div class="card-body">
                            <div class="cb-admin-section-kicker">4. Gelismis</div>
                            <div class="cb-admin-section-title">Teknik detaylar ana akistan ayrik</div>
                            <p class="cb-admin-section-description">Audit, incidents, trace, health ve config history gibi teknik merkezler yalnizca gerektiginde acilir.</p>
                            @await Html.PartialAsync("Foundation/_AdminInfoStrip", new AdminInfoStripViewModel { Tone = "info", Title = advanced.StatusLabel, Message = advanced.PrimaryMessage, Meta = advanced.Summary })
                            <div class="cb-admin-summary-grid mt-6">
                                @foreach (var item in advanced.Items)
                                {
                                    <div class="cb-admin-summary-card">
                                        <span class="cb-admin-summary-label">@item.Label</span>
                                        <strong>@item.Value</strong>
                                        <small>@item.Summary</small>
                                        <div class="cb-admin-inline-actions mt-5">
                                            <a href="@item.Href" class="btn btn-light-primary font-weight-bold">Ac</a>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </section>
                </div>
            </div>
        </div>

        <script>
            document.addEventListener('DOMContentLoaded', function () {
                var currentHash = window.location.hash;
                if (!currentHash) {
                    return;
                }

                var tabLink = Array.prototype.find.call(
                    document.querySelectorAll('[data-cb-super-admin-flow-tab-link]'),
                    function (candidate) { return candidate.getAttribute('href') === currentHash; });

                if (!tabLink) {
                    return;
                }

                if (window.jQuery && window.jQuery.fn && window.jQuery.fn.tab) {
                    window.jQuery(tabLink).tab('show');
                    return;
                }

                tabLink.click();
            });
        </script>
    }
</div>






