@{
    var headerModel = new AdminPageHeaderViewModel
    {
        Eyebrow = "Global Bot Ops",
        Title = "Bot Operasyonları",
        Description = "Platform genelindeki kullanıcı botlarını durum, market, risk ve AI etkisi sinyalleriyle tek ekranda izleyen Super Admin operasyon yüzeyi.",
        StatusBadge = new AdminBadgeViewModel { Label = "Bot Ops", Tone = "warning", IconText = "BT" },
        MetaBadges = new[]
        {
            new AdminBadgeViewModel { Label = "Paper / Live", Tone = "neutral", IconText = "PL" },
            new AdminBadgeViewModel { Label = "Force Stop Guarded", Tone = "critical", IconText = "FS" },
            new AdminBadgeViewModel { Label = "Strategy Aware", Tone = "info", IconText = "ST" }
        },
        SecondaryActionText = "Exchange hesapları",
        SecondaryActionHref = Url.Action("ExchangeAccounts", "Admin", new { area = "Admin" }),
        PrimaryActionText = "System health",
        PrimaryActionHref = Url.Action("SystemHealth", "Admin", new { area = "Admin" })
    };
}

<div class="row">
    <div class="col-12">
        <div class="card card-custom gutter-b cb-card cb-admin-card">
            <div class="card-body">
                @await Html.PartialAsync("Foundation/_AdminPageHeader", headerModel)

                @await Html.PartialAsync("Foundation/_AdminInfoStrip", new AdminInfoStripViewModel
                {
                    Tone = "warning",
                    Title = "Global bot operations",
                    Message = "Gerçek runtime, start/stop ve event stream backend'i bu yüzeyle hizalanır. Bu ekran; durum yoğunluğu, risk sinyali ve bot detaylarını gerçek snapshot ile gösterir.",
                    Meta = "Operational"
                })

                <div class="mt-6">
                    @await Html.PartialAsync("Foundation/_AdminBotSummaryMeta")
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-8">
        @await Html.PartialAsync("Foundation/_AdminBotFilterBar")
        @await Html.PartialAsync("Foundation/_AdminBotOperationsTable")
    </div>

    <div class="col-xl-4">
        @await Html.PartialAsync("Foundation/_AdminBotHelpCard")
    </div>

    <div class="col-12">
        @await Html.PartialAsync("Foundation/_AdminEmptyState", new UiStateViewModel
        {
            Title = "Bot operasyonları hazır",
            Message = "Listeler ve summary kartları gerçek bot snapshot verisiyle doldurulur. Sonuç yoksa ürün seviyesi empty-state görünür.",
            IconText = "BT",
            ActionText = "Exchange hesapları",
            ActionHref = Url.Action("ExchangeAccounts", "Admin", new { area = "Admin" }),
            SecondaryActionText = "Sistem sağlığı",
            SecondaryActionHref = Url.Action("SystemHealth", "Admin", new { area = "Admin" })
        })
    </div>
</div>
