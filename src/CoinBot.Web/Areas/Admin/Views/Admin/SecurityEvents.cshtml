@{
    var headerModel = new AdminPageHeaderViewModel
    {
        Eyebrow = "Security Triage",
        Title = "Güvenlik Olayları",
        Description = "Failed login yoğunluğu, invalid MFA, suspicious session, risky exchange permission ve admin critical action sinyallerini güvenlik odaklı triage ve olay listesiyle toplayan Super Admin güvenlik izleme yüzeyi.",
        StatusBadge = new AdminBadgeViewModel { Label = "Security Watch", Tone = "critical", IconText = "SC" },
        MetaBadges = new[]
        {
            new AdminBadgeViewModel { Label = "Masked PII", Tone = "healthy", IconText = "MS" },
            new AdminBadgeViewModel { Label = "Triage View", Tone = "warning", IconText = "TR" },
            new AdminBadgeViewModel { Label = "Review First", Tone = "neutral", IconText = "RV" }
        },
        SecondaryActionText = "Audit / log merkezi",
        SecondaryActionHref = Url.Action("Audit", "Admin", new { area = "Admin" }),
        PrimaryActionText = "Notifications",
        PrimaryActionHref = Url.Action("Notifications", "Admin", new { area = "Admin" })
    };
}

<div class="row">
    <div class="col-12">
        <div class="card card-custom gutter-b cb-card cb-admin-card">
            <div class="card-body">
                @await Html.PartialAsync("Foundation/_AdminPageHeader", headerModel)

                @await Html.PartialAsync("Foundation/_AdminInfoStrip", new AdminInfoStripViewModel
                {
                    Tone = "critical",
                    Title = "Security events",
                    Message = "Gerçek brute-force detection, IP/device anomaly backend ve MFA event stream bu yüzeyde bir araya gelir. Ekran; security summary, triage paneli ve event listesiyle çalışır.",
                    Meta = "Masked"
                })

                <div class="mt-6">
                    @await Html.PartialAsync("Foundation/_AdminSecuritySummaryMeta")
                </div>
            </div>
        </div>
    </div>

    <div class="col-12">
        @await Html.PartialAsync("Foundation/_AdminSecurityFilterBar")
    </div>

    <div class="col-xl-4">
        @await Html.PartialAsync("Foundation/_AdminSecurityTriagePanel")
    </div>

    <div class="col-xl-8">
        @await Html.PartialAsync("Foundation/_AdminSecurityEventList")
    </div>
</div>
