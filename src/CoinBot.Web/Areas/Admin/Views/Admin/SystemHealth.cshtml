@using CoinBot.Application.Abstractions.Monitoring
@using CoinBot.Domain.Enums
@{
    var dashboard = ViewData["AdminMonitoringDashboardSnapshot"] as MonitoringDashboardSnapshot
        ?? MonitoringDashboardSnapshot.Empty(DateTime.UtcNow);

    string DescribeParityTone(string tone)
    {
        return tone.ToLowerInvariant() switch
        {
            "healthy" => "healthy",
            "warning" => "warning",
            "degraded" => "warning",
            _ => "critical"
        };
    }

    string ResolveCoreWorkerTone()
    {
        var workers = dashboard.WorkerHeartbeats
            .Where(worker => !string.Equals(worker.WorkerKey, "market-scanner", StringComparison.OrdinalIgnoreCase))
            .ToArray();

        if (workers.Length == 0)
        {
            return "critical";
        }

        var hasCritical = workers.Any(worker => worker.HealthState == MonitoringHealthState.Critical);
        if (hasCritical)
        {
            return "critical";
        }

        var hasStale = workers.Any(worker => worker.FreshnessTier == MonitoringFreshnessTier.Stale);
        return hasStale ? "warning" : "healthy";
    }

    string ResolveMarketScannerTone()
    {
        var scannerWorker = dashboard.WorkerHeartbeats.FirstOrDefault(worker =>
            string.Equals(worker.WorkerKey, "market-scanner", StringComparison.OrdinalIgnoreCase));

        if (scannerWorker is null)
        {
            return "critical";
        }

        if (scannerWorker.HealthState == MonitoringHealthState.Healthy &&
            scannerWorker.FreshnessTier != MonitoringFreshnessTier.Stale)
        {
            return "healthy";
        }

        if (scannerWorker.HealthState == MonitoringHealthState.Critical ||
            scannerWorker.FreshnessTier == MonitoringFreshnessTier.Stale)
        {
            return "critical";
        }

        return "warning";
    }

    var coreWorkerTone = ResolveCoreWorkerTone();
    var marketScannerTone = ResolveMarketScannerTone();
    var paritySummary = $"Core worker {DescribeParityTone(coreWorkerTone)}, market scanner {DescribeParityTone(marketScannerTone)}.";
    var parityStripTone = coreWorkerTone == "critical" || marketScannerTone == "critical"
        ? "critical"
        : coreWorkerTone == "warning" || marketScannerTone == "warning"
            ? "warning"
            : "healthy";
    var headerModel = new AdminPageHeaderViewModel
    {
        Eyebrow = "Runtime Monitoring",
        Title = "System Health / Worker Status",
        Description = "API, web app, queue ve worker health sinyallerini failed jobs, stale warning ve incident severity görünümüyle tek ekranda toplayan Super Admin monitoring yüzeyi.",
        StatusBadge = new AdminBadgeViewModel { Label = "Health Watch", Tone = "degraded", IconText = "HL" },
        MetaBadges = new[]
        {
            new AdminBadgeViewModel { Label = "Heartbeat Aware", Tone = "info", IconText = "HB" },
            new AdminBadgeViewModel { Label = "Retry Safe", Tone = "warning", IconText = "RT" },
            new AdminBadgeViewModel { Label = "Job Focus", Tone = "critical", IconText = "JB" }
        },
        SecondaryActionText = "Audit / loglar",
        SecondaryActionHref = Url.Action("Audit", "Admin", new { area = "Admin" }),
        PrimaryActionText = "Incidents",
        PrimaryActionHref = Url.Action("Incidents", "Admin", new { area = "Admin" })
    };
}

<div class="row">
    <div class="col-12">
        <div class="card card-custom gutter-b cb-card cb-admin-card">
            <div class="card-body">
                @await Html.PartialAsync("Foundation/_AdminPageHeader", headerModel)

                @await Html.PartialAsync("Foundation/_AdminInfoStrip", new AdminInfoStripViewModel
                {
                    Tone = "info",
                    Title = "System health snapshot",
                    Message = "Redis latency ve clock drift sinyalleri gerçek probe/circuit-breaker read-model üzerinden dashboard'a akıyor. Warm/cold snapshot modeli korunur.",
                    Meta = "Snapshot/read-model monitoring"
                })

                <div class="mt-6">
                    @await Html.PartialAsync("Foundation/_AdminSystemHealthFreshnessStrip")
                </div>
                <div class="mt-6" data-cb-system-health-parity>
                    <span class="d-none" data-cb-system-health-parity-summary>@paritySummary</span>
                    <span class="d-none" data-cb-system-health-core-tone>@coreWorkerTone</span>
                    <span class="d-none" data-cb-system-health-market-scanner-tone>@marketScannerTone</span>
                    @await Html.PartialAsync("Foundation/_AdminInfoStrip", new AdminInfoStripViewModel
                    {
                        Tone = parityStripTone,
                        Title = "Runtime parity",
                        Message = paritySummary,
                        Meta = $"Core={coreWorkerTone}; Scanner={marketScannerTone}"
                    })
                </div>
            </div>
        </div>
    </div>

    <div class="col-12">
        @await Html.PartialAsync("Foundation/_AdminSystemHealthKpis")
    </div>

    <div class="col-12">
        @await Html.PartialAsync("Foundation/_AdminOperationalObservabilityCard")
    </div>

    <div class="col-xl-7">
        @await Html.PartialAsync("Foundation/_AdminWorkerHealthList")
    </div>

    <div class="col-xl-5">
        @await Html.PartialAsync("Foundation/_AdminUltraDebugLogHealthCard")

        @await Html.PartialAsync("Foundation/_AdminMarketDataCacheHealthCard")

        @await Html.PartialAsync("Foundation/_AdminMarketScannerCard")

        @await Html.PartialAsync("Foundation/_AdminInfoStrip", new AdminInfoStripViewModel
        {
            Tone = "warning",
            Title = "Follow-up routes",
            Message = "Incident timeline ve audit kayitlari ayri read-model ekranlarinda tutulur. System health burada yalnizca snapshot ve heartbeat durumunu gosterir.",
            Meta = "Snapshot only"
        })
    </div>
</div>

