@model CoinBot.Application.Abstractions.Policy.GlobalPolicySnapshot
@{
    var selectedVersion = (GlobalPolicyVersionSnapshot)ViewData["AdminSelectedConfigVersion"]!;
    var canEditGlobalPolicy = ViewData["AdminCanEditGlobalPolicy"] is bool canEditValue && canEditValue;
    var headerModel = new AdminPageHeaderViewModel
    {
        Eyebrow = "Governance / Config History Detail",
        Title = $"Version {selectedVersion.Version}",
        Description = "Seçili policy version icin diff, source, rollback ve snapshot detaylari.",
        StatusBadge = new AdminBadgeViewModel { Label = $"v{selectedVersion.Version}", Tone = "info", IconText = "CF" },
        MetaBadges = new[]
        {
            new AdminBadgeViewModel { Label = selectedVersion.Policy.AutonomyPolicy.Mode.ToString(), Tone = "warning", IconText = "AU" },
            new AdminBadgeViewModel { Label = $"{selectedVersion.DiffEntries.Count} diff", Tone = "healthy", IconText = "DF" },
            new AdminBadgeViewModel { Label = $"{selectedVersion.Policy.SymbolRestrictions.Count} restriction", Tone = "info", IconText = "SR" }
        },
        SecondaryActionText = "Config history",
        SecondaryActionHref = Url.Action("ConfigHistory", "Admin", new { area = "Admin" }),
        PrimaryActionText = "Approvals",
        PrimaryActionHref = Url.Action("Approvals", "Admin", new { area = "Admin" })
    };
    var policyJson = JsonSerializer.Serialize(selectedVersion.Policy, new JsonSerializerOptions(JsonSerializerDefaults.Web) { WriteIndented = true });
    string DescribeRestrictionEffect(SymbolRestrictionState state) => state switch
    {
        SymbolRestrictionState.Blocked => "Tum emirler fail-closed bloklanir.",
        SymbolRestrictionState.ReviewOnly => "Review/advisory olarak isaretlenir.",
        SymbolRestrictionState.ReduceOnly => "Yalnizca exposure azaltan emirler gecer.",
        SymbolRestrictionState.CloseOnly => "Yalnizca pozisyon kapatan emirler gecer.",
        _ => "Policy evaluation uygulanir."
    };
}

<div class="row">
    <div class="col-12">
        <div class="card card-custom gutter-b cb-card cb-admin-card">
            <div class="card-body">
                @await Html.PartialAsync("Foundation/_AdminPageHeader", headerModel)
                @await Html.PartialAsync("Foundation/_AdminInfoStrip", new AdminInfoStripViewModel
                {
                    Tone = "info",
                    Title = "Version detail",
                    Message = selectedVersion.ChangeSummary,
                    Meta = selectedVersion.Source ?? "Unknown source"
                })

                @if (!canEditGlobalPolicy)
                {
                    <div class="cb-admin-info-strip cb-admin-info-strip-warning mt-6">
                        <div>
                            <div class="cb-admin-info-strip-title">Read-only policy detail</div>
                            <div class="cb-admin-info-strip-text">Bu rolde sadece history ve diff gorulebilir.</div>
                        </div>
                        <span class="cb-admin-info-strip-meta">Read-only</span>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card card-custom gutter-b cb-card cb-admin-card">
            <div class="card-body">
                <div class="cb-admin-table-header mb-4">
                    <div>
                        <div class="cb-admin-section-kicker">Version metadata</div>
                        <div class="cb-admin-section-title">Commit details</div>
                    </div>
                </div>

                <div class="table-responsive cb-admin-table-wrap mb-0">
                    <table class="table table-borderless cb-admin-table mb-0">
                        <tbody>
                            <tr>
                                <th>CreatedAtUtc</th>
                                <td>@selectedVersion.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm:ss") UTC</td>
                            </tr>
                            <tr>
                                <th>CreatedByUserId</th>
                                <td>@selectedVersion.CreatedByUserId</td>
                            </tr>
                            <tr>
                                <th>Source</th>
                                <td>@(selectedVersion.Source ?? "-")</td>
                            </tr>
                            <tr>
                                <th>CorrelationId</th>
                                <td>@(selectedVersion.CorrelationId ?? "-")</td>
                            </tr>
                            <tr>
                                <th>RolledBackFromVersion</th>
                                <td>@(selectedVersion.RolledBackFromVersion?.ToString() ?? "-")</td>
                            </tr>
                            <tr>
                                <th>ChangeSummary</th>
                                <td>@selectedVersion.ChangeSummary</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="card card-custom gutter-b cb-card cb-admin-card">
            <div class="card-body">
                <div class="cb-admin-table-header mb-4">
                    <div>
                        <div class="cb-admin-section-kicker">Policy profile</div>
                        <div class="cb-admin-section-title">Execution and autonomy guard</div>
                    </div>
                </div>

                <div class="table-responsive cb-admin-table-wrap mb-0">
                    <table class="table table-borderless cb-admin-table mb-0">
                        <tbody>
                            <tr>
                                <th>MaxOrderNotional</th>
                                <td>@(selectedVersion.Policy.ExecutionGuardPolicy.MaxOrderNotional?.ToString("0.##") ?? "-")</td>
                            </tr>
                            <tr>
                                <th>MaxPositionNotional</th>
                                <td>@(selectedVersion.Policy.ExecutionGuardPolicy.MaxPositionNotional?.ToString("0.##") ?? "-")</td>
                            </tr>
                            <tr>
                                <th>MaxDailyTrades</th>
                                <td>@(selectedVersion.Policy.ExecutionGuardPolicy.MaxDailyTrades?.ToString() ?? "-")</td>
                            </tr>
                            <tr>
                                <th>CloseOnlyBlocksNewPositions</th>
                                <td>@selectedVersion.Policy.ExecutionGuardPolicy.CloseOnlyBlocksNewPositions</td>
                            </tr>
                            <tr>
                                <th>AutonomyMode</th>
                                <td>@selectedVersion.Policy.AutonomyPolicy.Mode</td>
                            </tr>
                            <tr>
                                <th>RequireManualApprovalForLive</th>
                                <td>@selectedVersion.Policy.AutonomyPolicy.RequireManualApprovalForLive</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card card-custom gutter-b cb-card cb-admin-card cb-admin-table-card">
            <div class="card-body">
                <div class="cb-admin-table-header mb-4">
                    <div>
                        <div class="cb-admin-section-kicker">Restrictions</div>
                        <div class="cb-admin-section-title">Symbol restriction list</div>
                    </div>
                </div>

                <div class="table-responsive cb-admin-table-wrap">
                    <table class="table table-borderless cb-admin-table mb-0">
                        <thead>
                            <tr>
                                <th>Symbol</th>
                                <th>State</th>
                                <th>Effective state</th>
                                <th>Reason</th>
                                <th>UpdatedAtUtc</th>
                                <th>UpdatedBy</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (selectedVersion.Policy.SymbolRestrictions.Count == 0)
                            {
                                <tr>
                                    <td colspan="6" class="text-muted">Restriction yok.</td>
                                </tr>
                            }
                            else
                            {
                                foreach (var restriction in selectedVersion.Policy.SymbolRestrictions)
                                {
                                    <tr>
                                        <td>@restriction.Symbol</td>
                                        <td>@restriction.State</td>
                                        <td>@DescribeRestrictionEffect(restriction.State)</td>
                                        <td>@(restriction.Reason ?? "-")</td>
                                        <td>@(restriction.UpdatedAtUtc?.ToString("yyyy-MM-dd HH:mm:ss") ?? "-") UTC</td>
                                        <td>@(restriction.UpdatedByUserId ?? "-")</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="card card-custom gutter-b cb-card cb-admin-card cb-admin-table-card">
            <div class="card-body">
                <div class="cb-admin-table-header mb-4">
                    <div>
                        <div class="cb-admin-section-kicker">Diff</div>
                        <div class="cb-admin-section-title">Change entries</div>
                    </div>
                </div>

                <div class="table-responsive cb-admin-table-wrap">
                    <table class="table table-borderless cb-admin-table mb-0">
                        <thead>
                            <tr>
                                <th>Path</th>
                                <th>ChangeType</th>
                                <th>Before</th>
                                <th>After</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (selectedVersion.DiffEntries.Count == 0)
                            {
                                <tr>
                                    <td colspan="4" class="text-muted">Diff yok.</td>
                                </tr>
                            }
                            else
                            {
                                foreach (var diff in selectedVersion.DiffEntries)
                                {
                                    <tr>
                                        <td>@diff.Path</td>
                                        <td>@diff.ChangeType</td>
                                        <td>@(diff.Before ?? "-")</td>
                                        <td>@(diff.After ?? "-")</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="card card-custom gutter-b cb-card cb-admin-card">
            <div class="card-body">
                <div class="cb-admin-table-header mb-4">
                    <div>
                        <div class="cb-admin-section-kicker">Snapshot</div>
                        <div class="cb-admin-section-title">Policy JSON</div>
                    </div>
                </div>
                <pre class="mb-0 p-4 bg-light rounded"><code>@policyJson</code></pre>
            </div>
        </div>
    </div>
</div>
