@model IReadOnlyCollection<CoinBot.Application.Abstractions.Administration.AdminTraceListItem>
@using CoinBot.Web.ViewModels.Admin
@{
    var query = ViewData["AdminTraceQuery"] as string;
    var headerModel = new AdminPageHeaderViewModel
    {
        Eyebrow = "Correlation Trace",
        Title = "Audit & Log Merkezi",
        Description = "CorrelationId tabanli decision ve execution trace read-modeli; signal -> decision -> execution zinciri minimal admin listesi.",
        StatusBadge = new AdminBadgeViewModel { Label = "Trace Index", Tone = "info", IconText = "TR" },
        MetaBadges = new[]
        {
            new AdminBadgeViewModel { Label = "Masked", Tone = "healthy", IconText = "MS" },
            new AdminBadgeViewModel { Label = "Read Model", Tone = "warning", IconText = "RM" },
            new AdminBadgeViewModel { Label = "No Live Query", Tone = "neutral", IconText = "NL" }
        },
        SecondaryActionText = "Sistem sağlığı",
        SecondaryActionHref = Url.Action("SystemHealth", "Admin", new { area = "Admin" }),
        PrimaryActionText = "Global search",
        PrimaryActionHref = Url.Action("Search", "Admin", new { area = "Admin" })
    };
}

<div class="row">
    <div class="col-12">
        <div class="card card-custom gutter-b cb-card cb-admin-card">
            <div class="card-body">
                @await Html.PartialAsync("Foundation/_AdminPageHeader", headerModel)

                @await Html.PartialAsync("Foundation/_AdminInfoStrip", new AdminInfoStripViewModel
                {
                    Tone = "info",
                    Title = "Correlation zinciri admin read-modeli",
                    Message = "Liste snapshot/read-model verisinden beslenir. Canli trading path veya agir trace sorgusu admin UI'ya bind edilmez.",
                    Meta = string.IsNullOrWhiteSpace(query) ? "Recent traces" : $"Query={query}"
                })
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="card card-custom gutter-b cb-card cb-admin-card cb-admin-table-card">
            <div class="card-body">
                <div class="cb-admin-table-header">
                    <div>
                        <div class="cb-admin-section-kicker">Trace List</div>
                        <div class="cb-admin-section-title">Correlation trace listesi</div>
                        <p class="cb-admin-section-description mb-0">Decision sayisi, execution sayisi, kullanici ve provider son dokunusunu tek satirda gorursunuz.</p>
                    </div>
                    @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel
                    {
                        Label = $"{Model.Count} row",
                        Tone = Model.Count > 0 ? "healthy" : "warning",
                        IconText = "LS"
                    })
                </div>

                <div class="table-responsive cb-admin-table-wrap">
                    <table class="table table-borderless cb-admin-table mb-0">
                        <thead>
                            <tr>
                                <th>CorrelationId</th>
                                <th>User</th>
                                <th>Symbol</th>
                                <th>Decision</th>
                                <th>Execution</th>
                                <th>Provider</th>
                                <th>LastUpdatedAtUtc</th>
                                <th>Aksiyon</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Count == 0)
                            {
                                <tr>
                                    <td colspan="8" class="text-muted">Trace bulunamadi. Query, CorrelationId, DecisionId veya ExecutionAttemptId ile tekrar deneyin.</td>
                                </tr>
                            }
                            else
                            {
                                foreach (var row in Model)
                                {
                                    <tr>
                                        <td><strong>@row.CorrelationId</strong></td>
                                        <td>@(row.UserId ?? "-")</td>
                                        <td>@((row.Symbol is null ? "-" : $"{row.Symbol} / {row.Timeframe ?? "?"}"))</td>
                                        <td>
                                            <div>@(row.DecisionOutcome ?? "-")</div>
                                            <small class="text-muted">Count=@row.DecisionCount @(string.IsNullOrWhiteSpace(row.VetoReasonCode) ? string.Empty : $"| Veto={row.VetoReasonCode}")</small>
                                        </td>
                                        <td>@row.ExecutionCount</td>
                                        <td>@(row.LatestExecutionProvider ?? "-")</td>
                                        <td>@row.LastUpdatedAtUtc.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                        <td>
                                            <a asp-area="Admin"
                                               asp-controller="Admin"
                                               asp-action="TraceDetail"
                                               asp-route-correlationId="@row.CorrelationId"
                                               class="btn btn-xs btn-light-primary font-weight-bold">Detay</a>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
