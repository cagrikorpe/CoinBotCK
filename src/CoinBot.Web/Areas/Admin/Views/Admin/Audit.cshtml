@model CoinBot.Web.ViewModels.Admin.AdminIncidentAuditDecisionCenterViewModel
@using CoinBot.Contracts.Common
@using CoinBot.Web.ViewModels.Admin
@{
    var pagination = Model.Pagination;
    var isInitialFastMode =
        !Model.Filters.HasActiveFilters &&
        string.IsNullOrWhiteSpace(Model.Filters.FocusReference) &&
        (pagination?.Page ?? Model.Filters.Page) == 1;

    string BuildAuditHref(int targetPage, int? targetPageSize = null, string? focusReference = null, bool clearFocus = false, bool forceUltraLog = false)
    {
        return Url.Action("AuditLogs", "Admin", new
        {
            area = "Admin",
            query = Model.Filters.Query,
            correlationId = Model.Filters.CorrelationId,
            decisionId = Model.Filters.DecisionId,
            executionAttemptId = Model.Filters.ExecutionAttemptId,
            userId = Model.Filters.UserId,
            symbol = Model.Filters.Symbol,
            outcome = Model.Filters.Outcome,
            reasonCode = Model.Filters.ReasonCode,
            take = Model.Filters.Take,
            page = targetPage,
            pageSize = targetPageSize ?? pagination?.PageSize ?? Model.Filters.PageSize,
            focus = clearFocus ? null : focusReference ?? Model.Filters.FocusReference,
            logBucket = Model.UltraDebugLog?.SearchView?.SelectedBucketValue,
            logCategory = Model.UltraDebugLog?.SearchView?.SelectedCategoryValue,
            logSource = Model.UltraDebugLog?.SearchView?.SourceFilter,
            logSearch = Model.UltraDebugLog?.SearchView?.SearchTerm,
            logTimeWindow = Model.UltraDebugLog?.SearchView?.SelectedTimeWindowValue,
            logTake = Model.UltraDebugLog?.SearchView?.SelectedTake,
            ultraLog = forceUltraLog || Model.UltraDebugLog is not null ? true : (bool?)null
        }) ?? "#";
    }

    string BuildFocusHref(string focusReference)
    {
        return BuildAuditHref(
            targetPage: pagination?.Page ?? Model.Filters.Page,
            targetPageSize: pagination?.PageSize ?? Model.Filters.PageSize,
            focusReference: focusReference);
    }

    string BuildUltraLogHref()
    {
        return BuildAuditHref(
            targetPage: pagination?.Page ?? Model.Filters.Page,
            targetPageSize: pagination?.PageSize ?? Model.Filters.PageSize,
            forceUltraLog: true);
    }

    IReadOnlyCollection<int> BuildVisiblePages()
    {
        if (pagination is null)
        {
            return Array.Empty<int>();
        }

        var pages = new SortedSet<int> { pagination.Page };

        if (pagination.Page > 1)
        {
            pages.Add(1);
            pages.Add(pagination.Page - 1);
        }

        if (pagination.HasNextPage)
        {
            pages.Add(pagination.Page + 1);
        }

        return pages.ToArray();
    }

    var ultraLog = Model.UltraDebugLog;
    var ultraLogSearch = ultraLog?.SearchView;
    var canExportMaskedLogs = User.HasClaim(ApplicationClaimTypes.Permission, ApplicationPermissions.PlatformAdministration);

    string? traceDetailHref = Model.Detail.HasSelection && !string.Equals(Model.Detail.CorrelationId, "Unavailable", StringComparison.OrdinalIgnoreCase)
        ? Url.Action("TraceDetail", "Admin", new
        {
            area = "Admin",
            correlationId = Model.Detail.CorrelationId,
            decisionId = string.Equals(Model.Detail.DecisionId, "Unavailable", StringComparison.OrdinalIgnoreCase) ? null : Model.Detail.DecisionId,
            executionAttemptId = string.Equals(Model.Detail.ExecutionAttemptId, "Unavailable", StringComparison.OrdinalIgnoreCase) ? null : Model.Detail.ExecutionAttemptId
        })
        : null;
    string? incidentDetailHref = Model.Detail.HasSelection && !string.Equals(Model.Detail.IncidentReference, "Unavailable", StringComparison.OrdinalIgnoreCase)
        ? Url.Action("IncidentDetail", "Admin", new { area = "Admin", incidentReference = Model.Detail.IncidentReference })
        : null;
    string? approvalDetailHref = Model.Detail.HasSelection && !string.Equals(Model.Detail.ApprovalReference, "Unavailable", StringComparison.OrdinalIgnoreCase)
        ? Url.Action("ApprovalDetail", "Admin", new { area = "Admin", approvalReference = Model.Detail.ApprovalReference })
        : null;

    var headerModel = new AdminPageHeaderViewModel
    {
        Eyebrow = "Observability / Governance",
        Title = "Incident / Audit / Decision Center",
        Description = "Allow, block, retry ve skip kararlarini admin audit, approval ve incident zinciriyle birlikte tek merkezde okutur.",
        StatusBadge = new AdminBadgeViewModel { Label = Model.HasError ? "Degraded" : "Read Model", Tone = Model.HasError ? "critical" : "info", IconText = "ID" },
        MetaBadges = new[]
        {
            new AdminBadgeViewModel { Label = "Masked", Tone = "healthy", IconText = "MS" },
            new AdminBadgeViewModel { Label = "Audit bound", Tone = "warning", IconText = "AU" },
            new AdminBadgeViewModel { Label = "Fail closed", Tone = "critical", IconText = "FC" }
        },
        SecondaryActionText = "Approval merkezi",
        SecondaryActionHref = Url.Action("Approvals", "Admin", new { area = "Admin" }),
        PrimaryActionText = "Incident merkezi",
        PrimaryActionHref = Url.Action("Incidents", "Admin", new { area = "Admin" })
    };
}

<div class="row" data-cb-admin-decision-center>
    <div class="col-12">
        <div class="card card-custom gutter-b cb-card cb-admin-card">
            <div class="card-body">
                @await Html.PartialAsync("Foundation/_AdminPageHeader", headerModel)
                @await Html.PartialAsync("Foundation/_AdminInfoStrip", new AdminInfoStripViewModel
                {
                    Tone = Model.HasError ? "critical" : "info",
                    Title = "Tek merkez decision / audit / incident gorunumu",
                    Message = "Outcome, reason code, changed by, before/after ve approval/incident zinciri ayni admin sayfasinda okunur.",
                    Meta = $"Refresh={Model.RefreshedAtUtcLabel}"
                })

                @if (Model.HasError)
                {
                    <div class="cb-admin-info-strip cb-admin-info-strip-danger mt-6">
                        <div>
                            <div class="cb-admin-info-strip-title">Read-model unavailable</div>
                            <div class="cb-admin-info-strip-text">@(Model.ErrorMessage ?? "Incident / audit / decision verisi alinamadi.")</div>
                        </div>
                        <span class="cb-admin-info-strip-meta">Blocked</span>
                    </div>
                }

                <div class="cb-admin-summary-grid mt-6" data-cb-admin-decision-summary>
                    @foreach (var card in Model.SummaryCards)
                    {
                        <div class="cb-admin-summary-card">
                            <span class="cb-admin-summary-label">@card.Label</span>
                            <strong>@card.Value</strong>
                            <small>@card.Summary</small>
                        </div>
                    }
                </div>

                @if (!Model.Filters.HasActiveFilters)
                {
                    <div class="cb-admin-info-strip cb-admin-info-strip-info mt-6">
                        <div>
                            <div class="cb-admin-info-strip-title">Latest bounded preview</div>
                            <div class="cb-admin-info-strip-text">İlk yükte son 6 saatten bounded kayıt önizlemesi gösterilir. Daha eski veya daha geniş arama için filtre uygulayın.</div>
                        </div>
                        <span class="cb-admin-info-strip-meta">6h preview</span>
                    </div>
                }

                @if (TempData["AdminUltraDebugLogSuccess"] is string ultraLogSuccessMessage)
                {
                    <div class="cb-admin-info-strip cb-admin-info-strip-healthy mt-6">
                        <div>
                            <div class="cb-admin-info-strip-title">Ultra log durumu</div>
                            <div class="cb-admin-info-strip-text">@ultraLogSuccessMessage</div>
                        </div>
                        <span class="cb-admin-info-strip-meta">Applied</span>
                    </div>
                }

                @if (TempData["AdminUltraDebugLogError"] is string ultraLogErrorMessage)
                {
                    <div class="cb-admin-info-strip cb-admin-info-strip-danger mt-6">
                        <div>
                            <div class="cb-admin-info-strip-title">Ultra log rejected</div>
                            <div class="cb-admin-info-strip-text">@ultraLogErrorMessage</div>
                        </div>
                        <span class="cb-admin-info-strip-meta">Blocked</span>
                    </div>
                }

                @if (ultraLog is not null)
                {
                    <div class="cb-admin-table-header mt-6 mb-4">
                        <div>
                            <div class="cb-admin-section-kicker">Ultra Debug Log</div>
                            <div class="cb-admin-section-title">Süreli ve kalıcı ultra debug mode</div>
                            <p class="cb-admin-section-description mb-0">Normal bucket yazımı sürer. Ultra bucket yalnız süreli mode açıkken güvenli özetler yazar.</p>
                        </div>
                        @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel
                        {
                            Label = ultraLog.StatusLabel,
                            Tone = ultraLog.StatusTone,
                            IconText = "UL"
                        })
                    </div>

                    <div class="cb-admin-summary-grid">
                        <div class="cb-admin-summary-card">
                            <span class="cb-admin-summary-label">Durum</span>
                            <strong>@ultraLog.StatusLabel</strong>
                            <small>@ultraLog.StatusMessage</small>
                        </div>
                        <div class="cb-admin-summary-card">
                            <span class="cb-admin-summary-label">Başlatan admin</span>
                            <strong>@ultraLog.StartedByAdmin</strong>
                            <small>Duration=@ultraLog.DurationLabel</small>
                        </div>
                        <div class="cb-admin-summary-card">
                            <span class="cb-admin-summary-label">Normal logs limiti</span>
                            <strong>@ultraLog.NormalLogsLimitLabel</strong>
                            <small>Her zaman yazan bucket</small>
                        </div>
                        <div class="cb-admin-summary-card">
                            <span class="cb-admin-summary-label">Ultra logs limiti</span>
                            <strong>@ultraLog.UltraLogsLimitLabel</strong>
                            <small>Yalnız ultra mode açıkken</small>
                        </div>
                        <div class="cb-admin-summary-card">
                            <span class="cb-admin-summary-label">Normal logs kullanım</span>
                            <strong>@ultraLog.NormalLogsUsageLabel</strong>
                            <small>Limit=@ultraLog.NormalLogsLimitLabel</small>
                        </div>
                        <div class="cb-admin-summary-card">
                            <span class="cb-admin-summary-label">Ultra logs kullanım</span>
                            <strong>@ultraLog.UltraLogsUsageLabel</strong>
                            <small>Limit=@ultraLog.UltraLogsLimitLabel</small>
                        </div>
                        <div class="cb-admin-summary-card">
                            <span class="cb-admin-summary-label">Disk free space</span>
                            <strong>@ultraLog.DiskFreeSpaceLabel</strong>
                            <small>Log root için kullanılabilir alan</small>
                        </div>
                        <div class="cb-admin-summary-card">
                            <span class="cb-admin-summary-label">Safety mode</span>
                            <strong>@ultraLog.SafetyModeLabel</strong>
                            <small>Disk pressure / write failure fallback</small>
                        </div>
                        <div class="cb-admin-summary-card">
                            <span class="cb-admin-summary-label">Başlangıç</span>
                            <strong>@ultraLog.StartedAtUtcLabel</strong>
                            <small>Bitiş=@ultraLog.ExpiresAtUtcLabel</small>
                        </div>
                        <div class="cb-admin-summary-card">
                            <span class="cb-admin-summary-label">Kalan süre</span>
                            <strong>@ultraLog.RemainingLabel</strong>
                            <small>Reason=@ultraLog.AutoDisabledReasonCode</small>
                        </div>
                    </div>

                    @if (ultraLog.LatestStructuredEvent is not null)
                    {
                        <div class="cb-admin-table-header mt-6 mb-4">
                            <div>
                                <div class="cb-admin-section-kicker">Structured Observability</div>
                                <div class="cb-admin-section-title">Son ultra-debug event özeti</div>
                                <p class="cb-admin-section-description mb-0">Category, blocker ve latency özeti tek yüzeyde görünür. Alanlar masked NDJSON kaydından derive edilir.</p>
                            </div>
                        </div>

                        <div class="cb-admin-summary-grid">
                            <div class="cb-admin-summary-card">
                                <span class="cb-admin-summary-label">Son category</span>
                                <strong>@ultraLog.LatestStructuredEvent.CategoryLabel</strong>
                                <small>@ultraLog.LatestStructuredEvent.EventName</small>
                            </div>
                            <div class="cb-admin-summary-card">
                                <span class="cb-admin-summary-label">Son symbol / timeframe</span>
                                <strong>@ultraLog.LatestStructuredEvent.SymbolLabel</strong>
                                <small>@ultraLog.LatestStructuredEvent.TimeframeLabel</small>
                            </div>
                            <div class="cb-admin-summary-card">
                                <span class="cb-admin-summary-label">Son source layer</span>
                                <strong>@ultraLog.LatestStructuredEvent.SourceLayerLabel</strong>
                                <small>@ultraLog.LatestStructuredEvent.OccurredAtUtcLabel</small>
                            </div>
                            <div class="cb-admin-summary-card">
                                <span class="cb-admin-summary-label">Son reason / blocker</span>
                                <strong>@ultraLog.LatestStructuredEvent.DecisionReasonCodeLabel</strong>
                                <small>@ultraLog.LatestStructuredEvent.BlockerCodeLabel</small>
                            </div>
                            <div class="cb-admin-summary-card">
                                <span class="cb-admin-summary-label">Son latency breakdown</span>
                                <strong>@ultraLog.LatestStructuredEvent.LatencyBreakdownLabel</strong>
                                <small>@ultraLog.LatestStructuredEvent.Summary</small>
                            </div>
                        </div>
                    }

                    @if (ultraLog.LatestCategoryEvents?.Count > 0)
                    {
                        <div class="cb-admin-summary-grid mt-4">
                            @foreach (var categoryEvent in ultraLog.LatestCategoryEvents)
                            {
                                <div class="cb-admin-summary-card">
                                    <span class="cb-admin-summary-label">@categoryEvent.CategoryLabel</span>
                                    <strong>@categoryEvent.EventName</strong>
                                    <small>@categoryEvent.SymbolLabel · @categoryEvent.TimeframeLabel · @categoryEvent.LatencyBreakdownLabel</small>
                                </div>
                            }
                        </div>
                    }

                    @if (ultraLogSearch is not null || ultraLog.NormalLogsTail is not null || ultraLog.UltraLogsTail is not null)
                    {
                        <div class="cb-admin-table-header mt-6 mb-4">
                            <div>
                                <div class="cb-admin-section-kicker">Masked Tail</div>
                                <div class="cb-admin-section-title">Search / filter / time-window preview</div>
                                <p class="cb-admin-section-description mb-0">Arama masked text üzerinde çalışır. Sunucu tarafında satır, dosya ve byte penceresi sabit sınırlarla tutulur.</p>
                            </div>
                        </div>

                        @if (ultraLogSearch is not null)
                        {
                            <form asp-area="Admin" asp-controller="Admin" asp-action="AuditLogs" method="get" class="row">
                                <input type="hidden" name="ultraLog" value="true" />
                                <input type="hidden" name="query" value="@Model.Filters.Query" />
                                <input type="hidden" name="correlationId" value="@Model.Filters.CorrelationId" />
                                <input type="hidden" name="decisionId" value="@Model.Filters.DecisionId" />
                                <input type="hidden" name="executionAttemptId" value="@Model.Filters.ExecutionAttemptId" />
                                <input type="hidden" name="userId" value="@Model.Filters.UserId" />
                                <input type="hidden" name="symbol" value="@Model.Filters.Symbol" />
                                <input type="hidden" name="outcome" value="@Model.Filters.Outcome" />
                                <input type="hidden" name="reasonCode" value="@Model.Filters.ReasonCode" />
                                <input type="hidden" name="focus" value="@Model.Filters.FocusReference" />
                                <input type="hidden" name="take" value="@Model.Filters.Take" />

                                <div class="col-md-2 mb-4">
                                    <label class="form-label">Bucket</label>
                                    <select name="logBucket" class="form-control">
                                        @foreach (var option in ultraLogSearch.BucketOptions)
                                        {
                                            <option value="@option.Value" selected="@option.IsSelected">@option.Label</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-2 mb-4">
                                    <label class="form-label">Category</label>
                                    <select name="logCategory" class="form-control">
                                        @foreach (var option in ultraLogSearch.CategoryOptions)
                                        {
                                            <option value="@option.Value" selected="@option.IsSelected">@option.Label</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-2 mb-4">
                                    <label class="form-label">Time window</label>
                                    <select name="logTimeWindow" class="form-control">
                                        @foreach (var option in ultraLogSearch.TimeWindowOptions)
                                        {
                                            <option value="@option.Value" selected="@option.IsSelected">@option.Label</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-2 mb-4">
                                    <label class="form-label">Source</label>
                                    <input name="logSource" class="form-control" value="@ultraLogSearch.SourceFilter" maxlength="128" placeholder="ExecutionEngine" />
                                </div>
                                <div class="col-md-2 mb-4">
                                    <label class="form-label">Search</label>
                                    <input name="logSearch" class="form-control" value="@ultraLogSearch.SearchTerm" maxlength="128" placeholder="dispatch / blocker / corr-..." />
                                </div>
                                <div class="col-md-1 mb-4">
                                    <label class="form-label">Limit</label>
                                    <select name="logTake" class="form-control">
                                        @foreach (var option in ultraLogSearch.TakeOptions)
                                        {
                                            <option value="@option.Value" selected="@option.IsSelected">@option.Label</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-1 mb-4 d-flex align-items-end">
                                    <button type="submit" class="btn btn-primary font-weight-bolder w-100">Ara</button>
                                </div>
                            </form>

                            <div class="cb-admin-info-strip cb-admin-info-strip-info mb-4">
                                <div>
                                    <div class="cb-admin-info-strip-title">Search guard</div>
                                    <div class="cb-admin-info-strip-text">@ultraLogSearch.PerformanceGuardLabel</div>
                                </div>
                                <span class="cb-admin-info-strip-meta">Server-side</span>
                            </div>

                            @if (canExportMaskedLogs)
                            {
                                <div class="cb-admin-info-strip cb-admin-info-strip-info mb-4">
                                    <div>
                                        <div class="cb-admin-info-strip-title">Masked export</div>
                                        <div class="cb-admin-info-strip-text">NDJSON veya ZIP yalnız izinli bucket/category/source filtreleriyle dışarı verilir. Hard cap: 500 satır · 24 dosya · 2 MB · masked payload.</div>
                                    </div>
                                    <div class="d-flex flex-wrap gap-2">
                                        <form asp-area="Admin" asp-controller="Admin" asp-action="ExportUltraDebugLog" method="get" class="mb-0">
                                            <input type="hidden" name="logBucket" value="@ultraLogSearch.SelectedBucketValue" />
                                            <input type="hidden" name="logCategory" value="@ultraLogSearch.SelectedCategoryValue" />
                                            <input type="hidden" name="logSource" value="@ultraLogSearch.SourceFilter" />
                                            <input type="hidden" name="logSearch" value="@ultraLogSearch.SearchTerm" />
                                            <input type="hidden" name="logTimeWindow" value="@ultraLogSearch.SelectedTimeWindowValue" />
                                            <input type="hidden" name="maxRows" value="200" />
                                            <button type="submit" class="btn btn-light-primary font-weight-bold">NDJSON export</button>
                                        </form>
                                        <form asp-area="Admin" asp-controller="Admin" asp-action="ExportUltraDebugLog" method="get" class="mb-0">
                                            <input type="hidden" name="logBucket" value="@ultraLogSearch.SelectedBucketValue" />
                                            <input type="hidden" name="logCategory" value="@ultraLogSearch.SelectedCategoryValue" />
                                            <input type="hidden" name="logSource" value="@ultraLogSearch.SourceFilter" />
                                            <input type="hidden" name="logSearch" value="@ultraLogSearch.SearchTerm" />
                                            <input type="hidden" name="logTimeWindow" value="@ultraLogSearch.SelectedTimeWindowValue" />
                                            <input type="hidden" name="maxRows" value="200" />
                                            <input type="hidden" name="zipPackage" value="true" />
                                            <button type="submit" class="btn btn-light font-weight-bold">ZIP export</button>
                                        </form>
                                    </div>
                                </div>
                            }

                            <div class="card card-custom gutter-b cb-card cb-admin-card">
                                <div class="card-body">
                                    <div class="cb-admin-table-header mb-4">
                                        <div>
                                            <div class="cb-admin-section-kicker">@ultraLogSearch.SearchResult.BucketLabel</div>
                                            <div class="cb-admin-section-title">@ultraLogSearch.SearchResult.SummaryLabel</div>
                                            <p class="cb-admin-section-description mb-0">Time window, category, source ve masked search terimi birlikte uygulanır.</p>
                                        </div>
                                        @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel
                                        {
                                            Label = ultraLogSearch.SearchResult.IsTruncated ? "Bounded" : "Complete",
                                            Tone = ultraLogSearch.SearchResult.IsTruncated ? "warning" : "healthy",
                                            IconText = "SR"
                                        })
                                    </div>

                                    @if (ultraLogSearch.SearchResult.Lines.Count == 0)
                                    {
                                        <div class="text-muted">Seçili filtrelerle eşleşen preview satırı bulunamadı.</div>
                                    }
                                    else
                                    {
                                        <div class="table-responsive cb-admin-table-wrap">
                                            <table class="table table-borderless cb-admin-table mb-0">
                                                <thead>
                                                    <tr>
                                                        <th>When</th>
                                                        <th>Bucket</th>
                                                        <th>Category</th>
                                                        <th>Source</th>
                                                        <th>Event</th>
                                                        <th>Summary</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var line in ultraLogSearch.SearchResult.Lines)
                                                    {
                                                        <tr>
                                                            <td>@line.OccurredAtUtcLabel</td>
                                                            <td>@line.BucketLabel</td>
                                                            <td>@line.CategoryLabel</td>
                                                            <td>@line.SourceLabel</td>
                                                            <td>
                                                                <div><strong>@line.EventName</strong></div>
                                                                <small class="text-muted">@line.SymbolLabel</small>
                                                            </td>
                                                            <td>
                                                                <div>@line.Summary</div>
                                                                <small class="text-muted">@line.SourceFileLabel · Corr=@line.CorrelationIdLabel</small>
                                                                @if (!string.Equals(line.DetailPreview, "n/a", StringComparison.OrdinalIgnoreCase))
                                                                {
                                                                    <details class="mt-2">
                                                                        <summary class="text-muted">Masked detail</summary>
                                                                        <pre class="mt-2 mb-0"><code>@line.DetailPreview</code></pre>
                                                                    </details>
                                                                }
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        <div class="row">
                            @foreach (var tail in new[] { ultraLog.NormalLogsTail, ultraLog.UltraLogsTail }.Where(item => item is not null))
                            {
                                <div class="col-xl-6">
                                    <div class="card card-custom gutter-b cb-card cb-admin-card">
                                        <div class="card-body">
                                            <div class="cb-admin-table-header mb-4">
                                                <div>
                                                    <div class="cb-admin-section-kicker">@tail!.BucketLabel</div>
                                                    <div class="cb-admin-section-title">@tail.SummaryLabel</div>
                                                    <p class="cb-admin-section-description mb-0">Tail window max 8 satır, max 2 dosya, max 128 KB / dosya.</p>
                                                </div>
                                                @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel
                                                {
                                                    Label = tail.IsTruncated ? "Truncated" : "Complete",
                                                    Tone = tail.IsTruncated ? "warning" : "healthy",
                                                    IconText = "TL"
                                                })
                                            </div>

                                            @if (tail.Lines.Count == 0)
                                            {
                                                <div class="text-muted">Preview bulunamadı.</div>
                                            }
                                            else
                                            {
                                                <div class="table-responsive cb-admin-table-wrap">
                                                    <table class="table table-borderless cb-admin-table mb-0">
                                                        <thead>
                                                            <tr>
                                                                <th>When</th>
                                                                <th>Category</th>
                                                                <th>Source</th>
                                                                <th>Event</th>
                                                                <th>Summary</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            @foreach (var line in tail.Lines)
                                                            {
                                                                <tr>
                                                                    <td>@line.OccurredAtUtcLabel</td>
                                                                    <td>@line.CategoryLabel</td>
                                                                    <td>@line.SourceLabel</td>
                                                                    <td>
                                                                        <div><strong>@line.EventName</strong></div>
                                                                        <small class="text-muted">@line.SymbolLabel</small>
                                                                    </td>
                                                                    <td>
                                                                        <div>@line.Summary</div>
                                                                        <small class="text-muted">@line.SourceFileLabel · Corr=@line.CorrelationIdLabel</small>
                                                                        @if (!string.Equals(line.DetailPreview, "n/a", StringComparison.OrdinalIgnoreCase))
                                                                        {
                                                                            <details class="mt-2">
                                                                                <summary class="text-muted">Masked detail</summary>
                                                                                <pre class="mt-2 mb-0"><code>@line.DetailPreview</code></pre>
                                                                            </details>
                                                                        }
                                                                    </td>
                                                                </tr>
                                                            }
                                                        </tbody>
                                                    </table>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }

                    <div class="row mt-4">
                        <div class="col-lg-8">
                            <form asp-area="Admin" asp-controller="Admin" asp-action="EnableUltraDebugLog" method="post" class="row">
                                @Html.AntiForgeryToken()
                                <div class="col-md-3 mb-4">
                                    <label class="form-label">Ultra Detaylı Log Modu</label>
                                    <div class="form-control d-flex align-items-center gap-2">
                                        <input type="checkbox" @(ultraLog.IsEnabled ? "checked" : null) @(ultraLog.IsEnabled ? "disabled" : null) />
                                        <span>@(ultraLog.IsEnabled ? "Açık" : "Kapalı")</span>
                                    </div>
                                </div>
                                <div class="col-md-3 mb-4">
                                    <label class="form-label">Süre</label>
                                    <select name="durationKey" class="form-control" required>
                                        <option value="">Süre seçin</option>
                                        @foreach (var duration in ultraLog.DurationOptions)
                                        {
                                            <option value="@duration.Key" selected="@duration.IsSelected">@duration.Label</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-3 mb-4">
                                    <label class="form-label">Normal Logs Limiti (MB)</label>
                                    <select name="normalLogsLimitMb" class="form-control" required>
                                        <option value="">Limit seçin</option>
                                        @foreach (var limit in ultraLog.NormalLogsLimitOptions)
                                        {
                                            <option value="@limit.ValueMb" selected="@limit.IsSelected">@limit.Label</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-3 mb-4">
                                    <label class="form-label">Ultra Logs Limiti (MB)</label>
                                    <select name="ultraLogsLimitMb" class="form-control" required>
                                        <option value="">Limit seçin</option>
                                        @foreach (var limit in ultraLog.UltraLogsLimitOptions)
                                        {
                                            <option value="@limit.ValueMb" selected="@limit.IsSelected">@limit.Label</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-12 mb-4 d-flex align-items-end">
                                    <button type="submit" class="btn btn-primary font-weight-bolder w-100" @(ultraLog.IsEnabled ? "disabled" : null)>Ultra log aç</button>
                                </div>
                            </form>
                        </div>
                        <div class="col-lg-4">
                            <form asp-area="Admin" asp-controller="Admin" asp-action="DisableUltraDebugLog" method="post" class="h-100 d-flex align-items-end">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-light-danger font-weight-bolder w-100" @(!ultraLog.IsEnabled ? "disabled" : null)>Ultra log kapat</button>
                            </form>
                        </div>
                    </div>
                }
                else
                {
                    <div class="cb-admin-info-strip cb-admin-info-strip-info mt-6">
                        <div>
                            <div class="cb-admin-info-strip-title">Ultra debug diagnostics lazy</div>
                            <div class="cb-admin-info-strip-text">Varsayılan audit yükünde ultra log snapshot, tail ve masked search yüklenmez.</div>
                        </div>
                        <a class="btn btn-light-primary font-weight-bold" href="@BuildUltraLogHref()">Ultra log panelini yükle</a>
                    </div>
                }
            </div>
        </div>
    </div>

    @if (!isInitialFastMode)
    {
        <div class="col-12">
            @await Html.PartialAsync("Foundation/_AdminLogTraceDebugDeepDive", Model)
        </div>
    }
    else
    {
        <div class="col-12">
            <div class="card card-custom gutter-b cb-card cb-admin-card">
                <div class="card-body">
                    <div class="cb-admin-info-strip cb-admin-info-strip-info">
                        <div>
                            <div class="cb-admin-info-strip-title">Initial fast mode</div>
                            <div class="cb-admin-info-strip-text">İlk yükte gelişmiş trace/debug yüzeyi kapalı tutulur. Focus seçince veya filtre uygulayınca tam teknik panel açılır.</div>
                        </div>
                        <span class="cb-admin-info-strip-meta">Fast shell</span>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="col-12">
        <div class="card card-custom gutter-b cb-card cb-admin-card">
            <div class="card-body">
                <div class="cb-admin-table-header mb-4">
                    <div>
                        <div class="cb-admin-section-kicker">Filter</div>
                        <div class="cb-admin-section-title">Outcome, reason code ve scope filtreleri</div>
                        <p class="cb-admin-section-description mb-0">Allow, block, retry ve skip ayrimi tek toolbar uzerinden daraltilir. Bos reason code sessiz gecilmez; Unavailable olarak gorunur.</p>
                    </div>
                    @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel
                    {
                        Label = Model.Filters.HasActiveFilters ? "Filtered" : "All rows",
                        Tone = Model.Filters.HasActiveFilters ? "warning" : "healthy",
                        IconText = "FL"
                    })
                </div>

                <form asp-area="Admin" asp-controller="Admin" asp-action="AuditLogs" method="get" class="row">
                    <input type="hidden" name="ultraLog" value="@(ultraLog is not null ? "true" : "false")" />
                    <input type="hidden" name="logBucket" value="@ultraLogSearch?.SelectedBucketValue" />
                    <input type="hidden" name="logCategory" value="@ultraLogSearch?.SelectedCategoryValue" />
                    <input type="hidden" name="logSource" value="@ultraLogSearch?.SourceFilter" />
                    <input type="hidden" name="logSearch" value="@ultraLogSearch?.SearchTerm" />
                    <input type="hidden" name="logTimeWindow" value="@ultraLogSearch?.SelectedTimeWindowValue" />
                    <input type="hidden" name="logTake" value="@ultraLogSearch?.SelectedTake" />
                    <div class="col-md-3 mb-4">
                        <label class="form-label">Query</label>
                        <input name="query" class="form-control" value="@Model.Filters.Query" maxlength="128" placeholder="Correlation / action / summary" />
                    </div>
                    <div class="col-md-3 mb-4">
                        <label class="form-label">CorrelationId</label>
                        <input name="correlationId" class="form-control" value="@Model.Filters.CorrelationId" maxlength="128" placeholder="corr-..." />
                    </div>
                    <div class="col-md-2 mb-4">
                        <label class="form-label">DecisionId</label>
                        <input name="decisionId" class="form-control" value="@Model.Filters.DecisionId" maxlength="64" placeholder="dec-..." />
                    </div>
                    <div class="col-md-2 mb-4">
                        <label class="form-label">ExecutionId</label>
                        <input name="executionAttemptId" class="form-control" value="@Model.Filters.ExecutionAttemptId" maxlength="64" placeholder="exe-..." />
                    </div>
                    <div class="col-md-2 mb-4">
                        <label class="form-label">User</label>
                        <input name="userId" class="form-control" value="@Model.Filters.UserId" maxlength="450" placeholder="user-id" />
                    </div>
                    <div class="col-md-3 mb-4">
                        <label class="form-label">Symbol / scope</label>
                        <input name="symbol" class="form-control" value="@Model.Filters.Symbol" maxlength="32" placeholder="BTCUSDT / Global" />
                    </div>
                    <div class="col-md-3 mb-4">
                        <label class="form-label">Outcome</label>
                        <select id="cb_admin_audit_filter_outcome" name="outcome" class="form-control">
                            <option value="">Tum outcome'lar</option>
                            <option value="Allow" selected="@(string.Equals(Model.Filters.Outcome, "Allow", StringComparison.OrdinalIgnoreCase))">Allow</option>
                            <option value="Block" selected="@(string.Equals(Model.Filters.Outcome, "Block", StringComparison.OrdinalIgnoreCase))">Block</option>
                            <option value="Retry" selected="@(string.Equals(Model.Filters.Outcome, "Retry", StringComparison.OrdinalIgnoreCase))">Retry</option>
                            <option value="Skip" selected="@(string.Equals(Model.Filters.Outcome, "Skip", StringComparison.OrdinalIgnoreCase))">Skip</option>
                        </select>
                    </div>
                    <div class="col-md-3 mb-4">
                        <label class="form-label">Reason code</label>
                        <input id="cb_admin_audit_filter_reason_code" name="reasonCode" class="form-control" value="@Model.Filters.ReasonCode" maxlength="128" placeholder="Allowed / RiskVeto / ..." />
                    </div>
                    <div class="col-md-1 mb-4">
                        <label class="form-label">Take</label>
                        <input name="take" type="number" min="25" max="200" class="form-control" value="@Model.Filters.Take" />
                    </div>
                    <div class="col-md-1 mb-4">
                        <label class="form-label">Page size</label>
                        <select name="pageSize" class="form-control">
                            <option value="10" selected="@(Model.Filters.PageSize == 10)">10</option>
                            <option value="25" selected="@(Model.Filters.PageSize == 25)">25</option>
                            <option value="50" selected="@(Model.Filters.PageSize == 50)">50</option>
                            <option value="100" selected="@(Model.Filters.PageSize == 100)">100</option>
                        </select>
                    </div>
                    <div class="col-md-2 mb-4 d-flex align-items-end gap-2">
                        <button type="submit" class="btn btn-primary font-weight-bolder">Uygula</button>
                        <a href="@(ultraLog is not null ? BuildAuditHref(1, Model.Filters.PageSize, clearFocus: true, forceUltraLog: true) : Url.Action("AuditLogs", "Admin", new { area = "Admin", page = 1, pageSize = Model.Filters.PageSize }))" class="btn btn-light font-weight-bold">Temizle</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-xl-7">
        <div class="card card-custom gutter-b cb-card cb-admin-card cb-admin-table-card">
            <div class="card-body">
                <div class="cb-admin-table-header">
                    <div>
                        <div class="cb-admin-section-kicker">Decision explorer</div>
                        <div class="cb-admin-section-title">Outcome normalize edilmis kayit listesi</div>
                        <p class="cb-admin-section-description mb-0">Allow / block / retry / skip ayrimi, reason code ve actor bilgisi tek satirda gorunur.</p>
                    </div>
                    @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel
                    {
                        Label = pagination is null ? $"{Model.Rows.Count} row" : $"Sayfa {pagination.Page} · {Model.Rows.Count}/{pagination.PageSize}",
                        Tone = Model.Rows.Count > 0 ? "healthy" : "warning",
                        IconText = "LS"
                    })
                </div>

                @if (pagination is not null)
                {
                    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-4 mb-4">
                        <div class="text-muted">
                            Sayfa @pagination.Page · @Model.Rows.Count kayıt gösteriliyor
                            @if (pagination.HasNextPage)
                            {
                                <span>· daha fazlası olabilir</span>
                            }
                        </div>
                        <div class="d-flex flex-wrap align-items-center gap-2">
                            <span class="text-muted">Page size</span>
                            @foreach (var option in new[] { 10, 25, 50, 100 })
                            {
                                if (option == pagination.PageSize)
                                {
                                    <span class="btn btn-xs btn-light-primary font-weight-bold disabled">@option</span>
                                }
                                else
                                {
                                    <a href="@BuildAuditHref(1, option, clearFocus: true)" class="btn btn-xs btn-light font-weight-bold">@option</a>
                                }
                            }
                        </div>
                    </div>
                }

                <div class="table-responsive cb-admin-table-wrap">
                    <table class="table table-borderless cb-admin-table mb-0">
                        <thead>
                            <tr>
                                <th>Outcome</th>
                                <th>Kind</th>
                                <th>Reason</th>
                                <th>ChangedBy</th>
                                <th>When</th>
                                <th>Scope</th>
                                <th>Summary</th>
                                <th>Aksiyon</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Rows.Count == 0)
                            {
                                <tr>
                                    <td colspan="8" class="text-muted">@Model.EmptyStateMessage</td>
                                </tr>
                            }
                            else
                            {
                                foreach (var row in Model.Rows)
                                {
                                    var isSelected = Model.Detail.HasSelection && string.Equals(Model.Detail.Reference, row.Reference, StringComparison.OrdinalIgnoreCase);
                                    <tr data-cb-admin-decision-row data-cb-admin-decision-outcome="@row.OutcomeLabel" class="@(isSelected ? "cb-admin-row-selected" : string.Empty)">
                                        <td>
                                            @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel
                                            {
                                                Label = row.OutcomeLabel,
                                                Tone = row.OutcomeTone,
                                                IconText = row.OutcomeLabel[..1]
                                            })
                                        </td>
                                        <td>
                                            <div><strong>@row.Kind</strong></div>
                                            <small class="text-muted">@row.StatusLabel</small>
                                        </td>
                                        <td>
                                            <div>@row.ReasonCode</div>
                                            <small class="text-muted">@row.ReasonType</small>
                                        </td>
                                        <td>@row.ChangedBy</td>
                                        <td>@row.OccurredAtUtcLabel</td>
                                        <td>@row.ScopeLabel</td>
                                        <td>@row.Summary</td>
                                        <td>
                                            <a href="@BuildFocusHref(row.Reference)" class="btn btn-xs btn-light-primary font-weight-bold">Detay</a>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>

                @if (pagination is not null)
                {
                    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-4">
                        <div class="d-flex flex-wrap align-items-center gap-2">
                            @if (pagination.HasPreviousPage)
                            {
                                <a href="@BuildAuditHref(pagination.Page - 1, clearFocus: true)" class="btn btn-sm btn-light font-weight-bold">Önceki</a>
                            }
                            else
                            {
                                <span class="btn btn-sm btn-light disabled">Önceki</span>
                            }

                            @foreach (var pageNumber in BuildVisiblePages())
                            {
                                if (pageNumber == pagination.Page)
                                {
                                    <span class="btn btn-sm btn-primary disabled">@pageNumber</span>
                                }
                                else
                                {
                                    <a href="@BuildAuditHref(pageNumber, clearFocus: true)" class="btn btn-sm btn-light font-weight-bold">@pageNumber</a>
                                }
                            }

                            @if (pagination.HasNextPage)
                            {
                                <a href="@BuildAuditHref(pagination.Page + 1, clearFocus: true)" class="btn btn-sm btn-light font-weight-bold">Sonraki</a>
                            }
                            else
                            {
                                <span class="btn btn-sm btn-light disabled">Sonraki</span>
                            }
                        </div>
                        <small class="text-muted">Bounded preview pagination · exact total count yok · daha fazla kayıt için page size artır veya Sonraki kullan</small>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-xl-5">
        <div class="card card-custom gutter-b cb-card cb-admin-card" data-cb-admin-decision-detail>
            <div class="card-body">
                <div class="cb-admin-table-header mb-4">
                    <div>
                        <div class="cb-admin-section-kicker">Detail</div>
                        <div class="cb-admin-section-title">Karar zinciri detayi</div>
                        <p class="cb-admin-section-description mb-0">Last decision, reason code, changed by, when, before/after, approval history ve incident timeline ayni panelde gorunur.</p>
                    </div>
                </div>

                @if (!Model.Detail.HasSelection)
                {
                    <div class="cb-admin-info-strip cb-admin-info-strip-warning">
                        <div>
                            <div class="cb-admin-info-strip-title">Secili kayit yok</div>
                            <div class="cb-admin-info-strip-text">@Model.Detail.Summary</div>
                        </div>
                        <span class="cb-admin-info-strip-meta">Empty</span>
                    </div>
                }
                else
                {
                    <div class="cb-inline-stack mb-4">
                        @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = Model.Detail.OutcomeLabel, Tone = Model.Detail.OutcomeTone, IconText = "OC" })
                        @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = Model.Detail.Kind, Tone = "neutral", IconText = "KD" })
                        @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = Model.Detail.ReasonCode, Tone = "warning", IconText = "RC" })
                    </div>

                    <div class="cb-admin-summary-grid">
                        <div class="cb-admin-summary-card">
                            <span class="cb-admin-summary-label">LastDecision</span>
                            <strong>@Model.Detail.OutcomeLabel</strong>
                            <small>@Model.Detail.StatusLabel</small>
                        </div>
                        <div class="cb-admin-summary-card">
                            <span class="cb-admin-summary-label">ChangedBy</span>
                            <strong>@Model.Detail.ChangedBy</strong>
                            <small>@Model.Detail.ScopeLabel</small>
                        </div>
                        <div class="cb-admin-summary-card">
                            <span class="cb-admin-summary-label">When</span>
                            <strong>@Model.Detail.OccurredAtUtcLabel</strong>
                            <small>@Model.Detail.Reference</small>
                        </div>
                        <div class="cb-admin-summary-card">
                            <span class="cb-admin-summary-label">ReasonType</span>
                            <strong>@Model.Detail.ReasonType</strong>
                            <small data-cb-admin-decision-code>@Model.Detail.ReasonCode</small>
                        </div>
                    </div>

                    <div class="cb-admin-info-strip cb-admin-info-strip-info mt-5">
                        <div>
                            <div class="cb-admin-info-strip-title">Decision summary</div>
                            <div class="cb-admin-info-strip-text">@Model.Detail.Summary</div>
                        </div>
                        <span class="cb-admin-info-strip-meta">@(string.Equals(Model.Detail.OutcomeLabel, "Unknown", StringComparison.OrdinalIgnoreCase) ? "Review" : Model.Detail.OutcomeLabel)</span>
                    </div>

                    <div class="table-responsive cb-admin-table-wrap mt-5">
                        <table class="table table-borderless cb-admin-table mb-0">
                            <tbody>
                                <tr>
                                    <th>Before</th>
                                    <td data-cb-admin-before>@Model.Detail.BeforeSummary</td>
                                </tr>
                                <tr>
                                    <th>After</th>
                                    <td data-cb-admin-after>@Model.Detail.AfterSummary</td>
                                </tr>
                                <tr>
                                    <th>CorrelationId</th>
                                    <td>@Model.Detail.CorrelationId</td>
                                </tr>
                                <tr>
                                    <th>DecisionId</th>
                                    <td>@Model.Detail.DecisionId</td>
                                </tr>
                                <tr>
                                    <th>ExecutionAttemptId</th>
                                    <td>@Model.Detail.ExecutionAttemptId</td>
                                </tr>
                                <tr>
                                    <th>IncidentReference</th>
                                    <td>@Model.Detail.IncidentReference</td>
                                </tr>
                                <tr>
                                    <th>ApprovalReference</th>
                                    <td>@Model.Detail.ApprovalReference</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="d-flex flex-wrap gap-2 mt-5">
                        @if (!string.IsNullOrWhiteSpace(traceDetailHref))
                        {
                            <a href="@traceDetailHref" class="btn btn-light-info font-weight-bold">Trace detail</a>
                        }
                        @if (!string.IsNullOrWhiteSpace(approvalDetailHref))
                        {
                            <a href="@approvalDetailHref" class="btn btn-light-primary font-weight-bold">Approval detail</a>
                        }
                        @if (!string.IsNullOrWhiteSpace(incidentDetailHref))
                        {
                            <a href="@incidentDetailHref" class="btn btn-light-warning font-weight-bold">Incident detail</a>
                        }
                    </div>

                    <div class="mt-6" data-cb-admin-trace-section>
                        <div class="cb-admin-section-kicker">Execution trace</div>
                        <div class="cb-admin-section-title">Decision / execution trail</div>
                        <p class="cb-admin-section-description">Kararin signal, decision ve execution ayaklari zaman sirali gorunur.</p>
                        @if (Model.Detail.DecisionExecutionTrace.Count == 0)
                        {
                            <div class="text-muted">Trace detail bu kayit icin mevcut degil.</div>
                        }
                        else
                        {
                            foreach (var item in Model.Detail.DecisionExecutionTrace)
                            {
                                <div class="border-left border-primary pl-4 ml-2 mb-4" data-cb-admin-trace-item>
                                    <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                                        @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = item.Kind, Tone = item.Tone, IconText = "TR" })
                                        <strong>@item.Title</strong>
                                    </div>
                                    <div>@item.Summary</div>
                                    <div class="text-muted">@item.OccurredAtUtcLabel · Actor=@item.ChangedBy · @item.Meta</div>
                                </div>
                            }
                        }
                    </div>

                    <div class="mt-6" data-cb-admin-approval-history>
                        <div class="cb-admin-section-kicker">Approval history</div>
                        <div class="cb-admin-section-title">Approval zinciri</div>
                        <p class="cb-admin-section-description">Kim onayladi veya reddetti, hangi adimda ve ne zaman gorunur.</p>
                        @if (Model.Detail.ApprovalHistory.Count == 0)
                        {
                            <div class="text-muted">Approval history bu secim icin bagli degil.</div>
                        }
                        else
                        {
                            foreach (var item in Model.Detail.ApprovalHistory)
                            {
                                <div class="border-left border-primary pl-4 ml-2 mb-4" data-cb-admin-approval-item>
                                    <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                                        @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = item.Kind, Tone = item.Tone, IconText = "AP" })
                                        <strong>@item.Title</strong>
                                    </div>
                                    <div>@item.Summary</div>
                                    <div class="text-muted">@item.OccurredAtUtcLabel · Actor=@item.ChangedBy · @item.Meta</div>
                                </div>
                            }
                        }
                    </div>

                    <div class="mt-6" data-cb-admin-incident-timeline>
                        <div class="cb-admin-section-kicker">Incident timeline</div>
                        <div class="cb-admin-section-title">Incident olay zinciri</div>
                        <p class="cb-admin-section-description">Block, retry, approval ve recovery olaylari zaman sirali gorunur.</p>
                        @if (Model.Detail.IncidentTimeline.Count == 0)
                        {
                            <div class="text-muted">Incident timeline bu secim icin bagli degil.</div>
                        }
                        else
                        {
                            foreach (var item in Model.Detail.IncidentTimeline)
                            {
                                <div class="border-left border-primary pl-4 ml-2 mb-4" data-cb-admin-incident-item>
                                    <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                                        @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = item.Kind, Tone = item.Tone, IconText = "IN" })
                                        <strong>@item.Title</strong>
                                    </div>
                                    <div>@item.Summary</div>
                                    <div class="text-muted">@item.OccurredAtUtcLabel · Actor=@item.ChangedBy · @item.Meta</div>
                                </div>
                            }
                        }
                    </div>

                    <div class="mt-6" data-cb-admin-audit-trail>
                        <div class="cb-admin-section-kicker">Admin audit log</div>
                        <div class="cb-admin-section-title">Ilgili admin degisiklikleri</div>
                        <p class="cb-admin-section-description">ChangedBy / Before / After zinciri ayni correlation veya incident bagina gore secilir.</p>
                        @if (Model.Detail.AdminAuditTrail.Count == 0)
                        {
                            <div class="text-muted">Bagli ek admin degisikligi bulunamadi.</div>
                        }
                        else
                        {
                            foreach (var item in Model.Detail.AdminAuditTrail)
                            {
                                <div class="border-left border-primary pl-4 ml-2 mb-4" data-cb-admin-audit-item>
                                    <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                                        @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = item.Kind, Tone = item.Tone, IconText = "AU" })
                                        <strong>@item.Title</strong>
                                    </div>
                                    <div>@item.Summary</div>
                                    <div class="text-muted">@item.OccurredAtUtcLabel · Actor=@item.ChangedBy · @item.Meta</div>
                                </div>
                            }
                        }
                    </div>

                    <details class="mt-6" data-cb-admin-raw-json>
                        <summary class="text-muted">Masked payload</summary>
                        <pre class="mt-3 mb-0"><code>@Model.Detail.RawJson</code></pre>
                    </details>
                }
            </div>
        </div>
    </div>
</div>

