@{
    var returnUrl = ViewData["AdminAuthReturnUrl"]?.ToString() ?? "/admin";
    var headerModel = new AdminPageHeaderViewModel
    {
        Eyebrow = "Session Boundary",
        Title = "Session Expired",
        Description = "Admin alanında oturum süresi dolduğunda yeniden giriş veya yeniden doğrulama için temiz, profesyonel bir güvenlik ekranı gösterilir.",
        StatusBadge = new AdminBadgeViewModel { Label = "Session Expired", Tone = "warning", IconText = "SE" },
        MetaBadges = new[]
        {
            new AdminBadgeViewModel { Label = "Idle Timeout", Tone = "warning", IconText = "ID" },
            new AdminBadgeViewModel { Label = "Re-Auth Ready", Tone = "info", IconText = "RA" }
        },
        PrimaryActionText = "Yeniden giriş",
        PrimaryActionHref = Url.Action("Login", "Admin", new { area = "Admin", returnUrl }),
        SecondaryActionText = "Ana shell",
        SecondaryActionHref = Url.Action("Index", "Home", new { area = string.Empty })
    };
}

<div class="row">
    <div class="col-xl-8">
        <div class="card card-custom gutter-b cb-card cb-admin-card">
            <div class="card-body">
                @await Html.PartialAsync("Foundation/_AdminPageHeader", headerModel)

                @await Html.PartialAsync("Foundation/_AdminInfoStrip", new AdminInfoStripViewModel
                {
                    Tone = "warning",
                    Title = "Oturum güvenli biçimde kapatıldı",
                    Message = "Yüksek ayrıcalıklı oturum bekleme süresi aşıldığında veya güvenlik sınırı değiştiğinde yeniden kimlik doğrulama istenir.",
                    Meta = "Re-auth required"
                })

                <div class="cb-admin-security-state-grid mt-6">
                    @await Html.PartialAsync("Foundation/_AdminErrorState", new UiStateViewModel
                    {
                        Title = "Yüksek ayrıcalıklı oturum süren doldu",
                        Message = "Yüksek ayrıcalıklı alanda boşta kalma süresi veya yeniden doğrulama gereksinimi nedeniyle oturum geçersiz sayıldı. Yeniden giriş veya step-up ile devam edilebilir.",
                        IconText = "!",
                        ActionText = "Yeniden giriş",
                        ActionHref = Url.Action("Login", "Admin", new { area = "Admin", returnUrl }),
                        SecondaryActionText = "Ana shell",
                        SecondaryActionHref = Url.Action("Index", "Home", new { area = string.Empty })
                    })
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-4">
        @await Html.PartialAsync("Foundation/_AdminSecurityHelpCard", new AdminSecurityHelpCardViewModel
        {
            Eyebrow = "Session note",
            Title = "Neden yeniden doğrulama istenebilir",
            Description = "Idle timeout, cihaz değişimi veya daha hassas bir route'a geçiş admin oturumunun yeniden doğrulanmasını tetikleyebilir.",
            BadgeLabel = "Session",
            BadgeTone = "warning",
            Items = new[]
            {
                "Idle timeout warning",
                "Security-sensitive action note",
                "Başka cihazda aktif oturum olabilir"
            },
            ActionText = "Yeniden giriş",
            ActionHref = Url.Action("Login", "Admin", new { area = "Admin", returnUrl })
        })
    </div>
</div>
