@model IReadOnlyCollection<CoinBot.Application.Abstractions.Administration.ApiCredentialAdminSummary>
@using CoinBot.Web.ViewModels.Admin
@{
    var headerModel = new AdminPageHeaderViewModel
    {
        Eyebrow = "Credential Monitoring",
        Title = "Exchange Hesapları",
        Description = "Admin tarafında plaintext gostermeden masked fingerprint, permission summary ve son validation durumunu izler.",
        StatusBadge = new AdminBadgeViewModel { Label = "Credential HQ", Tone = "info", IconText = "HQ" },
        MetaBadges = new[]
        {
            new AdminBadgeViewModel { Label = "No Plaintext", Tone = "healthy", IconText = "SK" },
            new AdminBadgeViewModel { Label = "Validation", Tone = "warning", IconText = "VL" },
            new AdminBadgeViewModel { Label = "Read Only", Tone = "neutral", IconText = "RO" }
        },
        SecondaryActionText = "Audit merkezi",
        SecondaryActionHref = Url.Action("Audit", "Admin", new { area = "Admin" }),
        PrimaryActionText = "Kullanicilar",
        PrimaryActionHref = Url.Action("Users", "Admin", new { area = "Admin" })
    };
}

<div class="row">
    <div class="col-12">
        <div class="card card-custom gutter-b cb-card cb-admin-card">
            <div class="card-body">
                @await Html.PartialAsync("Foundation/_AdminPageHeader", headerModel)

                @await Html.PartialAsync("Foundation/_AdminInfoStrip", new AdminInfoStripViewModel
                {
                    Tone = "info",
                    Title = "Credential summary read-modeli",
                    Message = "Admin yalniz masked fingerprint, permission summary, son validation zamani ve son hata nedenini gorur. Secret/plaintext UI'ya cikmaz.",
                    Meta = $"{Model.Count} account"
                })
            </div>
        </div>
    </div>

    <div class="col-12">
        @await Html.PartialAsync("Foundation/_AdminExchangeAccountsTable", Model)
    </div>
</div>
