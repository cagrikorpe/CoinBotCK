@using CoinBot.Application.Abstractions.Administration
@{
    var snapshot = ViewData["AdminSupportLookupPageSnapshot"] as AdminSupportLookupSnapshot;
    var hasQuery = !string.IsNullOrWhiteSpace(snapshot?.Query);
    var headerModel = new AdminPageHeaderViewModel
    {
        Eyebrow = "Support Ops",
        Title = "Destek Araçları",
        Description = "Kullanıcı lookup, hızlı operasyon özeti, read-only diagnostic panel ve güvenli destek CTA'larını aynı yüzeyde toplayan Super Admin destek operasyonları yüzeyi.",
        StatusBadge = new AdminBadgeViewModel { Label = "Support Desk", Tone = "info", IconText = "SD" },
        MetaBadges = new[]
        {
            new AdminBadgeViewModel { Label = "Read-only Aware", Tone = "warning", IconText = "RO" },
            new AdminBadgeViewModel { Label = "No Impersonation", Tone = "critical", IconText = "IM" },
            new AdminBadgeViewModel { Label = "Fast Lookup", Tone = "healthy", IconText = "LK" }
        },
        SecondaryActionText = "Kullanıcılara git",
        SecondaryActionHref = Url.Action("Users", "Admin", new { area = "Admin" }),
        PrimaryActionText = "Audit / loglar",
        PrimaryActionHref = Url.Action("Audit", "Admin", new { area = "Admin" })
    };
}

<div class="row">
    <div class="col-12">
        <div class="card card-custom gutter-b cb-card cb-admin-card">
            <div class="card-body">
                @await Html.PartialAsync("Foundation/_AdminPageHeader", headerModel)

                @await Html.PartialAsync("Foundation/_AdminInfoStrip", new AdminInfoStripViewModel
                {
                    Tone = "info",
                    Title = "Güvenli destek akışı",
                    Message = "Support ekranı hızlı lookup ve read-only diagnostic yüzeyi sunar. İnceleme ve güvenli yönlendirme aynı yüzeyde tutulur.",
                    Meta = "Read-only support"
                })
            </div>
        </div>
    </div>

    <div class="col-12">
        @await Html.PartialAsync("Foundation/_AdminSupportLookupPanel")
    </div>

    @if (!hasQuery)
    {
        <div class="col-12">
            @await Html.PartialAsync("Foundation/_AdminEmptyState", new UiStateViewModel
            {
                Title = snapshot?.EmptyStateTitle ?? "Arama yapın",
                Message = snapshot?.EmptyStateMessage ?? "Kullanıcı, bot, exchange veya güvenlik kaydı bulmak için lookup sorgusu girin.",
                IconText = "SP",
                ActionText = "Kullanıcılara git",
                ActionHref = Url.Action("Users", "Admin", new { area = "Admin" }),
                SecondaryActionText = "Audit / loglar",
                SecondaryActionHref = Url.Action("Audit", "Admin", new { area = "Admin" })
            })
        </div>
    }
    else
    {
        <div class="col-xl-5">
            @await Html.PartialAsync("Foundation/_AdminSupportQuickUserSummary")
        </div>

        <div class="col-xl-7">
            @await Html.PartialAsync("Foundation/_AdminSupportDiagnosticPanel")
        </div>

        <div class="col-xl-6">
            @await Html.PartialAsync("Foundation/_AdminSupportCriticalEvents")
        </div>

        <div class="col-xl-6">
            @await Html.PartialAsync("Foundation/_AdminSupportBotErrors")
        </div>

        <div class="col-12">
            @await Html.PartialAsync("Foundation/_AdminSupportActionPanel")
        </div>
    }
</div>
