@{
    var returnUrl = ViewData["AdminAuthReturnUrl"]?.ToString() ?? "/admin";
    var headerModel = new AdminPageHeaderViewModel
    {
        Eyebrow = "Security Boundary",
        Title = "Access Denied",
        Description = "Bu oturum admin portal erişim koşullarını karşılamadığı için istenen yüzey açılmadı.",
        StatusBadge = new AdminBadgeViewModel { Label = "Access Denied", Tone = "critical", IconText = "AD" },
        MetaBadges = new[]
        {
            new AdminBadgeViewModel { Label = "Authenticated", Tone = "warning", IconText = "AU" },
            new AdminBadgeViewModel { Label = "Admin Access Missing", Tone = "critical", IconText = "GD" }
        },
        PrimaryActionText = "Ana shell'e dön",
        PrimaryActionHref = Url.Action("Index", "Home", new { area = string.Empty }),
        SecondaryActionText = "Oturum sınırı yardımı",
        SecondaryActionHref = Url.Action("SessionExpired", "Admin", new { area = "Admin", returnUrl })
    };
}

<div class="row">
    <div class="col-xl-8">
        <div class="card card-custom gutter-b cb-card cb-admin-card">
            <div class="card-body">
                @await Html.PartialAsync("Foundation/_AdminPageHeader", headerModel)

                @await Html.PartialAsync("Foundation/_AdminInfoStrip", new AdminInfoStripViewModel
                {
                    Tone = "critical",
                    Title = "Admin erişimi fail-closed korunur",
                    Message = "Bu hesap admin portal claim'ini veya gerekli güvenlik koşullarını taşımadığı için erişim açılmadı. Mevcut oturum güvenli biçimde korunur.",
                    Meta = "403"
                })

                <div class="mt-6">
                    @await Html.PartialAsync("Foundation/_AdminErrorState", new UiStateViewModel
                    {
                        Title = "Bu yüzeye erişim iznin yok",
                        Message = "Admin portal erişimi olmayan veya güvenlik kontrolünü tamamlamayan oturumlar bu yüzeyi açamaz. Farklı bir hesapla devam etmek için mevcut oturumu kapatın.",
                        IconText = "!",
                        ActionText = "Ana shell",
                        ActionHref = Url.Action("Index", "Home", new { area = string.Empty }),
                        SecondaryActionText = "Session yardımı",
                        SecondaryActionHref = Url.Action("SessionExpired", "Admin", new { area = "Admin", returnUrl })
                    })
                </div>

                <div class="cb-auth-action-row mt-6">
                    <form asp-area="" asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                        <button type="submit" class="btn btn-primary font-weight-bolder px-8">Farklı hesapla giriş</button>
                    </form>
                    <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-clean text-muted font-weight-bold">Ana shell</a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-4">
        @await Html.PartialAsync("Foundation/_AdminSecurityHelpCard", new AdminSecurityHelpCardViewModel
        {
            Eyebrow = "What now?",
            Title = "Çıkmaz oluşturmayan yönlendirme",
            Description = "Access denied ekranı mevcut oturumu ifşa etmeden ana shell'e dönüş, güvenli çıkış ve oturum yardımı seçenekleri sunar.",
            BadgeLabel = "Help",
            BadgeTone = "info",
            Items = new[]
            {
                "Mevcut oturumu kapatıp doğru hesapla devam et",
                "Session expired yardım ekranını kullan",
                "Gerekirse daha düşük ayrıcalıklı ana shell'e dön"
            },
            ActionText = "Session expired ekranı",
            ActionHref = Url.Action("SessionExpired", "Admin", new { area = "Admin", returnUrl })
        })
    </div>
</div>
