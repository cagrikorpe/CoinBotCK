@{
    var headerModel = new AdminPageHeaderViewModel
    {
        Eyebrow = "Identity Workspace",
        Title = "Kullanıcılar",
        Description = "Kullanıcı listesi, filtre barı, güvenlik sinyalleri ve kontrollü admin aksiyonları için operasyonel kullanıcı yönetimi yüzeyi.",
        StatusBadge = new AdminBadgeViewModel { Label = "User Ops", Tone = "info", IconText = "US" },
        MetaBadges = new[]
        {
            new AdminBadgeViewModel { Label = "Super Admin", Tone = "role", IconText = "SA" },
            new AdminBadgeViewModel { Label = "Controlled Actions", Tone = "warning", IconText = "CF" }
        },
        SecondaryActionText = "Role matrix",
        SecondaryActionHref = Url.Action("RoleMatrix", "Admin", new { area = "Admin" }),
        PrimaryActionText = "Kullanıcı detayı",
        PrimaryActionHref = Url.Action("UserDetail", "Admin", new { area = "Admin", id = "usr-001" })
    };
}

<div class="row">
    <div class="col-12">
        <div class="card card-custom gutter-b cb-card cb-admin-card">
            <div class="card-body">
                @await Html.PartialAsync("Foundation/_AdminPageHeader", headerModel)

                @await Html.PartialAsync("Foundation/_AdminInfoStrip", new AdminInfoStripViewModel
                {
                    Tone = "info",
                    Title = "User management",
                    Message = "Arama, filtre, durum badge'leri ve gerçek kullanıcı detay sayfası aynı yüzeyde toplanır. Backend paging ve policy enforcement bu akışla hizalanır.",
                    Meta = "User ops"
                })

                <div class="mt-6">
                    @await Html.PartialAsync("Foundation/_AdminUsersFilterBar")
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-8">
        @await Html.PartialAsync("Foundation/_AdminUsersTable")
    </div>

    <div class="col-xl-4">
        @await Html.PartialAsync("Foundation/_AdminSecurityHelpCard", new AdminSecurityHelpCardViewModel
        {
            Eyebrow = "Admin actions",
            Title = "Kontrollü kullanıcı aksiyonları",
                    Description = "Askıya alma, açma ve not akışı yalnız gerçek backend endpoint'lere bağlı kalır.",
            BadgeLabel = "User Ops",
            BadgeTone = "warning",
            Items = new[]
            {
                "User detail page",
                "Audit ve risk ekranlarına yönlendirme",
                "Role matrix görünürlüğü"
            },
            ActionText = "Kullanıcı detayı",
            ActionHref = Url.Action("UserDetail", "Admin", new { area = "Admin", id = "usr-014" })
        })
    </div>

    <div class="col-12">
        @await Html.PartialAsync("Foundation/_AdminEmptyState", new UiStateViewModel
        {
            Title = "Kullanıcı görünümü hazır",
            Message = "Liste ve detail ekranları gerçek snapshot verisiyle doldurulur. Sonuç yoksa ürün seviyesi empty-state gösterilir.",
            IconText = "US",
            ActionText = "Kullanıcı listesi",
            ActionHref = Url.Action("Users", "Admin", new { area = "Admin" }),
            SecondaryActionText = "Destek araçları",
            SecondaryActionHref = Url.Action("SupportTools", "Admin", new { area = "Admin" })
        })
    </div>
</div>
