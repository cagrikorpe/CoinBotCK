@{
    var returnUrl = ViewData["AdminAuthReturnUrl"]?.ToString() ?? "/admin";
    var headerModel = new AdminPageHeaderViewModel
    {
        Eyebrow = "Scoped Permission",
        Title = "Insufficient Permission",
        Description = "Oturum açık; ancak istenen aksiyon için gerekli kapsam bu hesapta yok.",
        StatusBadge = new AdminBadgeViewModel { Label = "Limited Scope", Tone = "warning", IconText = "SC" },
        MetaBadges = new[]
        {
            new AdminBadgeViewModel { Label = "Authenticated", Tone = "info", IconText = "AU" },
            new AdminBadgeViewModel { Label = "Scope Guard", Tone = "warning", IconText = "GD" }
        },
        PrimaryActionText = "Admin overview",
        PrimaryActionHref = Url.Action("Overview", "Admin", new { area = "Admin" }),
        SecondaryActionText = "Ana shell",
        SecondaryActionHref = Url.Action("Index", "Home", new { area = string.Empty })
    };
}

<div class="row">
    <div class="col-xl-8">
        <div class="card card-custom gutter-b cb-card cb-admin-card">
            <div class="card-body">
                @await Html.PartialAsync("Foundation/_AdminPageHeader", headerModel)

                @await Html.PartialAsync("Foundation/_AdminInfoStrip", new AdminInfoStripViewModel
                {
                    Tone = "warning",
                    Title = "Kapsam guard açık kaldı",
                    Message = "Bu oturum admin alanına girebilir; ancak hedef aksiyon için gerekli claim veya rol kapsamı bulunmadığından işlem açılmadı.",
                    Meta = "Scoped access"
                })

                <div class="mt-6">
                    @await Html.PartialAsync("Foundation/_AdminEmptyState", new UiStateViewModel
                    {
                        Title = "Bu işlem için rol kapsamın yetersiz",
                        Message = "Daha geniş yetki gerektiren aksiyonlar fail-closed korunur. Yetkin olan başka bir hesapla devam edebilir veya admin overview'e dönebilirsin.",
                        IconText = "?",
                        ActionText = "Admin overview",
                        ActionHref = Url.Action("Overview", "Admin", new { area = "Admin" }),
                        SecondaryActionText = "Session yardımı",
                        SecondaryActionHref = Url.Action("SessionExpired", "Admin", new { area = "Admin", returnUrl })
                    })
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-4">
        @await Html.PartialAsync("Foundation/_AdminSecurityHelpCard", new AdminSecurityHelpCardViewModel
        {
            Eyebrow = "Permission hints",
            Title = "Kapsam yetersizliğinde güvenli sonraki adım",
            Description = "Kritik işlem açılamadığında kullanıcıyı loop'a sokmadan overview, ana shell veya güvenli çıkış seçenekleri sunulur.",
            BadgeLabel = "RBAC",
            BadgeTone = "role",
            Items = new[]
            {
                "Daha dar kapsamlı yüzeylere geri dön",
                "Gerekirse farklı bir hesapla devam et",
                "Session yardım ekranını kullan"
            },
            ActionText = "Ana shell",
            ActionHref = Url.Action("Index", "Home", new { area = string.Empty })
        })
    </div>
</div>
