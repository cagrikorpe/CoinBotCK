@{
    Layout = "_AdminAuthLayout";
    ViewData["Title"] = "Admin MFA";
    ViewData["AuthTitle"] = "İkinci güvenlik doğrulaması";
    ViewData["AuthDescription"] = "Admin alanı için zorunlu MFA adımı; method seçimi, invalid code state ve retry yüzeyi hazırdır.";
    ViewData["AuthEyebrow"] = "Step-Up Required";
    ViewData["AuthStage"] = "Admin MFA Verify";
    ViewData["AuthProgress"] = "2 / 2";
    ViewData["AuthBackHref"] = Url.Action("Login", "Admin", new { area = "Admin" });
    ViewData["AuthHighlights"] = new[]
    {
        "Authenticator app ve e-posta kodu method seçimi",
        "6 haneli code input ve invalid code error state",
        "Resend, countdown ve farklı hesapla giriş CTA’ları"
    };
}

<div class="cb-auth-panel cb-auth-panel-compact cb-admin-auth-panel">
    <div class="cb-auth-panel-header">
        <div>
            <div class="cb-page-eyebrow">Multi-Factor Authentication</div>
            <h2 class="cb-page-title">Doğrulama kodunu girin</h2>
            <p class="cb-page-description">Admin alanı için MFA zorunludur. Gerçek provider entegrasyonu bu akışla hizalanır; profesyonel erişim yüzeyi korunur.</p>
        </div>
        @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = "Second Factor", Tone = "role", IconText = "2F" })
    </div>

    <div class="cb-auth-methods">
        <button type="button" class="cb-auth-method is-active">Authenticator App</button>
        <button type="button" class="cb-auth-method">Email Code</button>
    </div>

    <div class="cb-auth-alert cb-auth-alert-info mt-6">
        Admin alanında MFA atlanamaz. Kritik aksiyonlar için ek olarak re-auth step-up istenebilir.
    </div>

    <form class="cb-auth-form-grid" action="#" method="post" novalidate>
        <div class="form-group mb-0">
            <label class="cb-form-label">6 haneli MFA kodu</label>
            <div class="cb-otp-group" data-cb-otp-group>
                <input type="text" inputmode="numeric" maxlength="1" class="form-control cb-otp-input" data-cb-otp />
                <input type="text" inputmode="numeric" maxlength="1" class="form-control cb-otp-input" data-cb-otp />
                <input type="text" inputmode="numeric" maxlength="1" class="form-control cb-otp-input" data-cb-otp />
                <input type="text" inputmode="numeric" maxlength="1" class="form-control cb-otp-input" data-cb-otp />
                <input type="text" inputmode="numeric" maxlength="1" class="form-control cb-otp-input" data-cb-otp />
                <input type="text" inputmode="numeric" maxlength="1" class="form-control cb-otp-input" data-cb-otp />
            </div>
            <div class="cb-field-feedback">OTP alanı, tek input veya bölünmüş input yaklaşımına genişleyebilecek şekilde bırakılmıştır.</div>
        </div>

        <div class="cb-auth-row-between">
            <span class="cb-auth-meta">Kod süresi: <strong>00:21</strong></span>
            <a href="#" class="cb-auth-inline-link">Kodu yeniden gönder</a>
        </div>

        <div class="cb-validation-summary cb-validation-summary-danger">
            Invalid code, expired code veya method mismatch hata dili bu bölgede gösterilir.
        </div>

        <div class="cb-auth-action-row">
            <button type="submit" class="btn btn-primary font-weight-bolder px-10" data-cb-button-loading>
                <span class="cb-btn-label">Doğrula</span>
                <span class="cb-btn-spinner"></span>
            </button>
            <a asp-area="Admin" asp-controller="Admin" asp-action="Login" class="btn btn-clean text-muted font-weight-bold">Farklı hesapla giriş</a>
        </div>
    </form>
</div>

<div class="row mt-6">
    <div class="col-xl-6">
        @await Html.PartialAsync("Foundation/_AdminSecurityHelpCard", new AdminSecurityHelpCardViewModel
        {
            Eyebrow = "Why MFA?",
            Title = "MFA neden zorunlu",
            Description = "Yüksek ayrıcalıklı yüzeylerde parola tek başına yeterli kabul edilmez. Bu nedenle admin alanı ikinci doğrulamayı görünür şekilde zorunlu kılar.",
            BadgeLabel = "MFA",
            BadgeTone = "warning",
            Items = new[]
            {
                "Authenticator app birincil yöntem olarak öne çıkar",
                "Email code yalnızca fallback olarak gösterilir",
                "Gerçek doğrulama provider’ı sonraki backend fazına bağlanır"
            }
        })
    </div>
    <div class="col-xl-6">
        @await Html.PartialAsync("Foundation/_AdminSecurityHelpCard", new AdminSecurityHelpCardViewModel
        {
            Eyebrow = "Next step",
            Title = "Sonraki güvenlik akışı",
            Description = "MFA sonrasında admin shell açılır; bazı destructive işlemler ayrıca re-auth step-up isteyebilir.",
            BadgeLabel = "Step-Up",
            BadgeTone = "info",
            Items = new[]
            {
                "Bot force stop",
                "Maintenance mode",
                "Global ayar değişimi"
            },
            ActionText = "Re-auth modal örneği",
            ActionHref = "#cb_admin_reauth_modal"
        })
    </div>
</div>
