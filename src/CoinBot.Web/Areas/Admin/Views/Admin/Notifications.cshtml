@{
    var headerModel = new AdminPageHeaderViewModel
    {
        Eyebrow = "Platform Alerts",
        Title = "Bildirim / Alarm Merkezi",
        Description = "AI, risk, worker, security ve system alarm sinyallerini durum ve severity filtreleriyle tek merkezde toplayan Super Admin alarm merkezi.",
        StatusBadge = new AdminBadgeViewModel { Label = "Alert Hub", Tone = "warning", IconText = "AL" },
        MetaBadges = new[]
        {
            new AdminBadgeViewModel { Label = "State Aware", Tone = "info", IconText = "ST" },
            new AdminBadgeViewModel { Label = "Severity Filtered", Tone = "critical", IconText = "SV" },
            new AdminBadgeViewModel { Label = "Ops Links", Tone = "degraded", IconText = "LK" }
        },
        SecondaryActionText = "Audit / log merkezi",
        SecondaryActionHref = Url.Action("Audit", "Admin", new { area = "Admin" }),
        PrimaryActionText = "Security events",
        PrimaryActionHref = Url.Action("SecurityEvents", "Admin", new { area = "Admin" })
    };
}

<div class="row">
    <div class="col-12">
        <div class="card card-custom gutter-b cb-card cb-admin-card">
            <div class="card-body">
                @await Html.PartialAsync("Foundation/_AdminPageHeader", headerModel)
            </div>
        </div>
    </div>

    <div class="col-12">
        @await Html.PartialAsync("Foundation/_AdminAlertSummaryMeta")
    </div>

    <div class="col-12">
        @await Html.PartialAsync("Foundation/_AdminAlertFilterBar")
    </div>

    <div class="col-12">
        @await Html.PartialAsync("Foundation/_AdminAlertCategoryStrip")
    </div>

    <div class="col-xl-8">
        @await Html.PartialAsync("Foundation/_AdminAlertList")
    </div>

    <div class="col-xl-4">
        @await Html.PartialAsync("Foundation/_AdminAlertPolicyCta")
    </div>
</div>
