@using CoinBot.Application.Abstractions.Administration
@{
    var entityId = ViewData["AdminEntityId"]?.ToString() ?? "usr-unknown";
    var snapshot = ViewData["AdminUserDetailPageSnapshot"] as AdminUserDetailPageSnapshot;
    var botCount = snapshot?.Bots.Count ?? 0;
    var exchangeConnected = (snapshot?.ExchangeAccounts.Count ?? 0) > 0;
    var approvalPending = snapshot?.StatusLabel.Contains("bekliyor", StringComparison.OrdinalIgnoreCase) == true;
    var successMessage = TempData["AdminUserSuccess"] as string;
    var errorMessage = TempData["AdminUserError"] as string;
}

<div class="row" data-cb-admin-user-detail-soft>
    <div class="col-12">
        <section class="card card-custom gutter-b cb-card cb-admin-card">
            <div class="card-body">
                <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-4">
                    <div>
                        <div class="cb-admin-section-kicker">Kullanıcı Detayı</div>
                        <h1 class="cb-admin-section-title mb-2">Kullanıcı</h1>
                        <p class="cb-admin-section-description mb-0">Temel bilgiler, rol ve güvenlik durumu burada sade şekilde görünür.</p>
                        @if (!string.IsNullOrWhiteSpace(successMessage))
                        {
                            <div class="alert alert-success mt-5 mb-0">@successMessage</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(errorMessage))
                        {
                            <div class="alert alert-danger mt-5 mb-0">@errorMessage</div>
                        }
                    </div>
                    <a asp-area="Admin" asp-controller="Admin" asp-action="Users" class="btn btn-light-primary font-weight-bold">Kullanıcılar</a>
                </div>
            </div>
        </section>
    </div>

    @if (snapshot is null)
    {
        <div class="col-12">
            <section class="card card-custom gutter-b cb-card cb-admin-card">
                <div class="card-body text-center py-8">
                    <strong>Kullanıcı bulunamadı</strong>
                    <p class="text-muted mb-5">Bu kullanıcı için gösterilecek bilgi yok.</p>
                    <a asp-area="Admin" asp-controller="Admin" asp-action="Users" class="btn btn-light-primary font-weight-bold">Kullanıcı listesi</a>
                </div>
            </section>
        </div>
    }
    else
    {
        <div class="col-xl-7">
            <section class="card card-custom gutter-b cb-card cb-admin-card">
                <div class="card-body">
                    <div class="cb-admin-section-kicker">Temel Bilgiler</div>
                    <h2 class="cb-admin-section-title mb-5">@snapshot.DisplayName</h2>

                    <div class="row">
                        <div class="col-md-6 mb-5">
                            <div class="text-muted small font-weight-bold">Kullanıcı adı</div>
                            <div class="font-weight-bold">@snapshot.UserName</div>
                        </div>
                        <div class="col-md-6 mb-5">
                            <div class="text-muted small font-weight-bold">Görünen ad</div>
                            <div class="font-weight-bold">@snapshot.DisplayName</div>
                        </div>
                        <div class="col-md-6 mb-5" data-cb-admin-user-role-security>
                            <div class="text-muted small font-weight-bold">Rol</div>
                            <div class="font-weight-bold">@snapshot.RoleSummary</div>
                        </div>
                        <div class="col-md-6 mb-5">
                            <div class="text-muted small font-weight-bold">Durum</div>
                            <div class="font-weight-bold">@snapshot.StatusLabel</div>
                        </div>
                        <div class="col-md-6 mb-5">
                            <div class="text-muted small font-weight-bold">MFA</div>
                            <div class="font-weight-bold">@snapshot.MfaLabel</div>
                        </div>
                        <div class="col-md-6 mb-5">
                            <div class="text-muted small font-weight-bold">Bağlı bot sayısı</div>
                            <div class="font-weight-bold">@botCount</div>
                        </div>
                        <div class="col-md-6 mb-0">
                            <div class="text-muted small font-weight-bold">Exchange bağlı mı</div>
                            <div class="font-weight-bold">@(exchangeConnected ? "Hazır" : "Eksik")</div>
                        </div>
                    </div>
                </div>
            </section>
        </div>

        <div class="col-xl-5">
            <section class="card card-custom gutter-b cb-card cb-admin-card" data-cb-admin-user-security-actions>
                <div class="card-body">
                    <div class="cb-admin-section-kicker">Rol ve Güvenlik</div>
                    <h2 class="cb-admin-section-title mb-2">Güvenlik aksiyonları</h2>
                    <p class="cb-admin-section-description mb-5">Bu işlemler güvenli onay tamamlanmadan çalışmaz.</p>

                    @if (approvalPending)
                    {
                        <form method="post" asp-area="Admin" asp-controller="Admin" asp-action="ApproveUser" class="mb-5" data-cb-admin-user-approve-form>
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@snapshot.UserId" />
                            <button type="submit" class="btn btn-primary font-weight-bold" data-cb-admin-user-approve>Onayla</button>
                        </form>
                    }

                    <div class="d-flex flex-column gap-3">
                        <button type="button" class="btn btn-light-danger font-weight-bold text-left" disabled data-cb-admin-user-action="disable">Pasife al</button>
                        <button type="button" class="btn btn-light-primary font-weight-bold text-left" disabled data-cb-admin-user-action="password-reset">Şifre sıfırla</button>
                        <button type="button" class="btn btn-light-primary font-weight-bold text-left" disabled data-cb-admin-user-action="mfa-reset">MFA sıfırla</button>
                    </div>

                    <p class="text-muted small mt-5 mb-0">Bu işlemler ayrı güvenlik onayı gerektirir.</p>
                </div>
            </section>
        </div>
    }
</div>




