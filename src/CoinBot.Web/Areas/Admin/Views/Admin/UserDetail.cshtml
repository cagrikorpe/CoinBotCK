@{
    var entityId = ViewData["AdminEntityId"]?.ToString() ?? "usr-unknown";
    var headerModel = new AdminPageHeaderViewModel
    {
        Eyebrow = "Identity Detail",
        Title = "Kullanıcı Detayı",
        Description = "Profil özeti, güvenlik durumu, bot ve exchange summary ile son aktiviteleri operasyon odaklı bir admin detail screen içinde toplar.",
        StatusBadge = new AdminBadgeViewModel { Label = entityId, Tone = "neutral", IconText = "ID" },
        MetaBadges = new[]
        {
            new AdminBadgeViewModel { Label = "User Ops", Tone = "info", IconText = "US" },
            new AdminBadgeViewModel { Label = "Controlled Access", Tone = "warning", IconText = "CF" }
        },
        SecondaryActionText = "Kullanıcılara dön",
        SecondaryActionHref = Url.Action("Users", "Admin", new { area = "Admin" }),
        PrimaryActionText = "Audit / loglar",
        PrimaryActionHref = Url.Action("Audit", "Admin", new { area = "Admin" })
    };
}

<div class="row">
    <div class="col-12">
        <div class="card card-custom gutter-b cb-card cb-admin-card">
            <div class="card-body">
                @await Html.PartialAsync("Foundation/_AdminPageHeader", headerModel)

                @await Html.PartialAsync("Foundation/_AdminInfoStrip", new AdminInfoStripViewModel
                {
                    Tone = "warning",
                    Title = "Detail page",
                    Message = "Gerçek user backend verisi, audit feed ve permission enforcement bu yüzeyde operasyonel inceleme için birleştirilir.",
                    Meta = "Drawer + page parity"
                })

                <div class="card card-custom gutter-b cb-card cb-admin-card mt-6">
                    <div class="card-body">
                        <div class="cb-admin-section-kicker">Related actions</div>
                        <div class="cb-admin-section-title">İlişkili yüzeyler</div>
                        <p class="cb-admin-section-description">Kullanıcı için gerçek operasyon, destek ve denetim yüzeyleri kullanılabilir.</p>
                        <div class="cb-admin-inline-actions mt-5">
                            <a asp-area="Admin" asp-controller="Admin" asp-action="Audit" asp-route-userId="@entityId" class="btn btn-light-primary font-weight-bold">Audit / loglar</a>
                            <a asp-area="Admin" asp-controller="Admin" asp-action="SupportTools" asp-route-query="@entityId" class="btn btn-light-primary font-weight-bold">Destek araçları</a>
                            <a asp-area="Admin" asp-controller="Admin" asp-action="Users" class="btn btn-light-primary font-weight-bold">Kullanıcılar</a>
                            <a asp-area="Admin" asp-controller="Admin" asp-action="RoleMatrix" class="btn btn-light-primary font-weight-bold">Role matrix</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-4">
        @await Html.PartialAsync("Foundation/_AdminUserProfileSummary")
        @await Html.PartialAsync("Foundation/_AdminUserSecuritySummary")
        @await Html.PartialAsync("Foundation/_AdminUserRiskSummary")

        @await Html.PartialAsync("Foundation/_AdminSecurityHelpCard", new AdminSecurityHelpCardViewModel
        {
            Eyebrow = "Related actions",
            Title = "İlişkili yüzeyler",
            Description = "Kullanıcı için gerçek operasyon, destek ve denetim yüzeyleri kullanılabilir.",
            BadgeLabel = "User Ops",
            BadgeTone = "info",
            Items = new[]
            {
                "Audit ve log inceleme",
                "Support lookup",
                "Role matrix ve policy görünümü"
            },
            ActionText = "Audit / loglar",
            ActionHref = Url.Action("Audit", "Admin", new { area = "Admin", userId = entityId })
        })
    </div>

    <div class="col-xl-8">
        @await Html.PartialAsync("Foundation/_AdminUserBotSummary")
        @await Html.PartialAsync("Foundation/_AdminUserExchangeSummary")
        @await Html.PartialAsync("Foundation/_AdminUserActivityTimeline")
        @await Html.PartialAsync("Foundation/_AdminUserCriticalLogs")
    </div>

    <div class="col-12">
        @await Html.PartialAsync("Foundation/_AdminEmptyState", new UiStateViewModel
        {
            Title = "Kullanıcı detayı hazır",
            Message = "Profil, bot, exchange ve activity snapshot'ları gerçek veriyle gelir. Kayıt yoksa ürün seviyesi empty-state görünür.",
            IconText = "ID",
            ActionText = "Kullanıcılara dön",
            ActionHref = Url.Action("Users", "Admin", new { area = "Admin" }),
            SecondaryActionText = "Destek araçları",
            SecondaryActionHref = Url.Action("SupportTools", "Admin", new { area = "Admin" })
        })
    </div>

</div>
