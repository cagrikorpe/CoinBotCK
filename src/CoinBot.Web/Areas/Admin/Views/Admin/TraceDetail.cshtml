@model CoinBot.Application.Abstractions.Administration.AdminTraceDetailSnapshot
@using System.Linq
@using CoinBot.Application.Abstractions.Administration
@using CoinBot.Web.ViewModels.Admin
@using System.Text.Json
@{
    string FormatUtc(DateTime? value) => value.HasValue ? value.Value.ToUniversalTime().ToString("yyyy-MM-dd HH:mm:ss") + " UTC" : "n/a";
    string FormatNumber(int? value, string suffix = "") => value.HasValue ? value.Value.ToString() + suffix : "n/a";
    string FormatText(string? value) => string.IsNullOrWhiteSpace(value) ? "n/a" : value;
    string FormatDecisionDirection(string? snapshotJson)
    {
        if (string.IsNullOrWhiteSpace(snapshotJson))
        {
            return "n/a";
        }

        try
        {
            using var document = JsonDocument.Parse(snapshotJson);
            if (!document.RootElement.TryGetProperty("EvaluationResult", out var evaluationElement))
            {
                evaluationElement = document.RootElement;
            }

            string? ReadDirection(string propertyName)
            {
                return evaluationElement.TryGetProperty(propertyName, out var property) && property.ValueKind == JsonValueKind.String
                    ? property.GetString()
                    : null;
            }

            var direction = ReadDirection("Direction");
            var entryDirection = ReadDirection("EntryDirection");
            var exitDirection = ReadDirection("ExitDirection");
            var parts = new List<string>();
            if (!string.IsNullOrWhiteSpace(direction) && !string.Equals(direction, "Neutral", StringComparison.OrdinalIgnoreCase)) parts.Add($"Direction={direction}");
            if (!string.IsNullOrWhiteSpace(entryDirection) && !string.Equals(entryDirection, "Neutral", StringComparison.OrdinalIgnoreCase)) parts.Add($"Entry={entryDirection}");
            if (!string.IsNullOrWhiteSpace(exitDirection) && !string.Equals(exitDirection, "Neutral", StringComparison.OrdinalIgnoreCase)) parts.Add($"Exit={exitDirection}");
            return parts.Count == 0 ? "n/a" : string.Join(" · ", parts);
        }
        catch
        {
            return "n/a";
        }
    }
    var primaryDecision = Model.DecisionTraces.FirstOrDefault();
    var primaryExecution = Model.ExecutionTraces.FirstOrDefault();
    var handoffAttempts = Model.HandoffAttempts ?? Array.Empty<AdminTraceHandoffAttemptSnapshot>();
    var executionTransitions = Model.ExecutionTransitions ?? Array.Empty<AdminTraceExecutionTransitionSnapshot>();
    var timelineEntries = Model.DecisionTraces
        .Select(decision => new
        {
            OccurredAtUtc = decision.DecisionAtUtc ?? decision.CreatedAtUtc,
            KindLabel = "Decision / Risk",
            Reference = decision.DecisionId,
            SecondaryReference = decision.StrategySignalId?.ToString(),
            Title = $"{decision.Symbol} / {decision.Timeframe}",
            Summary = decision.DecisionSummary ?? $"Outcome={decision.DecisionOutcome} · Risk={(decision.RiskScore?.ToString() ?? "-")} · Strategy={decision.StrategyVersion}",
            Meta = $"ReasonType={FormatText(decision.DecisionReasonType)} · ReasonCode={FormatText(decision.DecisionReasonCode)} · Direction={FormatDecisionDirection(decision.SnapshotJson)} · DecisionAt={FormatUtc(decision.DecisionAtUtc ?? decision.CreatedAtUtc)} · LastCandle={FormatUtc(decision.LastCandleAtUtc)} · DataAge={FormatNumber(decision.DataAgeMs, "ms")} · Threshold={FormatNumber(decision.StaleThresholdMs, "ms")} · Continuity={FormatText(decision.ContinuityState)}{(string.IsNullOrWhiteSpace(decision.VetoReasonCode) ? string.Empty : $" · Veto={decision.VetoReasonCode}")}",
            RequestMasked = (string?)null,
            ResponseMasked = (string?)decision.SnapshotJson
        })
        .Concat(handoffAttempts.Select(handoff => new
        {
            OccurredAtUtc = handoff.CompletedAtUtc,
            KindLabel = "Scanner / Handoff",
            Reference = handoff.HandoffAttemptId.ToString("N"),
            SecondaryReference = handoff.StrategySignalId?.ToString(),
            Title = $"{FormatText(handoff.Symbol)} / {FormatText(handoff.Timeframe)}",
            Summary = $"{handoff.ExecutionRequestStatus} · {handoff.StrategyDecisionOutcome} · Blocker={(handoff.BlockerCode ?? "-")}",
            Meta = $"ScanCycle={handoff.ScanCycleId:N} · Bot={(handoff.BotId?.ToString() ?? "-")} · Env={(handoff.ExecutionEnvironment ?? "-")} · Side={(handoff.ExecutionSide ?? "-")} · Guard={FormatText(handoff.GuardSummary)}",
            RequestMasked = (string?)null,
            ResponseMasked = (string?)handoff.BlockerSummary
        }))
        .Concat(Model.ExecutionTraces.Select(execution => new
        {
            OccurredAtUtc = execution.CreatedAtUtc,
            KindLabel = "Execution / Order",
            Reference = execution.ExecutionAttemptId,
            SecondaryReference = execution.ExecutionOrderId?.ToString(),
            Title = execution.Provider,
            Summary = $"Status={(execution.HttpStatusCode?.ToString() ?? "-")} · ExchangeCode={(execution.ExchangeCode ?? "-")} · OrderId={(execution.ExecutionOrderId?.ToString() ?? "-")}",
            Meta = $"Endpoint={execution.Endpoint} · Latency={(execution.LatencyMs?.ToString() ?? "-")}ms · CommandId={execution.CommandId}",
            RequestMasked = execution.RequestMasked,
            ResponseMasked = execution.ResponseMasked
        }))
        .Concat(executionTransitions.Select(transition => new
        {
            OccurredAtUtc = transition.OccurredAtUtc,
            KindLabel = "Execution transition",
            Reference = transition.EventCode,
            SecondaryReference = transition.ExecutionOrderId.ToString(),
            Title = $"{transition.State} · Seq={transition.SequenceNumber}",
            Summary = transition.Detail ?? $"Execution order transitioned to {transition.State}.",
            Meta = $"OrderId={transition.ExecutionOrderId} · Correlation={transition.CorrelationId} · Parent={transition.ParentCorrelationId ?? "-"}",
            RequestMasked = (string?)null,
            ResponseMasked = (string?)null
        }))
        .OrderBy(entry => entry.OccurredAtUtc)
        .ToArray();
    var decisionSummary = primaryDecision is null
        ? "Decision=n/a"
        : $"Decision={primaryDecision.DecisionId} · Signal={(primaryDecision.StrategySignalId?.ToString() ?? "-")} · Outcome={primaryDecision.DecisionOutcome} · Reason={FormatText(primaryDecision.DecisionReasonCode)} · DecisionAt={FormatUtc(primaryDecision.DecisionAtUtc ?? primaryDecision.CreatedAtUtc)} · Risk={(primaryDecision.RiskScore?.ToString() ?? "-")} · Latency={primaryDecision.LatencyMs}ms{(string.IsNullOrWhiteSpace(primaryDecision.VetoReasonCode) ? string.Empty : $" · Veto={primaryDecision.VetoReasonCode}")}";
    var executionSummary = primaryExecution is null
        ? "Execution=n/a"
        : $"Execution={primaryExecution.ExecutionAttemptId} · Provider={primaryExecution.Provider} · Order={(primaryExecution.ExecutionOrderId?.ToString() ?? "-")} · Status={(primaryExecution.HttpStatusCode?.ToString() ?? "-")} · Latency={(primaryExecution.LatencyMs?.ToString() ?? "-")}ms";
    var headerModel = new AdminPageHeaderViewModel
    {
        Eyebrow = "Trace Detail",
        Title = "Correlation Trace Detail",
        Description = "Decision ve execution kayitlarini ayni correlation anahtari altinda maskeli ve sorgulanabilir olarak sunar.",
        StatusBadge = new AdminBadgeViewModel { Label = "Detail", Tone = "info", IconText = "DT" },
        MetaBadges = new[]
        {
            new AdminBadgeViewModel { Label = $"{Model.DecisionTraces.Count} decision", Tone = "healthy", IconText = "DC" },
            new AdminBadgeViewModel { Label = $"{handoffAttempts.Count} handoff", Tone = "info", IconText = "HF" },
            new AdminBadgeViewModel { Label = $"{Model.ExecutionTraces.Count} execution", Tone = "warning", IconText = "EX" },
            new AdminBadgeViewModel { Label = $"{executionTransitions.Count} transition", Tone = "neutral", IconText = "TR" }
        },
        SecondaryActionText = "Audit search",
        SecondaryActionHref = Url.Action("Audit", "Admin", new { area = "Admin", query = Model.CorrelationId })
    };
}

<div class="row">
    <div class="col-12">
        <div class="card card-custom gutter-b cb-card cb-admin-card">
            <div class="card-body">
                @await Html.PartialAsync("Foundation/_AdminPageHeader", headerModel)

                @await Html.PartialAsync("Foundation/_AdminInfoStrip", new AdminInfoStripViewModel
                {
                    Tone = "info",
                    Title = "Correlation root",
                    Message = Model.CorrelationId,
                    Meta = $"{decisionSummary} | {executionSummary}"
                })

                @if (primaryDecision is not null)
                {
                    <div class="cb-admin-summary-grid mt-4">
                        <div class="cb-admin-summary-card" data-cb-trace-decision-outcome>
                            <span class="cb-admin-summary-label">Decision outcome</span>
                            <strong>@primaryDecision.DecisionOutcome</strong>
                            <small data-cb-trace-decision-reason-type>@FormatText(primaryDecision.DecisionReasonType)</small>
                        </div>
                        <div class="cb-admin-summary-card" data-cb-trace-decision-reason-code>
                            <span class="cb-admin-summary-label">Reason code</span>
                            <strong>@FormatText(primaryDecision.DecisionReasonCode)</strong>
                            <small data-cb-trace-decision-at>@FormatUtc(primaryDecision.DecisionAtUtc ?? primaryDecision.CreatedAtUtc)</small>
                        </div>
                        <div class="cb-admin-summary-card" data-cb-trace-decision-direction>
                            <span class="cb-admin-summary-label">Direction</span>
                            <strong>@FormatDecisionDirection(primaryDecision.SnapshotJson)</strong>
                            <small data-cb-trace-decision-signal>@(primaryDecision.StrategySignalId?.ToString() ?? "n/a")</small>
                        </div>
                        <div class="cb-admin-summary-card" data-cb-trace-market-last-candle>
                            <span class="cb-admin-summary-label">Market freshness</span>
                            <strong>@FormatUtc(primaryDecision.LastCandleAtUtc)</strong>
                            <small data-cb-trace-market-age>@FormatNumber(primaryDecision.DataAgeMs, "ms")</small>
                            <small data-cb-trace-market-threshold>Threshold=@FormatNumber(primaryDecision.StaleThresholdMs, "ms")</small>
                        </div>
                        <div class="cb-admin-summary-card" data-cb-trace-continuity-state>
                            <span class="cb-admin-summary-label">Continuity</span>
                            <strong>@FormatText(primaryDecision.ContinuityState)</strong>
                            <small data-cb-trace-continuity-gap-count>@FormatNumber(primaryDecision.ContinuityGapCount)</small>
                        </div>
                    </div>

                    <div class="cb-admin-info-strip cb-admin-info-strip-warning mt-4" data-cb-trace-decision-summary>
                        <div>
                            <div class="cb-admin-info-strip-title">Execution decision summary</div>
                            <div class="cb-admin-info-strip-text">@FormatText(primaryDecision.DecisionSummary)</div>
                        </div>
                        <span class="cb-admin-info-strip-meta" data-cb-trace-market-stale-reason>@FormatText(primaryDecision.StaleReason)</span>
                    </div>

                    <div class="text-muted mt-3">
                        <span data-cb-trace-continuity-gap-start>GapStart=@FormatUtc(primaryDecision.ContinuityGapStartedAtUtc)</span>
                        ·
                        <span data-cb-trace-continuity-gap-last-seen>GapLastSeen=@FormatUtc(primaryDecision.ContinuityGapLastSeenAtUtc)</span>
                        ·
                        <span data-cb-trace-continuity-recovery>Recovered=@FormatUtc(primaryDecision.ContinuityRecoveredAtUtc)</span>
                    </div>
                }

                <div class="d-flex flex-wrap gap-2 mt-4">
                    <a asp-area="Admin"
                       asp-controller="Admin"
                       asp-action="Audit"
                       asp-route-query="@Model.CorrelationId"
                       class="btn btn-light-primary font-weight-bold">Audit search</a>
                    @if (primaryDecision is not null)
                    {
                        <a asp-area="Admin"
                           asp-controller="Admin"
                           asp-action="TraceDetail"
                           asp-route-correlationId="@Model.CorrelationId"
                           asp-route-decisionId="@primaryDecision.DecisionId"
                           class="btn btn-light-info font-weight-bold">Focus decision</a>
                    }
                    @if (primaryExecution is not null)
                    {
                        <a asp-area="Admin"
                           asp-controller="Admin"
                           asp-action="TraceDetail"
                           asp-route-correlationId="@Model.CorrelationId"
                           asp-route-executionAttemptId="@primaryExecution.ExecutionAttemptId"
                           class="btn btn-light-warning font-weight-bold">Focus execution</a>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="card card-custom gutter-b cb-card cb-admin-card cb-admin-table-card">
            <div class="card-body">
                <div class="cb-admin-table-header">
                    <div>
                        <div class="cb-admin-section-kicker">Timeline</div>
                        <div class="cb-admin-section-title">Signal -> decision -> execution kronolojisi</div>
                        <p class="cb-admin-section-description mb-0">Ayni correlation altindaki scanner, handoff, decision, execution ve transition kayitlari zaman sirali gorunur. Request/response payload alanlari masked kalir.</p>
                    </div>
                </div>

                @if (timelineEntries.Length == 0)
                {
                    <p class="text-muted mb-0">Bu correlation icin timeline kaydi yok.</p>
                }
                else
                {
                    foreach (var entry in timelineEntries)
                    {
                        <div class="mb-5 pb-5 border-bottom">
                            <div class="d-flex flex-wrap justify-content-between gap-2">
                                <div>
                                    <div><strong>@entry.KindLabel</strong> · @entry.Reference</div>
                                    <div class="text-muted">@entry.Title</div>
                                </div>
                                <div class="text-muted">@entry.OccurredAtUtc.ToString("yyyy-MM-dd HH:mm:ss") UTC</div>
                            </div>
                            <div class="mt-2">@entry.Summary</div>
                            <div class="text-muted mt-2">@entry.Meta</div>
                            @if (!string.IsNullOrWhiteSpace(entry.SecondaryReference))
                            {
                                <div class="text-muted mt-2">LinkedId=@entry.SecondaryReference</div>
                            }
                            @if (!string.IsNullOrWhiteSpace(entry.RequestMasked))
                            {
                                <details class="mt-3">
                                    <summary class="text-muted">Request masked</summary>
                                    <pre class="mt-2"><code>@entry.RequestMasked</code></pre>
                                </details>
                            }
                            @if (!string.IsNullOrWhiteSpace(entry.ResponseMasked))
                            {
                                <details class="mt-3">
                                    <summary class="text-muted">Payload masked</summary>
                                    <pre class="mt-2 mb-0"><code>@entry.ResponseMasked</code></pre>
                                </details>
                            }
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    <div class="col-xl-6">
        <div class="card card-custom gutter-b cb-card cb-admin-card cb-admin-table-card">
            <div class="card-body">
                <div class="cb-admin-table-header">
                    <div>
                        <div class="cb-admin-section-kicker">Decision Trace</div>
                        <div class="cb-admin-section-title">Decision listesi</div>
                    </div>
                </div>

                @if (Model.DecisionTraces.Count == 0)
                {
                    <p class="text-muted mb-0">Decision trace kaydi yok.</p>
                }
                else
                {
                    foreach (var decision in Model.DecisionTraces)
                    {
                        <div class="mb-5 pb-5 border-bottom">
                            <div><strong>@decision.DecisionId</strong> · @decision.DecisionOutcome · @decision.Symbol / @decision.Timeframe</div>
                            <div class="text-muted">@decision.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm:ss") UTC · DecisionAt=@FormatUtc(decision.DecisionAtUtc ?? decision.CreatedAtUtc) · Risk=@(decision.RiskScore?.ToString() ?? "-") · Latency=@decision.LatencyMs ms @(string.IsNullOrWhiteSpace(decision.VetoReasonCode) ? string.Empty : $"· Veto={decision.VetoReasonCode}")</div>
                            <div class="text-muted">SignalId=@(decision.StrategySignalId?.ToString() ?? "-")</div>
                            <div class="text-muted">ReasonType=@FormatText(decision.DecisionReasonType) · ReasonCode=@FormatText(decision.DecisionReasonCode) · Direction=@FormatDecisionDirection(decision.SnapshotJson) · Summary=@FormatText(decision.DecisionSummary)</div>
                            <div class="text-muted">LastCandleAtUtc=@FormatUtc(decision.LastCandleAtUtc) · DataAgeMs=@FormatNumber(decision.DataAgeMs) · StaleThresholdMs=@FormatNumber(decision.StaleThresholdMs) · StaleReason=@FormatText(decision.StaleReason)</div>
                            <div class="text-muted">ContinuityState=@FormatText(decision.ContinuityState) · GapCount=@FormatNumber(decision.ContinuityGapCount) · GapStart=@FormatUtc(decision.ContinuityGapStartedAtUtc) · GapLastSeen=@FormatUtc(decision.ContinuityGapLastSeenAtUtc) · Recovered=@FormatUtc(decision.ContinuityRecoveredAtUtc)</div>
                            <div class="d-flex flex-wrap gap-2 mt-3">
                                <a asp-area="Admin"
                                   asp-controller="Admin"
                                   asp-action="TraceDetail"
                                   asp-route-correlationId="@Model.CorrelationId"
                                   asp-route-decisionId="@decision.DecisionId"
                                   class="btn btn-xs btn-light-info font-weight-bold">Focus decision</a>
                            </div>
                            <details class="mt-3">
                                <summary class="text-muted">Snapshot JSON</summary>
                                <pre class="mt-2 mb-0"><code>@decision.SnapshotJson</code></pre>
                            </details>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    <div class="col-xl-6">
        <div class="card card-custom gutter-b cb-card cb-admin-card cb-admin-table-card">
            <div class="card-body">
                <div class="cb-admin-table-header">
                    <div>
                        <div class="cb-admin-section-kicker">Execution Trace</div>
                        <div class="cb-admin-section-title">Execution listesi</div>
                    </div>
                </div>

                @if (Model.ExecutionTraces.Count == 0)
                {
                    <p class="text-muted mb-0">Execution trace kaydi yok.</p>
                }
                else
                {
                    foreach (var execution in Model.ExecutionTraces)
                    {
                        <div class="mb-5 pb-5 border-bottom">
                            <div><strong>@execution.ExecutionAttemptId</strong> · @execution.Provider · @execution.Endpoint</div>
                            <div class="text-muted">@execution.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm:ss") UTC · Status=@(execution.HttpStatusCode?.ToString() ?? "-") · ExchangeCode=@(execution.ExchangeCode ?? "-") · Latency=@(execution.LatencyMs?.ToString() ?? "-") ms</div>
                            <div class="text-muted">CommandId=@execution.CommandId</div>
                            <div class="text-muted">OrderId=@(execution.ExecutionOrderId?.ToString() ?? "-")</div>
                            <div class="d-flex flex-wrap gap-2 mt-3">
                                <a asp-area="Admin"
                                   asp-controller="Admin"
                                   asp-action="TraceDetail"
                                   asp-route-correlationId="@Model.CorrelationId"
                                   asp-route-executionAttemptId="@execution.ExecutionAttemptId"
                                   class="btn btn-xs btn-light-warning font-weight-bold">Focus execution</a>
                            </div>
                            <details class="mt-3">
                                <summary class="text-muted">Request masked</summary>
                                <pre class="mt-2"><code>@(execution.RequestMasked ?? "{}")</code></pre>
                            </details>
                            <details class="mt-3">
                                <summary class="text-muted">Response masked</summary>
                                <pre class="mt-2 mb-0"><code>@(execution.ResponseMasked ?? "{}")</code></pre>
                            </details>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>
