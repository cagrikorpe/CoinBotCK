@{
    var headerModel = new AdminPageHeaderViewModel
    {
        Eyebrow = "Global AI Ops",
        Title = "Strategy / AI İzleme",
        Description = "Platform genelindeki strategy template kullanımı, AI health, confidence/veto sinyalleri ve explainability örneklerini tek ekranda özetleyen Super Admin AI izleme yüzeyi.",
        StatusBadge = new AdminBadgeViewModel { Label = "AI Watch", Tone = "degraded", IconText = "AI" },
        MetaBadges = new[]
        {
            new AdminBadgeViewModel { Label = "Model Health", Tone = "warning", IconText = "HL" },
            new AdminBadgeViewModel { Label = "Explainable", Tone = "info", IconText = "XP" },
            new AdminBadgeViewModel { Label = "Veto Aware", Tone = "critical", IconText = "VT" }
        },
        SecondaryActionText = "Bot operasyonları",
        SecondaryActionHref = Url.Action("BotOperations", "Admin", new { area = "Admin" }),
        PrimaryActionText = "Audit / loglar",
        PrimaryActionHref = Url.Action("Audit", "Admin", new { area = "Admin" })
    };
}

<div class="row">
    <div class="col-12">
        <div class="card card-custom gutter-b cb-card cb-admin-card">
            <div class="card-body">
                @await Html.PartialAsync("Foundation/_AdminPageHeader", headerModel)

                @await Html.PartialAsync("Foundation/_AdminInfoStrip", new AdminInfoStripViewModel
                {
                    Tone = "warning",
                    Title = "Global strategy / AI monitoring",
                    Message = "Gerçek AI backend, model scoring, cluster analizi ve strategy health pipeline bu yüzeyle hizalanır. Ekran; usage yoğunluğu, model health, veto/confidence ve explainability snapshot'larını gösterir.",
                    Meta = "Operational monitoring"
                })

                <div class="mt-6">
                    @await Html.PartialAsync("Foundation/_AdminStrategyAiSummaryMeta")
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-7">
        @await Html.PartialAsync("Foundation/_AdminStrategyUsagePanel")
        @await Html.PartialAsync("Foundation/_AdminConfidenceVetoPanel")
    </div>

    <div class="col-xl-5">
        @await Html.PartialAsync("Foundation/_AdminGlobalAiHealthPanel")
        @await Html.PartialAsync("Foundation/_AdminExplainabilitySamplePanel")
        @await Html.PartialAsync("Foundation/_AdminStrategyTemplateCatalogPanel")
        @await Html.PartialAsync("Foundation/_AdminStrategyAiHelpCard")
    </div>
</div>
