@model CoinBot.Web.ViewModels.Admin.AdminActivationControlCenterViewModel
@{
    var activationCenter = Model;
    var executionSnapshot = (CoinBot.Application.Abstractions.Execution.GlobalExecutionSwitchSnapshot)ViewData["AdminExecutionSwitchSnapshot"]!;
    var globalSystemStateSnapshot = (CoinBot.Application.Abstractions.Administration.GlobalSystemStateSnapshot)ViewData["AdminGlobalSystemStateSnapshot"]!;
    var crisisPreview = ViewData["AdminCrisisEscalationPreview"] as CoinBot.Web.ViewModels.Admin.AdminCrisisEscalationPreviewViewModel;
    var canEditGlobalPolicy = ViewData["AdminCanEditGlobalPolicy"] is bool canEditValue && canEditValue;
    var canRefreshClockDrift = ViewData["AdminCanRefreshClockDrift"] is bool canRefreshClockDriftValue && canRefreshClockDriftValue;
    var clockDrift = ViewData["AdminClockDriftSnapshot"] as CoinBot.Web.ViewModels.Settings.ClockDriftInfoViewModel;
    var driftGuard = ViewData["AdminDriftGuardSnapshot"] as CoinBot.Web.ViewModels.Settings.MarketDriftGuardInfoViewModel;
    var retentionSnapshot = ViewData["AdminLogCenterRetentionSnapshot"] as CoinBot.Application.Abstractions.Administration.LogCenterRetentionSnapshot;
    var readinessItems = activationCenter.ReadinessChecklist.ToDictionary(item => item.Key, StringComparer.OrdinalIgnoreCase);
    var configStateItem = readinessItems["config-state"];
    var tradingModeItem = readinessItems["trading-mode"];
    var globalStateItem = readinessItems["global-system-state"];
    var timeSyncItem = readinessItems["server-time-sync"];
    var readinessGateItem = readinessItems["readiness-gate"];
    var pilotActivationItem = readinessItems["pilot-activation"];
    var pilotNotionalItem = readinessItems["pilot-notional-cap"];
    var hasRuntimeSnapshots = clockDrift is not null && driftGuard is not null;
    var runtimeHealthy = timeSyncItem.IsPassing && readinessGateItem.IsPassing;
    var runtimeFailureSummary = activationCenter.LastDecision.Summary;
    var activationBlockers = activationCenter.BlockingItems.Select(item => item.Summary).ToArray();
    var activationReady = activationCenter.IsActivatable;
    var activationTone = activationCenter.StatusTone;
    var activationSummaryLabel = activationCenter.StatusLabel;
    var liveSnapshotStatus = runtimeHealthy ? "Hazir" : hasRuntimeSnapshots ? "Dikkat" : "Eksik";
    var liveSnapshotTone = runtimeHealthy ? "healthy" : hasRuntimeSnapshots ? "warning" : "critical";
    var criticalControlsStatus = canEditGlobalPolicy ? (configStateItem.IsPassing ? "Hazir" : "Dikkat") : "Salt okunur";
    var criticalControlsTone = canEditGlobalPolicy ? (configStateItem.IsPassing ? "healthy" : configStateItem.Tone) : "info";
    var executionStepStatus = activationCenter.IsActivatable
        ? executionSnapshot.IsTradeMasterArmed ? "Armed" : "Hazir"
        : "Dikkat";
    var executionStepTone = activationCenter.IsActivatable
        ? executionSnapshot.IsTradeMasterArmed ? "healthy" : "warning"
        : "critical";
    var systemStateStepStatus = globalStateItem.IsPassing ? "Hazir" : globalStateItem.StatusLabel;
    var systemStateStepTone = globalStateItem.Tone;
    var runtimeSyncStepStatus = runtimeHealthy ? "Hazir" : timeSyncItem.StatusCode == "unknown" || readinessGateItem.StatusCode == "unknown" ? "Eksik" : "Dikkat";
    var runtimeSyncStepTone = runtimeHealthy ? "healthy" : timeSyncItem.StatusCode == "unknown" || readinessGateItem.StatusCode == "unknown" ? "critical" : "warning";
    var riskStepStatus = pilotNotionalItem.IsPassing ? (canEditGlobalPolicy ? "Hazir" : "Salt okunur") : "Dikkat";
    var riskStepTone = canEditGlobalPolicy ? pilotNotionalItem.Tone : "info";
    var activationGuidance = activationCenter.Guidance;
    var headerModel = new AdminPageHeaderViewModel
    {
        Eyebrow = "System Settings",
        Title = "Global Ayarlar",
        Description = "Sistem genel ayarlari, canli durum ozeti ve kritik operasyon kontrolleri.",
        StatusBadge = new AdminBadgeViewModel { Label = "System Scope", Tone = "warning", IconText = "GS" },
        MetaBadges = new[]
        {
            new AdminBadgeViewModel { Label = "Read-model", Tone = "info", IconText = "RM" },
            new AdminBadgeViewModel { Label = "Audit Bound", Tone = "critical", IconText = "AU" },
            new AdminBadgeViewModel { Label = "Admin Only", Tone = "warning", IconText = "AO" }
        },
        SecondaryActionText = "Support tools",
        SecondaryActionHref = Url.Action("SupportTools", "Admin", new { area = "Admin" }),
        PrimaryActionText = "Config history",
        PrimaryActionHref = Url.Action("ConfigHistory", "Admin", new { area = "Admin" })
    };
}

<div class="row">
    <div class="col-12">
        <div class="card card-custom gutter-b cb-card cb-admin-card">
            <div class="card-body">
                @await Html.PartialAsync("Foundation/_AdminPageHeader", headerModel)

                @await Html.PartialAsync("Foundation/_AdminInfoStrip", new AdminInfoStripViewModel
                {
                    Tone = "warning",
                    Title = "Bu ekran sistem ayarıdır",
                    Message = "Bu sayfada yalnizca gercek backend write/read-model baglari bulunan execution, global state, crisis, retention, policy ve runtime sync alanlari gosterilir.",
                    Meta = "Global Scope"
                })

                @if (!canEditGlobalPolicy)
                {
                    <div class="cb-admin-info-strip cb-admin-info-strip-info mt-6">
                        <div>
                            <div class="cb-admin-info-strip-title">Read-only policy visibility</div>
                            <div class="cb-admin-info-strip-text">Bu rolde global policy gorulebilir ancak degistirilemez. Kritik POST aksiyonlari yalnizca SuperAdmin tarafinda aciktir.</div>
                        </div>
                        <span class="cb-admin-info-strip-meta">Read-only</span>
                    </div>
                }

                @if (TempData["AdminExecutionSwitchSuccess"] is string executionSwitchSuccessMessage)
                {
                    <div class="cb-admin-info-strip cb-admin-info-strip-healthy mt-6">
                        <div>
                            <div class="cb-admin-info-strip-title">Switch update</div>
                            <div class="cb-admin-info-strip-text">@executionSwitchSuccessMessage</div>
                        </div>
                        <span class="cb-admin-info-strip-meta">Applied</span>
                    </div>
                }

                @if (TempData["AdminExecutionSwitchError"] is string executionSwitchErrorMessage)
                {
                    <div class="cb-admin-info-strip cb-admin-info-strip-danger mt-6">
                        <div>
                            <div class="cb-admin-info-strip-title">Switch update rejected</div>
                            <div class="cb-admin-info-strip-text">@executionSwitchErrorMessage</div>
                        </div>
                        <span class="cb-admin-info-strip-meta">Blocked</span>
                    </div>
                }

                @if (TempData["AdminClockDriftSuccess"] is string clockDriftSuccessMessage)
                {
                    <div class="cb-admin-info-strip cb-admin-info-strip-healthy mt-6">
                        <div>
                            <div class="cb-admin-info-strip-title">Server-time sync yenilendi</div>
                            <div class="cb-admin-info-strip-text">@clockDriftSuccessMessage</div>
                        </div>
                        <span class="cb-admin-info-strip-meta">Applied</span>
                    </div>
                }

                @if (TempData["AdminClockDriftError"] is string clockDriftErrorMessage)
                {
                    <div class="cb-admin-info-strip cb-admin-info-strip-danger mt-6">
                        <div>
                            <div class="cb-admin-info-strip-title">Server-time sync yenilenemedi</div>
                            <div class="cb-admin-info-strip-text">@clockDriftErrorMessage</div>
                        </div>
                        <span class="cb-admin-info-strip-meta">Blocked</span>
                    </div>
                }

                @if (TempData["AdminGlobalSystemStateSuccess"] is string globalSystemStateSuccessMessage)
                {
                    <div class="cb-admin-info-strip cb-admin-info-strip-healthy mt-6">
                        <div>
                            <div class="cb-admin-info-strip-title">Global system state update</div>
                            <div class="cb-admin-info-strip-text">@globalSystemStateSuccessMessage</div>
                        </div>
                        <span class="cb-admin-info-strip-meta">Applied</span>
                    </div>
                }

                @if (TempData["AdminGlobalSystemStateError"] is string globalSystemStateErrorMessage)
                {
                    <div class="cb-admin-info-strip cb-admin-info-strip-danger mt-6">
                        <div>
                            <div class="cb-admin-info-strip-title">Global system state rejected</div>
                            <div class="cb-admin-info-strip-text">@globalSystemStateErrorMessage</div>
                        </div>
                        <span class="cb-admin-info-strip-meta">Blocked</span>
                    </div>
                }

                @if (TempData["AdminGlobalPolicySuccess"] is string globalPolicySuccessMessage)
                {
                    <div class="cb-admin-info-strip cb-admin-info-strip-healthy mt-6">
                        <div>
                            <div class="cb-admin-info-strip-title">Global policy update</div>
                            <div class="cb-admin-info-strip-text">@globalPolicySuccessMessage</div>
                        </div>
                        <span class="cb-admin-info-strip-meta">Applied</span>
                    </div>
                }

                @if (TempData["AdminGlobalPolicyError"] is string globalPolicyErrorMessage)
                {
                    <div class="cb-admin-info-strip cb-admin-info-strip-danger mt-6">
                        <div>
                            <div class="cb-admin-info-strip-title">Global policy rejected</div>
                            <div class="cb-admin-info-strip-text">@globalPolicyErrorMessage</div>
                        </div>
                        <span class="cb-admin-info-strip-meta">Blocked</span>
                    </div>
                }

                @if (TempData["AdminCrisisEscalationSuccess"] is string crisisSuccessMessage)
                {
                    <div class="cb-admin-info-strip cb-admin-info-strip-healthy mt-6">
                        <div>
                            <div class="cb-admin-info-strip-title">Crisis command applied</div>
                            <div class="cb-admin-info-strip-text">@crisisSuccessMessage</div>
                        </div>
                        <span class="cb-admin-info-strip-meta">Applied</span>
                    </div>
                }

                @if (TempData["AdminCrisisEscalationError"] is string crisisErrorMessage)
                {
                    <div class="cb-admin-info-strip cb-admin-info-strip-danger mt-6">
                        <div>
                            <div class="cb-admin-info-strip-title">Crisis command blocked</div>
                            <div class="cb-admin-info-strip-text">@crisisErrorMessage</div>
                        </div>
                        <span class="cb-admin-info-strip-meta">Blocked</span>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="row cb-admin-settings-layout">
    <div class="col-xl-3 col-lg-4">
        @await Html.PartialAsync("Foundation/_AdminGlobalSettingsSectionNav")
    </div>
    <div class="col-xl-9 col-lg-8">
        <div class="cb-admin-settings-shell">
            <div class="tab-content" id="cb_admin_settings_tab_content">
                <div class="tab-pane fade show active" id="cb_admin_settings_tab_overview" role="tabpanel" aria-labelledby="cb_admin_settings_tab_link_overview">
                    <section id="cb_admin_settings_live_snapshot" class="card card-custom gutter-b cb-card cb-admin-card cb-admin-settings-section">
                        <div class="card-body">
                            <div class="cb-admin-section-kicker">Genel Durum</div>
                            <div class="d-flex flex-wrap align-items-start justify-content-between gap-4">
                                <div>
                                    <div class="cb-admin-section-title">Sistemin hazirlik ozeti</div>
                                    <p class="cb-admin-section-description">Sistemin anlik saglik ve hazir olma ozetini gosterir. Bu sekme yalnizca salt okunur canli gorunurluk ve bir sonraki adimi gosterir.</p>
                                </div>
                                @await Html.PartialAsync("_AdminBadge", new AdminBadgeViewModel
                                {
                                    Label = activationSummaryLabel,
                                    Tone = activationTone,
                                    IconText = "OV"
                                })
                            </div>

                            <div class="cb-admin-summary-grid mt-6">
                                <div class="cb-admin-summary-card">
                                    <span class="cb-admin-summary-label">Sistem durumu</span>
                                    <strong>@globalSystemStateSnapshot.State</strong>
                                    <small>@globalSystemStateSnapshot.ReasonCode</small>
                                </div>
                                <div class="cb-admin-summary-card">
                                    <span class="cb-admin-summary-label">Execution durumu</span>
                                    <strong>@(executionSnapshot.IsTradeMasterArmed ? "Armed" : "Disarmed")</strong>
                                    <small>DemoMode: @(executionSnapshot.DemoModeEnabled ? "Enabled" : "Disabled")</small>
                                </div>
                                <div class="cb-admin-summary-card">
                                    <span class="cb-admin-summary-label">Clock drift</span>
                                    <strong>@(clockDrift?.StatusLabel ?? "n/a")</strong>
                                    <small>@(clockDrift?.DriftLabel ?? "n/a")</small>
                                </div>
                                <div class="cb-admin-summary-card">
                                    <span class="cb-admin-summary-label">Last sync</span>
                                    <strong>@(clockDrift?.LastSyncLabel ?? "n/a")</strong>
                                    <small>@(clockDrift?.RefreshCadenceLabel ?? "Refresh bilgisi yok")</small>
                                </div>
                                <div class="cb-admin-summary-card">
                                    <span class="cb-admin-summary-label">Aktivasyona uygunluk</span>
                                    <strong>@activationSummaryLabel</strong>
                                    <small>@activationGuidance</small>
                                </div>
                                <div class="cb-admin-summary-card">
                                    <span class="cb-admin-summary-label">Son block reason</span>
                                    <strong>@runtimeFailureSummary</strong>
                                    <small>@(activationReady ? "Hazir gorunuyor" : "Eksik kontrol var")</small>
                                </div>
                            </div>

                            <div class="cb-admin-info-strip cb-admin-info-strip-info mt-6">
                                <div>
                                    <div class="cb-admin-info-strip-title">Su an yapman gereken</div>
                                    <div class="cb-admin-info-strip-text">@(activationReady ? "Kurulum sihirbazini kisa bir son kontrolden gecirip Aktivasyon sekmesine ilerleyin." : "Once Kurulum Sihirbazi ve Kritik Ayarlar sekmelerindeki eksikleri kapatip sonra Aktivasyon sekmesine donun.")</div>
                                </div>
                                <span class="cb-admin-info-strip-meta">Next</span>
                            </div>

                            <div class="cb-admin-info-strip cb-admin-info-strip-warning mt-5">
                                <div>
                                    <div class="cb-admin-info-strip-title">Canli Snapshot / Salt Okunur</div>
                                    <div class="cb-admin-info-strip-text">Buradaki kartlar runtime snapshot'tir. User settings, browser timezone veya normal kullanici ayarlari bu verileri degistirmez.</div>
                                </div>
                                <span class="cb-admin-info-strip-meta">Live</span>
                            </div>

                            <div class="cb-admin-inline-actions mt-6">
                                <a class="btn btn-light-primary font-weight-bold" data-toggle="tab" href="#cb_admin_settings_tab_wizard" role="tab">Kurulum sihirbazi</a>
                                <a class="btn btn-light-warning font-weight-bold" data-toggle="tab" href="#cb_admin_settings_tab_critical" role="tab">Kritik ayarlar</a>
                                <a class="btn btn-light-danger font-weight-bold" data-toggle="tab" href="#cb_admin_settings_tab_activation" role="tab">Aktivasyon</a>
                                <a asp-area="Admin" asp-controller="Admin" asp-action="SystemHealth" class="btn btn-primary font-weight-bolder">System health</a>
                            </div>
                        </div>
                    </section>
                </div>

                <div class="tab-pane fade" id="cb_admin_settings_tab_wizard" role="tabpanel" aria-labelledby="cb_admin_settings_tab_link_wizard">
                    <section id="cb_admin_settings_quick_start" class="card card-custom gutter-b cb-card cb-admin-card cb-admin-settings-section">
                        <div class="card-body">
                            <div class="cb-admin-section-kicker">Kurulum Sihirbazi</div>
                            <div class="d-flex flex-wrap align-items-start justify-content-between gap-4">
                                <div>
                                    <div class="cb-admin-section-title">Ilk ayarlari dogru sirayla tamamlayin</div>
                                    <p class="cb-admin-section-description">Ilk ayarlari dogru sirayla tamamlamaniz icin rehberlik eder. Her adim ilgili sekmeye yonlendirir; backend workflow uretmez.</p>
                                </div>
                                @await Html.PartialAsync("_AdminBadge", new AdminBadgeViewModel
                                {
                                    Label = activationReady ? "Hazir" : "Checklist",
                                    Tone = activationReady ? "healthy" : "warning",
                                    IconText = "WZ"
                                })
                            </div>

                            <div class="cb-admin-info-strip cb-admin-info-strip-info mt-6">
                                <div>
                                    <div class="cb-admin-info-strip-title">Rehber akis</div>
                                    <div class="cb-admin-info-strip-text">Bu liste once ne yapacaginizi gosterir. Her adim durum rozeti ve ilgili sekmeye kisayol tasir.</div>
                                </div>
                                <span class="cb-admin-info-strip-meta">Guide</span>
                            </div>

                            <div class="cb-admin-summary-grid mt-6">
                                <div class="cb-admin-summary-card">
                                    <span class="cb-admin-summary-label">1. Canli Durumu Kontrol Et</span>
                                    <strong>@liveSnapshotStatus</strong>
                                    <small>Sistem snapshot, son sync ve son hata ozetini once burada kontrol edin.</small>
                                    <div class="cb-admin-page-meta mt-4">@await Html.PartialAsync("_AdminBadge", new AdminBadgeViewModel { Label = liveSnapshotStatus, Tone = liveSnapshotTone, IconText = "01" })</div>
                                    <a href="#cb_admin_settings_tab_overview" data-toggle="tab" role="tab" class="btn btn-light-primary font-weight-bold mt-5">Genel durum</a>
                                </div>
                                <div class="cb-admin-summary-card">
                                    <span class="cb-admin-summary-label">2. Kritik Kontrolleri Gozden Gecir</span>
                                    <strong>@criticalControlsStatus</strong>
                                    <small>Yazilabilir config, audit etkisi ve guarded POST alanlarini ayri okuyun.</small>
                                    <div class="cb-admin-page-meta mt-4">@await Html.PartialAsync("_AdminBadge", new AdminBadgeViewModel { Label = criticalControlsStatus, Tone = criticalControlsTone, IconText = "02" })</div>
                                    <a href="#cb_admin_settings_tab_critical" data-toggle="tab" role="tab" class="btn btn-light-primary font-weight-bold mt-5">Kritik ayarlar</a>
                                </div>
                                <div class="cb-admin-summary-card">
                                    <span class="cb-admin-summary-label">3. Execution Hard Gate'i Dogrula</span>
                                    <strong>@executionStepStatus</strong>
                                    <small>TradeMaster ve DemoMode dogru pozisyonda olmadan aktivasyon yolunu acmayin.</small>
                                    <div class="cb-admin-page-meta mt-4">@await Html.PartialAsync("_AdminBadge", new AdminBadgeViewModel { Label = executionStepStatus, Tone = executionStepTone, IconText = "03" })</div>
                                    <a href="#cb_admin_settings_tab_critical" data-toggle="tab" role="tab" class="btn btn-light-primary font-weight-bold mt-5">Execution gate</a>
                                </div>
                                <div class="cb-admin-summary-card">
                                    <span class="cb-admin-summary-label">4. Global System State'i Ayarla</span>
                                    <strong>@systemStateStepStatus</strong>
                                    <small>Sistemin genel calisma modu uygun degilse execution fail-closed kalir.</small>
                                    <div class="cb-admin-page-meta mt-4">@await Html.PartialAsync("_AdminBadge", new AdminBadgeViewModel { Label = systemStateStepStatus, Tone = systemStateStepTone, IconText = "04" })</div>
                                    <a href="#cb_admin_settings_tab_critical" data-toggle="tab" role="tab" class="btn btn-light-primary font-weight-bold mt-5">System state</a>
                                </div>
                                <div class="cb-admin-summary-card">
                                    <span class="cb-admin-summary-label">5. Runtime Sync Islemlerini Calistir</span>
                                    <strong>@runtimeSyncStepStatus</strong>
                                    <small>Server-time sync ve drift guard sinyalleri aktivasyon oncesi temiz gorunmelidir.</small>
                                    <div class="cb-admin-page-meta mt-4">@await Html.PartialAsync("_AdminBadge", new AdminBadgeViewModel { Label = runtimeSyncStepStatus, Tone = runtimeSyncStepTone, IconText = "05" })</div>
                                    <a href="#cb_admin_settings_tab_sync" data-toggle="tab" role="tab" class="btn btn-light-primary font-weight-bold mt-5">Senkronizasyon</a>
                                </div>
                                <div class="cb-admin-summary-card">
                                    <span class="cb-admin-summary-label">6. Risk / Policy Limitlerini Kontrol Et</span>
                                    <strong>@riskStepStatus</strong>
                                    <small>Global policy ve symbol restriction limitlerini son kez gozden gecirin.</small>
                                    <div class="cb-admin-page-meta mt-4">@await Html.PartialAsync("_AdminBadge", new AdminBadgeViewModel { Label = riskStepStatus, Tone = riskStepTone, IconText = "06" })</div>
                                    <a href="#cb_admin_settings_tab_critical" data-toggle="tab" role="tab" class="btn btn-light-primary font-weight-bold mt-5">Risk / policy</a>
                                </div>
                                <div class="cb-admin-summary-card">
                                    <span class="cb-admin-summary-label">7. Aktivasyon Oncesi Son Kontrol</span>
                                    <strong>@(activationReady ? "Hazir" : "Eksik")</strong>
                                    <small>Aktivasyon sekmesi son blocker listesi ve emergency erisim yolunu bir araya getirir.</small>
                                    <div class="cb-admin-page-meta mt-4">@await Html.PartialAsync("_AdminBadge", new AdminBadgeViewModel { Label = activationReady ? "Hazir" : "Eksik", Tone = activationTone, IconText = "07" })</div>
                                    <a href="#cb_admin_settings_tab_activation" data-toggle="tab" role="tab" class="btn btn-light-primary font-weight-bold mt-5">Aktivasyon</a>
                                </div>
                            </div>
                        </div>
                    </section>
                </div>

                <div class="tab-pane fade" id="cb_admin_settings_tab_critical" role="tabpanel" aria-labelledby="cb_admin_settings_tab_link_critical">
                    <section id="cb_admin_settings_controls" class="card card-custom gutter-b cb-card cb-admin-card cb-admin-settings-section">
                        <div class="card-body">
                            <div class="cb-admin-section-kicker">Kritik Ayarlar</div>
                            <div class="d-flex flex-wrap align-items-start justify-content-between gap-4">
                                <div>
                                    <div class="cb-admin-section-title">Aktivasyon oncesi kontrol edilmesi gereken temel konfigürasyonlar</div>
                                    <p class="cb-admin-section-description">Sistemi acmadan once gereken write etkili alanlar burada toplanir. Salt okunur bilgi ile degistirilebilir alanlar karistirilmaz.</p>
                                </div>
                                @await Html.PartialAsync("_AdminBadge", new AdminBadgeViewModel
                                {
                                    Label = canEditGlobalPolicy ? "Write enabled" : "Read-only",
                                    Tone = canEditGlobalPolicy ? "critical" : "info",
                                    IconText = canEditGlobalPolicy ? "WR" : "RO"
                                })
                            </div>

                            <div class="cb-admin-summary-grid mt-6">
                                <div class="cb-admin-summary-card"><span class="cb-admin-summary-label">Kritik kontroller</span><strong>@criticalControlsStatus</strong><small>Yazilabilir config ve guarded POST aksiyonlari bu sekmede toplandi.</small></div>
                                <div class="cb-admin-summary-card"><span class="cb-admin-summary-label">Execution hard gate</span><strong>@executionStepStatus</strong><small>TradeMaster ve DemoMode backend hard gate olarak calisir.</small></div>
                                <div class="cb-admin-summary-card"><span class="cb-admin-summary-label">Global system state</span><strong>@systemStateStepStatus</strong><small>Global calisma modu fail-closed execution davranisini belirler.</small></div>
                                <div class="cb-admin-summary-card"><span class="cb-admin-summary-label">Risk / policy limits</span><strong>@riskStepStatus</strong><small>Uzun restriction tablolari asagidaki collapse icinde tutulur.</small></div>
                            </div>

                            <div class="cb-admin-info-strip cb-admin-info-strip-warning mt-6">
                                <div>
                                    <div class="cb-admin-info-strip-title">Yazilabilir Konfigürasyon</div>
                                    <div class="cb-admin-info-strip-text">Bu sekmedeki degisiklikler audit etkili, anti-forgery korumali ve MFA bagli kritik operasyon degisiklikleridir.</div>
                                </div>
                                <span class="cb-admin-info-strip-meta">Audit</span>
                            </div>
                        </div>
                    </section>

                    @await Html.PartialAsync("Foundation/_AdminGlobalExecutionSwitchSection", executionSnapshot)
                    @await Html.PartialAsync("Foundation/_AdminGlobalSystemStateSection", globalSystemStateSnapshot)

                    <details class="card card-custom gutter-b cb-card cb-admin-card cb-admin-settings-section">
                        <summary class="card-body font-weight-bolder">Risk / Policy limitlerini goster</summary>
                        <div class="px-8 pb-8 pt-2">
                            <div class="cb-helper-text mb-5">Risk / Policy Engine uzun restriction tablolarini ana gorunumu bogmamak icin varsayilan olarak kapali tutar.</div>
                            @await Html.PartialAsync("Foundation/_AdminRiskPolicyDefaultsSection")
                        </div>
                    </details>
                </div>

                <div class="tab-pane fade" id="cb_admin_settings_tab_sync" role="tabpanel" aria-labelledby="cb_admin_settings_tab_link_sync">
                    <section id="cb_admin_settings_quick_actions" class="card card-custom gutter-b cb-card cb-admin-card cb-admin-settings-section">
                        <div class="card-body">
                            <div class="cb-admin-section-kicker">Senkronizasyon ve Islemler</div>
                            <div class="d-flex flex-wrap align-items-start justify-content-between gap-4">
                                <div>
                                    <div class="cb-admin-section-title">Canli senkron ve hizli operasyon aksiyonlari</div>
                                    <p class="cb-admin-section-description">Runtime sync, server time refresh ve hizli kontrol aksiyonlari tek blokta tutulur. Anlik refresh ile persisted config yazimi ayri kalir.</p>
                                </div>
                                @await Html.PartialAsync("_AdminBadge", new AdminBadgeViewModel
                                {
                                    Label = canRefreshClockDrift ? "Refresh ready" : "Read-only",
                                    Tone = canRefreshClockDrift ? "warning" : "info",
                                    IconText = "QA"
                                })
                            </div>

                            <div class="cb-admin-inline-actions mt-6">
                                @if (canRefreshClockDrift)
                                {
                                    <form asp-area="Admin" asp-controller="Admin" asp-action="RefreshClockDrift" method="post" class="d-inline-block">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-light-warning font-weight-bold">Server time refresh</button>
                                    </form>
                                }
                                <a class="btn btn-light-primary font-weight-bold" data-toggle="tab" href="#cb_admin_settings_tab_critical" role="tab">Execution hard gate</a>
                                <a class="btn btn-light-primary font-weight-bold" data-toggle="tab" href="#cb_admin_settings_tab_critical" role="tab">Global system state</a>
                                <a class="btn btn-light-danger font-weight-bold" data-toggle="tab" href="#cb_admin_settings_tab_activation" role="tab">Emergency / soft halt</a>
                                <a asp-area="Admin" asp-controller="Admin" asp-action="SystemHealth" class="btn btn-primary font-weight-bolder">Health / control refresh</a>
                            </div>

                            <div class="cb-admin-info-strip cb-admin-info-strip-info mt-6">
                                <div>
                                    <div class="cb-admin-info-strip-title">Kritik Aksiyon</div>
                                    <div class="cb-admin-info-strip-text">Bu sekmedeki refresh ve sync butonlari runtime operasyon aksiyonudur. Persisted config degisikligi degildir.</div>
                                </div>
                                <span class="cb-admin-info-strip-meta">Runtime</span>
                            </div>
                        </div>
                    </section>

                    @if (clockDrift is not null && driftGuard is not null)
                    {
                        <section id="cb_admin_settings_clock_sync" class="card card-custom gutter-b cb-card cb-admin-card cb-admin-settings-section">
                            <div class="card-body">
                                <div class="cb-admin-section-kicker">Runtime Sync Ops</div>
                                <div class="d-flex flex-wrap align-items-start justify-content-between gap-4">
                                    <div>
                                        <div class="cb-admin-section-title">Server-time sync ve drift guard snapshot'i</div>
                                        <p class="cb-admin-section-description">Canli senkronizasyon, saat offset'i ve market-data drift kararini read-only snapshot olarak gosterir. Refresh aksiyonu policy bazli olarak korunur.</p>
                                    </div>
                                    @await Html.PartialAsync("_AdminBadge", new AdminBadgeViewModel
                                    {
                                        Label = canRefreshClockDrift ? "Write" : "Read-only",
                                        Tone = canRefreshClockDrift ? "warning" : "info",
                                        IconText = canRefreshClockDrift ? "RW" : "RO"
                                    })
                                </div>

                                <div class="cb-admin-settings-switch-grid mt-6">
                                    <div class="cb-admin-summary-card">
                                        <span class="cb-admin-summary-label">Server-time sync</span>
                                        <strong>@clockDrift.StatusLabel</strong>
                                        <small>Last sync: @clockDrift.LastSyncLabel</small>
                                        <div class="table-responsive mt-5">
                                            <table class="table table-borderless mb-0"><tbody>
                                                <tr><td class="font-weight-bolder">Local app time</td><td>@clockDrift.LocalAppTimeLabel</td></tr>
                                                <tr><td class="font-weight-bolder">Exchange server time</td><td>@clockDrift.ExchangeServerTimeLabel</td></tr>
                                                <tr><td class="font-weight-bolder">Measured offset</td><td>@clockDrift.OffsetLabel</td></tr>
                                                <tr><td class="font-weight-bolder">Measured drift</td><td>@clockDrift.DriftLabel</td></tr>
                                                <tr><td class="font-weight-bolder">Refresh cadence</td><td>@clockDrift.RefreshCadenceLabel</td></tr>
                                            </tbody></table>
                                        </div>
                                        @if (!string.IsNullOrWhiteSpace(clockDrift.FailureReason))
                                        {
                                            <div class="cb-admin-info-strip cb-admin-info-strip-warning mt-5">
                                                <div><div class="cb-admin-info-strip-title">Last sync failure</div><div class="cb-admin-info-strip-text">@clockDrift.FailureReason</div></div>
                                                <span class="cb-admin-info-strip-meta">Retry aware</span>
                                            </div>
                                        }
                                    </div>
                                    <div class="cb-admin-summary-card">
                                        <span class="cb-admin-summary-label">Drift guard</span>
                                        <strong>@driftGuard.StateLabel</strong>
                                        <small>@driftGuard.ReasonLabel</small>
                                        <div class="table-responsive mt-5">
                                            <table class="table table-borderless mb-0"><tbody>
                                                <tr><td class="font-weight-bolder">Source</td><td>@driftGuard.SourceLabel</td></tr>
                                                <tr><td class="font-weight-bolder">Threshold</td><td>@driftGuard.ThresholdLabel</td></tr>
                                                <tr><td class="font-weight-bolder">Latest heartbeat</td><td>@driftGuard.LatestHeartbeatLabel</td></tr>
                                                <tr><td class="font-weight-bolder">Latest data age</td><td>@driftGuard.LatestDataAgeLabel</td></tr>
                                                <tr><td class="font-weight-bolder">Last state change</td><td>@driftGuard.LastStateChangedLabel</td></tr>
                                            </tbody></table>
                                        </div>
                                        <div class="cb-admin-info-strip cb-admin-info-strip-warning mt-5">
                                            <div><div class="cb-admin-info-strip-title">Retry expectation</div><div class="cb-admin-info-strip-text">@driftGuard.RetryExpectation</div></div>
                                            <span class="cb-admin-info-strip-meta">Fail-closed</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </section>
                    }
                    else
                    {
                        <section id="cb_admin_settings_clock_sync" class="card card-custom gutter-b cb-card cb-admin-card cb-admin-settings-section">
                            <div class="card-body">
                                <div class="cb-admin-section-kicker">Runtime Sync Ops</div>
                                <div class="cb-admin-section-title">Snapshot bekleniyor</div>
                                <p class="cb-admin-section-description mb-0">Clock drift veya drift guard snapshot'i henuz gelmedi. Worker warmup ve runtime sync kontrol edilmeden aktivasyon yolu acilmamalidir.</p>
                            </div>
                        </section>
                    }
                </div>

                <div class="tab-pane fade" id="cb_admin_settings_tab_activation" role="tabpanel" aria-labelledby="cb_admin_settings_tab_link_activation">
                    @await Html.PartialAsync("Foundation/_AdminActivationControlCenterSection", Model)

                    <details id="cb_admin_settings_crisis_panel" class="card card-custom gutter-b cb-card cb-admin-card cb-admin-settings-section">
                        <summary class="card-body font-weight-bolder">Emergency / soft halt panelini goster</summary>
                        <div class="px-8 pb-8 pt-2">
                            <div class="cb-helper-text mb-5">Crisis escalation kontrolleri yalniz acil mudahale gerektiginde acilmalidir.</div>
                            @await Html.PartialAsync("Foundation/_AdminCrisisEscalationSection", crisisPreview)
                        </div>
                    </details>
                </div>

                <div class="tab-pane fade" id="cb_admin_settings_tab_details" role="tabpanel" aria-labelledby="cb_admin_settings_tab_link_details">
                    <section id="cb_admin_settings_details" class="card card-custom gutter-b cb-card cb-admin-card cb-admin-settings-section">
                        <div class="card-body">
                            <div class="cb-admin-section-kicker">Gecmis ve Detaylar</div>
                            <div class="d-flex flex-wrap align-items-start justify-content-between gap-4">
                                <div>
                                    <div class="cb-admin-section-title">Loglar, gecmis kayitlar ve ileri seviye teknik bilgiler</div>
                                    <p class="cb-admin-section-description">Uzun tablolar ve dusuk oncelikli teknik detaylar ana gorunumu bogmamak icin bu sekmede tutulur.</p>
                                </div>
                                @await Html.PartialAsync("_AdminBadge", new AdminBadgeViewModel
                                {
                                    Label = "Details",
                                    Tone = "info",
                                    IconText = "DT"
                                })
                            </div>

                            <div class="cb-admin-info-strip cb-admin-info-strip-info mt-6">
                                <div>
                                    <div class="cb-admin-info-strip-title">Dusuk oncelikli detaylar</div>
                                    <div class="cb-admin-info-strip-text">Config history, state history, audit ve system health baglantilari burada toplanir; ilk aktivasyon akisinda ust sekmeler kullanilmalidir.</div>
                                </div>
                                <span class="cb-admin-info-strip-meta">History</span>
                            </div>

                            <div class="cb-admin-inline-actions mt-6">
                                <a asp-area="Admin" asp-controller="Admin" asp-action="ConfigHistory" class="btn btn-light-primary font-weight-bold">Config history</a>
                                <a asp-area="Admin" asp-controller="Admin" asp-action="SystemStateHistory" class="btn btn-light-warning font-weight-bold">State history</a>
                                <a asp-area="Admin" asp-controller="Admin" asp-action="Audit" class="btn btn-primary font-weight-bolder">Audit / trace</a>
                                <a asp-area="Admin" asp-controller="Admin" asp-action="SystemHealth" class="btn btn-light-primary font-weight-bold">System health</a>
                            </div>
                        </div>
                    </section>

                    <details class="card card-custom gutter-b cb-card cb-admin-card cb-admin-settings-section" open>
                        <summary class="card-body font-weight-bolder">Logging / retention ozetini goster</summary>
                        <div class="px-8 pb-8 pt-2">
                            @await Html.PartialAsync("Foundation/_AdminLoggingRetentionSection")
                        </div>
                    </details>
                </div>
            </div>
        </div>
    </div>
</div>
