@using CoinBot.Application.Abstractions.Administration
@{
    var snapshot = ViewData["AdminUserDetailPageSnapshot"] as AdminUserDetailPageSnapshot;
    var history = snapshot?.ValidationHistory ?? Array.Empty<AdminUserExchangeValidationSnapshot>();
}

<div class="card card-custom gutter-b cb-card cb-admin-card">
    <div class="card-body">
        <div class="cb-admin-panel-head">
            <div>
                <div class="cb-admin-section-kicker">Validation History</div>
                <div class="cb-admin-section-title">Credential validation geçmişi</div>
            </div>
            @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel
            {
                Label = snapshot is null ? "Veri yok" : $"{history.Count} kayıt",
                Tone = snapshot is null ? "neutral" : "info",
                IconText = "VH"
            })
        </div>

        @if (snapshot is null)
        {
            @await Html.PartialAsync("Foundation/_AdminEmptyState", new UiStateViewModel
            {
                Title = "Validation geçmişi yok",
                Message = "Kullanıcı için credential validation geçmişi bulunamadı.",
                IconText = "VH",
                ActionText = "Kullanıcı listesi",
                ActionHref = Url.Action("Users", "Admin", new { area = "Admin" }),
                SecondaryActionText = "Exchange hesapları",
                SecondaryActionHref = Url.Action("ExchangeAccounts", "Admin", new { area = "Admin" })
            })
        }
        else if (history.Count == 0)
        {
            @await Html.PartialAsync("Foundation/_AdminEmptyState", new UiStateViewModel
            {
                Title = "Henüz validation kaydı yok",
                Message = "İlk credential submit işleminden sonra key geçerliliği, trade izni, withdraw guard ve environment sonucu burada listelenir.",
                IconText = "VH",
                ActionText = "Exchange hesapları",
                ActionHref = Url.Action("ExchangeAccounts", "Admin", new { area = "Admin" }),
                SecondaryActionText = "Kullanıcı listesi",
                SecondaryActionHref = Url.Action("Users", "Admin", new { area = "Admin" })
            })
        }
        else
        {
            <div class="table-responsive mt-5">
                <table class="table table-borderless cb-admin-table mb-0">
                    <thead>
                        <tr>
                            <th>Zaman</th>
                            <th>Durum</th>
                            <th>Permission</th>
                            <th>Kontroller</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in history)
                        {
                            <tr>
                                <td>
                                    <div class="cb-admin-mini-stat">
                                        <strong>@item.ExchangeDisplayName</strong>
                                        <small>@item.TimeLabel</small>
                                    </div>
                                </td>
                                <td>
                                    <div class="cb-admin-mini-stat">
                                        <strong>@item.ValidationStatus</strong>
                                        <small>@item.EnvironmentScope · @(item.IsEnvironmentMatch ? "uyumlu" : "uyumsuz")</small>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(item.FailureReason))
                                    {
                                        <div class="text-danger small mt-2">@item.FailureReason</div>
                                    }
                                </td>
                                <td>
                                    <div class="cb-admin-mini-stat">
                                        <strong>@item.PermissionSummary</strong>
                                        <small>Fingerprint: @(item.MaskedFingerprint ?? "yok")</small>
                                    </div>
                                </td>
                                <td>
                                    <div class="cb-admin-mini-stat">
                                        <strong>Key @(item.IsKeyValid ? "OK" : "FAIL") · Trade @(item.CanTrade ? "Y" : "N") · Withdraw @(item.CanWithdraw ? "Y" : "N")</strong>
                                        <small>Spot @(item.SupportsSpot ? "Y" : "N") · Futures @(item.SupportsFutures ? "Y" : "N")</small>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
