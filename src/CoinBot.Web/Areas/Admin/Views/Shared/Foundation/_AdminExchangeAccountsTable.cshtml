@model IReadOnlyCollection<CoinBot.Application.Abstractions.Administration.ApiCredentialAdminSummary>
@using CoinBot.Web.ViewModels.Admin

<div class="card card-custom gutter-b cb-card cb-admin-card cb-admin-table-card">
    <div class="card-body">
        <div class="cb-admin-table-header">
            <div>
                <div class="cb-admin-section-kicker">Credential Grid</div>
                <div class="cb-admin-section-title">Masked credential summary listesi</div>
                <p class="cb-admin-section-description mb-0">Validation durumu, permission ozeti ve son hata nedeni tek satirda izlenir; plaintext credential gosterilmez.</p>
            </div>
            @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = "Read Model", Tone = "info", IconText = "RM" })
        </div>

        <div class="table-responsive cb-admin-table-wrap">
            <table class="table table-borderless cb-admin-table cb-admin-exchange-table mb-0">
                <thead>
                    <tr>
                        <th>Kullanici</th>
                        <th>Exchange</th>
                        <th>Hesap</th>
                        <th>Fingerprint</th>
                        <th>Validation</th>
                        <th>Permission</th>
                        <th>LastValidationAtUtc</th>
                        <th>LastFailure</th>
                        <th>Aksiyon</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Count == 0)
                    {
                        <tr>
                            <td colspan="9" class="text-muted">Credential summary bulunamadi.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var row in Model)
                        {
                            var validationTone = row.ValidationStatus.Equals("Valid", StringComparison.OrdinalIgnoreCase)
                                ? "healthy"
                                : row.ValidationStatus.Equals("Missing", StringComparison.OrdinalIgnoreCase)
                                    ? "warning"
                                    : "critical";
                            <tr>
                                <td>@row.OwnerUserId</td>
                                <td>@row.ExchangeName</td>
                                <td>
                                    <div class="cb-admin-mini-stat">
                                        <strong>@row.DisplayName</strong>
                                        <small>@(row.IsReadOnly ? "ReadOnly" : "Trading")</small>
                                    </div>
                                </td>
                                <td><code>@(row.MaskedFingerprint ?? "missing")</code></td>
                                <td>
                                    @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel
                                    {
                                        Label = row.ValidationStatus,
                                        Tone = validationTone,
                                        IconText = "VL"
                                    })
                                </td>
                                <td>@(row.PermissionSummary ?? "-")</td>
                                <td>@(row.LastValidationAtUtc?.ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</td>
                                <td>@(row.LastFailureReason ?? "-")</td>
                                <td>
                                    <div class="cb-admin-inline-actions cb-admin-inline-actions-compact">
                                        <a asp-area="Admin"
                                           asp-controller="Admin"
                                           asp-action="Audit"
                                           asp-route-query="@row.OwnerUserId"
                                           class="btn btn-xs btn-light-primary font-weight-bold">Trace</a>
                                        <a asp-area="Admin"
                                           asp-controller="Admin"
                                           asp-action="UserDetail"
                                           asp-route-id="@row.OwnerUserId"
                                           class="btn btn-xs btn-light-primary font-weight-bold">Kullanici</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
