@using CoinBot.Application.Abstractions.Administration
@{
    var snapshot = ViewData["AdminUsersPageSnapshot"] as AdminUsersPageSnapshot;
    var users = snapshot?.Users ?? Array.Empty<AdminUserListItemSnapshot>();
    var summaryTiles = snapshot?.SummaryTiles ?? Array.Empty<AdminStatTileSnapshot>();
}

<div class="card card-custom gutter-b cb-card cb-admin-card cb-admin-table-card">
    <div class="card-body">
        <div class="cb-admin-table-header">
            <div>
                <div class="cb-admin-section-kicker">User List</div>
                <div class="cb-admin-section-title">Kullanıcı yönetimi listesi</div>
                <p class="cb-admin-section-description mb-0">Durum, MFA, bot ve exchange summary sinyalleri gerçek snapshot verisinden okunur.</p>
            </div>
            <div class="cb-admin-inline-actions">
                @foreach (var tile in summaryTiles.Take(2))
                {
                    @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel
                    {
                        Label = $"{tile.Label}: {tile.Value}",
                        Tone = tile.Tone,
                        IconText = "US"
                    })
                }
            </div>
        </div>

        <div class="cb-admin-summary-grid cb-admin-user-summary-grid mt-5">
            @foreach (var tile in summaryTiles)
            {
                <div class="cb-admin-summary-card">
                    <span class="cb-admin-summary-label">@tile.Label</span>
                    <strong>@tile.Value</strong>
                    <small>@tile.Meta</small>
                </div>
            }
        </div>

        <div class="table-responsive cb-admin-table-wrap mt-5">
            <table class="table table-borderless cb-admin-table cb-admin-users-table mb-0">
                <thead>
                    <tr>
                        <th>Kullanıcı</th>
                        <th>Durum</th>
                        <th>MFA</th>
                        <th>Rol</th>
                        <th>Bot</th>
                        <th>Exchange</th>
                        <th>Son aktivite</th>
                        <th>Aksiyon</th>
                    </tr>
                </thead>
                <tbody>
                    @if (users.Count == 0)
                    {
                        <tr>
                            <td colspan="8">
                                @await Html.PartialAsync("Foundation/_AdminEmptyState", new UiStateViewModel
                                {
                                    Title = "Kullanıcı bulunamadı",
                                    Message = "Filtrelerle eşleşen kullanıcı yok. Filtreyi temizleyin veya yeni bir query deneyin.",
                                    IconText = "US",
                                    ActionText = "Filtreyi temizle",
                                    ActionHref = Url.Action("Users", "Admin", new { area = "Admin" }),
                                    SecondaryActionText = "Destek araçları",
                                    SecondaryActionHref = Url.Action("SupportTools", "Admin", new { area = "Admin" })
                                })
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var user in users)
                        {
                            <tr>
                                <td>
                                    <div class="cb-admin-user-cell">
                                        <span class="cb-admin-user-avatar">@user.DisplayName.Substring(0, 1)</span>
                                        <div>
                                            <strong class="cb-admin-user-name">@user.DisplayName</strong>
                                            <div class="cb-admin-user-meta">@user.UserName · @(user.Email ?? user.UserId)</div>
                                        </div>
                                    </div>
                                </td>
                                <td>@await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = user.StatusLabel, Tone = user.StatusTone, IconText = "ST" })</td>
                                <td>@await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = user.MfaLabel, Tone = user.MfaTone, IconText = "2F" })</td>
                                <td><div class="cb-admin-mini-stat"><strong>@user.RoleSummary</strong><small>Role</small></div></td>
                                <td><div class="cb-admin-mini-stat"><strong>@user.BotCount</strong><small>Bot bağlı</small></div></td>
                                <td><div class="cb-admin-mini-stat"><strong>@user.ExchangeCount</strong><small>Exchange bağlı</small></div></td>
                                <td>
                                    <div class="cb-admin-mini-stat">
                                        <strong>@user.LastActivityLabel</strong>
                                        <small>@(user.LastActivityAtUtc?.ToString("yyyy-MM-dd HH:mm:ss") ?? "Veri yok") UTC</small>
                                    </div>
                                </td>
                                <td>
                                    <div class="cb-admin-table-actions justify-content-end">
                                        <a asp-area="Admin" asp-controller="Admin" asp-action="UserDetail" asp-route-id="@user.UserId" class="btn btn-xs btn-light-primary font-weight-bold">Detay</a>
                                        <a asp-area="Admin" asp-controller="Admin" asp-action="Audit" asp-route-userId="@user.UserId" class="btn btn-xs btn-light-primary font-weight-bold">Loglar</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
