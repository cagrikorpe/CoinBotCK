@using CoinBot.Application.Abstractions.MarketData
@{
    var dashboard = ViewData["AdminMonitoringDashboardSnapshot"] as MonitoringDashboardSnapshot
        ?? MonitoringDashboardSnapshot.Empty(DateTime.UtcNow);
    var cacheSnapshot = dashboard.MarketDataCache ?? SharedMarketDataCacheHealthSnapshot.Empty(dashboard.LastRefreshedAtUtc);
    var streamSnapshots = cacheSnapshot.StreamSnapshots
        .OrderBy(snapshot => snapshot.DataType)
        .ThenBy(snapshot => snapshot.Symbol, StringComparer.Ordinal)
        .ThenBy(snapshot => snapshot.Timeframe, StringComparer.Ordinal)
        .ToArray();
    var symbolSnapshots = cacheSnapshot.SymbolFreshness
        .OrderBy(snapshot => snapshot.DataType)
        .ThenBy(snapshot => snapshot.Symbol, StringComparer.Ordinal)
        .ThenBy(snapshot => snapshot.Timeframe, StringComparer.Ordinal)
        .Take(8)
        .ToArray();
    var cacheTone = cacheSnapshot.ProviderUnavailableCount > 0 || cacheSnapshot.DeserializeFailedCount > 0 || cacheSnapshot.InvalidPayloadCount > 0
        ? "critical"
        : cacheSnapshot.StaleHitCount > 0 || cacheSnapshot.MissCount > 0 || symbolSnapshots.Any(snapshot => snapshot.LastReadStatus != SharedMarketDataCacheReadStatus.HitFresh || snapshot.StaleReasonCode != SharedMarketDataCacheStaleReasonCode.Fresh)
            ? "warning"
            : "healthy";
    var metricsText = $"Hit={cacheSnapshot.HitCount} · Miss={cacheSnapshot.MissCount} · Stale={cacheSnapshot.StaleHitCount} · Provider={cacheSnapshot.ProviderUnavailableCount} · Invalid={cacheSnapshot.InvalidPayloadCount} · Deserialize={cacheSnapshot.DeserializeFailedCount}";
}

<div class="card card-custom gutter-b cb-card cb-admin-card cb-admin-panel-card" data-cb-market-data-cache-health-card>
    <div class="card-body">
        <div class="cb-admin-panel-head">
            <div>
                <div class="cb-admin-section-kicker">Market Data Cache</div>
                <div class="cb-admin-section-title">Shared cache health / parity</div>
                <p class="cb-admin-section-description mb-0">Ticker/kline/depth read status, stale reason ve source layer tek shared cache collector snapshot'ından okunur.</p>
            </div>
            @await Html.PartialAsync("_AdminBadge", new AdminBadgeViewModel { Label = cacheTone == "healthy" ? "Cache Fresh" : cacheTone == "warning" ? "Cache Review" : "Cache Critical", Tone = cacheTone, IconText = "MD" })
        </div>

        <div class="cb-admin-worker-meta-grid mt-6">
            <div class="cb-admin-summary-card">
                <span class="cb-admin-summary-label">Read metrics</span>
                <strong data-cb-cache-health-metrics>@metricsText</strong>
                <small data-cb-cache-health-observed-at>@cacheSnapshot.LastObservedAtUtc.ToUniversalTime().ToString("yyyy-MM-dd HH:mm:ss") UTC</small>
            </div>
            @foreach (var streamSnapshot in streamSnapshots)
            {
                <div class="cb-admin-summary-card" data-cb-cache-stream-row data-cb-cache-stream-type="@streamSnapshot.DataType">
                    <span class="cb-admin-summary-label">@streamSnapshot.DataType.ToString() stream</span>
                    <strong class="cb-mono" data-cb-cache-stream-updated>@(streamSnapshot.UpdatedAtUtc?.ToUniversalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "n/a")</strong>
                    <small data-cb-cache-stream-source>@streamSnapshot.Symbol / @(streamSnapshot.Timeframe ?? "spot") · @streamSnapshot.SourceLayer · @streamSnapshot.StaleReasonCode</small>
                </div>
            }
        </div>

        @if (symbolSnapshots.Length == 0)
        {
            <div class="cb-admin-info-strip cb-admin-info-strip-warning mt-6">
                <div>
                    <div class="cb-admin-info-strip-title">No cache reads or projections yet</div>
                    <div class="cb-admin-info-strip-text">Market-data consumer veya producer path'i bir shared cache key'e dokunduğunda symbol freshness snapshot burada görünür.</div>
                </div>
                <span class="cb-admin-info-strip-meta">Pending</span>
            </div>
        }
        else
        {
            <div class="table-responsive mt-6">
                <table class="table table-borderless cb-admin-table mb-0">
                    <thead>
                    <tr>
                        <th>Scope</th>
                        <th>Status</th>
                        <th>Updated</th>
                        <th>Source</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var symbolSnapshot in symbolSnapshots)
                    {
                        <tr data-cb-cache-symbol-row>
                            <td>
                                <div class="cb-admin-job-title" data-cb-cache-symbol>@symbolSnapshot.Symbol</div>
                                <small class="cb-admin-job-meta" data-cb-cache-scope>@symbolSnapshot.DataType / @(symbolSnapshot.Timeframe ?? "spot")</small>
                            </td>
                            <td>
                                <div class="cb-mono" data-cb-cache-status>@symbolSnapshot.LastReadStatus</div>
                                <small class="cb-admin-job-meta" data-cb-cache-reason>@symbolSnapshot.StaleReasonCode</small>
                            </td>
                            <td>
                                <div class="cb-mono" data-cb-cache-updated>@(symbolSnapshot.UpdatedAtUtc?.ToUniversalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "n/a")</div>
                                <small class="cb-admin-job-meta" data-cb-cache-fresh-until>@(symbolSnapshot.FreshUntilUtc?.ToUniversalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "n/a")</small>
                            </td>
                            <td>
                                <div class="cb-admin-job-title" data-cb-cache-source>@symbolSnapshot.SourceLayer</div>
                                <small class="cb-admin-job-meta" data-cb-cache-summary>@(symbolSnapshot.ReasonSummary ?? "n/a")</small>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
