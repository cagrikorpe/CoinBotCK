@using CoinBot.Application.Abstractions.Administration
@{
    var snapshot = ViewData["AdminSecurityEventsPageSnapshot"] as AdminSecurityEventsPageSnapshot;
    var tiles = snapshot?.SummaryTiles ?? Array.Empty<AdminStatTileSnapshot>();
}

<div class="cb-admin-summary-grid cb-admin-security-summary-grid">
    @if (tiles.Count == 0)
    {
        <div class="cb-admin-summary-card">
            <span class="cb-admin-summary-label">Security snapshot</span>
            <strong>Veri yok</strong>
            <small>Güvenlik olayı bulunamadı</small>
        </div>
    }
    else
    {
        @foreach (var tile in tiles)
        {
            <div class="cb-admin-summary-card">
                <span class="cb-admin-summary-label">@tile.Label</span>
                <strong>@tile.Value</strong>
                <small>@tile.Meta</small>
            </div>
        }
    }
</div>
