<div class="card card-custom gutter-b cb-card cb-admin-card">
    <div class="card-body">
        <div class="cb-admin-panel-head">
            <div>
                <div class="cb-admin-section-kicker">Advanced Filters</div>
                <div class="cb-admin-section-title">Gelişmiş filtre toolbar</div>
                <p class="cb-admin-section-description mb-0">Kategori, severity, kullanıcı, modül, bot/strategy, zaman aralığı ve text search alanlarını tek satırda toplar.</p>
            </div>
            <button type="button" class="btn btn-light-primary font-weight-bold" data-toggle="modal" data-target="#cb_admin_log_export_modal">Export placeholder</button>
        </div>

        <div class="cb-filter-bar cb-admin-filter-bar cb-admin-audit-filter-bar mt-6">
            <div class="cb-filter-field">
                <label class="cb-form-label">Text search</label>
                <input class="form-control cb-form-control" placeholder="event, actor, correlation id, trace" />
            </div>
            <div class="cb-filter-field">
                <label class="cb-form-label">Kategori</label>
                <select class="form-control cb-form-control">
                    <option>Tüm kategoriler</option>
                    <option>Security</option>
                    <option>Runtime</option>
                    <option>AI</option>
                </select>
            </div>
            <div class="cb-filter-field">
                <label class="cb-form-label">Severity</label>
                <select class="form-control cb-form-control">
                    <option>Tüm seviyeler</option>
                    <option>Critical</option>
                    <option>Error</option>
                    <option>Warning</option>
                </select>
            </div>
            <div class="cb-filter-field">
                <label class="cb-form-label">Kullanıcı</label>
                <input class="form-control cb-form-control" placeholder="Scoped user placeholder" />
            </div>
            <div class="cb-filter-field">
                <label class="cb-form-label">Modül</label>
                <select class="form-control cb-form-control">
                    <option>Tüm modüller</option>
                    <option>Bot Ops</option>
                    <option>Exchange</option>
                    <option>Settings</option>
                </select>
            </div>
            <div class="cb-filter-field">
                <label class="cb-form-label">Bot / Strategy</label>
                <input class="form-control cb-form-control" placeholder="Bot, strategy, template" />
            </div>
            <div class="cb-filter-field">
                <label class="cb-form-label">Zaman aralığı</label>
                <select class="form-control cb-form-control">
                    <option>Son 24 saat</option>
                    <option>Son 7 gün</option>
                    <option>Custom placeholder</option>
                </select>
            </div>
            <div class="cb-filter-field">
                <label class="cb-form-label">Admin action</label>
                <select class="form-control cb-form-control">
                    <option>Tümü</option>
                    <option>Security sensitive</option>
                    <option>Configuration</option>
                </select>
            </div>
            <div class="cb-filter-field cb-filter-actions cb-admin-user-filter-actions">
                <button type="button" class="btn btn-light-primary font-weight-bold">Temizle</button>
                <button type="button" class="btn btn-primary font-weight-bolder">Uygula</button>
            </div>
        </div>

        <div class="cb-admin-filter-summary mt-5">
            <div class="cb-admin-filter-summary-copy">
                <strong>Aktif filtre özeti</strong>
                <span>Security + Critical + Son 24 saat + Admin action + Text search foundation görünümü</span>
            </div>
            <div class="cb-admin-filter-chip-list">
                <span class="cb-admin-filter-chip">Security</span>
                <span class="cb-admin-filter-chip">Critical</span>
                <span class="cb-admin-filter-chip">24 saat</span>
                <span class="cb-admin-filter-chip">Admin action</span>
            </div>
        </div>
    </div>
</div>
