@using CoinBot.Application.Abstractions.Administration
@{
    var snapshot = ViewData["AdminStrategyAiMonitoringPageSnapshot"] as AdminStrategyAiMonitoringPageSnapshot;
    var rows = snapshot?.UsageRows ?? Array.Empty<AdminStrategyUsageSnapshot>();
}

<div class="card card-custom gutter-b cb-card cb-admin-card cb-admin-table-card">
    <div class="card-body">
        <div class="cb-admin-panel-head">
            <div>
                <div class="cb-admin-section-kicker">Strategy Usage</div>
                <div class="cb-admin-section-title">Aktif strategy template kullanımı</div>
                <p class="cb-admin-section-description mb-0">Template kaynağı, validation sonucu, confidence score ve rule-level explainability gerçek strategy snapshot verisinden okunur.</p>
            </div>
            @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = snapshot is null ? "Veri yok" : $"{rows.Count} template", Tone = "info", IconText = "ST" })
        </div>

        @if (rows.Count == 0)
        {
            @await Html.PartialAsync("Foundation/_AdminEmptyState", new UiStateViewModel
            {
                Title = "Strategy verisi yok",
                Message = "Bu filtre için strategy usage sonucu bulunamadı.",
                IconText = "ST",
                ActionText = "Bot operasyonları",
                ActionHref = Url.Action("BotOperations", "Admin", new { area = "Admin" }),
                SecondaryActionText = "Audit / loglar",
                SecondaryActionHref = Url.Action("Audit", "Admin", new { area = "Admin" })
            })
        }
        else
        {
            <div class="cb-admin-strategy-usage-grid mt-6">
                @foreach (var row in rows)
                {
                    <div class="cb-admin-alert-item @(row.HealthTone == "critical" ? "cb-admin-alert-item-critical" : row.HealthTone == "warning" ? "cb-admin-alert-item-warning" : "cb-admin-alert-item-info")" data-cb-strategy-usage-row>
                        <div class="d-flex align-items-start justify-content-between gap-4">
                            <div>
                                <strong data-cb-strategy-usage-name>@row.DisplayName</strong>
                                <small data-cb-strategy-usage-note>@row.Note</small>
                            </div>
                            @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = row.HealthLabel, Tone = row.HealthTone, IconText = "PB" })
                        </div>
                        <div class="cb-admin-summary-grid cb-admin-strategy-usage-meta">
                            <div class="cb-admin-summary-card">
                                <span class="cb-admin-summary-label">Template</span>
                                <strong data-cb-strategy-usage-template>@row.TemplateName</strong>
                                <small data-cb-strategy-usage-validation>@row.TemplateKey · @row.ValidationStatusCode · <span data-cb-strategy-usage-runtime-template-revision>@row.RuntimeTemplateRevisionLabel</span></small>
                            </div>
                            <div class="cb-admin-summary-card">
                                <span class="cb-admin-summary-label">Score</span>
                                <strong class="cb-mono" data-cb-strategy-usage-score>@row.LatestScoreLabel</strong>
                                <small data-cb-strategy-usage-validation-summary>@row.ValidationSummary</small>
                            </div>
                            <div class="cb-admin-summary-card">
                                <span class="cb-admin-summary-label">Kullanım</span>
                                <strong class="cb-mono">@row.SignalCount</strong>
                                <small>Signal sayısı</small>
                            </div>
                            <div class="cb-admin-summary-card">
                                <span class="cb-admin-summary-label">Veto</span>
                                <strong class="cb-mono">@row.VetoCount</strong>
                                <small>Oran @($"{row.VetoRate:P0}")</small>
                            </div>
                            <div class="cb-admin-summary-card">
                                <span class="cb-admin-summary-label">Lifecycle</span>
                                <strong class="cb-mono" data-cb-strategy-usage-runtime-version>@row.RuntimeVersionLabel</strong>
                                <small data-cb-strategy-usage-latest-version>Latest @row.LatestVersionLabel · Template @row.LatestTemplateRevisionLabel</small>
                            </div>
                        </div>
                        <div class="cb-admin-info-strip cb-admin-info-strip-info mt-4">
                            <div>
                                <div class="cb-admin-info-strip-title">Son evaluation</div>
                                <div class="cb-admin-info-strip-text" data-cb-strategy-usage-explainability>@row.LatestExplainabilitySummary</div>
                                <div class="cb-admin-info-strip-text mt-2" data-cb-strategy-usage-rule-summary>@row.LatestRuleSummary</div>
                            </div>
                            <span class="cb-admin-info-strip-meta">@row.LatestSignalType · @row.LatestSignalAtLabel · Veto=@(string.IsNullOrWhiteSpace(row.LatestVetoReason) ? "Yok" : row.LatestVetoReason) · Token=<span data-cb-strategy-usage-lifecycle-token>@row.LifecycleTokenLabel</span></span>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
