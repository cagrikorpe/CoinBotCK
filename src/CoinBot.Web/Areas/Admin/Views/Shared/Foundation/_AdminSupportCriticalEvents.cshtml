@using CoinBot.Application.Abstractions.Administration
@{
    var snapshot = ViewData["AdminSupportLookupPageSnapshot"] as AdminSupportLookupSnapshot;
    var events = snapshot?.CriticalEvents ?? Array.Empty<AdminUserLogSnapshot>();
}

<div class="card card-custom gutter-b cb-card cb-admin-card">
    <div class="card-body">
        <div class="cb-admin-section-kicker">Recent Critical Events</div>
        <div class="cb-admin-section-title">Son kritik olaylar</div>

        @if (events.Count == 0)
        {
            @await Html.PartialAsync("Foundation/_AdminEmptyState", new UiStateViewModel
            {
                Title = "Kritik olay yok",
                Message = "Bu arama için kritik olay bulunamadı.",
                IconText = "EV",
                ActionText = "Security events",
                ActionHref = Url.Action("SecurityEvents", "Admin", new { area = "Admin", query = snapshot?.Query }),
                SecondaryActionText = "Audit / loglar",
                SecondaryActionHref = Url.Action("Audit", "Admin", new { area = "Admin", query = snapshot?.Query })
            })
        }
        else
        {
            <div class="cb-admin-activity-list mt-5">
                @foreach (var item in events)
                {
                    <div class="cb-admin-incident-item">
                        <div>
                            <strong>@item.Title</strong>
                            <div class="cb-admin-user-meta">@item.Module · @item.TimeLabel · @item.TimestampUtc.ToString("yyyy-MM-dd HH:mm:ss") UTC</div>
                        </div>
                        @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = item.Severity, Tone = item.Tone, IconText = "SV" })
                    </div>
                }
            </div>
        }

        <div class="cb-admin-inline-actions mt-5">
            <a asp-area="Admin" asp-controller="Admin" asp-action="SecurityEvents" class="btn btn-light-primary font-weight-bold">Security olaylarına git</a>
            <a asp-area="Admin" asp-controller="Admin" asp-action="Audit" class="btn btn-clean text-muted font-weight-bold">Audit</a>
        </div>
    </div>
</div>
