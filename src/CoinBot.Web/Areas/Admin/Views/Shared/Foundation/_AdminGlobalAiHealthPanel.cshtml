@using CoinBot.Application.Abstractions.Administration
@{
    var snapshot = ViewData["AdminStrategyAiMonitoringPageSnapshot"] as AdminStrategyAiMonitoringPageSnapshot;
    var healthTile = snapshot?.HealthTiles.FirstOrDefault();
}

<div class="card card-custom gutter-b cb-card cb-admin-card cb-admin-panel-card">
    <div class="card-body">
        <div class="cb-admin-panel-head">
            <div>
                <div class="cb-admin-section-kicker">AI Health</div>
                <div class="cb-admin-section-title">Model health ve recommendation durumu</div>
            </div>
            @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = healthTile?.Value ?? "Veri yok", Tone = healthTile?.Tone ?? "neutral", IconText = "AI" })
        </div>

        @if (snapshot is null)
        {
            @await Html.PartialAsync("Foundation/_AdminEmptyState", new UiStateViewModel
            {
                Title = "AI health verisi yok",
                Message = "Strategy/AI snapshot'u bulunamadı.",
                IconText = "AI",
                ActionText = "Strategy / AI",
                ActionHref = Url.Action("StrategyAiMonitoring", "Admin", new { area = "Admin" }),
                SecondaryActionText = "Bot operasyonları",
                SecondaryActionHref = Url.Action("BotOperations", "Admin", new { area = "Admin" })
            })
        }
        else
        {
            <div class="cb-admin-ai-health-grid mt-6">
                @foreach (var tile in snapshot.HealthTiles)
                {
                    <div class="cb-admin-summary-card">
                        <span class="cb-admin-summary-label">@tile.Label</span>
                        <strong>@tile.Value</strong>
                        <small>@tile.Meta</small>
                    </div>
                }
            </div>
        }

        <div class="cb-admin-inline-actions mt-6">
            <a asp-area="Admin" asp-controller="Admin" asp-action="Overview" class="btn btn-primary font-weight-bolder">Dashboard bağlantısı</a>
            <a asp-area="Admin" asp-controller="Admin" asp-action="Audit" class="btn btn-light-primary font-weight-bold">Audit / loglar</a>
        </div>
    </div>
</div>
