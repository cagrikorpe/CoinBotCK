<div class="card card-custom gutter-b cb-card cb-admin-card">
    <div class="card-body">
        <div class="cb-admin-panel-head">
            <div>
                <div class="cb-admin-section-kicker">Exchange Summary</div>
                <div class="cb-admin-section-title">Exchange özeti</div>
            </div>
            @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = "1 uyarı", Tone = "warning", IconText = "EX" })
        </div>
        <div class="cb-admin-summary-grid mt-5 cb-admin-user-summary-grid">
            <div class="cb-admin-summary-card">
                <span class="cb-admin-summary-label">Toplam bağlantı</span>
                <strong>3</strong>
                <small>Credential detayı gösterilmez</small>
            </div>
            <div class="cb-admin-summary-card">
                <span class="cb-admin-summary-label">Aktif / Uyarı</span>
                <strong>2 / 1</strong>
                <small>Sync issue placeholder</small>
            </div>
            <div class="cb-admin-summary-card">
                <span class="cb-admin-summary-label">Son sync</span>
                <strong>8 dk önce</strong>
                <small>Delayed değil</small>
            </div>
        </div>
        <a asp-area="Admin" asp-controller="Admin" asp-action="ExchangeAccounts" class="btn btn-light-primary font-weight-bold mt-5">Exchange hesaplarına git</a>
    </div>
</div>
