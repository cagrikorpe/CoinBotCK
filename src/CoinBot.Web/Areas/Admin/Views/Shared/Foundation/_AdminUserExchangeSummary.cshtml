@using CoinBot.Application.Abstractions.Administration
@{
    var snapshot = ViewData["AdminUserDetailPageSnapshot"] as AdminUserDetailPageSnapshot;
    var exchanges = snapshot?.ExchangeAccounts ?? Array.Empty<AdminUserExchangeSnapshot>();
}

<div class="card card-custom gutter-b cb-card cb-admin-card">
    <div class="card-body">
        <div class="cb-admin-panel-head">
            <div>
                <div class="cb-admin-section-kicker">Exchange Summary</div>
                <div class="cb-admin-section-title">Exchange özeti</div>
            </div>
            @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = snapshot is null ? "Veri yok" : $"{exchanges.Count} bağlantı", Tone = snapshot is null ? "neutral" : "warning", IconText = "EX" })
        </div>

        @if (snapshot is null)
        {
            @await Html.PartialAsync("Foundation/_AdminEmptyState", new UiStateViewModel
            {
                Title = "Exchange detayı yok",
                Message = "Kullanıcı için exchange snapshot'u bulunamadı.",
                IconText = "EX",
                ActionText = "Exchange hesapları",
                ActionHref = Url.Action("ExchangeAccounts", "Admin", new { area = "Admin" }),
                SecondaryActionText = "Kullanıcı listesi",
                SecondaryActionHref = Url.Action("Users", "Admin", new { area = "Admin" })
            })
        }
        else
        {
            <div class="cb-admin-summary-grid mt-5 cb-admin-user-summary-grid">
                <div class="cb-admin-summary-card">
                    <span class="cb-admin-summary-label">Toplam bağlantı</span>
                    <strong>@exchanges.Count</strong>
                    <small>Account sayısı</small>
                </div>
                <div class="cb-admin-summary-card">
                    <span class="cb-admin-summary-label">Aktif</span>
                    <strong>@exchanges.Count(item => item.CredentialStatusTone == "healthy")</strong>
                    <small>Credential healthy</small>
                </div>
                <div class="cb-admin-summary-card">
                    <span class="cb-admin-summary-label">Read-only</span>
                    <strong>@exchanges.Count(item => item.PermissionSummary.Contains("Read-only", StringComparison.OrdinalIgnoreCase))</strong>
                    <small>Trade kapalı</small>
                </div>
            </div>

            <div class="table-responsive mt-5">
                <table class="table table-borderless cb-admin-table mb-0">
                    <thead>
                        <tr>
                            <th>Exchange</th>
                            <th>Durum</th>
                            <th>Fingerprint</th>
                            <th>Permission</th>
                            <th>Last validated</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var exchange in exchanges)
                        {
                            <tr>
                                <td>
                                    <div class="cb-admin-mini-stat">
                                        <strong>@exchange.DisplayName</strong>
                                        <small>@exchange.ExchangeName</small>
                                    </div>
                                </td>
                                <td>@await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = exchange.CredentialStatus, Tone = exchange.CredentialStatusTone, IconText = "ST" })</td>
                                <td><code>@exchange.Fingerprint</code></td>
                                <td>@exchange.PermissionSummary</td>
                                <td>@(exchange.LastValidatedAtUtc?.ToString("yyyy-MM-dd HH:mm:ss") ?? "Veri yok") UTC</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <a asp-area="Admin" asp-controller="Admin" asp-action="ExchangeAccounts" class="btn btn-light-primary font-weight-bold mt-5">Exchange hesaplarına git</a>
    </div>
</div>
