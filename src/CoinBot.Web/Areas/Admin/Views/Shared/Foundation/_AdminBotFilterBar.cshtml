@using CoinBot.Application.Abstractions.Administration
@{
    var snapshot = ViewData["AdminBotOperationsPageSnapshot"] as AdminBotOperationsPageSnapshot;
    var query = snapshot?.Query ?? string.Empty;
    var status = snapshot?.StatusFilter ?? string.Empty;
    var mode = snapshot?.ModeFilter ?? string.Empty;
}

<div class="card card-custom gutter-b cb-card cb-admin-card">
    <div class="card-body">
        <div class="cb-admin-table-header">
            <div>
                <div class="cb-admin-section-kicker">Filter Toolbar</div>
                <div class="cb-admin-section-title">Bot filtreleri</div>
                <p class="cb-admin-section-description mb-0">Kullanıcı, durum ve mode filtreleri gerçek bot snapshot verisini daraltır.</p>
            </div>
            @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = snapshot is null ? "Veri yok" : $"{snapshot.Bots.Count} bot", Tone = "info", IconText = "FL" })
        </div>

        <form asp-area="Admin" asp-controller="Admin" asp-action="BotOperations" method="get" class="cb-admin-filter-bar cb-admin-bot-filter-bar mt-6">
            <div class="cb-filter-field">
                <label class="cb-form-label">Bot adı ara</label>
                <input type="text" name="query" value="@query" class="form-control cb-form-control" aria-label="Bot adı / kullanıcı / template" />
            </div>
            <div class="cb-filter-field">
                <label class="cb-form-label">Durum</label>
                <select name="status" class="form-control cb-form-control">
                    <option value="">Tüm durumlar</option>
                    @if (string.Equals(status, "Aktif", StringComparison.OrdinalIgnoreCase))
                    {
                        <option value="Aktif" selected="selected">Aktif</option>
                    }
                    else
                    {
                        <option value="Aktif">Aktif</option>
                    }
                    @if (string.Equals(status, "Durduruldu", StringComparison.OrdinalIgnoreCase))
                    {
                        <option value="Durduruldu" selected="selected">Durduruldu</option>
                    }
                    else
                    {
                        <option value="Durduruldu">Durduruldu</option>
                    }
                </select>
            </div>
            <div class="cb-filter-field">
                <label class="cb-form-label">Mode</label>
                <select name="mode" class="form-control cb-form-control">
                    <option value="">Tümü</option>
                    @if (string.Equals(mode, "Live", StringComparison.OrdinalIgnoreCase))
                    {
                        <option value="Live" selected="selected">Live</option>
                    }
                    else
                    {
                        <option value="Live">Live</option>
                    }
                    @if (string.Equals(mode, "Demo", StringComparison.OrdinalIgnoreCase))
                    {
                        <option value="Demo" selected="selected">Demo</option>
                    }
                    else
                    {
                        <option value="Demo">Demo</option>
                    }
                </select>
            </div>
            <div class="cb-admin-filter-actions">
                <a asp-area="Admin" asp-controller="Admin" asp-action="BotOperations" class="btn btn-light-primary font-weight-bold">Temizle</a>
                <button type="submit" class="btn btn-primary font-weight-bolder">Filtreyi uygula</button>
            </div>
        </form>

        <div class="cb-admin-filter-summary mt-5">
            <span class="cb-admin-filter-chip">Live / Demo</span>
            @if (!string.IsNullOrWhiteSpace(status))
            {
                <span class="cb-admin-filter-chip">Durum: @status</span>
            }
            @if (!string.IsNullOrWhiteSpace(mode))
            {
                <span class="cb-admin-filter-chip">Mode: @mode</span>
            }
            @if (!string.IsNullOrWhiteSpace(query))
            {
                <span class="cb-admin-filter-chip">Query: @query</span>
            }
        </div>
    </div>
</div>
