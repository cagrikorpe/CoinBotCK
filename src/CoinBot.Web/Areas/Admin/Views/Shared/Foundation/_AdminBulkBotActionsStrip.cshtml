<div class="card card-custom gutter-b cb-card cb-admin-card">
    <div class="card-body">
        <div class="cb-admin-bulk-strip">
            <div>
                <div class="cb-admin-section-kicker">Bulk Operations</div>
                <div class="cb-admin-section-title">Toplu operasyon placeholder</div>
                <p class="cb-admin-section-description mb-0">Seçili botlarda pause, stop ve export akışları için controlled action strip hazırlanır. Gerçek batch execution yoktur.</p>
            </div>
            <div class="cb-admin-inline-actions cb-admin-inline-actions-compact">
                <button type="button" class="btn btn-light-warning font-weight-bold" data-toggle="modal" data-target="#cb_admin_confirm_modal" data-cb-modal-title="Seçili botları pause et" data-cb-modal-message="Toplu pause akışı yalnızca foundation seviyesindedir; gerçek runtime etkisi yoktur." data-cb-modal-confirm="Pause">Pause</button>
                <button type="button" class="btn btn-light-danger font-weight-bold" data-toggle="modal" data-target="#cb_admin_bot_force_stop_modal" data-cb-modal-title="Seçili botları force stop" data-cb-modal-message="Toplu force stop kritik aksiyon olarak ele alınır; audit reason ve re-auth zemini hazırdır." data-cb-modal-confirm="Force stop" data-cb-modal-tone="danger">Stop</button>
                <button type="button" class="btn btn-light-primary font-weight-bold" data-toggle="modal" data-target="#cb_admin_confirm_modal" data-cb-modal-title="Bot listesini export et" data-cb-modal-message="Export davranışı placeholder olarak hazırlanmıştır; gerçek dosya üretimi bağlı değildir." data-cb-modal-confirm="Export">Export</button>
            </div>
        </div>
    </div>
</div>
