                <div class="cb-admin-info-strip-title">Execution control</div>
                <div class="cb-admin-info-strip-text" data-cb-admin-global-kill-switch>
                    Global kill switch @executionControl.GlobalKillSwitchState · @executionControl.GlobalKillSwitchSummary
                </div>
                <div class="cb-admin-info-strip-text mt-2" data-cb-admin-current-execution-environment>
                    Current execution environment @executionControl.CurrentExecutionEnvironment · Global system @executionControl.GlobalSystemState · @executionControl.GlobalSystemStateSummary
                </div>
                <div class="cb-admin-info-strip-text mt-2" data-cb-admin-symbol-allowlist>
                    Symbol allowlist @executionControl.SymbolAllowlistSummary
                </div>
                <div class="cb-admin-info-strip-text mt-2" data-cb-admin-concurrency-summary>
                    Max concurrency / exposure @executionControl.ConcurrencyExposureSummary
                </div>
                <div class="cb-admin-info-strip-text mt-2" data-cb-admin-user-execution-override>
                    User execution override @executionControl.UserExecutionOverrideSummary
                </div>
                <div class="cb-admin-info-strip-text mt-2" data-cb-admin-bot-control-summary>
                    Bot enable / disable @executionControl.BotControlSummary
                </div>
                <div class="cb-admin-info-strip-text mt-2" data-cb-admin-last-execution-decision>
                    Last execution decision @executionControl.LastExecutionDecisionSummary
                </div>
                <div class="cb-admin-info-strip-text mt-2" data-cb-admin-execution-control-write-model>
                    Kill switch and global state keep existing ONAYLA + CSRF + audit flow in Settings. User override, bot enable / disable and symbol allowlist remain read-only here unless an admin write action already exists elsewhere.
                </div>
            </div>
            @await Html.PartialAsync("_AdminBadge", new AdminBadgeViewModel
            {
                Label = executionControl.State,
                Tone = ResolveTone(executionControl.State),
                IconText = "EC"
            })
        </div>

        <div class="cb-admin-worker-meta-grid mt-4">
            <div class="cb-admin-summary-card" data-cb-admin-execution-control-badge>
                <span class="cb-admin-summary-label">Execution environment</span>
                <strong>@executionControl.CurrentExecutionEnvironment</strong>
                <small>@executionControl.GlobalSystemState</small>
                <div class="cb-admin-page-meta mt-4">
                    @await Html.PartialAsync("_AdminBadge", new AdminBadgeViewModel
                    {
                        Label = executionControl.CurrentExecutionEnvironment,
                        Tone = executionControl.CurrentExecutionEnvironmentTone,
                        IconText = "ENV"
                    })
                </div>
            </div>
            <div class="cb-admin-summary-card" data-cb-admin-execution-control-bots>
                <span class="cb-admin-summary-label">Bot enable / disable</span>
                <strong>@executionControl.EnabledBotCount enabled</strong>
                <small>@executionControl.DisabledBotCount disabled</small>
            </div>
            <div class="cb-admin-summary-card" data-cb-admin-execution-control-overrides>
                <span class="cb-admin-summary-label">User execution override</span>
                <strong>@executionControl.ActiveUserExecutionOverrideCount active</strong>
                <small>SessionDisabled @executionControl.SessionDisabledOverrideCount · ReduceOnly @executionControl.ReduceOnlyOverrideCount</small>
            </div>
            <div class="cb-admin-summary-card" data-cb-admin-execution-control-allowlist>
                <span class="cb-admin-summary-label">Symbol allowlist</span>
                <strong>@executionControl.AllowedExecutionSymbolCount</strong>
                <small>@executionControl.SymbolAllowlistSummary</small>
            </div>
        </div>

        <div class="cb-admin-inline-actions mt-4" data-cb-admin-execution-control-links>
            <a asp-area="Admin" asp-controller="Admin" asp-action="Settings" asp-fragment="cb_admin_settings_execution" class="btn btn-sm btn-light-primary font-weight-bold">Execution hard gate</a>
            <a asp-area="Admin" asp-controller="Admin" asp-action="Settings" asp-fragment="cb_admin_settings_global_state" class="btn btn-sm btn-light-primary font-weight-bold">Global system state</a>
            <a asp-area="Admin" asp-controller="Admin" asp-action="BotOperations" class="btn btn-sm btn-light-primary font-weight-bold">Bot operations</a>
            <a asp-area="Admin" asp-controller="Admin" asp-action="Users" class="btn btn-sm btn-light-primary font-weight-bold">Users</a>
            <a asp-area="Admin" asp-controller="Admin" asp-action="ConfigHistory" class="btn btn-sm btn-light-primary font-weight-bold">Config history</a>
        </div>

        <div class="cb-admin-info-strip cb-admin-info-strip-info mt-4" data-cb-admin-multi-symbol-stability>
            <div>
                <div class="cb-admin-info-strip-title">Multi-symbol stability</div>
                <div class="cb-admin-info-strip-text" data-cb-admin-multi-symbol-stability-summary>
                    @multiSymbol.Summary
                </div>
                <div class="cb-admin-info-strip-text mt-2" data-cb-admin-multi-symbol-runtime-summary>
                    Total scanned symbols @multiSymbol.TotalScannedSymbols · Active symbols @multiSymbol.ActiveSymbolCount · Open positions @multiSymbol.OpenPositionCount · Exposure @multiSymbol.ExposureSummary
                </div>
                <div class="cb-admin-info-strip-text mt-2" data-cb-admin-multi-symbol-bot-scope>
                    Bot symbol scope @multiSymbol.BotScopeSummary
                </div>
                <div class="cb-admin-info-strip-text mt-2" data-cb-admin-multi-symbol-prepared>
                    Prepared symbols @multiSymbol.PreparedSymbolSummary
                </div>
                <div class="cb-admin-info-strip-text mt-2" data-cb-admin-multi-symbol-blocked>
                    Blocked symbols @multiSymbol.BlockedSymbolSummary
                </div>
                <div class="cb-admin-info-strip-text mt-2" data-cb-admin-multi-symbol-scope-blockers>
                    Scope blockers @multiSymbol.ScopeBlockerSummary
                </div>
                <div class="cb-admin-info-strip-text mt-2" data-cb-admin-multi-symbol-guardrails>
                    Guardrail summary @multiSymbol.GuardrailSummary
                </div>
                <div class="cb-admin-info-strip-text mt-2" data-cb-admin-multi-symbol-top-blockers>
                    Top blocker reasons @multiSymbol.TopBlockerReasons
                </div>
            </div>
            @await Html.PartialAsync("_AdminBadge", new AdminBadgeViewModel
            {
                Label = multiSymbol.State,
                Tone = ResolveTone(multiSymbol.State),
                IconText = "MS"
            })
        </div>

        <div class="table-responsive mt-4" data-cb-admin-multi-symbol-runtime>
            <table class="table table-borderless cb-admin-table mb-0" data-cb-admin-multi-symbol-runtime-table>
                <thead>
                <tr>
                    <th>Symbol</th>
                    <th>Status</th>
                    <th>Position</th>
                    <th>Exposure</th>
                    <th>Last signal</th>
                    <th>Last order</th>
                    <th>Last blocker</th>
                    <th>Scanner score</th>
                    <th>Ranking reason</th>
                    <th>Risk state</th>
                    <th>Freshness</th>
                    <th>Duplicate / cooldown</th>
                    <th>Last seen</th>
                </tr>
                </thead>
                <tbody data-cb-admin-multi-symbol-runtime-rows>
                @if (multiSymbolRuntimeRows.Length == 0)
                {
                    <tr data-cb-admin-multi-symbol-runtime-empty>
                        <td colspan="13">Multi-symbol runtime rows n/a.</td>
                    </tr>
                }
                else
                {
                    foreach (var row in multiSymbolRuntimeRows)
                    {
                        <tr data-cb-admin-multi-symbol-runtime-row>
                            <td data-cb-admin-multi-symbol-runtime-symbol>@row.Symbol</td>
                            <td>@row.StatusLabel</td>
                            <td>@row.PositionSide @(row.PositionQuantity?.ToString("0.########") ?? "n/a")</td>
                            <td>@row.ExposureLabel</td>
                            <td>@row.LastSignalLabel</td>
                            <td>@row.LastOrderLabel</td>
                            <td>@row.LastBlockerCode</td>
                            <td>@row.ScannerScoreLabel</td>
                            <td>@row.RankingReason</td>
                            <td>@row.RiskStateLabel</td>
                            <td>@row.FreshnessLabel</td>
                            <td>@row.DuplicateCooldownLabel</td>
                            <td>@(row.LastSeenUtc?.ToUniversalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "n/a")</td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>

        <div class="cb-admin-info-strip cb-admin-info-strip-info mt-4" data-cb-ops-pilot-config>
            <div>
                <div class="cb-admin-info-strip-title">Pilot config</div>
                <div class="cb-admin-info-strip-text" data-cb-ops-pilot-config-summary>
                    AutoManageAdoptedPositions=@pilotConfig.AutoManageAdoptedPositions · Dispatch=@pilotConfig.ExecutionDispatchMode · Symbols @pilotConfig.AllowedSymbolCount (@pilotConfig.AllowedSymbolsSummary)
                </div>
                <div class="cb-admin-info-strip-text mt-2" data-cb-ops-pilot-config-scope>
                    Allowed bot ids @pilotConfig.AllowedBotIdCount · Allowed user ids @pilotConfig.AllowedUserIdCount · Allowed exchange accounts @(pilotConfig.AllowedExchangeAccountIdCount?.ToString() ?? "n/a")
                </div>
            </div>
            <span class="cb-admin-info-strip-meta">Effective</span>
        </div>

        <div class="cb-admin-info-strip cb-admin-info-strip-info mt-4" data-cb-ops-private-sync>
            <div>
                <div class="cb-admin-info-strip-title">Private sync</div>
                <div class="cb-admin-info-strip-text" data-cb-ops-private-sync-summary>
                    State=@privateSync.State · Plane=@privateSync.Plane · Stream=@privateSync.PrivateStreamConnectionState · Drift=@privateSync.DriftStatus · AgeSec=@(privateSync.SyncAgeSeconds?.ToString() ?? "n/a")
                </div>
                <div class="cb-admin-info-strip-text mt-2" data-cb-ops-private-sync-drift>
                    Balance mismatches @((privateSync.BalanceMismatches?.ToString() ?? "n/a")) · Position mismatches @((privateSync.PositionMismatches?.ToString() ?? "n/a")) · Snapshot source @privateSync.SnapshotSource
                </div>
                <div class="cb-admin-info-strip-text mt-2" data-cb-ops-private-sync-timestamps>
                    Last balance sync @(privateSync.LastBalanceSyncedAtUtc?.ToUniversalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "n/a") · Last position sync @(privateSync.LastPositionSyncedAtUtc?.ToUniversalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "n/a") · Reconciled @(privateSync.LastStateReconciledAtUtc?.ToUniversalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "n/a")
                </div>
                <div class="cb-admin-info-strip-text mt-2" data-cb-ops-private-sync-health>
                    Drift summary @privateSync.DriftSummary · Last drift @(privateSync.LastDriftDetectedAtUtc?.ToUniversalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "n/a") · Consecutive failures @privateSync.ConsecutiveStreamFailureCount · Last error @(privateSync.LastErrorCode ?? "none")
                </div>
                <div class="cb-admin-info-strip-text mt-2" data-cb-ops-private-sync-safety>
                    Updated @(privateSync.UpdatedDate?.ToUniversalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "n/a") · Inactive blocked credential accounts @privateSync.InactiveBlockedCredentialAccountCount · PrivatePlaneStale rejects @privateSync.PrivatePlaneStaleRejectCount
                </div>
            </div>
            <span class="cb-admin-info-strip-meta">Futures</span>
        </div>

        <div class="cb-admin-info-strip cb-admin-info-strip-info mt-4" data-cb-ops-scanner-summary>
            <div>
                <div class="cb-admin-info-strip-title">Scanner + handoff</div>
                <div class="cb-admin-info-strip-text">
                    <span data-cb-ops-last-scanner-cycle>@(operational.LastScannerCycleCompletedAtUtc?.ToUniversalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "n/a")</span>
                    <span> · eligible </span>
                    <span data-cb-ops-eligible-count>@operational.EligibleCandidateCount</span>
                    <span> · top </span>
                    <span data-cb-ops-top-candidate>@(operational.TopCandidateSymbol ?? "n/a")</span>
                </div>
                <div class="cb-admin-info-strip-text mt-2" data-cb-ops-last-scanner-summary>@SanitizeOperationalSummary(operational.LastScannerCycleSummary)</div>
                <div class="cb-admin-info-strip-text mt-2" data-cb-ops-latest-handoff-summary>@SanitizeOperationalSummary(operational.LatestHandoffSummary)</div>
            </div>
            <span class="cb-admin-info-strip-meta">Latest cycle</span>
        </div>

        <div class="cb-admin-info-strip cb-admin-info-strip-info mt-4" data-cb-ops-exit-pnl-guard data-cb-admin-exit-pnl-evidence>
            <div>
                <div class="cb-admin-info-strip-title">Exit PnL Guard</div>
                <div class="cb-admin-info-strip-text" data-cb-admin-exit-pnl-evidence-fields>
                    Last exit summary · ExitSource · ExitPolicyDecision · ExitPolicyReason · PnL
                </div>
                @if (!exitPnl.LastExitAtUtc.HasValue)
                {
                    <div class="cb-admin-info-strip-text mt-2" data-cb-ops-exit-pnl-empty>
                        Last exit summary n/a · No exit evidence in bounded window.
                    </div>
                }
                else
                {
                    <div class="cb-admin-info-strip-text" data-cb-ops-exit-pnl-latest>
                        Last exit reason @((exitPnl.LastExitReason ?? "n/a")) · @(exitPnl.LastExitSymbol ?? "n/a") · @((exitPnl.LastExitSide ?? "n/a")) · @(exitPnl.LastExitAtUtc.Value.ToUniversalTime().ToString("yyyy-MM-dd HH:mm:ss")) UTC
                    </div>
                    <div class="cb-admin-info-strip-text mt-2" data-cb-ops-exit-pnl-last-summary>
                        Last exit summary @exitPnl.LastExitSummary
                    </div>
                    <div class="cb-admin-info-strip-text mt-2" data-cb-ops-exit-pnl-latest-summary>
                        ExitSource @((exitPnl.LastExitReason ?? "n/a")) · ExitPolicyDecision n/a · ExitPolicyReason n/a · Last estimated PnL @(exitPnl.LastEstimatedPnlQuote?.ToString("0.########") ?? "n/a") · PnL pct @(exitPnl.LastEstimatedPnlPct?.ToString("0.########") ?? "n/a") · Reduce-only exits @((exitPnl.LastExitReduceOnly?.ToString() ?? "n/a"))
                    </div>
                    @if (!string.IsNullOrWhiteSpace(exitPnl.LastBlockedExitSummary))
                    {
                        <div class="cb-admin-info-strip-text mt-2" data-cb-ops-exit-pnl-blocked-summary>
                            Last blocked exit @exitPnl.LastBlockedExitSummary
                        </div>
                    }
                    <div class="cb-admin-info-strip-text mt-2" data-cb-ops-exit-pnl-counts>
                        Exit decisions @exitPnl.LastExitCount · profitable @exitPnl.ProfitableExitCount · reverse blocked @exitPnl.ReverseBlockedUnprofitableCount · take-profit @exitPnl.TakeProfitExitCount · stop-loss @exitPnl.StopLossExitCount · trailing @exitPnl.TrailingExitCount · manual @exitPnl.ManualCloseCount
                    </div>
                }
            </div>
            <span class="cb-admin-info-strip-meta">Last 24h</span>
        </div>

        <div class="row mt-4">
            <div class="col-xl-6">
                <div class="cb-admin-info-strip cb-admin-info-strip-info" data-cb-ops-exit-orders data-cb-admin-recent-exit-orders>
                    <div>
                        <div class="cb-admin-info-strip-title">Recent exit orders</div>
                        <div class="cb-admin-info-strip-text">ExitSource · ExitPolicyDecision · ExitPolicyReason · PnL</div>
                        @if (recentExitOrders.Length == 0)
                        {
                            <div class="cb-admin-info-strip-text" data-cb-ops-exit-orders-empty>No recent exit order evidence in bounded window.</div>
                        }
                        else
                        {
                            foreach (var order in recentExitOrders)
                            {
                                <div class="cb-admin-info-strip-text mt-1" data-cb-ops-exit-order-row>
                                    @order.ObservedAtUtc.ToUniversalTime().ToString("yyyy-MM-dd HH:mm:ss") UTC · @order.Symbol · @order.SourceLabel · @order.PolicyDecision · @order.PolicyReason · pnl @(order.EstimatedPnlQuote?.ToString("0.########") ?? "n/a") / @(order.EstimatedPnlPct?.ToString("0.########") ?? "n/a") · @order.State
                                </div>
                            }
                        }
                    </div>
                    <span class="cb-admin-info-strip-meta">Last 5</span>
                </div>
            </div>
            <div class="col-xl-6">
                <div class="cb-admin-info-strip cb-admin-info-strip-info" data-cb-ops-entry-orders data-cb-admin-recent-entry-orders>
                    <div>
                        <div class="cb-admin-info-strip-title">Recent entry orders</div>
                        <div class="cb-admin-info-strip-text">EntrySource · Quantity · Price · State</div>
                        @if (recentEntryOrders.Length == 0)
                        {
                            <div class="cb-admin-info-strip-text" data-cb-ops-entry-orders-empty>No recent entry order evidence in bounded window.</div>
                        }
                        else
                        {
                            foreach (var order in recentEntryOrders)
                            {
                                <div class="cb-admin-info-strip-text mt-1" data-cb-ops-entry-order-row>
                                    @order.ObservedAtUtc.ToUniversalTime().ToString("yyyy-MM-dd HH:mm:ss") UTC · @order.Symbol · @order.SourceLabel · qty @order.Quantity.ToString("0.########") · price @(order.Price?.ToString("0.########") ?? "n/a") · @order.State
                                </div>
                            }
                        }
                    </div>
                    <span class="cb-admin-info-strip-meta">Last 5</span>
                </div>
            </div>
        </div>

        <div class="row mt-6">
            <div class="col-xl-6">
                <div class="cb-admin-info-strip cb-admin-info-strip-info" data-cb-ops-blocked-reasons>
                    <div>
                        <div class="cb-admin-info-strip-title">Latest blocked handoff reasons</div>
                        @if (blockedReasons.Length == 0)
                        {
                            <div class="cb-admin-info-strip-text" data-cb-ops-blocked-empty>No recent blocked handoff in bounded window.</div>
                        }
                        else
                        {
                            foreach (var reason in blockedReasons)
                            {
                                <div class="cb-admin-info-strip-text mt-1" data-cb-ops-blocked-reason>@reason.ReasonCode · @reason.Count</div>
                            }
                        }
                    </div>
                    <span class="cb-admin-info-strip-meta">Last 50</span>
                </div>
            </div>
            <div class="col-xl-6">
                <div class="cb-admin-info-strip cb-admin-info-strip-info" data-cb-ops-no-submit-reasons>
                    <div>
                        <div class="cb-admin-info-strip-title">Recent no-submit reasons</div>
                        @if (noSubmitReasons.Length == 0)
                        {
                            <div class="cb-admin-info-strip-text" data-cb-ops-no-submit-empty>No recent no-submit reason in bounded window.</div>
                        }
                        else
                        {
                            foreach (var reason in noSubmitReasons)
                            {
                                <div class="cb-admin-info-strip-text mt-1" data-cb-ops-no-submit-reason>@reason.ReasonCode · @reason.Count</div>
                            }
                        }
                    </div>
                    <span class="cb-admin-info-strip-meta">Last 200</span>
                </div>
            </div>
        </div>

        <div class="cb-admin-info-strip cb-admin-info-strip-info mt-4" data-cb-admin-failure-distribution>
            <div>
                <div class="cb-admin-info-strip-title">Recent order failures</div>
                @if (executionControl.FailureReasons.Count == 0)
                {
                    <div class="cb-admin-info-strip-text" data-cb-admin-failure-distribution-empty>No recent failure code in bounded window.</div>
                }
                else
                {
                    foreach (var reason in executionControl.FailureReasons)
                    {
                        <div class="cb-admin-info-strip-text mt-1" data-cb-admin-failure-distribution-row>@reason.ReasonCode · @reason.Count</div>
                    }
                }
            </div>
            <span class="cb-admin-info-strip-meta">Last 50</span>
        </div>

        <div class="row mt-4">
            <div class="col-xl-6">
                <div class="cb-admin-summary-card" data-cb-ops-janitor-summary>
                    <span class="cb-admin-summary-label">Janitor heartbeat</span>
                    <strong>@operational.JanitorSummary</strong>
                    <small>Latest retention/export availability</small>
                </div>
            </div>
            <div class="col-xl-6">
                <div class="cb-admin-summary-card" data-cb-ops-export-summary>
                    <span class="cb-admin-summary-label">Export path</span>
                    <strong>@operational.ExportSummary</strong>
                    <small>Masked, bounded, admin controlled</small>
                </div>
            </div>
        </div>

        @if (criticalWarnings.Length == 0)
        {
            <div class="cb-admin-info-strip cb-admin-info-strip-info mt-6" data-cb-ops-warning-empty>
                <div>
                    <div class="cb-admin-info-strip-title">Critical warnings</div>
                    <div class="cb-admin-info-strip-text">No critical warnings in the current bounded snapshot.</div>
                </div>
                <span class="cb-admin-info-strip-meta">Clear</span>
            </div>
        }
        else
        {
            <div class="cb-admin-info-strip cb-admin-info-strip-warning mt-6" data-cb-ops-warning-list>
                <div>
                    <div class="cb-admin-info-strip-title">Critical warnings</div>
                    @foreach (var warning in criticalWarnings)
                    {
                        <div class="cb-admin-info-strip-text mt-1" data-cb-ops-warning-item>@warning.Code · @warning.Summary</div>
                    }
                </div>
                <span class="cb-admin-info-strip-meta">Actionable</span>
            </div>
        }
    </div>
</div>
