        </div>

        <div class="cb-admin-info-strip cb-admin-info-strip-info mt-6" data-cb-ops-worker-summary>
            <div>
                <div class="cb-admin-info-strip-title">Worker heartbeat</div>
                <div class="cb-admin-info-strip-text" data-cb-ops-worker-heartbeat-summary>@SanitizeOperationalSummary(operational.WorkerHeartbeatSummary)</div>
