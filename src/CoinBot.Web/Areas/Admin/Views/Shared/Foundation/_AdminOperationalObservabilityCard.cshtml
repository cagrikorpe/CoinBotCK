            </div>
            @await Html.PartialAsync("_AdminBadge", new AdminBadgeViewModel
            {
                Label = operational.OverallState,
                Tone = ResolveTone(operational.OverallState),
                IconText = "OP"
            })
        </div>

        <div class="cb-admin-worker-meta-grid mt-6">
            <div class="cb-admin-summary-card" data-cb-ops-system-health-state>
                <span class="cb-admin-summary-label">System health</span>
                <strong>@operational.SystemHealthState</strong>
                <small>@operational.SystemHealthSummary</small>
            </div>
            <div class="cb-admin-summary-card" data-cb-ops-execution-readiness>
                <span class="cb-admin-summary-label">Execution readiness</span>
                <strong>@operational.ExecutionReadiness.State</strong>
                <small>@operational.ExecutionReadiness.Summary</small>
            </div>
            <div class="cb-admin-summary-card" data-cb-ops-ai-coverage>
                <span class="cb-admin-summary-label">AI outcome coverage</span>
                <strong>@operational.AiShadowOutcomeCoveragePercent.ToString("0.##")%</strong>
                <small>@operational.AiShadowOutcomeCoverageSummary</small>
            </div>
            <div class="cb-admin-summary-card" data-cb-ops-log-system-state>
                <span class="cb-admin-summary-label">Log / disk health</span>
                <strong>@operational.LogSystemState</strong>
                <small data-cb-ops-disk-pressure-state>Disk pressure @operational.DiskPressureState</small>
