@using CoinBot.Application.Abstractions.Monitoring
@{
    var dashboard = ViewData["AdminMonitoringDashboardSnapshot"] as MonitoringDashboardSnapshot
        ?? MonitoringDashboardSnapshot.Empty(DateTime.UtcNow);
    var operational = dashboard.OperationalObservability ?? OperationalObservabilitySnapshot.Empty();
    var blockedReasons = operational.BlockedReasons
        .OrderByDescending(item => item.Count)
        .ThenBy(item => item.ReasonCode, StringComparer.Ordinal)
        .ToArray();
    var noSubmitReasons = operational.NoSubmitReasons
        .OrderByDescending(item => item.Count)
        .ThenBy(item => item.ReasonCode, StringComparer.Ordinal)
        .ToArray();
    var exitPnl = operational.ExitPnlEvidence ?? OperationalExitPnlEvidenceSnapshot.Empty();
    var recentEntryOrders = exitPnl.RecentEntryOrders.ToArray();
    var recentExitOrders = exitPnl.RecentExitOrders.ToArray();
    var pilotConfig = operational.PilotConfigEvidence ?? OperationalPilotConfigEvidenceSnapshot.Empty();
    var privateSync = operational.PrivateSyncEvidence ?? OperationalPrivateSyncEvidenceSnapshot.Empty();
    var executionControl = operational.ExecutionControl ?? OperationalExecutionControlSnapshot.Empty();
    var multiSymbol = operational.MultiSymbolStability ?? OperationalMultiSymbolStabilitySnapshot.Empty();
    var multiSymbolRuntimeRows = multiSymbol.SymbolRows.ToArray();
    var criticalWarnings = operational.CriticalWarnings
        .ToArray();

    string ResolveTone(string? state)
    {
        return state switch
        {
            "Healthy" or "Ready" => "healthy",
            "Warning" or "Watching" => "warning",
            "Degraded" or "Disabled" => "degraded",
            "Critical" or "Blocked" => "critical",
            _ => "info"
        };
    }

    string SanitizeOperationalSummary(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "n/a";
        }

        var sanitized = value
            .Replace("ExchangeAccountIds", "ExchangeAccounts", StringComparison.Ordinal)
            .Replace("ExchangeAccountId", "ExchangeAccount", StringComparison.Ordinal)
            .Replace("CorrelationId", "Trace", StringComparison.Ordinal)
            .Replace("ExecutionAttemptId", "ExecutionAttempt", StringComparison.Ordinal)
            .Replace("DecisionId", "Decision", StringComparison.Ordinal)
            .Replace("OwnerUserId", "User", StringComparison.Ordinal)
            .Replace("UserId", "User", StringComparison.Ordinal);

        sanitized = System.Text.RegularExpressions.Regex.Replace(
            sanitized,
            @"\b(ScanCycleId|CandidateId|BotId|HandoffAttemptId|StrategySignalId|CorrelationId|ExecutionAttemptId|DecisionId|OwnerUserId|UserId|ExchangeAccountId)=[^;|]+",
            match => match.Groups[1].Value switch
            {
                "ScanCycleId" => "ScanCycle=redacted",
                "CandidateId" => "Candidate=redacted",
                "BotId" => "Bot=redacted",
                "HandoffAttemptId" => "HandoffAttempt=redacted",
                "StrategySignalId" => "StrategySignal=redacted",
                "CorrelationId" => "Trace=redacted",
                "ExecutionAttemptId" => "ExecutionAttempt=redacted",
                "DecisionId" => "Decision=redacted",
                "OwnerUserId" => "User=redacted",
                "UserId" => "User=redacted",
                "ExchangeAccountId" => "ExchangeAccount=redacted",
                _ => "internal=redacted"
            },
            System.Text.RegularExpressions.RegexOptions.CultureInvariant);

        return sanitized;
    }
}

<div class="card card-custom gutter-b cb-card cb-admin-card cb-admin-panel-card" data-cb-operational-observability-card>
    <div class="card-body">
        <div class="cb-admin-panel-head">
            <div>
