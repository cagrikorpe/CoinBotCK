<div class="card card-custom gutter-b cb-card cb-admin-card">
    <div class="card-body">
        <div class="cb-admin-panel-head">
            <div>
                <div class="cb-admin-section-kicker">Bot Summary</div>
                <div class="cb-admin-section-title">Bot özeti</div>
            </div>
            @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = "5 aktif / 2 pasif", Tone = "info", IconText = "BT" })
        </div>
        <div class="cb-admin-summary-grid mt-5 cb-admin-user-summary-grid">
            <div class="cb-admin-summary-card">
                <span class="cb-admin-summary-label">Toplam bot</span>
                <strong>7</strong>
                <small>Kullanıcıya bağlı bot placeholder</small>
            </div>
            <div class="cb-admin-summary-card">
                <span class="cb-admin-summary-label">Paper / Live</span>
                <strong>4 / 3</strong>
                <small>Mini dağılım</small>
            </div>
            <div class="cb-admin-summary-card">
                <span class="cb-admin-summary-label">Sorunlu bot</span>
                <strong>1 dikkat</strong>
                <small>Runtime warning placeholder</small>
            </div>
        </div>
        <a asp-area="Admin" asp-controller="Admin" asp-action="BotOperations" class="btn btn-light-primary font-weight-bold mt-5">Bot operasyonlarına git</a>
    </div>
</div>
