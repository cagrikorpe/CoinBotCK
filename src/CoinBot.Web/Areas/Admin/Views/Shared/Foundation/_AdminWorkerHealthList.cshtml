@{
    var dashboard = ViewData["AdminMonitoringDashboardSnapshot"] as MonitoringDashboardSnapshot
        ?? MonitoringDashboardSnapshot.Empty(DateTime.UtcNow);
    var workers = dashboard.WorkerHeartbeats
        .OrderByDescending(worker => worker.FreshnessTier)
        .ThenBy(worker => worker.WorkerName, StringComparer.Ordinal)
        .ToArray();
}

<div class="card card-custom gutter-b cb-card cb-admin-card cb-admin-panel-card">
    <div class="card-body">
        <div class="cb-admin-panel-head">
            <div>
                <div class="cb-admin-section-kicker">Worker Health</div>
                <div class="cb-admin-section-title">Worker heartbeat read-model</div>
                <p class="cb-admin-section-description mb-0">Last heartbeat, freshness tier, circuit breaker state ve failure sayilari monitoring worker tarafindan read-model'e yazilir.</p>
            </div>
            @await Html.PartialAsync("_AdminBadge", new AdminBadgeViewModel { Label = $"{workers.Length} workers", Tone = "info", IconText = "WK" })
        </div>

        @if (workers.Length == 0)
        {
            <div class="cb-admin-info-strip cb-admin-info-strip-warning mt-6">
                <div>
                    <div class="cb-admin-info-strip-title">No worker snapshot yet</div>
                    <div class="cb-admin-info-strip-text">Monitoring worker henüz worker heartbeat read-model kaydi üretmedi. Background cycle tamamlandiginda liste burada görünür.</div>
                </div>
                <span class="cb-admin-info-strip-meta">Pending</span>
            </div>
        }
        else
        {
            <div class="cb-admin-worker-list mt-6">
                @foreach (var worker in workers)
                {
                    var healthTone = worker.HealthState switch
                    {
                        MonitoringHealthState.Healthy => "healthy",
                        MonitoringHealthState.Warning => "warning",
                        MonitoringHealthState.Degraded => "degraded",
                        MonitoringHealthState.Critical => "critical",
                        _ => "info"
                    };
                    var freshnessTone = worker.FreshnessTier switch
                    {
                        MonitoringFreshnessTier.Hot => "healthy",
                        MonitoringFreshnessTier.Warm => "info",
                        MonitoringFreshnessTier.Cold => "warning",
                        MonitoringFreshnessTier.Stale => "critical",
                        _ => "info"
                    };
                    var breakerTone = worker.CircuitBreakerState switch
                    {
                        CircuitBreakerStateCode.Closed => "healthy",
                        CircuitBreakerStateCode.Retrying => "warning",
                        CircuitBreakerStateCode.Cooldown => "degraded",
                        CircuitBreakerStateCode.HalfOpen => "warning",
                        CircuitBreakerStateCode.Degraded => "critical",
                        _ => "info"
                    };

                    <div class="cb-admin-worker-item">
                        <div class="cb-admin-worker-main">
                            <div class="cb-admin-worker-title-row">
                                <div>
                                    <div class="cb-admin-job-title">@worker.WorkerName</div>
                                    <div class="cb-admin-job-meta">@worker.WorkerKey</div>
                                </div>
                                <div class="cb-admin-badge-stack">
                                    @await Html.PartialAsync("_AdminBadge", new AdminBadgeViewModel { Label = worker.HealthState.ToString(), Tone = healthTone, IconText = "HS" })
                                    @await Html.PartialAsync("_AdminBadge", new AdminBadgeViewModel { Label = worker.FreshnessTier.ToString(), Tone = freshnessTone, IconText = "FR" })
                                    @await Html.PartialAsync("_AdminBadge", new AdminBadgeViewModel { Label = worker.CircuitBreakerState.ToString(), Tone = breakerTone, IconText = "CB" })
                                </div>
                            </div>

                            <div class="cb-admin-worker-meta-grid mt-4">
                                <div class="cb-admin-summary-card">
                                    <span class="cb-admin-summary-label">Last heartbeat</span>
                                    <strong class="cb-mono">@worker.LastHeartbeatAtUtc.ToUniversalTime().ToString("HH:mm:ss") UTC</strong>
                                    <small>@(worker.SnapshotAgeSeconds?.ToString() ?? "n/a") sn snapshot age</small>
                                </div>
                                <div class="cb-admin-summary-card">
                                    <span class="cb-admin-summary-label">Last updated</span>
                                    <strong class="cb-mono">@worker.LastUpdatedAtUtc.ToUniversalTime().ToString("HH:mm:ss") UTC</strong>
                                    <small>@worker.ConsecutiveFailureCount consecutive failures</small>
                                </div>
                                <div class="cb-admin-summary-card">
                                    <span class="cb-admin-summary-label">Error</span>
                                    <strong>@(worker.LastErrorCode ?? "none")</strong>
                                    <small>@(worker.LastErrorMessage ?? worker.Detail ?? "No error detail")</small>
                                </div>
                            </div>
                        </div>

                        <div class="cb-admin-worker-actions">
                            <button type="button" class="btn btn-xs btn-light-primary font-weight-bold" data-cb-drawer-target="#cb_admin_worker_drawer">Detay</button>
                            <button type="button" class="btn btn-xs btn-light-warning font-weight-bold" data-toggle="modal" data-target="#cb_admin_job_retry_modal" data-cb-modal-title="Retry / recheck" data-cb-modal-message="Worker heartbeat snapshot read-only gösterilir; gerçek retry aksiyonu bu fazda devrede değildir." data-cb-modal-confirm="Retry başlat">Retry</button>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
