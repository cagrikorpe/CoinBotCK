<div class="card card-custom gutter-b cb-card cb-admin-card cb-admin-panel-card">
    <div class="card-body">
        <div class="cb-admin-panel-head">
            <div>
                <div class="cb-admin-section-kicker">Explainability</div>
                <div class="cb-admin-section-title">Recommendation açıklaması</div>
            </div>
            @await Html.PartialAsync("_AdminBadge", new AdminBadgeViewModel { Label = "Explainable", Tone = "info", IconText = "XP" })
        </div>

        <div class="cb-admin-profile-list mt-6">
            <div class="cb-admin-profile-row"><span>Recommendation summary</span><strong>BTCUSDT · Long watch / assisted</strong></div>
            <div class="cb-admin-profile-row"><span>Neden önerdi?</span><strong>Trend, momentum ve hacim sinyalleri uyum sağladı</strong></div>
            <div class="cb-admin-profile-row"><span>Neden veto edildi?</span><strong>Risk bandı ve confidence eşiği uygun değildi</strong></div>
        </div>

        <div class="cb-admin-chip-list mt-6">
            <span class="cb-admin-filter-chip">Trend güçlü</span>
            <span class="cb-admin-filter-chip">Momentum uygun</span>
            <span class="cb-admin-filter-chip">Hacim desteği</span>
            <span class="cb-admin-filter-chip">Risk guard</span>
            <span class="cb-admin-filter-chip">Soft veto</span>
        </div>

        <div class="cb-admin-info-strip cb-admin-info-strip-info mt-6">
            <div>
                <div class="cb-admin-info-strip-title">Explainability notu</div>
                <div class="cb-admin-info-strip-text">Operasyonel neden-sonuç bağlamı, audit ve trace ekranlarıyla birlikte okunur.</div>
            </div>
            <span class="cb-admin-info-strip-meta">Sample</span>
        </div>

        <div class="cb-admin-inline-actions mt-6">
            <a asp-area="Admin" asp-controller="Admin" asp-action="Audit" class="btn btn-light-primary font-weight-bold">Loglara git</a>
            <a asp-area="Admin" asp-controller="Admin" asp-action="StrategyAiMonitoring" class="btn btn-light-primary font-weight-bold">Strategy / AI</a>
        </div>
    </div>
</div>
