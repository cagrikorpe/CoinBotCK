@using CoinBot.Application.Abstractions.Administration
@{
    var snapshot = ViewData["AdminStrategyAiMonitoringPageSnapshot"] as AdminStrategyAiMonitoringPageSnapshot
        ?? AdminStrategyAiMonitoringPageSnapshot.Empty(DateTime.UtcNow);
    var explainability = snapshot.LatestExplainability;
}

<div class="card card-custom gutter-b cb-card cb-admin-card cb-admin-panel-card" data-cb-strategy-explainability-card>
    <div class="card-body">
        <div class="cb-admin-panel-head">
            <div>
                <div class="cb-admin-section-kicker">Explainability</div>
                <div class="cb-admin-section-title">Recommendation açıklaması</div>
            </div>
            @await Html.PartialAsync("_AdminBadge", new AdminBadgeViewModel { Label = explainability.Outcome, Tone = explainability.Outcome.StartsWith("Vetoed", StringComparison.OrdinalIgnoreCase) ? "warning" : "info", IconText = "XP" })
        </div>

        <div class="cb-admin-profile-list mt-6">
            <div class="cb-admin-profile-row"><span>Recommendation summary</span><strong data-cb-strategy-explainability-summary>@explainability.Symbol · @explainability.Timeframe · @explainability.ScoreLabel</strong></div>
            <div class="cb-admin-profile-row"><span>Strategy / Template</span><strong data-cb-strategy-explainability-template>@explainability.StrategyKey · @explainability.TemplateName · @(explainability.TemplateRevisionLabel ?? "r?")</strong></div>
            <div class="cb-admin-profile-row"><span>Runtime version</span><strong data-cb-strategy-explainability-version>@(explainability.VersionLabel ?? "Inactive")</strong></div>
            <div class="cb-admin-profile-row"><span>Neden geçti / kalmadı</span><strong data-cb-strategy-explainability-reason>@explainability.Summary</strong></div>
        </div>

        <div class="cb-admin-info-strip cb-admin-info-strip-info mt-6">
            <div>
                <div class="cb-admin-info-strip-title">Rule-level snapshot</div>
                <div class="cb-admin-info-strip-text" data-cb-strategy-explainability-rules>@explainability.RuleSummary</div>
            </div>
            <span class="cb-admin-info-strip-meta cb-mono" data-cb-strategy-explainability-at>@(explainability.EvaluatedAtUtc?.ToUniversalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "No evaluation")</span>
        </div>

        <div class="cb-admin-inline-actions mt-6">
            <a asp-area="Admin" asp-controller="Admin" asp-action="Audit" class="btn btn-light-primary font-weight-bold">Loglara git</a>
            <a asp-area="Admin" asp-controller="Admin" asp-action="StrategyAiMonitoring" class="btn btn-light-primary font-weight-bold">Strategy / AI</a>
        </div>
    </div>
</div>
