@using CoinBot.Application.Abstractions.Administration
@{
    var snapshot = ViewData["AdminNotificationsPageSnapshot"] as AdminNotificationsPageSnapshot;
    var alerts = snapshot?.Alerts ?? Array.Empty<AdminNotificationSnapshot>();
}

<div class="card card-custom gutter-b cb-card cb-admin-card cb-admin-table-card">
    <div class="card-body">
        <div class="cb-admin-table-header">
            <div>
                <div class="cb-admin-section-kicker">Alert Feed</div>
                <div class="cb-admin-section-title">Platform alarm listesi</div>
                <p class="cb-admin-section-description mb-0">Severity, kategori ve state alanları gerçek notification snapshot verisiyle okunur.</p>
            </div>
            <div class="cb-admin-inline-actions cb-admin-inline-actions-compact">
                @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = snapshot is null ? "Veri yok" : $"{alerts.Count} alert", Tone = "warning", IconText = "UN" })
            </div>
        </div>

        <div class="table-responsive cb-admin-table-wrap">
            <table class="table table-borderless cb-admin-table cb-admin-alert-table mb-0">
                <thead>
                    <tr>
                        <th>Başlık</th>
                        <th>Severity</th>
                        <th>Kategori</th>
                        <th>Source</th>
                        <th>Zaman</th>
                        <th>State</th>
                        <th>Kısa özet</th>
                        <th>Detay</th>
                    </tr>
                </thead>
                <tbody>
                    @if (alerts.Count == 0)
                    {
                        <tr>
                            <td colspan="8">
                                @await Html.PartialAsync("Foundation/_AdminEmptyState", new UiStateViewModel
                                {
                                    Title = "Aktif alarm yok",
                                    Message = "Bu filtre kombinasyonu için notification bulunamadı.",
                                    IconText = "AL",
                                    ActionText = "Genel bakış",
                                    ActionHref = Url.Action("Overview", "Admin", new { area = "Admin" }),
                                    SecondaryActionText = "System health",
                                    SecondaryActionHref = Url.Action("SystemHealth", "Admin", new { area = "Admin" })
                                })
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var alarm in alerts)
                        {
                            <tr>
                                <td>
                                    <div class="cb-admin-mini-stat">
                                        <strong>@alarm.Title</strong>
                                        <small>@alarm.Scope</small>
                                    </div>
                                </td>
                                <td>@await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = alarm.Severity, Tone = alarm.SeverityTone, IconText = "SV" })</td>
                                <td>@await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = alarm.Category, Tone = alarm.CategoryTone, IconText = "CT" })</td>
                                <td><span class="cb-admin-freshness-time cb-mono">@alarm.Source</span></td>
                                <td><span class="cb-admin-freshness-time cb-mono">@alarm.TimestampUtc.ToString("yyyy-MM-dd HH:mm:ss") UTC</span></td>
                                <td>@await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = alarm.StateLabel, Tone = alarm.StateTone, IconText = "RD" })</td>
                                <td class="text-muted">@alarm.Summary</td>
                                <td>
                                    <div class="cb-admin-inline-actions cb-admin-inline-actions-compact">
                                        <a asp-area="Admin" asp-controller="Admin" asp-action="Audit" asp-route-query="@alarm.Title" class="btn btn-xs btn-light-primary font-weight-bold">Audit</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
