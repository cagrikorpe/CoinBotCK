@using CoinBot.Application.Abstractions.Administration
@using CoinBot.Contracts.Common
@{
    var snapshot = ViewData["AdminBotOperationsPageSnapshot"] as AdminBotOperationsPageSnapshot;
    var bots = snapshot?.Bots ?? Array.Empty<AdminBotOperationSnapshot>();
    var canManageManualClose = Context.User.HasClaim(ApplicationClaimTypes.Permission, ApplicationPermissions.PlatformAdministration);
}

<div class="card card-custom gutter-b cb-card cb-admin-card cb-admin-table-card">
    <div class="card-body">
        <div class="cb-admin-table-header">
            <div>
                <div class="cb-admin-section-kicker">Bot Grid</div>
                <div class="cb-admin-section-title">Global bot monitoring listesi</div>
                <p class="cb-admin-section-description mb-0">Bot, kullanıcı, strategy, risk ve son operasyon sinyali gerçek snapshot verisinden okunur.</p>
            </div>
            @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = snapshot is null ? "Veri yok" : $"{bots.Count} bot", Tone = snapshot is null ? "neutral" : "info", IconText = "TB" })
        </div>

        <div class="table-responsive cb-admin-table-wrap">
            <table class="table table-borderless cb-admin-table cb-admin-bot-table mb-0">
                <thead>
                    <tr>
                        <th>Bot</th>
                        <th>Kullanıcı</th>
                        <th>Durum</th>
                        <th>Mode</th>
                        <th>Strategy</th>
                        <th>Risk</th>
                        <th>Son hata</th>
                        <th>Aksiyon</th>
                    </tr>
                </thead>
                <tbody>
                    @if (bots.Count == 0)
                    {
                        <tr>
                            <td colspan="8">
                                @await Html.PartialAsync("Foundation/_AdminEmptyState", new UiStateViewModel
                                {
                                    Title = "Bot bulunamadı",
                                    Message = "Filtre ile eşleşen bot yok.",
                                    IconText = "BT",
                                    ActionText = "Filtreyi temizle",
                                    ActionHref = Url.Action("BotOperations", "Admin", new { area = "Admin" }),
                                    SecondaryActionText = "Exchange hesapları",
                                    SecondaryActionHref = Url.Action("ExchangeAccounts", "Admin", new { area = "Admin" })
                                })
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var row in bots)
                        {
                            var lastErrorPreview = row.LastError.Length > 220
                                ? $"{row.LastError[..220]}..."
                                : row.LastError;
                            var showManualCloseSurface = canManageManualClose &&
                                                         (!string.IsNullOrWhiteSpace(row.ManualCloseSymbol) ||
                                                          !string.IsNullOrWhiteSpace(row.ManualClosePreviewUnavailableReason));
                            <tr>
                                <td>
                                    <div class="cb-admin-user-cell">
                                        <span class="cb-admin-user-avatar">@row.Name.Substring(0, 1)</span>
                                        <div>
                                            <div class="cb-admin-user-name">@row.Name</div>
                                            <div class="cb-admin-user-meta">@row.BotId</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="cb-admin-mini-stat">
                                        <strong>@row.OwnerDisplayName</strong>
                                        <small>@row.OwnerUserId</small>
                                    </div>
                                </td>
                                <td>@await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = row.StatusLabel, Tone = row.StatusTone, IconText = "ST" })</td>
                                <td>@await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = row.ModeLabel, Tone = row.ModeTone, IconText = "MD" })</td>
                                <td><div class="cb-admin-mini-stat"><strong>@row.StrategyKey</strong><small>Strategy key</small></div></td>
                                <td>
                                    @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = row.RiskLabel, Tone = row.RiskTone, IconText = "RK" })
                                    @if (!string.IsNullOrWhiteSpace(row.PositionAdoption) &&
                                         !string.Equals(row.PositionAdoption, "Skipped", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <div class="cb-admin-mini-stat mt-2" data-cb-admin-position-adoption>
                                            <strong>@row.PositionAdoption</strong>
                                            <small>@row.AdoptedPositionSymbol | @row.AdoptedPositionQuantity | @row.AdoptedPositionSide</small>
                                            <small>@row.AdoptionReason</small>
                                        </div>
                                    }
                                </td>
                                <td>
                                    <div class="cb-admin-mini-stat cb-admin-bot-last-error" data-cb-admin-bot-last-error title="@row.LastError">
                                        <strong>@lastErrorPreview</strong>
                                        <small>@row.LastAction</small>
                                    </div>
                                </td>
                                <td>
                                    <div class="cb-admin-inline-actions cb-admin-inline-actions-compact">
                                        <a asp-area="Admin" asp-controller="Admin" asp-action="UserDetail" asp-route-id="@row.OwnerUserId" class="btn btn-xs btn-light-primary font-weight-bold">Kullanıcı</a>
                                        <a asp-area="Admin" asp-controller="Admin" asp-action="Audit" asp-route-query="@row.Name" class="btn btn-xs btn-light-primary font-weight-bold">Audit</a>
                                        @if (showManualCloseSurface)
                                        {
                                            <details class="cb-admin-manual-close-panel" data-cb-admin-manual-close-panel>
                                                <summary class="btn btn-xs btn-light-danger font-weight-bold" data-cb-admin-manual-close-button>Close Position</summary>
                                                @if (!string.IsNullOrWhiteSpace(row.ManualCloseSymbol))
                                                {
                                                    <div class="cb-admin-mini-stat mt-3" data-cb-admin-manual-close-preview>
                                                        <strong>@row.ManualCloseSymbol</strong>
                                                        <small>Position @row.ManualClosePositionQuantityLabel | @row.ManualClosePositionDirectionLabel | Close @row.ManualCloseSideLabel</small>
                                                        <small>ReduceOnly=True | Environment=@row.ManualCloseEnvironmentLabel</small>
                                                    </div>
                                                }
                                                @if (row.CanManualClose)
                                                {
                                                    <form asp-area="Admin" asp-controller="Admin" asp-action="ManualCloseBotPosition" method="post" class="mt-3" data-cb-admin-manual-close-form data-cb-reauth-required="true">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="botId" value="@row.BotId" />
                                                        <input type="hidden" name="exchangeAccountId" value="@row.ManualCloseExchangeAccountId" />
                                                        <input type="hidden" name="symbol" value="@row.ManualCloseSymbol" />
                                                        <button type="submit" class="btn btn-xs btn-danger font-weight-bold" data-cb-admin-manual-close-confirm>Confirm Reduce-Only Close</button>
                                                    </form>
                                                }
                                                else
                                                {
                                                    <div class="cb-admin-mini-stat mt-3" data-cb-admin-manual-close-unavailable>
                                                        <strong>Close unavailable</strong>
                                                        <small>Active BinanceTestnet futures position and writable credential are required.</small>
                                                        @if (!string.IsNullOrWhiteSpace(row.ManualClosePreviewUnavailableReason))
                                                        {
                                                            <small data-cb-admin-manual-close-unavailable-reason>@row.ManualClosePreviewUnavailableReason</small>
                                                        }
                                                    </div>
                                                }
                                            </details>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
