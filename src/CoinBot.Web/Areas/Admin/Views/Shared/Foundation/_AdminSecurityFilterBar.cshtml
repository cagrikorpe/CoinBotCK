@using CoinBot.Application.Abstractions.Administration
@{
    var snapshot = ViewData["AdminSecurityEventsPageSnapshot"] as AdminSecurityEventsPageSnapshot;
    var query = snapshot?.Query ?? string.Empty;
    var severity = snapshot?.SeverityFilter ?? string.Empty;
    var module = snapshot?.ModuleFilter ?? string.Empty;
}

<div class="card card-custom gutter-b cb-card cb-admin-card">
    <div class="card-body">
        <div class="cb-admin-panel-head">
            <div>
                <div class="cb-admin-section-kicker">Security Filters</div>
                <div class="cb-admin-section-title">Güvenlik filtre toolbar</div>
                <p class="cb-admin-section-description mb-0">Event tipi, severity ve modül filtreleri gerçek security snapshot ile çalışır.</p>
            </div>
            <a asp-area="Admin" asp-controller="Admin" asp-action="Audit" class="btn btn-light-primary font-weight-bold">Audit merkezi</a>
        </div>

        <form asp-area="Admin" asp-controller="Admin" asp-action="SecurityEvents" method="get" class="cb-filter-bar cb-admin-filter-bar cb-admin-security-filter-bar mt-6">
            <div class="cb-filter-field">
                <label class="cb-form-label">Text search</label>
                <input type="text" name="query" value="@query" class="form-control cb-form-control" aria-label="event, actor veya modül" />
            </div>
            <div class="cb-filter-field">
                <label class="cb-form-label">Severity</label>
                <select name="severity" class="form-control cb-form-control">
                    <option value="">Tüm seviyeler</option>
                    @if (string.Equals(severity, "Critical", StringComparison.OrdinalIgnoreCase))
                    {
                        <option value="Critical" selected="selected">Critical</option>
                    }
                    else
                    {
                        <option value="Critical">Critical</option>
                    }
                    @if (string.Equals(severity, "Warning", StringComparison.OrdinalIgnoreCase))
                    {
                        <option value="Warning" selected="selected">Warning</option>
                    }
                    else
                    {
                        <option value="Warning">Warning</option>
                    }
                    @if (string.Equals(severity, "Info", StringComparison.OrdinalIgnoreCase))
                    {
                        <option value="Info" selected="selected">Info</option>
                    }
                    else
                    {
                        <option value="Info">Info</option>
                    }
                </select>
            </div>
            <div class="cb-filter-field">
                <label class="cb-form-label">Modül</label>
                <input type="text" name="module" value="@module" class="form-control cb-form-control" aria-label="Admin Auth / Exchange / Settings" />
            </div>
            <div class="cb-filter-field cb-filter-actions cb-admin-user-filter-actions">
                <a asp-area="Admin" asp-controller="Admin" asp-action="SecurityEvents" class="btn btn-light-primary font-weight-bold">Temizle</a>
                <button type="submit" class="btn btn-primary font-weight-bolder">Uygula</button>
            </div>
        </form>

        <div class="cb-admin-filter-summary mt-5">
            <div class="cb-admin-filter-summary-copy">
                <strong>Aktif filtre özeti</strong>
                <span>@(string.IsNullOrWhiteSpace(query) ? "Tümü" : query) · @(string.IsNullOrWhiteSpace(severity) ? "All severities" : severity) · @(string.IsNullOrWhiteSpace(module) ? "All modules" : module)</span>
            </div>
            <div class="cb-admin-filter-chip-list">
                @if (!string.IsNullOrWhiteSpace(severity))
                {
                    <span class="cb-admin-filter-chip">@severity</span>
                }
                @if (!string.IsNullOrWhiteSpace(module))
                {
                    <span class="cb-admin-filter-chip">@module</span>
                }
            </div>
        </div>
    </div>
</div>
