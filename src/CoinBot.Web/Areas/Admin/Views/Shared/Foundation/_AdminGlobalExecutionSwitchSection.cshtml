@model CoinBot.Application.Abstractions.Execution.GlobalExecutionSwitchSnapshot
@{
    var canEditGlobalPolicy = ViewData["AdminCanEditGlobalPolicy"] is bool canEditValue && canEditValue;
    var pilotOrderNotionalSummary = ViewData["AdminPilotOrderNotionalSummary"] as string ?? "Missing";
    var pilotOrderNotionalTone = ViewData["AdminPilotOrderNotionalTone"] as string ?? "critical";
}

<section id="cb_admin_settings_execution" class="card card-custom gutter-b cb-card cb-admin-card cb-admin-settings-section">
    <div class="card-body">
        <div class="cb-admin-section-kicker">Execution Hard Gate</div>
        <div class="d-flex flex-wrap align-items-start justify-content-between gap-4">
            <div>
                <div class="cb-admin-section-title">TradeMaster + DemoMode backend gate</div>
                <p class="cb-admin-section-description">Bu iki switch UI flag degil; tum execution isteklerinden once zorunlu calisan gerçek backend hard gate'i belirler.</p>
            </div>
            @await Html.PartialAsync("_AdminBadge", new AdminBadgeViewModel
            {
                Label = Model.IsPersisted ? "Persisted" : "Fail-closed",
                Tone = Model.IsPersisted ? "healthy" : "critical",
                IconText = Model.IsPersisted ? "OK" : "FC"
            })
        </div>

        <div class="cb-admin-info-strip cb-admin-info-strip-warning mt-6">
            <div>
                <div class="cb-admin-info-strip-title">Runtime davranisi</div>
                <div class="cb-admin-info-strip-text">TradeMaster kapaliysa tum emir akisi durur. DemoMode acikken live execution yolu, user veya bot override olsa bile fail-closed kapanir.</div>
            </div>
            <span class="cb-admin-info-strip-meta">Hard Gate</span>
        </div>

        <div class="cb-admin-settings-switch-grid mt-6">
            <div class="cb-admin-summary-card">
                <span class="cb-admin-summary-label">TradeMaster</span>
                <strong>@(Model.IsTradeMasterArmed ? "Armed" : "Disarmed")</strong>
                <small>Kapali oldugunda execution zinciri gate asamasinda kesilir.</small>
                <div class="cb-admin-page-meta mt-4">
                    @await Html.PartialAsync("_AdminBadge", new AdminBadgeViewModel
                    {
                        Label = Model.IsTradeMasterArmed ? "Armed" : "Disarmed",
                        Tone = Model.IsTradeMasterArmed ? "healthy" : "critical",
                        IconText = "TM"
                    })
                </div>
                @if (canEditGlobalPolicy)
                {
                    <form asp-area="Admin" asp-controller="Admin" asp-action="SetTradeMasterState" method="post" class="mt-5" data-cb-reauth-required="true">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="isArmed" value="@(!Model.IsTradeMasterArmed)" />
                        <input type="hidden" name="commandId" value="@(Guid.NewGuid().ToString("N"))" />
                        <div class="form-group mb-0">
                            <label class="cb-form-label">Audit reason</label>
                            <input name="reason" type="text" class="form-control cb-form-control" maxlength="256" required placeholder="TradeMaster degisikligi nedeni" />
                        </div>
                        <div class="form-group mt-4 mb-0">
                            <label class="cb-form-label">Onay ibaresi</label>
                            <input name="reauthToken" type="text" class="form-control cb-form-control" maxlength="64" required placeholder="ONAYLA" />
                        </div>
                        <button type="submit" class="btn @(Model.IsTradeMasterArmed ? "btn-light-danger" : "btn-light-primary") font-weight-bold mt-5">
                            @(Model.IsTradeMasterArmed ? "Disarm TradeMaster" : "Arm TradeMaster")
                        </button>
                    </form>
                }
                else
                {
                    <div class="cb-admin-info-strip cb-admin-info-strip-info mt-5">
                        <div>
                            <div class="cb-admin-info-strip-title">Read-only switch visibility</div>
                            <div class="cb-admin-info-strip-text">TradeMaster switch degeri gorulebilir ancak bu rolde degistirilemez.</div>
                        </div>
                        <span class="cb-admin-info-strip-meta">Read-only</span>
                    </div>
                }
            </div>

            <div class="cb-admin-summary-card">
                <span class="cb-admin-summary-label">DemoMode</span>
                <strong>@(Model.DemoModeEnabled ? "Enabled" : "Disabled")</strong>
                <small>Enabled oldugunda live execution yolu global olarak kapanir.</small>
                <div class="cb-admin-page-meta mt-4">
                    @await Html.PartialAsync("_AdminBadge", new AdminBadgeViewModel
                    {
                        Label = Model.DemoModeEnabled ? "Demo only" : "Live allowed",
                        Tone = Model.DemoModeEnabled ? "warning" : "critical",
                        IconText = "DM"
                    })
                </div>
                @if (Model.LiveModeApprovedAtUtc is DateTime approvedAtUtc)
                {
                    <div class="cb-helper-text mt-4">Son live approval: <strong>@approvedAtUtc.ToUniversalTime().ToString("yyyy-MM-dd HH:mm") UTC</strong></div>
                }
                @if (canEditGlobalPolicy)
                {
                    <form asp-area="Admin" asp-controller="Admin" asp-action="SetDemoMode" method="post" class="mt-5" data-cb-reauth-required="true">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="isEnabled" value="@(Model.DemoModeEnabled ? "false" : "true")" />
                        <input type="hidden" name="commandId" value="@(Guid.NewGuid().ToString("N"))" />
                        <div class="form-group mb-0">
                            <label class="cb-form-label">Audit reason</label>
                            <input name="reason" type="text" class="form-control cb-form-control" maxlength="256" required placeholder="DemoMode degisikligi nedeni" />
                        </div>
                        @if (Model.DemoModeEnabled)
                        {
                            <div class="form-group mt-4 mb-0">
                                <label class="cb-form-label">Live approval reference</label>
                                <input name="liveApprovalReference" type="text" class="form-control cb-form-control" maxlength="128" placeholder="change-ref-001" />
                            </div>
                        }
                        <div class="form-group mt-4 mb-0">
                            <label class="cb-form-label">Onay ibaresi</label>
                            <input name="reauthToken" type="text" class="form-control cb-form-control" maxlength="64" required placeholder="ONAYLA" />
                        </div>
                        <button type="submit" class="btn @(Model.DemoModeEnabled ? "btn-light-danger" : "btn-light-primary") font-weight-bold mt-5">
                            @(Model.DemoModeEnabled ? "Disable DemoMode" : "Enable DemoMode")
                        </button>
                    </form>
                }
                else
                {
                    <div class="cb-admin-info-strip cb-admin-info-strip-info mt-5">
                        <div>
                            <div class="cb-admin-info-strip-title">Read-only mode visibility</div>
                            <div class="cb-admin-info-strip-text">Demo/live izolasyon degeri bu rolde degistirilemez; yalnizca mevcut snapshot gosterilir.</div>
                        </div>
                        <span class="cb-admin-info-strip-meta">Read-only</span>
                    </div>
                }
            </div>
            <div class="cb-admin-summary-card">
                <span class="cb-admin-summary-label">Pilot hard cap</span>
                <strong>@pilotOrderNotionalSummary</strong>
                <small>Submit oncesi pilot notional ust siniri. Missing veya invalid oldugunda request fail-closed block olur.</small>
                <div class="cb-admin-page-meta mt-4">
                    @await Html.PartialAsync("_AdminBadge", new AdminBadgeViewModel
                    {
                        Label = pilotOrderNotionalTone == "healthy" ? "Bound" : "Blocked",
                        Tone = pilotOrderNotionalTone,
                        IconText = "HC"
                    })
                </div>
            </div>
        </div>
    </div>
</section>
