@using CoinBot.Application.Abstractions.Administration
@{
    var retention = ViewData["AdminLogCenterRetentionSnapshot"] as LogCenterRetentionSnapshot;
    var retentionEnabled = retention?.Enabled;
    var retentionTone = retentionEnabled is null ? "info" : retentionEnabled.Value ? "healthy" : "critical";
    var retentionLabel = retentionEnabled is null ? "Unknown" : retentionEnabled.Value ? "Enabled" : "Disabled";
    var lastRunText = retention?.LastRunAtUtc is null
        ? "n/a"
        : retention.LastRunAtUtc.Value.ToUniversalTime().ToString("yyyy-MM-dd HH:mm:ss") + " UTC";
}
<section id="cb_admin_settings_logging" class="card card-custom gutter-b cb-card cb-admin-card cb-admin-settings-section">
    <div class="card-body">
        <div class="cb-admin-section-kicker">Logging &amp; Retention</div>
        <div class="cb-admin-section-title">Log saklama ve güvenli export</div>
        <p class="cb-admin-section-description">DecisionTrace, ExecutionTrace, AdminAuditLog, Incident ve Approval kayıtları retention worker tarafından temizlenir; export aynı masking standardını kullanır.</p>

        <div class="cb-admin-summary-grid mt-6">
            <div class="cb-admin-summary-card">
                <span class="cb-admin-summary-label">Retention state</span>
                <strong>@retentionLabel</strong>
                <small>Log center retention snapshot</small>
            </div>
            <div class="cb-admin-summary-card">
                <span class="cb-admin-summary-label">Batch size</span>
                <strong class="cb-mono">@(retention?.BatchSize.ToString() ?? "n/a")</strong>
                <small>Retention worker batch cap</small>
            </div>
            <div class="cb-admin-summary-card">
                <span class="cb-admin-summary-label">Last run</span>
                <strong class="cb-mono">@lastRunText</strong>
                <small>@(retention?.LastRunSummary ?? "No retention run yet")</small>
            </div>
        </div>

        <div class="cb-admin-profile-list mt-5">
            <div class="cb-admin-profile-row">
                <span>DecisionTrace</span>
                <strong>@(retention?.DecisionTraceRetentionDays.ToString() ?? "n/a") gün</strong>
            </div>
            <div class="cb-admin-profile-row">
                <span>ExecutionTrace</span>
                <strong>@(retention?.ExecutionTraceRetentionDays.ToString() ?? "n/a") gün</strong>
            </div>
            <div class="cb-admin-profile-row">
                <span>AdminAuditLog</span>
                <strong>@(retention?.AdminAuditLogRetentionDays.ToString() ?? "n/a") gün</strong>
            </div>
            <div class="cb-admin-profile-row">
                <span>Incident / Approval</span>
                <strong>@((retention is null) ? "n/a" : $"{retention.IncidentRetentionDays} gün / {retention.ApprovalRetentionDays} gün")</strong>
            </div>
        </div>

        <div class="cb-admin-info-strip cb-admin-info-strip-@retentionTone mt-6">
            <div>
                <div class="cb-admin-info-strip-title">Logging &amp; retention notu</div>
                <div class="cb-admin-info-strip-text">Retention enforcement ve archive temizliği arka planda çalışan worker ile yapılır. Export ve log merkezinde masking standardı korunur; secrets, tokens ve hassas payload alanları düz metin görünmez.</div>
            </div>
            <span class="cb-admin-info-strip-meta">Fail-closed</span>
        </div>

        <div class="mt-6 cb-admin-inline-actions cb-admin-inline-actions-compact">
            <a asp-area="Admin" asp-controller="Admin" asp-action="Audit" class="btn btn-primary font-weight-bolder">Audit search</a>
            <a asp-area="Admin" asp-controller="Admin" asp-action="SystemHealth" class="btn btn-light-primary font-weight-bold">System health</a>
        </div>
    </div>
</section>
