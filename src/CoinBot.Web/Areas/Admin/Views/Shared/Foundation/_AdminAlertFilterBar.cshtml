@using CoinBot.Application.Abstractions.Administration
@{
    var snapshot = ViewData["AdminNotificationsPageSnapshot"] as AdminNotificationsPageSnapshot;
    var severity = snapshot?.SeverityFilter ?? string.Empty;
    var category = snapshot?.CategoryFilter ?? string.Empty;
}

<div class="card card-custom gutter-b cb-card cb-admin-card">
    <div class="card-body">
        <div class="cb-admin-panel-head">
            <div>
                <div class="cb-admin-section-kicker">Alert Filters</div>
                <div class="cb-admin-section-title">Severity ve kategori filtreleri</div>
                <p class="cb-admin-section-description mb-0">Alarm akışı gerçek notification snapshot üzerinden filtrelenir.</p>
            </div>
            <a asp-area="Admin" asp-controller="Admin" asp-action="SystemHealth" class="btn btn-light-primary font-weight-bold">Sistem sağlığı</a>
        </div>

        <form asp-area="Admin" asp-controller="Admin" asp-action="Notifications" method="get" class="cb-filter-bar cb-admin-filter-bar cb-admin-alert-filter-bar mt-6">
            <div class="cb-filter-field">
                <label class="cb-form-label">Severity</label>
                <select name="severity" class="form-control cb-form-control">
                    <option value="">Tüm severity</option>
                    @if (string.Equals(severity, "Critical", StringComparison.OrdinalIgnoreCase))
                    {
                        <option value="Critical" selected="selected">Critical</option>
                    }
                    else
                    {
                        <option value="Critical">Critical</option>
                    }
                    @if (string.Equals(severity, "Warning", StringComparison.OrdinalIgnoreCase))
                    {
                        <option value="Warning" selected="selected">Warning</option>
                    }
                    else
                    {
                        <option value="Warning">Warning</option>
                    }
                    @if (string.Equals(severity, "Info", StringComparison.OrdinalIgnoreCase))
                    {
                        <option value="Info" selected="selected">Info</option>
                    }
                    else
                    {
                        <option value="Info">Info</option>
                    }
                </select>
            </div>
            <div class="cb-filter-field">
                <label class="cb-form-label">Kategori</label>
                <input type="text" name="category" value="@category" class="form-control cb-form-control" aria-label="Health / Incident / Alert" />
            </div>
            <div class="cb-filter-field cb-filter-actions cb-admin-user-filter-actions">
                <a asp-area="Admin" asp-controller="Admin" asp-action="Notifications" class="btn btn-light-primary font-weight-bold">Temizle</a>
                <button type="submit" class="btn btn-primary font-weight-bolder">Uygula</button>
            </div>
        </form>

        <div class="cb-admin-filter-summary mt-5">
            <div class="cb-admin-filter-summary-copy">
                <strong>Aktif filtre özeti</strong>
                <span>@(string.IsNullOrWhiteSpace(severity) ? "All severities" : severity) · @(string.IsNullOrWhiteSpace(category) ? "All categories" : category)</span>
            </div>
            <div class="cb-admin-filter-chip-list">
                @if (!string.IsNullOrWhiteSpace(severity))
                {
                    <span class="cb-admin-filter-chip">@severity</span>
                }
                @if (!string.IsNullOrWhiteSpace(category))
                {
                    <span class="cb-admin-filter-chip">@category</span>
                }
            </div>
        </div>
    </div>
</div>
