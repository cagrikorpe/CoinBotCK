@using CoinBot.Application.Abstractions.Administration
@{
    var snapshot = ViewData["AdminUserDetailPageSnapshot"] as AdminUserDetailPageSnapshot;
    var logs = snapshot?.CriticalLogs ?? Array.Empty<AdminUserLogSnapshot>();
}

<div class="card card-custom gutter-b cb-card cb-admin-card">
    <div class="card-body">
        <div class="cb-admin-panel-head">
            <div>
                <div class="cb-admin-section-kicker">Critical Logs</div>
                <div class="cb-admin-section-title">Son kritik loglar</div>
            </div>
            <a asp-area="Admin" asp-controller="Admin" asp-action="Audit" asp-route-userId="@(snapshot?.UserId)" class="btn btn-light-primary font-weight-bold">Log merkezine git</a>
        </div>

        @if (snapshot is null || logs.Count == 0)
        {
            @await Html.PartialAsync("Foundation/_AdminEmptyState", new UiStateViewModel
            {
                Title = "Kritik log yok",
                Message = "Bu kullanıcı için kritik log kaydı bulunamadı.",
                IconText = "LG",
                ActionText = "Audit / loglar",
                ActionHref = Url.Action("Audit", "Admin", new { area = "Admin", userId = snapshot?.UserId }),
                SecondaryActionText = "Kullanıcı listesi",
                SecondaryActionHref = Url.Action("Users", "Admin", new { area = "Admin" })
            })
        }
        else
        {
            <div class="cb-admin-log-list mt-5">
                @foreach (var log in logs)
                {
                    <div class="cb-admin-log-item">
                        <div>
                            <div class="d-flex flex-wrap align-items-center gap-3">
                                @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = log.Severity, Tone = log.Tone, IconText = "LG" })
                                <strong class="cb-admin-log-title">@log.Title</strong>
                            </div>
                            <div class="cb-admin-log-meta">@log.Module · @log.TimeLabel · @log.TimestampUtc.ToString("yyyy-MM-dd HH:mm:ss") UTC</div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
