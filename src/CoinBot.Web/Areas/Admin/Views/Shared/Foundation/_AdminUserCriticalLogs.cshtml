@{
    var logs = new[]
    {
        new { Title = "MFA doğrulaması gecikti", Module = "Security", Time = "18 dk önce", Severity = "Warning", Tone = "warning" },
        new { Title = "Exchange sync retried", Module = "Exchange", Time = "1 saat önce", Severity = "Info", Tone = "info" },
        new { Title = "Bot runtime guard triggered", Module = "Bot", Time = "Dün", Severity = "Critical", Tone = "critical" }
    };
}
<div class="card card-custom gutter-b cb-card cb-admin-card">
    <div class="card-body">
        <div class="cb-admin-panel-head">
            <div>
                <div class="cb-admin-section-kicker">Critical Logs</div>
                <div class="cb-admin-section-title">Son kritik loglar</div>
            </div>
            <a asp-area="Admin" asp-controller="Admin" asp-action="Audit" class="btn btn-light-primary font-weight-bold">Log merkezine git</a>
        </div>
        <div class="cb-admin-log-list mt-5">
            @foreach (var log in logs)
            {
                <div class="cb-admin-log-item">
                    <div>
                        <div class="d-flex flex-wrap align-items-center gap-3">
                            @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = log.Severity, Tone = log.Tone, IconText = "LG" })
                            <strong class="cb-admin-log-title">@log.Title</strong>
                        </div>
                        <div class="cb-admin-log-meta">@log.Module · @log.Time</div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
