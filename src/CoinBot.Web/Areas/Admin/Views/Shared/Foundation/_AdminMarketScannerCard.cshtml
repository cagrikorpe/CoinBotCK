@{
    var dashboard = ViewData["AdminMonitoringDashboardSnapshot"] as MonitoringDashboardSnapshot
        ?? MonitoringDashboardSnapshot.Empty(DateTime.UtcNow);
    var scanner = dashboard.MarketScanner ?? MarketScannerDashboardSnapshot.Empty();
    var topCandidates = scanner.TopCandidates
        .OrderBy(candidate => candidate.Rank ?? int.MaxValue)
        .ThenBy(candidate => candidate.Symbol, StringComparer.Ordinal)
        .ToArray();
    var rejectedSamples = scanner.RejectedSamples
        .OrderBy(candidate => candidate.RejectionReason, StringComparer.Ordinal)
        .ThenBy(candidate => candidate.Symbol, StringComparer.Ordinal)
        .ToArray();
    var latestHandoff = scanner.LatestHandoff ?? MarketScannerHandoffSnapshot.Empty();
    var scannerTone = latestHandoff.ExecutionRequestStatus == "Prepared"
        ? "healthy"
        : scanner.EligibleCandidateCount > 0
            ? "warning"
            : scanner.ScannedSymbolCount > 0
                ? "warning"
                : "info";
    var completedAtText = scanner.LastScanCompletedAtUtc.HasValue
        ? scanner.LastScanCompletedAtUtc.Value.ToUniversalTime().ToString("yyyy-MM-dd HH:mm:ss") + " UTC"
        : "No scan yet";
}

<div class="card card-custom gutter-b cb-card cb-admin-card cb-admin-panel-card" data-cb-market-scanner-card>
    <div class="card-body">
        <div class="cb-admin-panel-head">
            <div>
                <div class="cb-admin-section-kicker">Market Scanner</div>
                <div class="cb-admin-section-title">Top-N candidate snapshot</div>
                <p class="cb-admin-section-description mb-0">Universe source, eligibility reason, 24h quote volume ve deterministic ranking son scan cycle read-model'inden okunur.</p>
            </div>
            @await Html.PartialAsync("_AdminBadge", new AdminBadgeViewModel { Label = scanner.EligibleCandidateCount > 0 ? "Candidates Ready" : "No Eligible", Tone = scannerTone, IconText = "SC" })
        </div>

        <div class="cb-admin-worker-meta-grid mt-6">
            <div class="cb-admin-summary-card">
                <span class="cb-admin-summary-label">Last scan</span>
                <strong class="cb-mono" data-cb-scanner-last-scan>@completedAtText</strong>
                <small data-cb-scanner-cycle>@(scanner.ScanCycleId?.ToString() ?? "n/a")</small>
            </div>
            <div class="cb-admin-summary-card">
                <span class="cb-admin-summary-label">Universe</span>
                <strong data-cb-scanner-universe>@scanner.UniverseSource</strong>
                <small data-cb-scanner-counts>@scanner.ScannedSymbolCount scanned / @scanner.EligibleCandidateCount eligible</small>
            </div>
            <div class="cb-admin-summary-card">
                <span class="cb-admin-summary-label">Best candidate</span>
                <strong data-cb-scanner-best-symbol>@(scanner.BestCandidateSymbol ?? "n/a")</strong>
                <small data-cb-scanner-best-score>@(scanner.BestCandidateScore?.ToString("0.####") ?? "n/a") score</small>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(scanner.CycleSummary) || !string.IsNullOrWhiteSpace(scanner.RejectionSummary))
        {
            <div class="cb-admin-info-strip cb-admin-info-strip-info mt-6" data-cb-scanner-cycle-reason-strip>
                <div>
                    <div class="cb-admin-info-strip-title">Cycle reason</div>
                    <div class="cb-admin-info-strip-text" data-cb-scanner-cycle-summary>@(scanner.CycleSummary ?? "n/a")</div>
                    @if (!string.IsNullOrWhiteSpace(scanner.RejectionSummary))
                    {
                        <div class="cb-admin-info-strip-text mt-2" data-cb-scanner-rejection-breakdown>@scanner.RejectionSummary</div>
                    }
                </div>
                <span class="cb-admin-info-strip-meta">Explainable</span>
            </div>
        }

        <div class="cb-admin-info-strip cb-admin-info-strip-info mt-4" data-cb-scanner-ai-ranking-strip>
            <div>
                <div class="cb-admin-info-strip-title">AI ranking rollout</div>
                <div class="cb-admin-info-strip-text">
                    <span>Fallbacks </span>
                    <span data-cb-scanner-ai-fallback-count>@scanner.AiRankingFallbackCount</span>
                    <span> · Suppressed </span>
                    <span data-cb-scanner-ai-suppression-count>@scanner.AiRankingSuppressionCount</span>
                    <span> · Top changed by AI </span>
                    <span data-cb-scanner-ai-top-changed-count>@scanner.AiRankingTopCandidateChangedCount</span>
                </div>
                @if (!string.IsNullOrWhiteSpace(scanner.AiRankingStatusSummary))
                {
                    <div class="cb-admin-info-strip-text mt-2" data-cb-scanner-ai-status-title>@(scanner.AiRankingStatusTitle ?? "AI ranking status")</div>
                    <div class="cb-admin-info-strip-text" data-cb-scanner-ai-status-summary>@scanner.AiRankingStatusSummary</div>
                    @if (!string.IsNullOrWhiteSpace(scanner.AiRankingStatusReason))
                    {
                        <div class="cb-admin-info-strip-text mt-1" data-cb-scanner-ai-status-reason>@scanner.AiRankingStatusReason</div>
                    }
                }
            </div>
            <span class="cb-admin-info-strip-meta">Rollback via config</span>
        </div>

        <div class="cb-admin-info-strip cb-admin-info-strip-info mt-6" data-cb-scanner-handoff-strip>
            <div>
                <div class="cb-admin-info-strip-title" data-cb-scanner-handoff-status>@latestHandoff.ExecutionRequestStatus</div>
                <div class="cb-admin-info-strip-text">
                    <span data-cb-scanner-handoff-symbol>@(latestHandoff.SelectedSymbol ?? "n/a")</span>
                    <span> · </span>
                    <span data-cb-scanner-handoff-selection>@latestHandoff.SelectionReason</span>
                    <span> · Market: </span>
                    <span data-cb-scanner-handoff-market-score>@(latestHandoff.CandidateMarketScore?.ToString("0.####") ?? "n/a")</span>
                    <span> · Strategy: </span>
                    <span data-cb-scanner-handoff-strategy>@latestHandoff.StrategyDecisionOutcome</span>
                    <span> · Strategy Score: </span>
                    <span data-cb-scanner-handoff-score>@(latestHandoff.StrategyScore?.ToString() ?? "n/a")</span>
                    <span> · Final: </span>
                    <span data-cb-scanner-handoff-composite-score>@(latestHandoff.CandidateScore?.ToString("0.####") ?? "n/a")</span>
                    <span> · Blocker: </span>
                    <span data-cb-scanner-handoff-blocker>@(latestHandoff.BlockerCode ?? "none")</span>
                </div>
                <div class="cb-admin-info-strip-text mt-2" data-cb-scanner-handoff-blocker-summary>@(latestHandoff.BlockerSummary ?? latestHandoff.DecisionSummary ?? "n/a")</div>
                <div class="cb-admin-info-strip-text mt-2" data-cb-scanner-handoff-guard>@(latestHandoff.GuardSummary ?? "n/a")</div>
            </div>
            <span class="cb-admin-info-strip-meta cb-mono" data-cb-scanner-handoff-at>@(latestHandoff.CompletedAtUtc?.ToUniversalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "No handoff")</span>
        </div>

        <div class="cb-admin-info-strip cb-admin-info-strip-info mt-4" data-cb-scanner-decision-strip>
            <div>
                <div class="cb-admin-info-strip-title">
                    Decision:
                    <span data-cb-scanner-decision>@latestHandoff.DecisionOutcome</span>
                    <span> / </span>
                    <span data-cb-scanner-decision-reason-type>@(latestHandoff.DecisionReasonType ?? "n/a")</span>
                    <span> / </span>
                    <span data-cb-scanner-decision-reason-code>@(latestHandoff.DecisionReasonCode ?? "n/a")</span>
                </div>
                <div class="cb-admin-info-strip-text" data-cb-scanner-decision-summary>@(latestHandoff.DecisionSummary ?? "Decision summary unavailable.")</div>
                <div class="cb-admin-info-strip-text mt-2">
                    <span>Last candle </span>
                    <span data-cb-scanner-market-last-candle>@(latestHandoff.MarketDataLastCandleAtUtc?.ToUniversalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "n/a")</span>
                    <span> · Data age </span>
                    <span data-cb-scanner-market-age>@(latestHandoff.MarketDataAgeMilliseconds?.ToString() ?? "n/a")</span>
                    <span> · Threshold </span>
                    <span data-cb-scanner-market-threshold>@(latestHandoff.MarketDataStaleThresholdMilliseconds?.ToString() ?? "n/a")</span>
                    <span> · Market reason </span>
                    <span data-cb-scanner-market-stale-reason>@(latestHandoff.MarketDataStaleReason ?? "n/a")</span>
                </div>
                <div class="cb-admin-info-strip-text mt-2">
                    <span>Continuity </span>
                    <span data-cb-scanner-continuity-state>@(latestHandoff.ContinuityState ?? "n/a")</span>
                    <span> · Gap count </span>
                    <span data-cb-scanner-continuity-gap-count>@(latestHandoff.ContinuityGapCount?.ToString() ?? "n/a")</span>
                    <span> · Gap start </span>
                    <span data-cb-scanner-continuity-gap-start>@(latestHandoff.ContinuityGapStartedAtUtc?.ToUniversalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "n/a")</span>
                    <span> · Gap last seen </span>
                    <span data-cb-scanner-continuity-gap-last-seen>@(latestHandoff.ContinuityGapLastSeenAtUtc?.ToUniversalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "n/a")</span>
                    <span> · Recovery </span>
                    <span data-cb-scanner-continuity-recovery>@(latestHandoff.ContinuityRecoveredAtUtc?.ToUniversalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "n/a")</span>
                </div>
            </div>
            <span class="cb-admin-info-strip-meta cb-mono" data-cb-scanner-decision-at>@(latestHandoff.DecisionAtUtc?.ToUniversalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "n/a")</span>
        </div>

        <div class="cb-admin-info-strip cb-admin-info-strip-info mt-4" data-cb-scanner-risk-strip>
            <div>
                <div class="cb-admin-info-strip-title">
                    Risk:
                    <span data-cb-scanner-risk-outcome>@(latestHandoff.RiskOutcome ?? "n/a")</span>
                    <span> / </span>
                    <span data-cb-scanner-risk-reason>@(latestHandoff.RiskVetoReasonCode ?? "None")</span>
                </div>
                <div class="cb-admin-info-strip-text" data-cb-scanner-risk-summary>@(latestHandoff.RiskSummary ?? "Risk snapshot unavailable.")</div>
                <div class="cb-admin-info-strip-text mt-2">
                    <span>Daily </span>
                    <span data-cb-scanner-risk-daily>@((latestHandoff.RiskCurrentDailyLossPercentage?.ToString("0.####") ?? "n/a") + "/" + (latestHandoff.RiskMaxDailyLossPercentage?.ToString("0.####") ?? "n/a") + "%")</span>
                    <span> · Weekly </span>
                    <span data-cb-scanner-risk-weekly>@((latestHandoff.RiskCurrentWeeklyLossPercentage?.ToString("0.####") ?? "n/a") + "/" + (latestHandoff.RiskMaxWeeklyLossPercentage?.ToString("0.####") ?? "n/a") + "%")</span>
                    <span> · Leverage </span>
                    <span data-cb-scanner-risk-leverage>@((latestHandoff.RiskCurrentLeverage?.ToString("0.####") ?? "n/a") + "→" + (latestHandoff.RiskProjectedLeverage?.ToString("0.####") ?? "n/a") + "/" + (latestHandoff.RiskMaxLeverage?.ToString("0.####") ?? "n/a") + "x")</span>
                    <span> · Symbol exposure </span>
                    <span data-cb-scanner-risk-symbol-exposure>@((latestHandoff.RiskCurrentSymbolExposurePercentage?.ToString("0.####") ?? "n/a") + "→" + (latestHandoff.RiskProjectedSymbolExposurePercentage?.ToString("0.####") ?? "n/a") + "/" + (latestHandoff.RiskMaxSymbolExposurePercentage?.ToString("0.####") ?? "n/a") + "%")</span>
                    <span> · Positions </span>
                    <span data-cb-scanner-risk-concurrent>@((latestHandoff.RiskCurrentOpenPositions?.ToString() ?? "n/a") + "→" + (latestHandoff.RiskProjectedOpenPositions?.ToString() ?? "n/a") + "/" + (latestHandoff.RiskMaxConcurrentPositions?.ToString() ?? "n/a"))</span>
                    <span> · Coin </span>
                    <span data-cb-scanner-risk-coin>@((latestHandoff.RiskBaseAsset ?? "n/a") + "=" + (latestHandoff.RiskCurrentCoinExposurePercentage?.ToString("0.####") ?? "n/a") + "→" + (latestHandoff.RiskProjectedCoinExposurePercentage?.ToString("0.####") ?? "n/a") + "/" + (latestHandoff.RiskMaxCoinExposurePercentage?.ToString("0.####") ?? "n/a") + "%")</span>
                </div>
            </div>
            <span class="cb-admin-info-strip-meta">Fail-closed</span>
        </div>

        @if (topCandidates.Length == 0)
        {
            <div class="cb-admin-info-strip cb-admin-info-strip-warning mt-6" data-cb-scanner-ai-empty-state>
                <div>
                    <div class="cb-admin-info-strip-title" data-cb-scanner-ai-empty-title>@(scanner.AiRankingStatusTitle ?? "No top candidate yet")</div>
                    <div class="cb-admin-info-strip-text" data-cb-scanner-ai-empty-summary>
                        @(scanner.AiRankingStatusSummary ?? "Scanner cycle tamamlandığında eligible Top-N candidate snapshot listesi burada görünür.")
                    </div>
                    @if (!string.IsNullOrWhiteSpace(scanner.AiRankingStatusReason))
                    {
                        <div class="cb-admin-info-strip-text mt-1" data-cb-scanner-ai-empty-reason>@scanner.AiRankingStatusReason</div>
                    }
                </div>
                <span class="cb-admin-info-strip-meta">Explainable</span>
            </div>
        }
        else
        {
            <div class="table-responsive mt-6">
                <table class="table table-borderless cb-admin-table mb-0">
                    <thead>
                    <tr>
                        <th>Rank</th>
                        <th>Symbol</th>
                        <th>Market / Strategy</th>
                        <th>Composite</th>
                        <th>Source</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var candidate in topCandidates)
                    {
                        <tr data-cb-scanner-top-row>
                            <td class="cb-mono" data-cb-scanner-top-rank>@(candidate.Rank?.ToString() ?? "-")</td>
                            <td>
                                <div class="cb-admin-job-title" data-cb-scanner-top-symbol>@candidate.Symbol</div>
                                <small class="cb-admin-job-meta" data-cb-scanner-top-price>@(candidate.LastPrice?.ToString("0.########") ?? "n/a")</small>
                                @if (candidate.AdvisoryReasonCodes.Count > 0)
                                {
                                    <div class="mt-2" data-cb-scanner-top-labels>
                                        @foreach (var reasonCode in candidate.AdvisoryReasonCodes)
                                        {
                                            <span class="badge badge-light-info mr-2">@reasonCode</span>
                                        }
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(candidate.AdvisorySummary))
                                {
                                    <small class="cb-admin-job-meta d-block mt-2" data-cb-scanner-top-advisory-summary>@candidate.AdvisorySummary</small>
                                }
                                @if (candidate.AdvisoryShadowScore.HasValue)
                                {
                                    <small class="cb-admin-job-meta d-block mt-2" data-cb-scanner-top-shadow-score>Shadow advisory @candidate.AdvisoryShadowScore.Value</small>
                                }
                                @if (candidate.AdvisoryShadowContributions.Count > 0)
                                {
                                    <small class="cb-admin-job-meta d-block mt-1" data-cb-scanner-top-shadow-contributions>@string.Join(" · ", candidate.AdvisoryShadowContributions)</small>
                                }
                            </td>
                            <td>
                                <div class="cb-mono" data-cb-scanner-top-market-score>@candidate.MarketScore.ToString("0.####")</div>
                                <small class="cb-admin-job-meta" data-cb-scanner-top-strategy-score>@(candidate.StrategyScore?.ToString() ?? "n/a")</small>
                            </td>
                            <td>
                                <div class="cb-mono" data-cb-scanner-top-composite-score>@candidate.Score.ToString("0.####")</div>
                                <small class="cb-admin-job-meta d-block" data-cb-scanner-top-ranking-mode>@(candidate.AiRankingMode ?? "n/a")</small>
                                <small class="cb-admin-job-meta d-block" data-cb-scanner-top-ranking-summary>
                                    Classical @(candidate.AiRankingClassicalScore?.ToString("0.####") ?? "n/a")
                                    · AI @(candidate.AdvisoryShadowScore?.ToString() ?? "n/a")
                                    · Combined @(candidate.AiRankingCombinedScore?.ToString("0.####") ?? "n/a")
                                </small>
                                @if (candidate.AiRankingInfluenceWeight.HasValue || candidate.AiRankingOutcomeCoveragePercent.HasValue)
                                {
                                    <small class="cb-admin-job-meta d-block mt-1" data-cb-scanner-top-ranking-guardrails>
                                        Influence @(candidate.AiRankingInfluenceWeight?.ToString("0.####") ?? "n/a")
                                        · Coverage @(candidate.AiRankingOutcomeCoveragePercent?.ToString("0.##") ?? "n/a")%
                                    </small>
                                }
                                @if (!string.IsNullOrWhiteSpace(candidate.AiRankingFallbackReason))
                                {
                                    <small class="cb-admin-job-meta d-block mt-1" data-cb-scanner-top-ranking-fallback>Fallback @candidate.AiRankingFallbackReason</small>
                                }
                                @if (!string.IsNullOrWhiteSpace(candidate.AiRankingAdaptiveFilterState))
                                {
                                    <small class="cb-admin-job-meta d-block mt-1" data-cb-scanner-top-ranking-filter>
                                        Filter @candidate.AiRankingAdaptiveFilterState@(string.IsNullOrWhiteSpace(candidate.AiRankingAdaptiveFilterReason) ? string.Empty : $" · {candidate.AiRankingAdaptiveFilterReason}")
                                    </small>
                                }
                            </td>
                            <td data-cb-scanner-top-source>@candidate.UniverseSource</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }

        @if (rejectedSamples.Length > 0)
        {
            <div class="cb-admin-info-strip cb-admin-info-strip-info mt-6" data-cb-scanner-rejected-strip>
                <div>
                    <div class="cb-admin-info-strip-title">Rejected samples</div>
                    <div class="cb-admin-info-strip-text" data-cb-scanner-rejected-summary>
                        @string.Join(" · ", rejectedSamples.Select(candidate => $"{candidate.Symbol}:{candidate.RejectionReason ?? "n/a"}"))
                    </div>
                    <div class="mt-3">
                        @foreach (var candidate in rejectedSamples)
                        {
                            <div class="cb-admin-info-strip-text mt-2" data-cb-scanner-rejected-candidate>
                                <strong data-cb-scanner-rejected-symbol>@candidate.Symbol</strong>
                                <span> · </span>
                                <span data-cb-scanner-rejected-reason>@(candidate.RejectionReason ?? "n/a")</span>
                                @if (candidate.AdvisoryReasonCodes.Count > 0)
                                {
                                    <span class="d-inline-block mt-2" data-cb-scanner-rejected-reason-codes>
                                        @foreach (var reasonCode in candidate.AdvisoryReasonCodes)
                                        {
                                            <span class="badge badge-light-info mr-2">@reasonCode</span>
                                        }
                                    </span>
                                }
                                @if (!string.IsNullOrWhiteSpace(candidate.AdvisorySummary))
                                {
                                    <small class="cb-admin-job-meta d-block mt-2" data-cb-scanner-rejected-advisory-summary>@candidate.AdvisorySummary</small>
                                }
                                @if (candidate.AdvisoryShadowScore.HasValue)
                                {
                                    <small class="cb-admin-job-meta d-block mt-2" data-cb-scanner-rejected-shadow-score>Shadow advisory @candidate.AdvisoryShadowScore.Value</small>
                                }
                                @if (candidate.AdvisoryShadowContributions.Count > 0)
                                {
                                    <small class="cb-admin-job-meta d-block mt-1" data-cb-scanner-rejected-shadow-contributions>@string.Join(" · ", candidate.AdvisoryShadowContributions)</small>
                                }
                                @if (!string.IsNullOrWhiteSpace(candidate.AiRankingMode))
                                {
                                    <small class="cb-admin-job-meta d-block mt-2" data-cb-scanner-rejected-ranking-mode>@candidate.AiRankingMode</small>
                                }
                                @if (!string.IsNullOrWhiteSpace(candidate.AiRankingFallbackReason))
                                {
                                    <small class="cb-admin-job-meta d-block mt-1" data-cb-scanner-rejected-ranking-fallback>Fallback @candidate.AiRankingFallbackReason</small>
                                }
                                @if (!string.IsNullOrWhiteSpace(candidate.AiRankingAdaptiveFilterState))
                                {
                                    <small class="cb-admin-job-meta d-block mt-1" data-cb-scanner-rejected-ranking-filter>
                                        Filter @candidate.AiRankingAdaptiveFilterState@(string.IsNullOrWhiteSpace(candidate.AiRankingAdaptiveFilterReason) ? string.Empty : $" · {candidate.AiRankingAdaptiveFilterReason}")
                                    </small>
                                }
                            </div>
                        }
                    </div>
                </div>
                <span class="cb-admin-info-strip-meta">Fail-closed</span>
            </div>
        }
    </div>
</div>
