@using CoinBot.Application.Abstractions.Administration
@{
    var snapshot = ViewData["AdminSupportLookupPageSnapshot"] as AdminSupportLookupSnapshot;
    var query = snapshot?.Query ?? string.Empty;
    var matchedUsers = snapshot?.MatchedUsers ?? Array.Empty<AdminUserListItemSnapshot>();
}

<div class="card card-custom gutter-b cb-card cb-admin-card">
    <div class="card-body">
        <div class="cb-admin-section-kicker">Support Lookup</div>
        <div class="cb-admin-section-title">Kullanıcı lookup alanı</div>
        <p class="cb-admin-section-description">Email, kullanıcı ID veya external reference ile hızlı arama yapılır. Sonuçlar gerçek read-model snapshot'tan gelir.</p>

        <form asp-area="Admin" asp-controller="Admin" asp-action="SupportTools" method="get" class="cb-admin-support-search-grid mt-6">
            <div class="form-group mb-0">
                <label class="cb-form-label">Kullanıcı arama</label>
                <input type="text" name="query" value="@query" class="form-control cb-form-control" aria-label="user id, email veya external ref" />
            </div>
            <div class="form-group mb-0 cb-filter-actions">
                <label class="cb-form-label">Lookup aksiyonu</label>
                <div class="cb-admin-inline-actions">
                    <button type="submit" class="btn btn-primary font-weight-bolder">Ara</button>
                    <a asp-area="Admin" asp-controller="Admin" asp-action="SupportTools" class="btn btn-light-primary font-weight-bold">Temizle</a>
                </div>
            </div>
        </form>

        <div class="cb-admin-inline-actions mt-5">
            <a asp-area="Admin" asp-controller="Admin" asp-action="Users" class="btn btn-light-primary font-weight-bold">Kullanıcılar</a>
            @if (!string.IsNullOrWhiteSpace(query))
            {
                <a asp-area="Admin" asp-controller="Admin" asp-action="Audit" asp-route-query="@query" class="btn btn-light-primary font-weight-bold">Audit</a>
            }
        </div>

        <div class="cb-admin-summary-card mt-6 cb-admin-support-result-card">
            <span class="cb-admin-summary-label">Arama sonucu</span>
            <strong>@(string.IsNullOrWhiteSpace(query) ? "Arama bekleniyor" : $"{matchedUsers.Count} kullanıcı")</strong>
            <small>@(snapshot?.EmptyStateMessage ?? "Kullanıcı, bot, exchange veya güvenlik kaydı arayın.")</small>
            <div class="cb-admin-badge-stack mt-4">
                @if (matchedUsers.Count > 0)
                {
                    var topUser = matchedUsers.First();
                    @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = topUser.StatusLabel, Tone = topUser.StatusTone, IconText = "ST" })
                    @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = topUser.MfaLabel, Tone = topUser.MfaTone, IconText = "2F" })
                }
                else
                {
                    @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = "Read-only", Tone = "warning", IconText = "RO" })
                }
            </div>
        </div>

        @if (snapshot is not null)
        {
            <div class="cb-admin-info-strip cb-admin-info-strip-info mt-5">
                <div>
                    <div class="cb-admin-info-strip-title">Son yenilenme</div>
                    <div class="cb-admin-info-strip-text">@snapshot.LastRefreshedAtUtc.ToString("yyyy-MM-dd HH:mm:ss") UTC</div>
                </div>
                <span class="cb-admin-info-strip-meta">Snapshot</span>
            </div>
        }
    </div>
</div>
