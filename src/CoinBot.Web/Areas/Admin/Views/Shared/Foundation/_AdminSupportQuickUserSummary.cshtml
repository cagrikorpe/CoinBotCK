@using CoinBot.Application.Abstractions.Administration
@{
    var snapshot = ViewData["AdminSupportLookupPageSnapshot"] as AdminSupportLookupSnapshot;
    var user = snapshot?.MatchedUsers.FirstOrDefault();
}

<div class="card card-custom gutter-b cb-card cb-admin-card">
    <div class="card-body">
        <div class="cb-admin-section-kicker">Quick User Summary</div>
        <div class="cb-admin-section-title">Hızlı kullanıcı özeti</div>

        @if (user is null)
        {
            @await Html.PartialAsync("Foundation/_AdminEmptyState", new UiStateViewModel
            {
                Title = "Kullanıcı bulunamadı",
                Message = "Search sonucu gelmedi.",
                IconText = "U",
                ActionText = "Kullanıcılar",
                ActionHref = Url.Action("Users", "Admin", new { area = "Admin" }),
                SecondaryActionText = "Audit / loglar",
                SecondaryActionHref = Url.Action("Audit", "Admin", new { area = "Admin" })
            })
        }
        else
        {
            <div class="cb-admin-profile-list mt-5">
                <div class="cb-admin-profile-row"><span>Kullanıcı</span><strong>@user.DisplayName</strong></div>
                <div class="cb-admin-profile-row"><span>Durum</span><strong>@user.StatusLabel</strong></div>
                <div class="cb-admin-profile-row"><span>MFA</span><strong>@user.MfaLabel</strong></div>
                <div class="cb-admin-profile-row"><span>Bot sayısı</span><strong>@user.BotCount</strong></div>
                <div class="cb-admin-profile-row"><span>Exchange sayısı</span><strong>@user.ExchangeCount</strong></div>
                <div class="cb-admin-profile-row"><span>Son aktivite</span><strong>@user.LastActivityLabel</strong></div>
            </div>

            <div class="cb-admin-inline-actions mt-5">
                <a asp-area="Admin" asp-controller="Admin" asp-action="UserDetail" asp-route-id="@user.UserId" class="btn btn-light-primary font-weight-bold">Kullanıcı detayına git</a>
                <a asp-area="Admin" asp-controller="Admin" asp-action="Audit" asp-route-userId="@user.UserId" class="btn btn-clean text-muted font-weight-bold">Audit</a>
            </div>
        }
    </div>
</div>
