@using CoinBot.Application.Abstractions.Administration
@{
    var snapshot = ViewData["AdminStrategyAiMonitoringPageSnapshot"] as AdminStrategyAiMonitoringPageSnapshot;
    var tiles = snapshot?.HealthTiles ?? Array.Empty<AdminStatTileSnapshot>();
}

<div class="card card-custom gutter-b cb-card cb-admin-card cb-admin-panel-card">
    <div class="card-body">
        <div class="cb-admin-panel-head">
            <div>
                <div class="cb-admin-section-kicker">Confidence / Veto</div>
                <div class="cb-admin-section-title">Global confidence ve veto summary</div>
                <p class="cb-admin-section-description mb-0">Confidence ve veto durumu gerçek strategy health snapshot'ından özetlenir.</p>
            </div>
            @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = snapshot is null ? "Veri yok" : "Snapshot", Tone = "warning", IconText = "VT" })
        </div>

        <div class="cb-admin-confidence-grid mt-6">
            @foreach (var tile in tiles)
            {
                <div class="cb-admin-summary-card">
                    <span class="cb-admin-summary-label">@tile.Label</span>
                    <strong>@tile.Value</strong>
                    <small>@tile.Meta</small>
                </div>
            }
        </div>

        @if (snapshot is null)
        {
            @await Html.PartialAsync("Foundation/_AdminEmptyState", new UiStateViewModel
            {
                Title = "Confidence verisi yok",
                Message = "Strategy health snapshot'u bulunamadı.",
                IconText = "VT",
                ActionText = "Strategy / AI",
                ActionHref = Url.Action("StrategyAiMonitoring", "Admin", new { area = "Admin" }),
                SecondaryActionText = "Audit / loglar",
                SecondaryActionHref = Url.Action("Audit", "Admin", new { area = "Admin" })
            })
        }
    </div>
</div>
