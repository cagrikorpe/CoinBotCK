@using CoinBot.Application.Abstractions.Administration
@{
    var snapshot = ViewData["AdminNotificationsPageSnapshot"] as AdminNotificationsPageSnapshot;
    var tiles = snapshot?.SummaryTiles ?? Array.Empty<AdminStatTileSnapshot>();
}

<div class="row cb-admin-summary-grid cb-admin-alert-summary-grid">
    @if (tiles.Count == 0)
    {
        <div class="col-xl-2 col-md-4 col-sm-6">
            @await Html.PartialAsync("Foundation/_AdminStatTile", new AdminStatTileViewModel
            {
                Label = "Alarm",
                Value = "0",
                Meta = "Bildirim bulunamadı",
                Tone = "neutral"
            })
        </div>
    }
    else
    {
        @foreach (var tile in tiles)
        {
            <div class="col-xl-2 col-md-4 col-sm-6">
                @await Html.PartialAsync("Foundation/_AdminStatTile", new AdminStatTileViewModel
                {
                    Label = tile.Label,
                    Value = tile.Value,
                    Meta = tile.Meta,
                    Tone = tile.Tone
                })
            </div>
        }
    }
</div>
