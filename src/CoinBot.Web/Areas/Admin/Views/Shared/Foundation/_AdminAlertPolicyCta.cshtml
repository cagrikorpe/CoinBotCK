<div class="card card-custom gutter-b cb-card cb-admin-card cb-admin-dashboard-card cb-admin-panel-card">
    <div class="card-body">
        <div class="cb-admin-panel-head">
            <div>
                <div class="cb-admin-section-kicker">Policy CTA</div>
                <div class="cb-admin-section-title">Notification policy</div>
            </div>
            @await Html.PartialAsync("_AdminBadge", new AdminBadgeViewModel { Label = "Read / Unread", Tone = "info", IconText = "NP" })
        </div>

        <div class="cb-admin-info-strip cb-admin-info-strip-warning mt-6">
            <div>
                <div class="cb-admin-info-strip-title">Bildirim policy yönlendirmesi</div>
                <div class="cb-admin-info-strip-text">Alarm routing ve güvenlik incelemesi için gerçek admin ekranlarına yönlendirme yapılır.</div>
            </div>
            <span class="cb-admin-info-strip-meta">Policy</span>
        </div>

        <div class="cb-admin-quick-actions-list mt-6">
            <a asp-area="Admin" asp-controller="Admin" asp-action="Notifications" class="cb-admin-action-item">
                <div>
                    <strong>Notification policy ekranına git</strong>
                    <small>Rule/source ve severity akışı</small>
                </div>
                <span>→</span>
            </a>
            <a asp-area="Admin" asp-controller="Admin" asp-action="SecurityEvents" class="cb-admin-action-item">
                <div>
                    <strong>Security alarmlarını aç</strong>
                    <small>Şüpheli ve yüksek riskli olaylarla karşılaştır</small>
                </div>
                <span>→</span>
            </a>
            <a asp-area="Admin" asp-controller="Admin" asp-action="SystemHealth" class="cb-admin-action-item">
                <div>
                    <strong>Worker / system health</strong>
                    <small>Worker alarm ve incident kaynaklarını doğrula</small>
                </div>
                <span>→</span>
            </a>
        </div>
    </div>
</div>
