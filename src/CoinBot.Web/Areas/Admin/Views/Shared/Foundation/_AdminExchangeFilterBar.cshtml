<div class="card card-custom gutter-b cb-card cb-admin-card">
    <div class="card-body">
        <div class="cb-admin-panel-head">
            <div>
                <div class="cb-admin-section-kicker">Filter Toolbar</div>
                <div class="cb-admin-section-title">Exchange monitoring filtreleri</div>
            </div>
            <div class="cb-admin-user-filter-actions">
                <button type="button" class="btn btn-light-primary font-weight-bold">Temizle</button>
                <button type="button" class="btn btn-primary font-weight-bolder">Uygula</button>
            </div>
        </div>

        <div class="cb-admin-user-filter-bar cb-admin-exchange-filter-bar mt-5">
            <div class="form-group mb-0">
                <label class="cb-form-label">Kullanıcı arama</label>
                <input class="form-control cb-form-control" placeholder="Kullanıcı adı / email / external id" />
            </div>
            <div class="form-group mb-0">
                <label class="cb-form-label">Kullanıcı</label>
                <select class="form-control cb-form-control">
                    <option>All users</option>
                    <option>Whale desk placeholder</option>
                    <option>Managed tenant placeholder</option>
                </select>
            </div>
            <div class="form-group mb-0">
                <label class="cb-form-label">Exchange tipi</label>
                <select class="form-control cb-form-control">
                    <option>Binance</option>
                    <option>All exchanges placeholder</option>
                </select>
            </div>
            <div class="form-group mb-0">
                <label class="cb-form-label">Spot / Futures</label>
                <select class="form-control cb-form-control">
                    <option>All</option>
                    <option>Spot</option>
                    <option>Futures</option>
                </select>
            </div>
            <div class="form-group mb-0">
                <label class="cb-form-label">Paper / Live</label>
                <select class="form-control cb-form-control">
                    <option>All</option>
                    <option>Paper</option>
                    <option>Live</option>
                </select>
            </div>
            <div class="form-group mb-0">
                <label class="cb-form-label">Bağlantı durumu</label>
                <select class="form-control cb-form-control">
                    <option>All</option>
                    <option>Connected</option>
                    <option>Disconnected</option>
                    <option>Stale</option>
                    <option>Degraded</option>
                </select>
            </div>
            <div class="form-group mb-0">
                <label class="cb-form-label">Permission risk</label>
                <select class="form-control cb-form-control">
                    <option>All</option>
                    <option>Permission ok</option>
                    <option>Mismatch</option>
                    <option>Withdrawal risk</option>
                </select>
            </div>
            <div class="form-group mb-0">
                <label class="cb-form-label">Sıralama</label>
                <select class="form-control cb-form-control">
                    <option>Son sync</option>
                    <option>Risk önceliği</option>
                    <option>Kullanıcı</option>
                </select>
            </div>
        </div>

        <div class="cb-admin-filter-summary mt-5">
            <div>
                <div class="cb-admin-section-kicker">Active filters</div>
                <div class="cb-admin-filter-chip-list mt-3">
                    <span class="cb-admin-filter-chip">Binance</span>
                    <span class="cb-admin-filter-chip">Live mode</span>
                    <span class="cb-admin-filter-chip">Permission risk</span>
                    <span class="cb-admin-filter-chip">Stale first</span>
                </div>
            </div>
            <span class="cb-admin-summary-label">Toplam sonuç: 1,142 placeholder</span>
        </div>
    </div>
</div>
