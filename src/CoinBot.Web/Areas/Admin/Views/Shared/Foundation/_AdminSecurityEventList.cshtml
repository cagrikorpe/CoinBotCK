@using CoinBot.Application.Abstractions.Administration
@{
    var snapshot = ViewData["AdminSecurityEventsPageSnapshot"] as AdminSecurityEventsPageSnapshot;
    var events = snapshot?.Events ?? Array.Empty<AdminSecurityEventSnapshot>();
}

<div class="card card-custom gutter-b cb-card cb-admin-card cb-admin-table-card">
    <div class="card-body">
        <div class="cb-admin-table-header">
            <div>
                <div class="cb-admin-section-kicker">Security Event List</div>
                <div class="cb-admin-section-title">Global security event listesi</div>
                <p class="cb-admin-section-description mb-0">Failed login, invalid MFA, suspicious session ve risky permission akışları güvenli şekilde listelenir.</p>
            </div>
            @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = snapshot is null ? "Veri yok" : $"{events.Count} event", Tone = "healthy", IconText = "MS" })
        </div>

        <div class="table-responsive cb-admin-table-wrap">
            <table class="table table-borderless cb-admin-table cb-admin-security-table mb-0">
                <thead>
                    <tr>
                        <th>Zaman</th>
                        <th>Event tipi</th>
                        <th>Severity</th>
                        <th>İlgili kullanıcı</th>
                        <th>Modül</th>
                        <th>Kısa özet</th>
                        <th>Detay</th>
                    </tr>
                </thead>
                <tbody>
                    @if (events.Count == 0)
                    {
                        <tr>
                            <td colspan="7">
                                @await Html.PartialAsync("Foundation/_AdminEmptyState", new UiStateViewModel
                                {
                                    Title = "Güvenlik olayı yok",
                                    Message = "Bu filtre kombinasyonu için security event bulunamadı.",
                                    IconText = "SC",
                                    ActionText = "Filtreleri temizle",
                                    ActionHref = Url.Action("SecurityEvents", "Admin", new { area = "Admin" }),
                                    SecondaryActionText = "Audit / loglar",
                                    SecondaryActionHref = Url.Action("Audit", "Admin", new { area = "Admin" })
                                })
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in events)
                        {
                            <tr>
                                <td><span class="cb-admin-freshness-time cb-mono">@item.TimestampUtc.ToString("yyyy-MM-dd HH:mm:ss") UTC</span></td>
                                <td>@await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = item.Category, Tone = item.CategoryTone, IconText = "EV" })</td>
                                <td>@await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = item.Severity, Tone = item.SeverityTone, IconText = "SV" })</td>
                                <td><div class="cb-admin-mini-stat"><strong>@item.Actor</strong><small>Masked actor</small></div></td>
                                <td><div class="cb-admin-mini-stat"><strong>@item.Module</strong><small>@string.Join(" · ", item.Tags)</small></div></td>
                                <td class="text-muted">
                                    <div class="cb-admin-mini-stat">
                                        <strong>@item.Summary</strong>
                                        <small>@item.Detail</small>
                                    </div>
                                </td>
                                <td>
                                    <a asp-area="Admin" asp-controller="Admin" asp-action="Audit" asp-route-query="@item.Summary" class="btn btn-xs btn-light-primary font-weight-bold">Audit</a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
