@using System.Linq
@using System.Security.Claims
@using CoinBot.Application.Abstractions.Administration
@{
    var pageTitle = ViewData["Title"]?.ToString() ?? "Super Admin";
    var pageDescription = ViewData["PageDescription"]?.ToString() ?? "Admin shell hazır.";
    var breadcrumbItems = ViewData["BreadcrumbItems"] as string[] ?? new[] { "Super Admin", pageTitle };
    var healthSnapshot = ViewData["AdminShellHealthSnapshot"] as AdminShellHealthSnapshot;
    var environmentLabel = healthSnapshot?.EnvironmentBadge ?? ViewData["AdminEnvironment"]?.ToString() ?? "DEMO";
    var buildLabel = ViewData["AdminBuild"]?.ToString() ?? "Build vNext";
    var tenantScope = ViewData["AdminTenantScope"]?.ToString() ?? "Tenant: Global";
    var roleLabel = ViewData["AdminRoleLabel"]?.ToString() ?? "Super Admin";
    var roleKey = ViewData["AdminRoleKey"]?.ToString() ?? "SuperAdmin";
    var freshnessLabel = ViewData["AdminFreshnessLabel"]?.ToString() ?? "Fresh";
    var searchQuery = ViewData["AdminSearchQuery"]?.ToString() ?? string.Empty;
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var displayName = User.Claims.FirstOrDefault(claim => claim.Type == ClaimTypes.Name)?.Value
        ?? User.Identity?.Name
        ?? roleLabel;
    var userInitialsSource = string.Concat(displayName.Where(char.IsLetterOrDigit).Take(2)).ToUpperInvariant();
    var userInitials = string.IsNullOrWhiteSpace(userInitialsSource) ? "SA" : userInitialsSource;
    var alertLabel = healthSnapshot?.SystemState == CoinBot.Domain.Enums.GlobalSystemStateKind.Degraded
        ? "1"
        : healthSnapshot?.IsManualOverride == true
            ? "!"
            : "0";
    var alertTitle = healthSnapshot is null
        ? "System health snapshot unavailable"
        : healthSnapshot.SystemState == CoinBot.Domain.Enums.GlobalSystemStateKind.Degraded
            ? $"System degraded · {healthSnapshot.ReasonCode}"
            : healthSnapshot.IsManualOverride
                ? $"Manual override · {healthSnapshot.ReasonCode}"
                : $"System healthy · {healthSnapshot.ReasonCode}";
    var environmentTone = environmentLabel == "LIVE"
        ? "critical"
        : environmentLabel == "DEGRADED"
            ? "degraded"
            : "warning";
    var lastUpdatedAtUtc = healthSnapshot?.LastUpdatedAtUtc?.ToUniversalTime().ToString("yyyy-MM-dd HH:mm:ss");
    var stateLabel = healthSnapshot?.SystemState.ToString() ?? "Active";
}
<div id="kt_header" class="header header-fixed cb-shell-header cb-admin-header">
    <div class="container-fluid d-flex align-items-center justify-content-between flex-wrap flex-sm-nowrap">
        <div class="d-flex align-items-center mr-5 cb-topbar-meta">
            <button class="btn btn-icon btn-clean d-lg-none mr-3" id="kt_aside_mobile_toggle_desktop" type="button">
                <span class="svg-icon svg-icon-xl">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="none">
                        <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                    </svg>
                </span>
            </button>
            <div>
                <div class="cb-shell-breadcrumb cb-admin-breadcrumb">
                    @for (var i = 0; i < breadcrumbItems.Length; i++)
                    {
                        <span>@breadcrumbItems[i]</span>
                        @if (i < breadcrumbItems.Length - 1)
                        {
                            <span class="cb-breadcrumb-separator">/</span>
                        }
                    }
                </div>
                <h1 class="cb-shell-title cb-admin-shell-title mb-0">@pageTitle</h1>
                <div class="cb-shell-description">@pageDescription</div>

                <div class="cb-admin-quick-meta">
                    <span class="cb-admin-quick-meta-item">@environmentLabel</span>
                    <span class="cb-admin-quick-meta-item">@buildLabel</span>
                    <span class="cb-admin-quick-meta-item">@tenantScope</span>
                    @if (!string.IsNullOrWhiteSpace(lastUpdatedAtUtc))
                    {
                        <span class="cb-admin-quick-meta-item">LastUpdatedAtUtc: @lastUpdatedAtUtc</span>
                    }
                </div>
            </div>
        </div>

        <div class="topbar cb-topbar cb-admin-topbar">
            <form asp-area="Admin" asp-controller="Admin" asp-action="Search" method="get" class="cb-top-search cb-admin-top-search d-none d-xl-flex">
                <span class="cb-top-search-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="none">
                        <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"></circle>
                        <path d="m20 20-3.5-3.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
                    </svg>
                </span>
                <input name="query" type="text" class="form-control border-0 bg-transparent" value="@searchQuery" aria-label="CorrelationId / OrderId / DecisionId / ExecutionAttemptId / IncidentId / UserId" />
            </form>

            <div class="cb-topbar-actions">
                <a asp-area="Admin" asp-controller="Admin" asp-action="SecurityEvents" class="btn btn-light-primary font-weight-bold cb-topbar-action">Security events</a>

                <a asp-area="Admin" asp-controller="Admin" asp-action="SystemHealth" class="btn btn-icon btn-clean cb-icon-button cb-admin-alert-button" title="@alertTitle">
                    <span class="cb-icon-badge cb-admin-alert-count">@alertLabel</span>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none">
                        <path d="M12 4l7 13H5L12 4Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"></path>
                        <path d="M12 9v4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"></path>
                        <circle cx="12" cy="16.5" r="1" fill="currentColor"></circle>
                    </svg>
                </a>

                @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = environmentLabel, Tone = environmentTone, IconText = "ENV" })
                @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = stateLabel, Tone = stateLabel == "Active" ? "healthy" : stateLabel == "Degraded" ? "degraded" : "critical", IconText = "GS" })
                @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = freshnessLabel, Tone = freshnessLabel == "Fresh" ? "healthy" : freshnessLabel == "Delayed" ? "warning" : freshnessLabel == "Degraded" ? "degraded" : "critical", IconText = "FD" })
                @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = roleLabel, Tone = "role", IconText = roleKey == "SuperAdmin" ? "SA" : roleKey == "OpsAdmin" ? "OA" : "SC" })

                <div class="dropdown">
                    <button class="btn btn-clean d-flex align-items-center px-2 py-2" type="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                        <span class="cb-user-avatar cb-admin-user-avatar">@userInitials</span>
                        <span class="cb-user-meta d-none d-md-inline-block">
                            <span class="cb-user-name">@displayName</span>
                            <span class="cb-user-role">@roleLabel</span>
                        </span>
                    </button>
                    <div class="dropdown-menu dropdown-menu-right dropdown-menu-anim-up dropdown-menu-lg p-0 cb-dropdown-menu cb-admin-dropdown-menu">
                        <div class="cb-dropdown-header cb-admin-dropdown-header">
                            <div class="cb-user-avatar cb-admin-user-avatar">@userInitials</div>
                            <div>
                                <div class="font-weight-bolder text-white">@displayName</div>
                                <div class="text-white-50">@roleLabel · @(isAuthenticated ? "Session live" : "Guest")</div>
                            </div>
                        </div>
                        <div class="navi navi-hover py-2">
                            <a asp-area="Admin" asp-controller="Admin" asp-action="Overview" class="navi-item px-4 py-3 d-flex justify-content-between align-items-center text-white-75">
                                <span class="navi-text">Genel Bakış</span>
                                @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = "Shell", Tone = "healthy" })
                            </a>
                            <a asp-area="Admin" asp-controller="Admin" asp-action="Audit" class="navi-item px-4 py-3 d-flex justify-content-between align-items-center text-white-75">
                                <span class="navi-text">Audit merkezi</span>
                                @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = "Trace", Tone = "info" })
                            </a>
                            <a asp-area="Admin" asp-controller="Admin" asp-action="Users" class="navi-item px-4 py-3 d-flex justify-content-between align-items-center text-white-75">
                                <span class="navi-text">Kullanıcı erişimi</span>
                                @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = "Identity", Tone = "role" })
                            </a>
                            <a asp-area="Admin" asp-controller="Admin" asp-action="Login" class="navi-item px-4 py-3 d-flex justify-content-between align-items-center text-white-75">
                                <span class="navi-text">Admin access</span>
                                @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = "MFA", Tone = "warning" })
                            </a>
                            <a asp-controller="Auth" asp-action="Logout" class="navi-item px-4 py-3 d-flex justify-content-between align-items-center text-white-75">
                                <span class="navi-text">Çıkış yap</span>
                                @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = "Auth", Tone = "neutral" })
                            </a>
                            <a asp-controller="Home" asp-action="Index" asp-area="" class="navi-item px-4 py-3 d-flex justify-content-between align-items-center text-white-75">
                                <span class="navi-text">Kullanıcı paneline dön</span>
                                @await Html.PartialAsync("Foundation/_AdminBadge", new AdminBadgeViewModel { Label = "UI", Tone = "neutral" })
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
