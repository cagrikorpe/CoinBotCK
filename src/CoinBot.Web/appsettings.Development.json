{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    }
  },
  "MarketData": {
    "Binance": {
      "Enabled": true,
      "RestBaseUrl": "https://testnet.binancefuture.com",
      "WebSocketBaseUrl": "wss://fstream.binancefuture.com"
    },
    "Scanner": {
      "Enabled": true,
      "ScanIntervalSeconds": 15,
      "MaxUniverseSymbols": 100,
      "TopCandidateCount": 10,
      "VolumeLookbackHours": 24,
      "MaxDataAgeSeconds": 120,
      "Min24hQuoteVolume": 1000000,
      "MinPrice": 0.00000001,
      "MaxPrice": 1000000,
      "HandoffEnabled": true,
      "AllowedQuoteAssets": [ "USDT" ]
    }
  },
  "BotExecutionPilot": {
    "Enabled": true,
    "DefaultSymbol": "BTCUSDT",
    "Timeframe": "1m",
    "DefaultLeverage": 1,
    "DefaultMarginType": "ISOLATED",
    "AllowedSymbols": [ "BTCUSDT", "ETHUSDT", "SOLUSDT" ],
    "MaxPilotOrderNotional": "250",
    "PerBotCooldownSeconds": 120,
    "PerSymbolCooldownSeconds": 60,
    "MaxOpenPositionsPerUser": 3,
    "PrimeHistoricalCandleCount": 200
  },
  "ExchangeSync": {
    "Binance": {
      "Enabled": true,
      "RestBaseUrl": "https://testnet.binancefuture.com",
      "WebSocketBaseUrl": "wss://fstream.binancefuture.com"
    }
  },
  "ExecutionSafety": {
    "DataLatencyGuard": {
      "StaleDataThresholdSeconds": 60,
      "StopDataThresholdSeconds": 120,
      "ClockDriftThresholdSeconds": 2
    }
  },
  "CredentialValidation": {
    "Binance": {
      "SpotProbeBaseUrl": "https://testnet.binance.vision"
    }
  }
}





