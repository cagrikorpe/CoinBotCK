{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    }
  },
  "MarketData": {
    "Binance": {
      "Enabled": true,
      "RestBaseUrl": "https://demo-fapi.binance.com",
      "WebSocketBaseUrl": "wss://fstream.binancefuture.com",
      "ReconciliationIntervalMinutes": 1
    },
    "Scanner": {
      "Enabled": true,
      "ScanIntervalSeconds": 15,
      "MaxUniverseSymbols": 100,
      "TopCandidateCount": 10,
      "VolumeLookbackHours": 24,
      "MaxDataAgeSeconds": 120,
      "Min24hQuoteVolume": 1000000,
      "MinPrice": 1e-08,
      "MaxPrice": 1000000,
      "HandoffEnabled": true,
      "AllowedQuoteAssets": [
        "USDT"
      ]
    }
  },
  "BotExecutionPilot": {
    "Enabled": true,
    "PilotActivationEnabled": true,
    "AllowGlobalSwitchBypass": true,
    "SignalEvaluationMode": "Live",
    "ExecutionDispatchMode": "Demo",
    "DefaultSymbol": "BTCUSDT",
    "Timeframe": "1m",
    "DefaultLeverage": 1,
    "DefaultMarginType": "ISOLATED",
    "AllowedSymbols": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "AllowedUserIds": [],
    "AllowedBotIds": [],
    "MaxPilotOrderNotional": "250",
    "LongRegimeFilterEnabled": true,
    "LongRegimeMaxEntryRsi": 68,
    "LongRegimeMinMacdHistogram": -0.005,
    "LongRegimeMinBollingerWidthPercentage": 0.07,
    "PerBotCooldownSeconds": 120,
    "PerSymbolCooldownSeconds": 60,
    "MaxOpenPositionsPerUser": 1,
    "PrimeHistoricalCandleCount": 200
  },
  "ExchangeSync": {
    "Binance": {
      "Enabled": true,
      "RestBaseUrl": "https://demo-fapi.binance.com",
      "WebSocketBaseUrl": "wss://fstream.binancefuture.com",
      "ReconciliationIntervalMinutes": 1
    }
  },
  "ExecutionSafety": {
    "DataLatencyGuard": {
      "StaleDataThresholdSeconds": 60,
      "StopDataThresholdSeconds": 120,
      "ClockDriftThresholdSeconds": 5
    }
  },
  "CredentialValidation": {
    "Binance": {
      "SpotProbeBaseUrl": "https://testnet.binance.vision"
    }
  }
}
