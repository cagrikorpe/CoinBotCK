@model CoinBot.Web.ViewModels.Bots.BotManagementIndexViewModel
@{
    ViewData["Title"] = "Botlarım";
    ViewData["ActiveNav"] = "Bots";
    ViewData["PageDescription"] = "Pilot botlarını listeleyin, düzenleyin ve etkinleştirin.";
    ViewData["BreadcrumbItems"] = new[] { "Automation", "Botlarım" };
}

<div class="row">
    <div class="col-12">
        <div class="card card-custom gutter-b">
            <div class="card-header border-0 pt-5">
                <div class="card-title">
                    <div>
                        <div class="text-muted font-weight-bold text-uppercase mb-1">Pilot Bots</div>
                        <h2 class="mb-0">Bot listesi</h2>
                    </div>
                </div>
                <div class="card-toolbar">
                    <a asp-action="Create" class="btn btn-primary font-weight-bolder">Yeni Bot</a>
                </div>
            </div>
            <div class="card-body">
                @if (TempData["BotControlSuccess"] is string successMessage)
                {
                    <div class="alert alert-success" role="alert">@successMessage</div>
                }

                @if (TempData["BotControlError"] is string errorMessage)
                {
                    <div class="alert alert-danger" role="alert">@errorMessage</div>
                }

                @if (Model.Bots.Count == 0)
                {
                    <div class="alert alert-info mb-0" role="alert">
                        Henüz pilot bot yok. Yeni bot oluşturarak BTCUSDT testnet pilotunu başlatabilirsiniz.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-head-custom table-vertical-center">
                            <thead>
                                <tr>
                                    <th>Bot</th>
                                    <th>Strategy</th>
                                    <th>Exchange</th>
                                    <th>Pilot</th>
                                    <th>Worker</th>
                                    <th>Execution</th>
                                    <th class="text-right">Aksiyon</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var bot in Model.Bots)
                                {
                                    <tr>
                                        <td>
                                            <div class="font-weight-bolder">@bot.Name</div>
                                            <div class="text-muted small">Open orders: @bot.OpenOrderCount | Open positions: @bot.OpenPositionCount</div>
                                        </td>
                                        <td>
                                            <div class="font-weight-bolder">@bot.StrategyDisplayName</div>
                                            <div class="text-muted small">@bot.StrategyKey</div>
                                            @if (!bot.HasPublishedStrategyVersion)
                                            {
                                                <div class="text-danger small">Yayınlanmış strategy versiyonu yok</div>
                                            }
                                        </td>
                                        <td>
                                            <div class="font-weight-bolder">@bot.ExchangeAccountDisplayName</div>
                                            <div class="text-muted small">
                                                @(bot.ExchangeAccountIsActive ? "Active" : "Inactive") / @(bot.ExchangeAccountIsWritable ? "Writable" : "ReadOnly")
                                            </div>
                                        </td>
                                        <td>
                                            <div class="font-weight-bolder">@bot.Symbol</div>
                                            <div class="text-muted small">Qty: @bot.QuantityDisplay</div>
                                            <div class="text-muted small">Lev: @bot.LeverageDisplay | @bot.MarginType</div>
                                        </td>
                                        <td>
                                            <div class="font-weight-bolder">@bot.LastJobStatus</div>
                                            <div class="text-muted small">@(string.IsNullOrWhiteSpace(bot.LastJobErrorCode) ? "Hata yok" : bot.LastJobErrorCode)</div>
                                        </td>
                                        <td>
                                            <div class="font-weight-bolder">@bot.LastExecutionState</div>
                                            <div class="text-muted small">@(string.IsNullOrWhiteSpace(bot.LastExecutionFailureCode) ? "Failure yok" : bot.LastExecutionFailureCode)</div>
                                        </td>
                                        <td class="text-right">
                                            <div class="d-inline-flex align-items-center">
                                                <span class="badge @(bot.IsEnabled ? "badge-success" : "badge-secondary") mr-3">
                                                    @(bot.IsEnabled ? "Enabled" : "Disabled")
                                                </span>
                                                <a asp-action="Edit" asp-route-botId="@bot.BotId" class="btn btn-sm btn-light-primary mr-2">Düzenle</a>
                                                <form asp-action="SetEnabled" asp-route-botId="@bot.BotId" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="isEnabled" value="@(!bot.IsEnabled)" />
                                                    <button type="submit" class="btn btn-sm @(bot.IsEnabled ? "btn-light-danger" : "btn-light-success")">
                                                        @(bot.IsEnabled ? "Disable" : "Enable")
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
