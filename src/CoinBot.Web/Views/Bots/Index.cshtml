@model CoinBot.Web.ViewModels.Bots.BotManagementIndexViewModel
@{
    ViewData["Title"] = "Botlarım";
    ViewData["ActiveNav"] = "Bots";
    ViewData["PageDescription"] = "Botlarınızı kısa ve net şekilde yönetin.";
    ViewData["BreadcrumbItems"] = new[] { "CoinBot", "Botlarım" };
}

<div class="row" data-cb-user-bots-page>
    <div class="col-12">
        <div class="card card-custom gutter-b cb-card">
            <div class="card-body">
                <div class="cb-page-header align-items-start">
                    <div>
                        <div class="cb-page-eyebrow">Botlarım</div>
                        <h2 class="cb-page-title">Bot listesi</h2>
                        <p class="cb-page-description">Botunuzu görün, stratejisini bağlayın ve durumunu anlayın.</p>
                    </div>
                    <div class="cb-toolbar">
                        <a asp-controller="StrategyBuilder" asp-action="Index" class="btn btn-light-primary font-weight-bolder">Strateji oluştur</a>
                        <a asp-action="Create" class="btn btn-primary font-weight-bolder">Yeni Bot</a>
                    </div>
                </div>

                @if (TempData["BotControlSuccess"] is string successMessage)
                {
                    <div class="cb-validation-summary cb-validation-summary-success mt-6" role="alert">@successMessage</div>
                }

                @if (TempData["BotControlError"] is string errorMessage)
                {
                    <div class="cb-validation-summary cb-validation-summary-danger mt-6" role="alert">@errorMessage</div>
                }

                @if (Model.Bots.Count == 0)
                {
                    <div class="cb-validation-summary cb-validation-summary-info mt-6" role="status">
                        Henüz bot yok. Bot oluşturmadan önce strateji oluşturabilirsiniz.
                    </div>
                }
                else
                {
                    <div class="table-responsive mt-6">
                        <table class="table table-borderless mb-0" data-cb-user-bot-list>
                            <thead>
                                <tr>
                                    <th>Bot</th>
                                    <th>Durum</th>
                                    <th>Strateji</th>
                                    <th>Symbol</th>
                                    <th>Son durum</th>
                                    <th class="text-right">Aksiyon</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var bot in Model.Bots)
                                {
                                    var stateBadgeClass = bot.PilotStateLabel switch
                                    {
                                        "LIVE" => "cb-badge-danger",
                                        "SHADOW" => "cb-badge-info",
                                        "PAUSED" => "cb-badge-neutral",
                                        _ => "cb-badge-neutral"
                                    };
                                    var enabledLabel = bot.IsEnabled ? "Aktif" : "Kapalı";
                                    var toggleText = bot.IsEnabled ? "Kapat" : "Aç";
                                    var enableBlocked = !bot.IsEnabled && !bot.HasPublishedStrategyVersion;

                                    <tr data-cb-user-bot-row>
                                        <td>
                                            <div class="font-weight-bolder" data-cb-bot-name>@bot.Name</div>
                                            <div class="mt-2"><span class="cb-badge @(bot.RuntimeDirectionTone == "success" ? "cb-badge-success" : bot.RuntimeDirectionTone == "danger" ? "cb-badge-danger" : "cb-badge-neutral")" data-cb-bot-runtime-direction>@bot.RuntimeDirectionLabel</span></div>
                                            <div class="mt-2"><span class="cb-badge @(bot.DirectionModeTone == "success" ? "cb-badge-success" : bot.DirectionModeTone == "danger" ? "cb-badge-danger" : bot.DirectionModeTone == "info" ? "cb-badge-info" : "cb-badge-neutral")" data-cb-bot-direction-mode>@bot.DirectionModeLabel</span></div>
                                            <div class="text-muted small mt-2">@enabledLabel · @bot.DirectionModeSummary · @bot.RuntimeDirectionSummary</div>
                                        </td>
                                        <td>
                                            <span class="cb-badge @stateBadgeClass" data-cb-bot-state-badge data-cb-bot-state-value="@bot.PilotStateLabel">@bot.PilotStateLabel</span>
                                            <div class="text-muted small mt-2" data-cb-bot-state-summary>@bot.PilotStateSummary</div>
                                            @if (!string.IsNullOrWhiteSpace(bot.LongRegimeGateLabel))
                                            {
                                                var longRegimeBadgeClass = bot.LongRegimeGateTone == "success"
                                                    ? "cb-badge-success"
                                                    : bot.LongRegimeGateTone == "danger"
                                                        ? "cb-badge-danger"
                                                        : bot.LongRegimeGateTone == "warning"
                                                            ? "cb-badge-warning"
                                                            : "cb-badge-neutral";
                                                <div class="mt-3" data-cb-bot-long-regime-card>
                                                    <div><span class="cb-badge @longRegimeBadgeClass" data-cb-bot-long-regime-status>@bot.LongRegimeGateLabel</span></div>
                                                    <div class="text-muted small mt-2" data-cb-bot-long-regime-policy>@bot.LongRegimePolicySummary</div>
                                                    <div class="text-muted small mt-2" data-cb-bot-long-regime-live>@bot.LongRegimeLiveSummary</div>
                                                    <div class="small mt-2" data-cb-bot-long-regime-explain>@bot.LongRegimeExplainSummary</div>
                                                </div>
                                            }
                                        </td>
                                        <td>
                                            <div class="font-weight-bolder" data-cb-bot-strategy>@bot.StrategyDisplayName</div>
                                            @if (!bot.HasPublishedStrategyVersion)
                                            {
                                                <div class="text-muted small" data-cb-bot-strategy-missing>Strateji hazır değil</div>
                                                <a asp-controller="StrategyBuilder" asp-action="Index" class="small">Strateji oluştur</a>
                                            }
                                        </td>
                                        <td>
                                            <div class="font-weight-bolder" data-cb-bot-symbol>@bot.Symbol</div>
                                            <div class="text-muted small">Miktar: @bot.QuantityDisplay</div>
                                        </td>
                                        <td>
                                            <div class="font-weight-bolder" data-cb-bot-last-status>@(string.IsNullOrWhiteSpace(bot.LastJobErrorCode) ? bot.LastJobStatus : "Worker çalışmıyor")</div>
                                            <div class="text-muted small">@bot.UpdatedAtLabel</div>
                                            <div class="cb-admin-info-strip mt-3" data-cb-bot-ops-card>
                                                <div class="cb-admin-info-strip-title">Signal / Decision / Order</div>
                                                <div class="small mt-2"><strong data-cb-bot-ops-signal-label>Son signal:</strong> <span data-cb-bot-ops-signal>@bot.LatestSignalText</span></div>
                                                <div class="small mt-2"><strong data-cb-bot-ops-decision-label>Runtime decision:</strong> <span data-cb-bot-ops-decision>@bot.RuntimeDecisionCardText</span></div>
                                                @if (!string.IsNullOrWhiteSpace(bot.RuntimeDecisionCardSummary))
                                                {
                                                    <div class="text-muted small mt-2" data-cb-bot-ops-decision-summary>@bot.RuntimeDecisionCardSummary</div>
                                                }
                                                <div class="small mt-2"><strong data-cb-bot-ops-order-label>Order state:</strong> <span data-cb-bot-ops-order>@bot.OrderStateCardText</span></div>
                                                <div class="small mt-2"><strong data-cb-bot-ops-reason-label>Rejection / failure:</strong> <span data-cb-bot-ops-reason>@bot.RejectionFailureCodeText</span></div>
                                                <div class="row mt-3" data-cb-bot-ops-counters>
                                                    <div class="col-12 col-xl-6 mb-3 mb-xl-0" data-cb-bot-entry-counters>
                                                        <div class="font-weight-bolder">Entry</div>
                                                        <div class="text-muted small mt-2">generated: <span data-cb-bot-entry-generated>@bot.EntryGeneratedCount</span> · skipped: <span data-cb-bot-entry-skipped>@bot.EntrySkippedCount</span> · vetoed: <span data-cb-bot-entry-vetoed>@bot.EntryVetoedCount</span></div>
                                                        <div class="text-muted small mt-1">ordered: <span data-cb-bot-entry-ordered>@bot.EntryOrderedCount</span> · filled: <span data-cb-bot-entry-filled>@bot.EntryFilledCount</span></div>
                                                    </div>
                                                    <div class="col-12 col-xl-6" data-cb-bot-exit-counters>
                                                        <div class="font-weight-bolder">Exit</div>
                                                        <div class="text-muted small mt-2">generated: <span data-cb-bot-exit-generated>@bot.ExitGeneratedCount</span> · skipped: <span data-cb-bot-exit-skipped>@bot.ExitSkippedCount</span> · vetoed: <span data-cb-bot-exit-vetoed>@bot.ExitVetoedCount</span></div>
                                                        <div class="text-muted small mt-1">ordered: <span data-cb-bot-exit-ordered>@bot.ExitOrderedCount</span> · filled: <span data-cb-bot-exit-filled>@bot.ExitFilledCount</span></div>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-right">
                                            <div class="d-inline-flex align-items-center">
                                                <a asp-action="Edit" asp-route-botId="@bot.BotId" class="btn btn-sm btn-light-primary font-weight-bold mr-2" data-cb-bot-detail>Detay</a>
                                                <form asp-action="SetEnabled" asp-route-botId="@bot.BotId" method="post" class="d-inline" data-cb-bot-toggle>
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="isEnabled" value="@(!bot.IsEnabled)" />
                                                    <button type="submit"
                                                            class="btn btn-sm @(bot.IsEnabled ? "btn-light-danger" : "btn-light-success") font-weight-bold"
                                                            disabled="@(enableBlocked)"
                                                            data-cb-bot-start-blocked="@enableBlocked.ToString().ToLowerInvariant()">
                                                        @toggleText
                                                    </button>
                                                    @if (enableBlocked)
                                                    {
                                                        <div class="text-muted small mt-2" data-cb-bot-start-block-reason>Strateji hazır değil.</div>
                                                    }
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
