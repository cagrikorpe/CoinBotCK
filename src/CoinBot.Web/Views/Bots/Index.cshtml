@model CoinBot.Web.ViewModels.Bots.BotManagementIndexViewModel
@{
    ViewData["Title"] = "Botlarım";
    ViewData["ActiveNav"] = "Bots";
    ViewData["PageDescription"] = "Botlarınızı kısa ve net şekilde yönetin.";
    ViewData["BreadcrumbItems"] = new[] { "CoinBot", "Botlarım" };
}

<div class="row" data-cb-user-bots-page>
    <div class="col-12">
        <div class="card card-custom gutter-b cb-card">
            <div class="card-body">
                <div class="cb-page-header align-items-start">
                    <div>
                        <div class="cb-page-eyebrow">Botlarım</div>
                        <h2 class="cb-page-title">Bot listesi</h2>
                        <p class="cb-page-description">Botunuzu görün, stratejisini bağlayın ve durumunu anlayın.</p>
                    </div>
                    <div class="cb-toolbar">
                        <a asp-controller="StrategyBuilder" asp-action="Index" class="btn btn-light-primary font-weight-bolder">Strateji oluştur</a>
                        <a asp-action="Create" class="btn btn-primary font-weight-bolder">Yeni Bot</a>
                    </div>
                </div>

                @if (TempData["BotControlSuccess"] is string successMessage)
                {
                    <div class="cb-validation-summary cb-validation-summary-success mt-6" role="alert">@successMessage</div>
                }

                @if (TempData["BotControlError"] is string errorMessage)
                {
                    <div class="cb-validation-summary cb-validation-summary-danger mt-6" role="alert">@errorMessage</div>
                }

                @if (Model.Bots.Count == 0)
                {
                    <div class="cb-validation-summary cb-validation-summary-info mt-6" role="status">
                        Henüz bot yok. Bot oluşturmadan önce strateji oluşturabilirsiniz.
                    </div>
                }
                else
                {
                    <div class="table-responsive mt-6">
                        <table class="table table-borderless mb-0" data-cb-user-bot-list>
                            <thead>
                                <tr>
                                    <th>Bot</th>
                                    <th>Durum</th>
                                    <th>Strateji</th>
                                    <th>Symbol</th>
                                    <th>Son durum</th>
                                    <th class="text-right">Aksiyon</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var bot in Model.Bots)
                                {
                                    var stateBadgeClass = bot.PilotStateLabel switch
                                    {
                                        "LIVE" => "cb-badge-danger",
                                        "SHADOW" => "cb-badge-info",
                                        "PAUSED" => "cb-badge-neutral",
                                        _ => "cb-badge-neutral"
                                    };
                                    var enabledLabel = bot.IsEnabled ? "Aktif" : "Kapalı";
                                    var toggleText = bot.IsEnabled ? "Kapat" : "Aç";
                                    var enableBlocked = !bot.IsEnabled && !bot.HasPublishedStrategyVersion;

                                    <tr data-cb-user-bot-row>
                                        <td>
                                            <div class="font-weight-bolder" data-cb-bot-name>@bot.Name</div>
                                            <div class="text-muted small">@enabledLabel</div>
                                        </td>
                                        <td>
                                            <span class="cb-badge @stateBadgeClass" data-cb-bot-state-badge data-cb-bot-state-value="@bot.PilotStateLabel">@bot.PilotStateLabel</span>
                                            <div class="text-muted small mt-2" data-cb-bot-state-summary>@bot.PilotStateSummary</div>
                                        </td>
                                        <td>
                                            <div class="font-weight-bolder" data-cb-bot-strategy>@bot.StrategyDisplayName</div>
                                            @if (!bot.HasPublishedStrategyVersion)
                                            {
                                                <div class="text-muted small" data-cb-bot-strategy-missing>Strateji hazır değil</div>
                                                <a asp-controller="StrategyBuilder" asp-action="Index" class="small">Strateji oluştur</a>
                                            }
                                        </td>
                                        <td>
                                            <div class="font-weight-bolder" data-cb-bot-symbol>@bot.Symbol</div>
                                            <div class="text-muted small">Miktar: @bot.QuantityDisplay</div>
                                        </td>
                                        <td>
                                            <div class="font-weight-bolder" data-cb-bot-last-status>@(string.IsNullOrWhiteSpace(bot.LastJobErrorCode) ? bot.LastJobStatus : "Worker çalışmıyor")</div>
                                            <div class="text-muted small">@bot.UpdatedAtLabel</div>
                                        </td>
                                        <td class="text-right">
                                            <div class="d-inline-flex align-items-center">
                                                <a asp-action="Edit" asp-route-botId="@bot.BotId" class="btn btn-sm btn-light-primary font-weight-bold mr-2" data-cb-bot-detail>Detay</a>
                                                <form asp-action="SetEnabled" asp-route-botId="@bot.BotId" method="post" class="d-inline" data-cb-bot-toggle>
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="isEnabled" value="@(!bot.IsEnabled)" />
                                                    <button type="submit"
                                                            class="btn btn-sm @(bot.IsEnabled ? "btn-light-danger" : "btn-light-success") font-weight-bold"
                                                            disabled="@(enableBlocked)"
                                                            data-cb-bot-start-blocked="@enableBlocked.ToString().ToLowerInvariant()">
                                                        @toggleText
                                                    </button>
                                                    @if (enableBlocked)
                                                    {
                                                        <div class="text-muted small mt-2" data-cb-bot-start-block-reason>Strateji hazır değil.</div>
                                                    }
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
