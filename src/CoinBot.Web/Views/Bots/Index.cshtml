@model CoinBot.Web.ViewModels.Bots.BotManagementIndexViewModel
@{
    ViewData["Title"] = "Botlarım";
    ViewData["ActiveNav"] = "Bots";
    ViewData["PageDescription"] = "Pilot botlarını listeleyin, düzenleyin ve etkinleştirin.";
    ViewData["BreadcrumbItems"] = new[] { "Automation", "Botlarım" };
}

<div class="row">
    <div class="col-12">
        <div class="card card-custom gutter-b">
            <div class="card-header border-0 pt-5">
                <div class="card-title">
                    <div>
                        <div class="text-muted font-weight-bold text-uppercase mb-1">Pilot Bots</div>
                        <h2 class="mb-0">Bot listesi</h2>
                    </div>
                </div>
                <div class="card-toolbar">
                    <a asp-action="Create" class="btn btn-primary font-weight-bolder">Yeni Bot</a>
                </div>
            </div>
            <div class="card-body">
                @if (TempData["BotControlSuccess"] is string successMessage)
                {
                    <div class="alert alert-success" role="alert">@successMessage</div>
                }

                @if (TempData["BotControlError"] is string errorMessage)
                {
                    <div class="alert alert-danger" role="alert">@errorMessage</div>
                }

                @if (Model.Bots.Count == 0)
                {
                    <div class="alert alert-info mb-0" role="alert">
                        Henüz pilot bot yok. Yeni bot oluşturarak BTCUSDT testnet pilotunu başlatabilirsiniz.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-head-custom table-vertical-center">
                            <thead>
                                <tr>
                                    <th>Bot</th>
                                    <th>Strategy</th>
                                    <th>Exchange</th>
                                    <th>Pilot</th>
                                    <th>Worker</th>
                                    <th>Execution</th>
                                    <th class="text-right">Aksiyon</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var bot in Model.Bots)
                                {
                                    <tr>
                                        <td>
                                            <div class="font-weight-bolder">@bot.Name</div>
                                            <div class="text-muted small">Open orders: @bot.OpenOrderCount | Open positions: @bot.OpenPositionCount</div>
                                            <div class="text-muted small">Updated: @bot.UpdatedAtLabel</div>
                                        </td>
                                        <td>
                                            <div class="font-weight-bolder">@bot.StrategyDisplayName</div>
                                            <div class="text-muted small">@bot.StrategyKey</div>
                                            @if (!bot.HasPublishedStrategyVersion)
                                            {
                                                <div class="text-danger small">Yayınlanmış strategy versiyonu yok</div>
                                            }
                                        </td>
                                        <td>
                                            <div class="font-weight-bolder">@bot.ExchangeAccountDisplayName</div>
                                            <div class="text-muted small">
                                                @(bot.ExchangeAccountIsActive ? "Active" : "Inactive") / @(bot.ExchangeAccountIsWritable ? "Writable" : "ReadOnly")
                                            </div>
                                        </td>
                                        <td>
                                            <div class="font-weight-bolder">@bot.Symbol</div>
                                            <div class="text-muted small">Qty: @bot.QuantityDisplay</div>
                                            <div class="text-muted small">Lev: @bot.LeverageDisplay | @bot.MarginType</div>
                                        </td>
                                        <td>
                                            <div class="font-weight-bolder">@bot.LastJobStatus</div>
                                            <div class="text-muted small">@(string.IsNullOrWhiteSpace(bot.LastJobErrorCode) ? "Hata yok" : bot.LastJobErrorCode)</div>
                                        </td>
                                        <td>
                                            <div class="font-weight-bolder">@bot.LastExecutionState</div>
                                            <div class="text-muted small">@(string.IsNullOrWhiteSpace(bot.LastExecutionFailureCode) ? "Failure yok" : bot.LastExecutionFailureCode)</div>
                                            <div class="text-muted small" data-cb-bot-exec-submit>@bot.LastExecutionSubmitStatusText</div>
                                            <div class="text-muted small" data-cb-bot-exec-retry>@bot.LastExecutionRetryText</div>
                                            <div class="text-muted small" data-cb-bot-exec-protection>@bot.LastExecutionProtectionText</div>
                                            @if (!string.IsNullOrWhiteSpace(bot.LastExecutionStageText))
                                            {
                                                <div class="text-muted small" data-cb-bot-exec-stage>@bot.LastExecutionStageText</div>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(bot.LastExecutionTransitionText))
                                            {
                                                <div class="text-muted small" data-cb-bot-exec-transition>@bot.LastExecutionTransitionText</div>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(bot.LastExecutionCorrelationText))
                                            {
                                                <div class="text-muted small" data-cb-bot-exec-correlation>@bot.LastExecutionCorrelationText</div>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(bot.LastExecutionClientOrderText))
                                            {
                                                <div class="text-muted small" data-cb-bot-exec-client-order>@bot.LastExecutionClientOrderText</div>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(bot.LastExecutionDuplicateText))
                                            {
                                                <div class="small text-warning" data-cb-bot-exec-duplicate>@bot.LastExecutionDuplicateText</div>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(bot.LastExecutionBlockDetail))
                                            {
                                                <div class="small text-dark">@bot.LastExecutionBlockDetail</div>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(bot.MarketDataBadgeText) ||
                                                 !string.IsNullOrWhiteSpace(bot.DecisionText) ||
                                                 !string.IsNullOrWhiteSpace(bot.DecisionSummaryText) ||
                                                 !string.IsNullOrWhiteSpace(bot.LastCandleAtLabel) ||
                                                 !string.IsNullOrWhiteSpace(bot.DataAgeText) ||
                                                 !string.IsNullOrWhiteSpace(bot.ContinuityStateText) ||
                                                 !string.IsNullOrWhiteSpace(bot.ContinuityGapText) ||
                                                 !string.IsNullOrWhiteSpace(bot.AffectedMarketText) ||
                                                 !string.IsNullOrWhiteSpace(bot.StaleReasonText))
                                            {
                                                <div class="mt-2 p-2 rounded bg-light" data-cb-bot-market-diagnostics>
                                                    @if (!string.IsNullOrWhiteSpace(bot.MarketDataBadgeText))
                                                    {
                                                        <div class="mb-1">
                                                            <span class="badge badge-warning" data-cb-bot-market-badge>@bot.MarketDataBadgeText</span>
                                                        </div>
                                                    }
                                                    @if (!string.IsNullOrWhiteSpace(bot.StaleReasonText))
                                                    {
                                                        <div class="small text-dark" data-cb-bot-market-reason>Reason: @bot.StaleReasonText</div>
                                                    }
                                                    @if (!string.IsNullOrWhiteSpace(bot.DecisionText))
                                                    {
                                                        <div class="small text-dark" data-cb-bot-decision>@bot.DecisionText</div>
                                                    }
                                                    @if (!string.IsNullOrWhiteSpace(bot.DecisionReasonCodeText))
                                                    {
                                                        <div class="text-muted small" data-cb-bot-decision-reason-code>@bot.DecisionReasonCodeText</div>
                                                    }
                                                    @if (!string.IsNullOrWhiteSpace(bot.DecisionSummaryText))
                                                    {
                                                        <div class="text-muted small" data-cb-bot-decision-summary>@bot.DecisionSummaryText</div>
                                                    }
                                                    @if (!string.IsNullOrWhiteSpace(bot.DecisionAtText))
                                                    {
                                                        <div class="text-muted small" data-cb-bot-decision-at>Decision at: @bot.DecisionAtText</div>
                                                    }
                                                    @if (!string.IsNullOrWhiteSpace(bot.AffectedMarketText))
                                                    {
                                                        <div class="text-muted small" data-cb-bot-market-affected>Affected: @bot.AffectedMarketText</div>
                                                    }
                                                    @if (!string.IsNullOrWhiteSpace(bot.LastCandleAtLabel))
                                                    {
                                                        <div class="text-muted small" data-cb-bot-market-candle>Last candle: @bot.LastCandleAtLabel</div>
                                                    }
                                                    @if (!string.IsNullOrWhiteSpace(bot.DataAgeText))
                                                    {
                                                        <div class="text-muted small" data-cb-bot-market-age>Data age: @bot.DataAgeText</div>
                                                    }
                                                    @if (!string.IsNullOrWhiteSpace(bot.MarketStaleThresholdText))
                                                    {
                                                        <div class="text-muted small" data-cb-bot-market-threshold>Stale threshold: @bot.MarketStaleThresholdText</div>
                                                    }
                                                    @if (!string.IsNullOrWhiteSpace(bot.ContinuityStateText) || !string.IsNullOrWhiteSpace(bot.ContinuityGapText))
                                                    {
                                                        <div class="text-muted small" data-cb-bot-market-continuity>
                                                            Continuity: @(string.IsNullOrWhiteSpace(bot.ContinuityStateText) ? "N/A" : bot.ContinuityStateText)
                                                            @if (!string.IsNullOrWhiteSpace(bot.ContinuityGapText))
                                                            {
                                                                <text> | Gap: @bot.ContinuityGapText</text>
                                                            }
                                                        </div>
                                                    }
                                                    @if (!string.IsNullOrWhiteSpace(bot.ContinuityGapStartedText))
                                                    {
                                                        <div class="text-muted small" data-cb-bot-market-gap-start>Gap start: @bot.ContinuityGapStartedText</div>
                                                    }
                                                    @if (!string.IsNullOrWhiteSpace(bot.ContinuityGapLastSeenText))
                                                    {
                                                        <div class="text-muted small" data-cb-bot-market-gap-last-seen>Gap last seen: @bot.ContinuityGapLastSeenText</div>
                                                    }
                                                    @if (!string.IsNullOrWhiteSpace(bot.ContinuityRecoveryText))
                                                    {
                                                        <div class="text-muted small" data-cb-bot-market-recovery>Recovered: @bot.ContinuityRecoveryText</div>
                                                    }
                                                </div>
                                            }
                                            @if (bot.IsCooldownActive)
                                            {
                                                <div class="mt-2">
                                                    <span class="badge badge-warning" data-cb-bot-cooldown-badge>Cooldown aktif</span>
                                                </div>
                                                <div class="text-muted small">
                                                    Blok bitişi: @bot.CooldownBlockedUntilLabel
                                                </div>
                                                <div class="text-muted small">
                                                    Kalan: @bot.CooldownRemainingText
                                                </div>
                                            }
                                            <div class="text-muted small">Last execution: @bot.LastExecutionAtLabel</div>
                                        </td>
                                        <td class="text-right">
                                            <div class="d-inline-flex align-items-center">
                                                <span class="badge @(bot.IsEnabled ? "badge-success" : "badge-secondary") mr-3">
                                                    @(bot.IsEnabled ? "Enabled" : "Disabled")
                                                </span>
                                                <a asp-action="Edit" asp-route-botId="@bot.BotId" class="btn btn-sm btn-light-primary mr-2">Düzenle</a>
                                                <form asp-action="SetEnabled" asp-route-botId="@bot.BotId" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="isEnabled" value="@(!bot.IsEnabled)" />
                                                    <button type="submit" class="btn btn-sm @(bot.IsEnabled ? "btn-light-danger" : "btn-light-success")">
                                                        @(bot.IsEnabled ? "Disable" : "Enable")
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>


