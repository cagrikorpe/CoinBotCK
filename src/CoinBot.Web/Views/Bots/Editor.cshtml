@model CoinBot.Web.ViewModels.Bots.BotManagementEditorViewModel
@using CoinBot.Domain.Enums
@{
    ViewData["Title"] = Model.IsEditMode ? "Bot Düzenle" : "Yeni Bot";
    ViewData["ActiveNav"] = "Bots";
    ViewData["PageDescription"] = "Botun temel ayarlarını sade şekilde yönetin.";
    ViewData["BreadcrumbItems"] = new[] { "CoinBot", "Botlarım", Model.IsEditMode ? "Düzenle" : "Yeni Bot" };
    var hasStrategies = Model.StrategyOptions.Count > 0;
    var hasReadyStrategy = Model.StrategyOptions.Any(option => option.IsReady);
}

<div class="row">
    <div class="col-xl-8">
        <div class="card card-custom gutter-b cb-card">
            <div class="card-body">
                <div class="cb-page-header align-items-start">
                    <div>
                        <div class="cb-page-eyebrow">Botlarım</div>
                        <h2 class="cb-page-title">@(Model.IsEditMode ? "Bot düzenle" : "Yeni bot oluştur")</h2>
                        <p class="cb-page-description">Botun stratejisini, symbol bilgisini ve durumunu belirleyin.</p>
                    </div>
                    <div class="cb-toolbar">
                        <a asp-controller="StrategyBuilder" asp-action="Index" class="btn btn-light-primary font-weight-bolder">Strateji oluştur</a>
                    </div>
                </div>

                <div asp-validation-summary="ModelOnly" class="cb-validation-summary cb-validation-summary-danger mt-6" role="alert"></div>

                @if (!hasStrategies)
                {
                    <div class="cb-validation-summary cb-validation-summary-info mt-6" role="status" data-cb-bot-no-strategy-message>
                        Önce strateji oluşturun. Strateji olmadan bot başlatılamaz.
                    </div>
                }
                else if (!hasReadyStrategy)
                {
                    <div class="cb-validation-summary cb-validation-summary-info mt-6" role="status" data-cb-bot-no-ready-strategy-message>
                        Strateji hazır değil. Bot kaydedilebilir, ama hazır olana kadar başlatılamaz.
                    </div>
                }

                <form asp-action="@(Model.IsEditMode ? "Edit" : "Create")"
                      asp-route-botId="@(Model.BotId)"
                      method="post"
                      class="mt-6">
                    @Html.AntiForgeryToken()

                    <div class="form-group">
                        <label asp-for="Form.Name">Bot adı</label>
                        <input asp-for="Form.Name" class="form-control" />
                        <span asp-validation-for="Form.Name" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Form.StrategyKey">Strateji</label>
                        <select asp-for="Form.StrategyKey" class="form-control" disabled="@(!hasStrategies)" data-cb-bot-strategy-select>
                            <option value="">Strateji seçin</option>
                            @foreach (var option in Model.StrategyOptions)
                            {
                                <option value="@option.Value" data-cb-bot-strategy-ready="@option.IsReady.ToString().ToLowerInvariant()">@option.Label</option>
                            }
                        </select>
                        <span asp-validation-for="Form.StrategyKey" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Form.Symbol">Symbol</label>
                        <select asp-for="Form.Symbol" class="form-control">
                            @foreach (var option in Model.SymbolOptions)
                            {
                                <option value="@option.Value">@option.Label</option>
                            }
                        </select>
                        <span asp-validation-for="Form.Symbol" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Form.Quantity">Miktar</label>
                        <input asp-for="Form.Quantity" class="form-control" />
                        <small class="form-text text-muted">Boş bırakılırsa sistem uygun miktarı kullanır.</small>
                        <span asp-validation-for="Form.Quantity" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Form.DirectionMode">Yön modu</label>
                        <select asp-for="Form.DirectionMode" class="form-control" data-cb-bot-direction-mode-select>
                            <option value="@TradingBotDirectionMode.LongOnly">LongOnly</option>
                            <option value="@TradingBotDirectionMode.ShortOnly">ShortOnly</option>
                            <option value="@TradingBotDirectionMode.LongShort">LongShort</option>
                        </select>
                        <small class="form-text text-muted">Runtime giriş yönü bu moda göre fail-closed filtrelenir.</small>
                        <span asp-validation-for="Form.DirectionMode" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Form.ExchangeAccountId">Binance hesabı</label>
                        <select asp-for="Form.ExchangeAccountId" class="form-control">
                            <option value="">Tek aktif hesabı kullan</option>
                            @foreach (var option in Model.ExchangeAccountOptions)
                            {
                                <option value="@option.Value">@option.Label</option>
                            }
                        </select>
                        <span asp-validation-for="Form.ExchangeAccountId" class="text-danger"></span>
                    </div>

                    <div class="form-row">
                        <div class="form-group col-md-6">
                            <label asp-for="Form.Leverage">Kaldıraç</label>
                            <select asp-for="Form.Leverage" class="form-control">
                                <option value="1">1</option>
                            </select>
                        </div>
                        <div class="form-group col-md-6">
                            <label asp-for="Form.MarginType">Margin</label>
                            <select asp-for="Form.MarginType" class="form-control">
                                <option value="ISOLATED">ISOLATED</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-group form-check">
                        <input asp-for="Form.IsEnabled" class="form-check-input" disabled="@(!hasReadyStrategy)" />
                        <label asp-for="Form.IsEnabled" class="form-check-label">Kaydettikten sonra bot açık olsun</label>
                        @if (!hasReadyStrategy)
                        {
                            <div class="text-muted small mt-2" data-cb-bot-enable-block-reason>Strateji hazır değil.</div>
                        }
                    </div>

                    <div class="d-flex justify-content-between align-items-center">
                        <a asp-action="Index" class="btn btn-light">Listeye dön</a>
                        <button type="submit" class="btn btn-primary" disabled="@(!hasStrategies)">Kaydet</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
