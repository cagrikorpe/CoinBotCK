@using CoinBot.Application.Abstractions.Dashboard
@model UserDashboardPortfolioSnapshot
@{
    ViewData["Title"] = "İşlemler";
    ViewData["ActiveNav"] = "Positions";
    ViewData["PageDescription"] = "Pozisyon, emir ve kâr zarar durumunuzu sade şekilde izleyin.";
    ViewData["BreadcrumbItems"] = new[] { "CoinBot", "İşlemler" };
    var defaultTab = (ViewData["DefaultTab"]?.ToString() ?? "positions").ToLowerInvariant();
}

@section Scripts {
    <script src="~/js/positions-foundation.js" asp-append-version="true"></script>
}

<div class="row" data-cb-positions-page data-cb-user-exec-page data-cb-positions-default-tab="@defaultTab">
    <div class="col-12">
        <div class="card card-custom gutter-b cb-card">
            <div class="card-body">
                <div class="cb-page-header">
                    <div>
                        <div class="cb-page-eyebrow">İşlemler</div>
                        <h2 class="cb-page-title">İşlemler</h2>
                        <p class="cb-page-description">Açık pozisyon, emir ve kâr zarar durumunuzu kısa özetle takip edin.</p>
                    </div>
                    <div class="cb-toolbar">
                        <span class="cb-badge cb-badge-info" data-cb-positions-sync-status>@Model.SyncStatusLabel</span>
                        <button type="button" class="btn btn-light-primary font-weight-bold" data-cb-positions-refresh>Yenile</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12" data-cb-positions-panel="content">
        @await Html.PartialAsync("Positions/_SummaryCards", Model)
    </div>

    <div class="col-12" data-cb-positions-panel="content">
        @await Html.PartialAsync("Positions/_Toolbar")
    </div>

    <div class="col-12" data-cb-positions-panel="content">
        <div class="card card-custom gutter-b cb-card">
            <div class="card-body pb-2">
                <div class="cb-tabs cb-tabs-headerless" data-cb-user-exec-tabs>
                    <button type="button" class="cb-tab is-active" data-cb-positions-tab-trigger="positions">Pozisyonlar</button>
                    <button type="button" class="cb-tab" data-cb-positions-tab-trigger="orders">Emirler</button>
                    <button type="button" class="cb-tab" data-cb-positions-tab-trigger="history">İşlem Geçmişi</button>
                    <button type="button" class="cb-tab" data-cb-positions-tab-trigger="pnl">Kâr / Zarar</button>
                </div>
            </div>
        </div>

        <div data-cb-positions-tab-panel="positions">
            @await Html.PartialAsync("Positions/_OpenPositionsCard", Model)
        </div>

        <div class="d-none" data-cb-positions-tab-panel="orders">
            @await Html.PartialAsync("Positions/_OrderHistoryCard", Model)
        </div>

        <div class="d-none" data-cb-positions-tab-panel="history">
            @await Html.PartialAsync("Positions/_ClosedPositionsCard", Model)
        </div>

        <div class="d-none" data-cb-positions-tab-panel="pnl">
            @await Html.PartialAsync("Positions/_HelpCard", Model)
        </div>
    </div>

    <div class="col-12">
        @await Html.PartialAsync("Positions/_StatePanels")
    </div>
</div>
