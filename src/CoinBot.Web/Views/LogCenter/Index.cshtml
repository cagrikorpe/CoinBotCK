@model CoinBot.Application.Abstractions.Administration.LogCenterPageSnapshot
@using System.Linq
@using CoinBot.Application.Abstractions.Administration
@{
    ViewData["Title"] = "Log Merkezi";
    ViewData["ActiveNav"] = "LogCenter";
    ViewData["PageDescription"] = "DecisionTrace, ExecutionTrace, AdminAuditLog, Incident timeline ve Approval action history tek merkezde, masked ve filtrelenebilir halde gösterilir.";
    ViewData["BreadcrumbItems"] = new[] { "System", "Log Merkezi" };

    var focusReference = ViewData["LogCenterFocusReference"]?.ToString();

    LogCenterEntrySnapshot? ResolveSelectedEntry()
    {
        if (!string.IsNullOrWhiteSpace(focusReference))
        {
            var matchedEntry = Model.Entries.FirstOrDefault(entry =>
                string.Equals(entry.Reference, focusReference, StringComparison.OrdinalIgnoreCase) ||
                string.Equals(entry.CorrelationId, focusReference, StringComparison.OrdinalIgnoreCase) ||
                string.Equals(entry.DecisionId, focusReference, StringComparison.OrdinalIgnoreCase) ||
                string.Equals(entry.ExecutionAttemptId, focusReference, StringComparison.OrdinalIgnoreCase) ||
                string.Equals(entry.IncidentReference, focusReference, StringComparison.OrdinalIgnoreCase) ||
                string.Equals(entry.ApprovalReference, focusReference, StringComparison.OrdinalIgnoreCase));

            if (matchedEntry is not null)
            {
                return matchedEntry;
            }
        }

        return Model.Entries.FirstOrDefault();
    }

    var selectedEntry = ResolveSelectedEntry();
    ViewData["LogCenterSelectedEntry"] = selectedEntry;
}

@section Scripts {
    <script src="~/js/log-center-ui.js" asp-append-version="true"></script>
}

<div class="row" data-cb-logcenter-page data-cb-logcenter-focus-reference="@(selectedEntry?.Reference ?? string.Empty)">
    <div class="col-12">
        <div class="card card-custom gutter-b cb-card">
            <div class="card-body">
                <div class="cb-page-header">
                    <div>
                        <div class="cb-page-eyebrow">Log Center</div>
                        <h2 class="cb-page-title">Operasyonel log merkezi</h2>
                        <p class="cb-page-description">Trace, audit, incident ve approval zincirleri DB/read-model üzerinden tek merkezde, masked ve export edilebilir şekilde görünür.</p>
                    </div>
                    <div class="cb-toolbar">
                        <a asp-area="Admin" asp-controller="Admin" asp-action="Audit" class="btn btn-light-primary font-weight-bold">Admin audit</a>
                        <a asp-area="Admin" asp-controller="Admin" asp-action="SystemHealth" class="btn btn-light-primary font-weight-bold">Sistem sağlığı</a>
                        <a asp-area="Admin" asp-controller="Admin" asp-action="Settings" class="btn btn-light-warning font-weight-bold">Retention ayarları</a>
                    </div>
                </div>

                <div class="cb-admin-info-strip cb-admin-info-strip-info mt-6">
                    <div>
                        <div class="cb-admin-info-strip-title">Gerçek veri yüzeyi</div>
                        <div class="cb-admin-info-strip-text">Snapshot, retention ve export akışı aynı read-model ve audit katmanını kullanır. Hassas payload alanları controller/export seviyesinde maskeleme ile korunur.</div>
                    </div>
                    <span class="cb-admin-info-strip-meta">DB-backed</span>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12">
        @await Html.PartialAsync("LogCenter/_SummaryMeta", Model.Summary)
    </div>

    <div class="col-12">
        @await Html.PartialAsync("LogCenter/_Toolbar", Model)
    </div>

    <div class="col-xl-8">
        @await Html.PartialAsync("LogCenter/_LogList", Model)
    </div>

    <div class="col-xl-4">
        @await Html.PartialAsync("LogCenter/_TraceInfoCard", Model)
        @await Html.PartialAsync("LogCenter/_HelpCard", Model)
    </div>

    <div class="col-12">
        @await Html.PartialAsync("LogCenter/_StatePanels", Model)
    </div>
</div>

@await Html.PartialAsync("LogCenter/_DetailDrawer", Model)
