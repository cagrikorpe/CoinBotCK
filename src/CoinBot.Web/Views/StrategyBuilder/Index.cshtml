@{
    var runtimeConfigJson = ViewData["StrategyBuilderRuntimeConfigJson"] as string ?? "{}";
    ViewData["Title"] = "Strateji Oluştur";
    ViewData["ActiveNav"] = "StrategyBuilder";
    ViewData["PageDescription"] = "Stratejinizi şablondan başlatın ve botunuza bağlayın.";
    ViewData["BreadcrumbItems"] = new[] { "CoinBot", "Strateji Oluştur" };
}

@section Scripts {
    <script src="~/js/strategy-builder-foundation.js" asp-append-version="true"></script>
}

<div class="row" data-cb-strategy-builder data-cb-strategy-scenario="blank" data-cb-market-mode="spot" data-cb-runtime-config='@runtimeConfigJson'>
    <div class="col-12">
        <div class="card card-custom gutter-b cb-card">
            <div class="card-body">
                <div class="cb-page-header align-items-start">
                    <div>
                        <div class="cb-page-eyebrow">Strateji</div>
                        <h2 class="cb-page-title">Strateji oluştur</h2>
                        <p class="cb-page-description">Bir şablon seçin, strateji taslağını oluşturun ve bot ekranında bu stratejiyi bağlayın.</p>
                    </div>
                    <div class="cb-toolbar">
                        <a asp-controller="Bots" asp-action="Create" class="btn btn-light-primary font-weight-bolder">Bota bağla</a>
                    </div>
                </div>

                @if (TempData["StrategyBuilderTemplateSuccess"] is string templateSuccess && !string.IsNullOrWhiteSpace(templateSuccess))
                {
                    <div class="cb-validation-summary cb-validation-summary-success mt-6" role="alert" data-cb-template-draft-success>@templateSuccess</div>
                }

                @if (TempData["StrategyBuilderTemplateError"] is string templateError && !string.IsNullOrWhiteSpace(templateError))
                {
                    <div class="cb-validation-summary cb-validation-summary-danger mt-6" role="alert" data-cb-template-draft-error>@templateError</div>
                }
            </div>
        </div>
    </div>

    <div class="col-xl-8">
        @await Html.PartialAsync("StrategyBuilder/_TemplateGallery")
    </div>

    <div class="col-xl-4">
        <div class="card card-custom gutter-b cb-card" data-cb-strategy-bind-card>
            <div class="card-body">
                <div class="cb-section-title">Bot ile bağla</div>
                <p class="cb-page-description mt-2">Taslak oluştuktan sonra Botlarım ekranında strateji seçimi yapabilirsiniz.</p>
                <a asp-controller="Bots" asp-action="Create" class="btn btn-primary font-weight-bolder">Yeni bot oluştur</a>
                <div class="text-muted font-size-sm mt-4">Strateji hazır değilse bot başlatılamaz.</div>
            </div>
        </div>
    </div>
</div>
