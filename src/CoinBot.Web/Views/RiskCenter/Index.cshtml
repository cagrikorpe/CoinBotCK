@model CoinBot.Web.Controllers.RiskCenterViewModel

@{
    ViewData["Title"] = "Risk Merkezi";
    ViewData["ActiveNav"] = "RiskCenter";
    ViewData["PageDescription"] = "Botların işlem açabilmesi için kullanıcı risk tercihlerini kaydedin.";
    ViewData["BreadcrumbItems"] = new[] { "Trade Lab", "Risk Merkezi" };
}

<div class="row">
    <div class="col-12">
        <div class="card card-custom gutter-b cb-card">
            <div class="card-body">
                <div class="cb-page-header">
                    <div>
                        <div class="cb-page-eyebrow">Risk tercihi</div>
                        <h2 class="cb-page-title">Risk Merkezi</h2>
                        <p class="cb-page-description">Botların işlem açabilmesi için önce risk limitlerinizi kaydedin.</p>
                    </div>
                    <div class="cb-toolbar">
                        <span class="cb-badge @(Model.HasProfile && !Model.Input.KillSwitchEnabled ? "cb-badge-success" : "cb-badge-warning")">@Model.StatusText</span>
                    </div>
                </div>

                @if (TempData["RiskCenterSuccess"] is string successMessage)
                {
                    <div class="alert alert-success mt-6 mb-0" role="alert">@successMessage</div>
                }

                <div class="cb-mini-helper-card mt-6">
                    <div class="cb-rule-setting-header">
                        <strong>Durum</strong>
                        @if (Model.LastUpdatedAtUtc is not null)
                        {
                            <span class="text-muted font-size-sm">Son kayıt: @Model.LastUpdatedAtUtc.Value.ToString("yyyy-MM-dd HH:mm") UTC</span>
                        }
                    </div>
                    <div class="text-muted font-size-sm mt-2">@Model.StatusSummary</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-8">
        @await Html.PartialAsync("RiskCenter/_PolicyForm", Model)
    </div>

    <div class="col-xl-4">
        <div class="card card-custom gutter-b cb-card">
            <div class="card-body">
                <div class="cb-section-title">Ne yapmalıyım?</div>
                <p class="text-muted font-size-sm mt-3 mb-4">Limitleri korumacı başlayın. Kaydettikten sonra bot ekranında paused nedeni değişecektir.</p>
                <div class="cb-rule-setting-list">
                    <div class="cb-rule-setting-item">
                        <div class="cb-rule-setting-header"><strong>Kaldıraç</strong><span class="cb-badge cb-badge-info">1x önerilir</span></div>
                        <div class="text-muted font-size-sm mt-2">İlk testte düşük kaldıraç daha güvenlidir.</div>
                    </div>
                    <div class="cb-rule-setting-item">
                        <div class="cb-rule-setting-header"><strong>Acil durdurma</strong><span class="cb-badge cb-badge-warning">Kapalı tutun</span></div>
                        <div class="text-muted font-size-sm mt-2">Acil durdurma açık kalırsa bot işlem açmaz.</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
