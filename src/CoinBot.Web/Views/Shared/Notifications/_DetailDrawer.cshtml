<aside class="cb-drawer cb-notification-drawer" id="cb_notifications_detail_drawer" aria-hidden="true">
    <div class="cb-drawer-header">
        <div>
            <div class="cb-drawer-eyebrow" id="cb_notifications_drawer_eyebrow">Notification Detail</div>
            <h5 class="cb-drawer-title mb-0" id="cb_notifications_drawer_title">Bildirim detayı</h5>
        </div>
        <button type="button" class="btn btn-xs btn-icon btn-light" data-cb-drawer-close>
            <span>&times;</span>
        </button>
    </div>
    <div class="cb-drawer-body">
        <div class="cb-inline-stack mb-4">
            <span class="cb-badge cb-badge-danger" id="cb_notifications_drawer_severity">Kritik</span>
            <span class="cb-badge cb-badge-warning" id="cb_notifications_drawer_category">Risk</span>
            <span class="cb-badge cb-badge-neutral" id="cb_notifications_drawer_read">Okunmamış</span>
        </div>

        <div class="cb-open-close-grid mb-5">
            <div class="cb-rule-setting-item">
                <span class="cb-form-label">Zaman</span>
                <strong class="cb-mono d-block mt-2" id="cb_notifications_drawer_time">21 Mar · 09:42</strong>
            </div>
            <div class="cb-rule-setting-item">
                <span class="cb-form-label">İlgili modül</span>
                <strong class="d-block mt-2" id="cb_notifications_drawer_module">Risk Merkezi</strong>
            </div>
        </div>

        <div class="cb-section">
            <div class="cb-section-title">Detay özeti</div>
            <p class="text-muted mb-0" id="cb_notifications_drawer_message">Bildirim, severity ve kategori bağlamı ile birlikte kısa ve operasyonel bir açıklamayla gösterilir.</p>
        </div>

        <div class="cb-section mt-6">
            <div class="cb-section-title">İlgili etiketler</div>
            <div class="cb-ai-chip-list mt-4">
                <span class="cb-badge cb-badge-neutral" id="cb_notifications_drawer_tag1">BTCUSDT</span>
                <span class="cb-badge cb-badge-neutral" id="cb_notifications_drawer_tag2">Risk limit</span>
                <span class="cb-badge cb-badge-neutral" id="cb_notifications_drawer_tag3">Manual review</span>
            </div>
        </div>

        <div class="cb-section mt-6">
            <div class="cb-section-title">Önerilen sonraki adım</div>
            <div class="cb-bot-mini-validation" id="cb_notifications_drawer_action">İlgili modüle geçerek sınır, ayar veya bot durumunu kontrollü şekilde gözden geçir.</div>
        </div>
    </div>
    <div class="cb-drawer-footer">
        <button type="button" class="btn btn-light-primary font-weight-bold" data-toggle="modal" data-target="#cb_confirm_modal" data-cb-modal-title="Okundu işaretle" data-cb-modal-message="Read/unread persist bu fazda bağlı değildir; aksiyon yalnızca foundation seviyesindedir." data-cb-modal-confirm="İşaretle">Okundu işaretle</button>
        <button type="button" class="btn btn-primary font-weight-bolder" id="cb_notifications_drawer_cta" data-toggle="modal" data-target="#cb_confirm_modal" data-cb-modal-title="İlgili ekrana git" data-cb-modal-message="İlgili modüle yönlendirme CTA'sı foundation seviyesinde hazırlanmıştır." data-cb-modal-confirm="Tamam">İlgili ekrana git</button>
        <button type="button" class="btn btn-light" data-cb-drawer-close>Kapat</button>
    </div>
</aside>
