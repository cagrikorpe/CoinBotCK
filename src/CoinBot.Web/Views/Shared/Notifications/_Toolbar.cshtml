<div class="card card-custom gutter-b cb-card">
    <div class="card-body">
        <div class="cb-filter-bar-wrap cb-filter-bar-wrap-5">
            <div class="position-relative">
                <span class="cb-bot-search-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="none">
                        <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"></circle>
                        <path d="m20 20-3.5-3.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
                    </svg>
                </span>
                <input type="text" class="form-control cb-form-control pl-12" placeholder="Bildirim ara (placeholder)" />
            </div>
            <select class="form-control cb-form-control" data-cb-notifications-filter-group="severity">
                <option value="all">Seviye: Tümü</option>
                <option value="critical">Kritik</option>
                <option value="warning">Uyarı</option>
                <option value="info">Bilgi</option>
            </select>
            <select class="form-control cb-form-control" data-cb-notifications-filter-group="read">
                <option value="all">Okunma: Tümü</option>
                <option value="unread">Okunmamış</option>
                <option value="read">Okunmuş</option>
            </select>
            <select class="form-control cb-form-control" data-cb-notifications-filter-group="category">
                <option value="all">Kategori: Tümü</option>
                <option value="ai">AI</option>
                <option value="risk">Risk</option>
                <option value="bot">Bot durumu</option>
            </select>
            <select class="form-control cb-form-control" data-cb-notifications-sort>
                <option value="latest">Sıralama: En yeni</option>
                <option value="priority">Öncelik</option>
            </select>
        </div>

        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mt-4">
            <div class="cb-chip-group cb-chip-group-sm">
                <span class="cb-chip is-active" id="cb_notifications_filter_chip_severity">Seviye: Tümü</span>
                <span class="cb-chip is-active" id="cb_notifications_filter_chip_read">Okunma: Tümü</span>
                <span class="cb-chip is-active" id="cb_notifications_filter_chip_category">Kategori: Tümü</span>
            </div>
            <button type="button" class="btn btn-light-primary font-weight-bold" data-cb-notifications-clear-filters>Filtreleri temizle</button>
        </div>
    </div>
</div>
