@model CoinBot.Application.Abstractions.Administration.LogCenterSummarySnapshot
@{
    var lastUpdatedText = Model.LastUpdatedAtUtc is null
        ? "n/a"
        : Model.LastUpdatedAtUtc.Value.ToUniversalTime().ToString("yyyy-MM-dd HH:mm:ss") + " UTC";
}

<div class="row">
    <div class="col-xl-2 col-md-4 col-6">
        <div class="card card-custom gutter-b cb-card cb-log-meta-card">
            <div class="card-body">
                <div class="cb-kpi-label">Toplam satır</div>
                <div class="cb-kpi-value cb-mono">@Model.TotalRows</div>
                <div class="cb-kpi-meta">Combined log center rows</div>
            </div>
        </div>
    </div>
    <div class="col-xl-2 col-md-4 col-6">
        <div class="card card-custom gutter-b cb-card cb-log-meta-card">
            <div class="card-body">
                <div class="cb-kpi-label">DecisionTrace</div>
                <div class="cb-kpi-value cb-mono">@Model.DecisionTraceRows</div>
                <div class="cb-kpi-meta">Signal -> decision</div>
            </div>
        </div>
    </div>
    <div class="col-xl-2 col-md-4 col-6">
        <div class="card card-custom gutter-b cb-card cb-log-meta-card">
            <div class="card-body">
                <div class="cb-kpi-label">ExecutionTrace</div>
                <div class="cb-kpi-value cb-mono">@Model.ExecutionTraceRows</div>
                <div class="cb-kpi-meta">Command -> provider</div>
            </div>
        </div>
    </div>
    <div class="col-xl-2 col-md-4 col-6">
        <div class="card card-custom gutter-b cb-card cb-log-meta-card">
            <div class="card-body">
                <div class="cb-kpi-label">Audit / incident</div>
                <div class="cb-kpi-value cb-mono">@(Model.AdminAuditLogRows + Model.IncidentRows + Model.IncidentEventRows)</div>
                <div class="cb-kpi-meta">Admin audit + incident timeline</div>
            </div>
        </div>
    </div>
    <div class="col-xl-2 col-md-4 col-6">
        <div class="card card-custom gutter-b cb-card cb-log-meta-card">
            <div class="card-body">
                <div class="cb-kpi-label">Approvals</div>
                <div class="cb-kpi-value cb-mono">@(Model.ApprovalQueueRows + Model.ApprovalActionRows)</div>
                <div class="cb-kpi-meta">Queue + action history</div>
            </div>
        </div>
    </div>
    <div class="col-xl-2 col-md-4 col-6">
        <div class="card card-custom gutter-b cb-card cb-log-meta-card">
            <div class="card-body">
                <div class="cb-kpi-label">Kritik / son güncelleme</div>
                <div class="cb-kpi-value cb-mono">@Model.CriticalRows</div>
                <div class="cb-kpi-meta">@lastUpdatedText</div>
            </div>
        </div>
    </div>
</div>
