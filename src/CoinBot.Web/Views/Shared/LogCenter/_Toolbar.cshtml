@model CoinBot.Application.Abstractions.Administration.LogCenterPageSnapshot
@{
    var filters = Model.Filters;
    var exportTake = Model.Filters.Take > 0 ? Model.Filters.Take : 100;
}

<div class="card card-custom gutter-b cb-card">
    <div class="card-body">
        <form asp-controller="LogCenter" asp-action="Index" method="get" class="cb-filter-bar cb-filter-bar-logs">
            <div class="cb-filter-field cb-filter-field-search">
                <label class="cb-form-label" for="cb_log_filter_query">Arama</label>
                <input type="text" id="cb_log_filter_query" name="query" class="form-control cb-form-control" value="@filters.Query" />
            </div>
            <div class="cb-filter-field">
                <label class="cb-form-label" for="cb_log_filter_correlation">CorrelationId</label>
                <input type="text" id="cb_log_filter_correlation" name="correlationId" class="form-control cb-form-control" value="@filters.CorrelationId" />
            </div>
            <div class="cb-filter-field">
                <label class="cb-form-label" for="cb_log_filter_decision">DecisionId</label>
                <input type="text" id="cb_log_filter_decision" name="decisionId" class="form-control cb-form-control" value="@filters.DecisionId" />
            </div>
            <div class="cb-filter-field">
                <label class="cb-form-label" for="cb_log_filter_execution">ExecutionAttemptId</label>
                <input type="text" id="cb_log_filter_execution" name="executionAttemptId" class="form-control cb-form-control" value="@filters.ExecutionAttemptId" />
            </div>
            <div class="cb-filter-field">
                <label class="cb-form-label" for="cb_log_filter_user">UserId</label>
                <input type="text" id="cb_log_filter_user" name="userId" class="form-control cb-form-control" value="@filters.UserId" />
            </div>
            <div class="cb-filter-field">
                <label class="cb-form-label" for="cb_log_filter_symbol">Symbol</label>
                <input type="text" id="cb_log_filter_symbol" name="symbol" class="form-control cb-form-control" value="@filters.Symbol" />
            </div>
            <div class="cb-filter-field">
                <label class="cb-form-label" for="cb_log_filter_status">Status</label>
                <input type="text" id="cb_log_filter_status" name="status" class="form-control cb-form-control" value="@filters.Status" />
            </div>
            <div class="cb-filter-field">
                <label class="cb-form-label" for="cb_log_filter_from">From UTC</label>
                <input type="date" id="cb_log_filter_from" name="fromUtc" class="form-control cb-form-control" value="@(filters.FromUtc?.ToString("yyyy-MM-dd"))" />
            </div>
            <div class="cb-filter-field">
                <label class="cb-form-label" for="cb_log_filter_to">To UTC</label>
                <input type="date" id="cb_log_filter_to" name="toUtc" class="form-control cb-form-control" value="@(filters.ToUtc?.ToString("yyyy-MM-dd"))" />
            </div>
            <div class="cb-filter-field">
                <label class="cb-form-label" for="cb_log_filter_take">Take</label>
                <select id="cb_log_filter_take" name="take" class="form-control cb-form-control">
                    @foreach (var option in new[] { 25, 50, 100, 250, 500, 1000 })
                    {
                        <option value="@option" selected="@(exportTake == option ? "selected" : null)">@option</option>
                    }
                </select>
            </div>
            <div class="cb-filter-actions">
                <button type="submit" class="btn btn-light-primary font-weight-bold">Filtreleri uygula</button>
                <button type="submit" class="btn btn-primary font-weight-bolder" formmethod="post" formaction="@Url.Action("Export", "LogCenter")">Güvenli CSV export</button>
                <a asp-controller="LogCenter" asp-action="Index" class="btn btn-light font-weight-bold">Temizle</a>
            </div>
            @Html.AntiForgeryToken()
        </form>

        <div class="cb-admin-info-strip cb-admin-info-strip-info mt-5">
            <div>
                <div class="cb-admin-info-strip-title">Filtreli görünüm</div>
                <div class="cb-admin-info-strip-text">Exact-match correlation, decision ve execution aramaları kritik trace zincirini doğrudan daraltır. Export aynı filtre setiyle masked CSV üretir.</div>
            </div>
            <span class="cb-admin-info-strip-meta">@exportTake row max</span>
        </div>
    </div>
</div>
