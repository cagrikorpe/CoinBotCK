@model CoinBot.Application.Abstractions.Administration.LogCenterPageSnapshot
@using System.Linq
@using CoinBot.Application.Abstractions.Administration
@using CoinBot.Web.ViewModels.Foundation
@{
    var selectedEntry = ViewData["LogCenterSelectedEntry"] as LogCenterEntrySnapshot ?? Model.Entries.FirstOrDefault();

    string ResolveBadgeClass(string tone)
    {
        return tone.ToLowerInvariant() switch
        {
            "critical" => "cb-badge cb-badge-danger",
            "warning" => "cb-badge cb-badge-warning",
            "degraded" => "cb-badge cb-badge-warning",
            "healthy" => "cb-badge cb-badge-success",
            "info" => "cb-badge cb-badge-info",
            _ => "cb-badge cb-badge-neutral"
        };
    }

    string? ResolveTraceHref()
    {
        if (selectedEntry is null)
        {
            return null;
        }

        if (!string.IsNullOrWhiteSpace(selectedEntry.DecisionId) || !string.IsNullOrWhiteSpace(selectedEntry.ExecutionAttemptId))
        {
            return Url.Action(
                "TraceDetail",
                "Admin",
                new
                {
                    area = "Admin",
                    correlationId = selectedEntry.CorrelationId,
                    decisionId = selectedEntry.DecisionId,
                    executionAttemptId = selectedEntry.ExecutionAttemptId
                });
        }

        return null;
    }

    string? ResolveIncidentHref()
    {
        return selectedEntry is null || string.IsNullOrWhiteSpace(selectedEntry.IncidentReference)
            ? null
            : Url.Action("IncidentDetail", "Admin", new { area = "Admin", incidentReference = selectedEntry.IncidentReference });
    }

    string? ResolveApprovalHref()
    {
        return selectedEntry is null || string.IsNullOrWhiteSpace(selectedEntry.ApprovalReference)
            ? null
            : Url.Action("ApprovalDetail", "Admin", new { area = "Admin", approvalReference = selectedEntry.ApprovalReference });
    }

    string ResolveAuditHref()
    {
        if (selectedEntry is null)
        {
            return Url.Action("Audit", "Admin", new { area = "Admin" })!;
        }

        var query = selectedEntry.CorrelationId ?? selectedEntry.Reference;
        return Url.Action("Audit", "Admin", new { area = "Admin", query })!;
    }
}

<aside class="cb-drawer cb-log-drawer" id="cb_logcenter_detail_drawer" aria-hidden="true">
    <div class="cb-drawer-header">
        <div>
            <div class="cb-drawer-eyebrow" id="cb_log_drawer_eyebrow">Log Detail</div>
            <h5 class="cb-drawer-title mb-0" id="cb_log_drawer_title">Log detayı</h5>
        </div>
        <button type="button" class="btn btn-xs btn-icon btn-light" data-cb-drawer-close><span>&times;</span></button>
    </div>
    <div class="cb-drawer-body">
        @if (selectedEntry is null)
        {
            @await Html.PartialAsync("Foundation/_EmptyState", new UiStateViewModel
            {
                IconText = "LG",
                Title = "Kayıt seçin",
                Message = "Listeden bir log kaydı seçildiğinde correlation root, raw JSON ve ilgili deep linkler burada görünür.",
                ActionText = "Filtrelere dön",
                ActionHref = "#cb_log_filter_query",
                SecondaryActionText = "Audit search",
                SecondaryActionHref = ResolveAuditHref()
            })
        }
        else
        {
            <div class="cb-inline-stack mb-4">
                <span class="cb-badge @ResolveBadgeClass(selectedEntry.Tone)" id="cb_log_drawer_severity">@(selectedEntry.Severity ?? selectedEntry.Tone)</span>
                <span class="cb-badge cb-badge-neutral" id="cb_log_drawer_category">@selectedEntry.Kind</span>
                <span class="cb-badge cb-badge-neutral" id="cb_log_drawer_trace">@(selectedEntry.CorrelationId ?? selectedEntry.Reference)</span>
            </div>

            <div class="cb-admin-summary-grid mt-4">
                <div class="cb-admin-summary-card">
                    <span class="cb-admin-summary-label">Reference</span>
                    <strong class="cb-mono" id="cb_log_drawer_reference">@selectedEntry.Reference</strong>
                    <small>@selectedEntry.Status</small>
                </div>
                <div class="cb-admin-summary-card">
                    <span class="cb-admin-summary-label">Correlation</span>
                    <strong class="cb-mono" id="cb_log_drawer_correlation">@(selectedEntry.CorrelationId ?? "-")</strong>
                    <small>@(selectedEntry.DecisionId ?? selectedEntry.ExecutionAttemptId ?? selectedEntry.IncidentReference ?? selectedEntry.ApprovalReference ?? "-")</small>
                </div>
                <div class="cb-admin-summary-card">
                    <span class="cb-admin-summary-label">Actor / Symbol</span>
                    <strong id="cb_log_drawer_actor">@(selectedEntry.UserId ?? "-")</strong>
                    <small id="cb_log_drawer_symbol">@(selectedEntry.Symbol ?? selectedEntry.Source ?? "n/a")</small>
                </div>
                <div class="cb-admin-summary-card">
                    <span class="cb-admin-summary-label">Created</span>
                    <strong class="cb-mono" id="cb_log_drawer_time">@selectedEntry.CreatedAtUtc.ToUniversalTime().ToString("yyyy-MM-dd HH:mm:ss") UTC</strong>
                    <small id="cb_log_drawer_source">@(selectedEntry.Source ?? "n/a")</small>
                </div>
            </div>

            <div class="cb-admin-badge-stack mt-5" id="cb_log_drawer_tags">
                @foreach (var tag in selectedEntry.Tags)
                {
                    <span class="cb-badge cb-badge-neutral">@tag</span>
                }
            </div>

            <div class="cb-admin-info-strip cb-admin-info-strip-info mt-5">
                <div>
                    <div class="cb-admin-info-strip-title">@selectedEntry.Title</div>
                    <div class="cb-admin-info-strip-text" id="cb_log_drawer_message">@selectedEntry.Summary</div>
                </div>
                <span class="cb-admin-info-strip-meta">@selectedEntry.Kind</span>
            </div>

            @if (!string.IsNullOrWhiteSpace(selectedEntry.DecisionReasonCode) || selectedEntry.DecisionAtUtc.HasValue)
            {
                <div class="cb-admin-summary-grid mt-5">
                    <div class="cb-admin-summary-card" data-cb-log-drawer-decision-outcome>
                        <span class="cb-admin-summary-label">Decision outcome</span>
                        <strong>@selectedEntry.Status</strong>
                        <small data-cb-log-drawer-decision-reason-type>@(selectedEntry.DecisionReasonType ?? "n/a")</small>
                    </div>
                    <div class="cb-admin-summary-card" data-cb-log-drawer-decision-reason-code>
                        <span class="cb-admin-summary-label">Reason code</span>
                        <strong>@(selectedEntry.DecisionReasonCode ?? "n/a")</strong>
                        <small data-cb-log-drawer-decision-at>@(selectedEntry.DecisionAtUtc.HasValue ? selectedEntry.DecisionAtUtc.Value.ToUniversalTime().ToString("yyyy-MM-dd HH:mm:ss") + " UTC" : "n/a")</small>
                    </div>
                    <div class="cb-admin-summary-card" data-cb-log-drawer-market-last-candle>
                        <span class="cb-admin-summary-label">Market data</span>
                        <strong>@(selectedEntry.LastCandleAtUtc.HasValue ? selectedEntry.LastCandleAtUtc.Value.ToUniversalTime().ToString("yyyy-MM-dd HH:mm:ss") + " UTC" : "n/a")</strong>
                        <small data-cb-log-drawer-market-age>@(selectedEntry.DataAgeMs?.ToString() ?? "n/a") ms / @(selectedEntry.StaleThresholdMs?.ToString() ?? "n/a") ms</small>
                    </div>
                    <div class="cb-admin-summary-card" data-cb-log-drawer-continuity-state>
                        <span class="cb-admin-summary-label">Continuity</span>
                        <strong>@(selectedEntry.ContinuityState ?? "n/a")</strong>
                        <small data-cb-log-drawer-continuity-gap-count>@(selectedEntry.ContinuityGapCount?.ToString() ?? "n/a")</small>
                    </div>
                </div>

                <div class="text-muted mt-3">
                    StaleReason=@(selectedEntry.StaleReason ?? "n/a")
                    · GapStart=@(selectedEntry.ContinuityGapStartedAtUtc.HasValue ? selectedEntry.ContinuityGapStartedAtUtc.Value.ToUniversalTime().ToString("yyyy-MM-dd HH:mm:ss") + " UTC" : "n/a")
                    · GapLastSeen=@(selectedEntry.ContinuityGapLastSeenAtUtc.HasValue ? selectedEntry.ContinuityGapLastSeenAtUtc.Value.ToUniversalTime().ToString("yyyy-MM-dd HH:mm:ss") + " UTC" : "n/a")
                    · Recovered=@(selectedEntry.ContinuityRecoveredAtUtc.HasValue ? selectedEntry.ContinuityRecoveredAtUtc.Value.ToUniversalTime().ToString("yyyy-MM-dd HH:mm:ss") + " UTC" : "n/a")
                </div>
            }

            <div class="mt-5">
                <div class="cb-section-title">Raw JSON viewer</div>
                <details class="mt-3" open>
                    <summary class="text-muted">Masked payload</summary>
                    <pre class="mt-3 mb-0"><code id="cb_log_drawer_raw_json">@(selectedEntry.RawJson ?? "{}")</code></pre>
                </details>
            </div>

            <div class="cb-section mt-6">
                <div class="cb-section-title">Davranış / privacy notu</div>
                <div class="cb-bot-mini-validation" id="cb_log_drawer_privacy">Masking standardı aktif: API key, secret, signature, auth header ve hassas payload alanları düz metin gösterilmez.</div>
            </div>

            <div class="cb-section mt-6">
                <div class="cb-section-title">Sonraki aksiyon</div>
                <div class="cb-bot-mini-validation" id="cb_log_drawer_action">İlgili trace, incident veya approval detayına geçip zinciri devam ettirebilirsin.</div>
            </div>
        }
    </div>
    <div class="cb-drawer-footer">
        @if (ResolveTraceHref() is string traceHref)
        {
            <a href="@traceHref" class="btn btn-light-primary font-weight-bold" id="cb_log_drawer_trace_link">Trace detail</a>
        }
        @if (ResolveIncidentHref() is string incidentHref)
        {
            <a href="@incidentHref" class="btn btn-light-primary font-weight-bold" id="cb_log_drawer_incident_link">Incident detail</a>
        }
        @if (ResolveApprovalHref() is string approvalHref)
        {
            <a href="@approvalHref" class="btn btn-light-primary font-weight-bold" id="cb_log_drawer_approval_link">Approval detail</a>
        }
        <a href="@ResolveAuditHref()" class="btn btn-light font-weight-bold" id="cb_log_drawer_audit_link">Audit search</a>
        <button type="button" class="btn btn-light" data-cb-drawer-close>Kapat</button>
    </div>
</aside>
