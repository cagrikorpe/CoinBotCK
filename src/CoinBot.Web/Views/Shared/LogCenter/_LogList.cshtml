@model CoinBot.Application.Abstractions.Administration.LogCenterPageSnapshot
@using System.Linq
@using System.Text.Json
@using CoinBot.Application.Abstractions.Administration
@{
    var selectedEntry = ViewData["LogCenterSelectedEntry"] as LogCenterEntrySnapshot;
    var selectedReference = selectedEntry?.Reference;
}

<div class="card card-custom gutter-b cb-card">
    <div class="card-body">
        <div class="cb-admin-table-header">
            <div>
                <div class="cb-admin-section-kicker">Log akışı</div>
                <div class="cb-admin-section-title">Correlation merkezli gerçek kayıtlar</div>
                <p class="cb-admin-section-description mb-0">DecisionTrace, ExecutionTrace, AdminAuditLog, Incident timeline ve Approval history aynı listede masked olarak akar.</p>
            </div>
            <span class="cb-badge cb-badge-info">@Model.Entries.Count row</span>
        </div>

        <div class="table-responsive cb-admin-table-wrap mt-4">
            <table class="table table-borderless cb-admin-table cb-admin-audit-table mb-0">
                <thead>
                    <tr>
                        <th>Zaman</th>
                        <th>Kind</th>
                        <th>Reference</th>
                        <th>Status</th>
                        <th>Correlation</th>
                        <th>Actor / Symbol</th>
                        <th>Summary</th>
                        <th>Detay</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Entries.Count == 0)
                    {
                        <tr>
                            <td colspan="8" class="text-muted">Filtrelere uyan log kaydı yok.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var entry in Model.Entries)
                        {
                            var isSelected = string.Equals(entry.Reference, selectedReference, StringComparison.OrdinalIgnoreCase);
                            var payload = JsonSerializer.Serialize(
                                entry,
                                new JsonSerializerOptions(JsonSerializerDefaults.Web));

                            <tr class="@(isSelected ? "is-selected" : string.Empty)" data-cb-log-row data-cb-log-row-reference="@entry.Reference">
                                <td class="cb-mono">@entry.CreatedAtUtc.ToUniversalTime().ToString("yyyy-MM-dd HH:mm:ss") UTC</td>
                                <td>
                                    <div class="d-flex flex-column gap-1">
                                        <span class="cb-badge cb-badge-info">@entry.Kind</span>
                                        <small class="text-muted">@entry.Tone / @(entry.Severity ?? "n/a")</small>
                                    </div>
                                </td>
                                <td>
                                    <div class="cb-admin-mini-stat">
                                        <strong class="cb-mono">@entry.Reference</strong>
                                        <small>@(string.IsNullOrWhiteSpace(entry.Source) ? "No source" : entry.Source)</small>
                                    </div>
                                </td>
                                <td>@entry.Status</td>
                                <td class="cb-mono">@(entry.CorrelationId ?? "-")</td>
                                <td>
                                    <div class="cb-admin-mini-stat">
                                        <strong>@(entry.UserId ?? "-")</strong>
                                        <small>@(entry.Symbol is null ? "-" : $"{entry.Symbol}")</small>
                                    </div>
                                </td>
                                <td>
                                    <div class="cb-admin-mini-stat">
                                        <strong>@entry.Title</strong>
                                        <small>@entry.Summary</small>
                                    </div>
                                </td>
                                <td>
                                    <div class="cb-admin-inline-actions cb-admin-inline-actions-compact">
                                        <button type="button"
                                                class="btn btn-xs btn-light-primary font-weight-bold"
                                                data-cb-drawer-target="#cb_logcenter_detail_drawer"
                                                data-cb-log-entry='@payload'>
                                            Detay
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
