@using System.Linq
@using System.Security.Claims
@{
    var pageTitle = ViewData["Title"]?.ToString() ?? "Ana Sayfa";
    var pageDescription = ViewData["PageDescription"]?.ToString() ?? "CoinBot günlük kullanım alanı.";
    var activeNav = ViewData["ActiveNav"]?.ToString() ?? "Dashboard";
    var breadcrumbItems = ViewData["BreadcrumbItems"] as string[] ?? new[] { "CoinBot", pageTitle };
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var displayName = User.Claims.FirstOrDefault(claim => claim.Type == ClaimTypes.Name)?.Value
        ?? User.Identity?.Name
        ?? "Guest";
    var roleLabel = User.Claims.FirstOrDefault(claim => claim.Type == ClaimTypes.Role)?.Value
        ?? (isAuthenticated ? "Authenticated" : "Guest");
    var initialsSource = string.Concat(displayName.Where(char.IsLetterOrDigit).Take(2)).ToUpperInvariant();
    var userInitials = string.IsNullOrWhiteSpace(initialsSource) ? "CB" : initialsSource;

    var navigation = new[]
    {
        new { Group = "Kullanım", Key = "Dashboard", Label = "Ana Sayfa", Initials = "AS", Controller = "Home", Action = "Index", Enabled = true, Badge = (string?)null, BadgeClass = string.Empty },
        new { Group = "Kullanım", Key = "Bots", Label = "Botlarım", Initials = "BT", Controller = "Bots", Action = "Index", Enabled = true, Badge = (string?)null, BadgeClass = string.Empty },
        new { Group = "Kullanım", Key = "Positions", Label = "İşlemler", Initials = "İŞ", Controller = "Positions", Action = "Index", Enabled = true, Badge = (string?)null, BadgeClass = string.Empty },
        new { Group = "Kullanım", Key = "RiskCenter", Label = "Risk", Initials = "RK", Controller = "RiskCenter", Action = "Index", Enabled = true, Badge = (string?)null, BadgeClass = string.Empty },
        new { Group = "Kullanım", Key = "Settings", Label = "Ayarlar", Initials = "AY", Controller = "Settings", Action = "Index", Enabled = true, Badge = (string?)null, BadgeClass = string.Empty }
    };
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>@pageTitle - CoinBot</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Poppins:300,400,500,600,700" />
    <link rel="stylesheet" href="~/metronic/assets/plugins/global/plugins.bundle.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/metronic/assets/css/style.bundle.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/metronic/assets/css/themes/layout/header/base/light.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/metronic/assets/css/themes/layout/header/menu/light.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/metronic/assets/css/themes/layout/brand/dark.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/metronic/assets/css/themes/layout/aside/dark.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body id="kt_body" class="header-fixed header-mobile-fixed aside-enabled aside-fixed aside-minimize-hoverable page-loading" data-cb-theme="dark">
    <div id="kt_header_mobile" class="header-mobile align-items-center header-mobile-fixed cb-shell-mobile-header">
        <a asp-controller="Home" asp-action="Index" class="brand-logo text-decoration-none">
            <span class="app-logo-mark">C</span>
            <span class="text-white font-size-h5 font-weight-bolder">CoinBot</span>
        </a>
        <div class="d-flex align-items-center">
            <button class="btn p-0 burger-icon burger-icon-left" id="kt_aside_mobile_toggle" type="button">
                <span></span>
            </button>
        </div>
    </div>

    <div class="d-flex flex-column flex-root">
        <div class="d-flex flex-row flex-column-fluid page">
            <div class="aside aside-left aside-fixed d-flex flex-column flex-row-auto cb-shell-aside" id="kt_aside">
                <div class="brand flex-column-auto cb-shell-brand" id="kt_brand">
                    <a asp-controller="Home" asp-action="Index" class="brand-logo text-decoration-none">
                        <span class="app-logo-mark">C</span>
                        <span>
                            <span class="text-white font-size-h4 font-weight-bolder d-block">CoinBot</span>
                            <span class="cb-brand-subtitle">Kullanıcı alanı</span>
                        </span>
                    </a>
                    <button class="brand-toggle btn btn-sm px-0" id="kt_aside_toggle" type="button" aria-label="Sidebar toggle">
                        <span class="svg-icon svg-icon-xl">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24px" height="24px" viewBox="0 0 24 24" version="1.1">
                                <g stroke="none" stroke-width="1" fill="none" fill-rule="evenodd">
                                    <polygon points="0 0 24 0 24 24 0 24"></polygon>
                                    <path d="M5.29288961,6.70710318 C4.90236532,6.31657888 4.90236532,5.68341391 5.29288961,5.29288961 C5.68341391,4.90236532 6.31657888,4.90236532 6.70710318,5.29288961 L12.7071032,11.2928896 C13.0856821,11.6714686 13.0989277,12.281055 12.7371505,12.675721 L7.23715054,18.675721 C6.86395813,19.08284 6.23139076,19.1103429 5.82427177,18.7371505 C5.41715278,18.3639581 5.38964985,17.7313908 5.76284226,17.3242718 L10.6158586,12.0300721 L5.29288961,6.70710318 Z" fill="#ffffff" fill-rule="nonzero" transform="translate(8.999997, 11.999999) scale(-1, 1) translate(-8.999997, -11.999999)"></path>
                                    <path d="M10.7071009,15.7071068 C10.3165766,16.0976311 9.68341162,16.0976311 9.29288733,15.7071068 C8.90236304,15.3165825 8.90236304,14.6834175 9.29288733,14.2928932 L15.2928873,8.29289322 C15.6714663,7.91431428 16.2810527,7.90106866 16.6757187,8.26284586 L22.6757187,13.7628459 C23.0828377,14.1360383 23.1103407,14.7686056 22.7371482,15.1757246 C22.3639558,15.5828436 21.7313885,15.6103465 21.3242695,15.2371541 L16.0300699,10.3841378 L10.7071009,15.7071068 Z" fill="#ffffff" fill-rule="nonzero" opacity="0.35" transform="translate(15.999997, 11.999999) scale(-1, 1) rotate(-270.000000) translate(-15.999997, -11.999999)"></path>
                                </g>
                            </svg>
                        </span>
                    </button>
                </div>

                <div class="aside-menu-wrapper flex-column-fluid" id="kt_aside_menu_wrapper">
                    <div id="kt_aside_menu" class="aside-menu my-4" data-menu-vertical="1" data-menu-scroll="1" data-menu-dropdown-timeout="500">
                        <ul class="menu-nav cb-menu-nav">
                            @foreach (var navSection in navigation.GroupBy(item => item.Group))
                            {
                                <li class="menu-section">
                                    <h4 class="menu-text">@navSection.Key</h4>
                                    <i class="menu-icon ki ki-bold-more-hor icon-md"></i>
                                </li>

                                @foreach (var item in navSection)
                                {
                                    var isActive = string.Equals(activeNav, item.Key, StringComparison.OrdinalIgnoreCase);
                                    <li class="menu-item @(isActive ? "menu-item-active" : string.Empty) @(item.Enabled ? string.Empty : "cb-menu-item-disabled")" aria-haspopup="true">
                                        @if (item.Enabled)
                                        {
                                            <a asp-controller="@item.Controller" asp-action="@item.Action" class="menu-link">
                                                <span class="menu-icon">
                                                    <span class="cb-menu-icon @(isActive ? "is-active" : string.Empty)">@item.Initials</span>
                                                </span>
                                                <span class="menu-text">@item.Label</span>
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="menu-link cursor-default" aria-disabled="true">
                                                <span class="menu-icon">
                                                    <span class="cb-menu-icon">@item.Initials</span>
                                                </span>
                                                <span class="menu-text">@item.Label</span>
                                                @if (!string.IsNullOrWhiteSpace(item.Badge))
                                                {
                                                    <span class="menu-label">
                                                        <span class="label label-inline @item.BadgeClass">@item.Badge</span>
                                                    </span>
                                                }
                                            </span>
                                        }
                                    </li>
                                }
                            }

                        </ul>
                    </div>
                </div>
            </div>

            <div class="d-flex flex-column flex-row-fluid wrapper cb-shell-wrapper" id="kt_wrapper">
                <div id="kt_header" class="header header-fixed cb-shell-header">
                    <div class="container-fluid d-flex align-items-center justify-content-between flex-wrap flex-sm-nowrap">
                        <div class="d-flex align-items-center mr-5 cb-topbar-meta">
                            <button class="btn btn-icon btn-clean d-lg-none mr-3" id="kt_aside_mobile_toggle_desktop" type="button">
                                <span class="svg-icon svg-icon-xl">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="none">
                                        <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                                    </svg>
                                </span>
                            </button>
                            <div>
                                <div class="cb-shell-breadcrumb">
                                    @for (var i = 0; i < breadcrumbItems.Length; i++)
                                    {
                                        <span>@breadcrumbItems[i]</span>
                                        @if (i < breadcrumbItems.Length - 1)
                                        {
                                            <span class="cb-breadcrumb-separator">/</span>
                                        }
                                    }
                                </div>
                                <h1 class="cb-shell-title mb-0">@pageTitle</h1>
                                <div class="cb-shell-description">@pageDescription</div>
                            </div>
                        </div>

                        <div class="topbar cb-topbar">

                            <div class="cb-topbar-actions">
                                <a asp-controller="Notifications" asp-action="Index" class="btn btn-icon btn-clean cb-icon-button" title="Bildirimler">
                                    <span class="cb-icon-badge">3</span>
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none">
                                        <path d="M12 5a4 4 0 0 0-4 4v2.5c0 .5-.2 1-.6 1.4L6 14.3V16h12v-1.7l-1.4-1.4c-.4-.4-.6-.9-.6-1.4V9a4 4 0 0 0-4-4Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
                                        <path d="M10 18a2 2 0 0 0 4 0" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                    </svg>
                                </a>
                                <button type="button" class="btn btn-icon btn-clean cb-icon-button" id="cb_theme_toggle" title="Tema">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none">
                                        <path d="M12 3v2.5M12 18.5V21M4.93 4.93l1.77 1.77M17.3 17.3l1.77 1.77M3 12h2.5M18.5 12H21M4.93 19.07l1.77-1.77M17.3 6.7l1.77-1.77" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                                        <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.6"/>
                                    </svg>
                                </button>
                                <div class="dropdown">
                                    <button class="btn btn-clean d-flex align-items-center px-2 py-2" type="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                        <span class="cb-user-avatar">@userInitials</span>
                                        <span class="cb-user-meta d-none d-md-inline-block">
                                            <span class="cb-user-name">@displayName</span>
                                            <span class="cb-user-role">@roleLabel</span>
                                        </span>
                                    </button>
                                    <div class="dropdown-menu dropdown-menu-right dropdown-menu-anim-up dropdown-menu-lg p-0 cb-dropdown-menu">
                                        <div class="cb-dropdown-header">
                                            <div class="cb-user-avatar">@userInitials</div>
                                            <div>
                                                <div class="font-weight-bolder text-white">@displayName</div>
                                                <div class="text-white-50">@roleLabel</div>
                                            </div>
                                        </div>
                                        <div class="navi navi-hover py-2">
                                            @if (isAuthenticated)
                                            {

                                                <a asp-controller="Settings" asp-action="Index" class="navi-item px-4 py-3 d-flex justify-content-between align-items-center text-white-75">
                                                    <span class="navi-text">Ayarlar</span>
                                                    <span class="cb-badge cb-badge-info">Hesap</span>
                                                </a>

                                                <form asp-controller="Auth" asp-action="Logout" method="post" class="px-4 py-3">
                                                    <button type="submit" class="btn btn-link p-0 d-flex w-100 justify-content-between align-items-center text-white-75">
                                                        <span class="navi-text">Çıkış yap</span>
                                                        <span class="cb-badge cb-badge-danger">Oturum</span>
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <a asp-controller="Auth" asp-action="Login" class="navi-item px-4 py-3 d-flex justify-content-between align-items-center text-white-75">
                                                    <span class="navi-text">Giriş yap</span>
                                                    <span class="cb-badge cb-badge-info">Oturum</span>
                                                </a>
                                                <a asp-controller="Auth" asp-action="Register" class="navi-item px-4 py-3 d-flex justify-content-between align-items-center text-white-75">
                                                    <span class="navi-text">Hesap oluştur</span>
                                                    <span class="cb-badge cb-badge-warning">Oturum</span>
                                                </a>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="content d-flex flex-column flex-column-fluid cb-shell-content" id="kt_content">
                    <div class="d-flex flex-column-fluid">
                        <div class="container-fluid metronic-page-content cb-content-container">
                            @RenderBody()
                        </div>
                    </div>
                </div>

                <div class="footer py-4 d-flex flex-lg-column cb-shell-footer" id="kt_footer">
                    <div class="container-fluid d-flex flex-column flex-md-row align-items-center justify-content-between">
                        <div class="order-2 order-md-1">
                            <span class="text-muted font-weight-bold mr-2">@DateTime.UtcNow.Year ©</span>
                            <span class="text-white-50">CoinBot</span>
                        </div>
                        <div class="nav nav-dark cb-footer-nav">
                            <a asp-controller="Home" asp-action="Index" class="nav-link pl-0 pr-5">Ana Sayfa</a>
                            <a asp-controller="Bots" asp-action="Index" class="nav-link pl-0 pr-5">Botlarım</a>
                            <a asp-controller="Positions" asp-action="Index" class="nav-link pl-0 pr-5">İşlemler</a>
                            <a asp-controller="RiskCenter" asp-action="Index" class="nav-link pl-0 pr-5">Risk</a>
                            <a asp-controller="Settings" asp-action="Index" class="nav-link pl-0 pr-0">Ayarlar</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @await Html.PartialAsync("Foundation/_ShellOverlays")

    <script>
        var KTAppSettings = {
            breakpoints: { sm: 576, md: 768, lg: 992, xl: 1200, xxl: 1400 },
            colors: {
                theme: {
                    base: { white: '#ffffff', primary: '#4B7CF3', secondary: '#2C3553', success: '#12C29C', info: '#5AC8FA', warning: '#FFB84D', danger: '#FF647C', light: '#202943', dark: '#0D1324' },
                    light: { white: '#ffffff', primary: '#E7EEFF', secondary: '#EEF1F7', success: '#D8FFF5', info: '#E6F7FF', warning: '#FFF4DF', danger: '#FFE3E7', light: '#F5F8FF', dark: '#D4DCEC' },
                    inverse: { white: '#ffffff', primary: '#ffffff', secondary: '#D0D8EA', success: '#ffffff', info: '#ffffff', warning: '#101827', danger: '#ffffff', light: '#4F5D7A', dark: '#ffffff' }
                },
                gray: { 'gray-100': '#F8FAFC', 'gray-200': '#DCE3F2', 'gray-300': '#AAB7D1', 'gray-400': '#8291B2', 'gray-500': '#6C7A97', 'gray-600': '#52607B', 'gray-700': '#334155', 'gray-800': '#1E293B', 'gray-900': '#0F172A' }
            },
            'font-family': 'Poppins'
        };
    </script>
    <script src="~/metronic/assets/plugins/global/plugins.bundle.js" asp-append-version="true"></script>
    <script src="~/metronic/assets/js/scripts.bundle.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

