<div class="card card-custom gutter-b cb-card cb-dashboard-card">
    <div class="card-header border-0 pt-6">
        <div class="card-title">
            <div>
                <h3 class="card-label font-weight-bolder mb-2">Loading / empty / error pattern</h3>
                <div class="cb-dashboard-card-meta">Exchange connect akışında tekrar kullanılacak state yüzeyleri.</div>
            </div>
        </div>
    </div>
    <div class="card-body pt-2">
        <div class="row">
            <div class="col-lg-4 mb-6">
                <div class="cb-section h-100">
                    <div class="cb-section-title mb-4">Permission loading</div>
                    @await Html.PartialAsync("Foundation/_LoadingState", new UiLoadingStateViewModel
                    {
                        Title = "İzinler kontrol ediliyor",
                        Message = "Gerçek Binance çağrısı olmadan, card bazlı loading görünümü burada tekrar kullanılabilir.",
                        CardCount = 1,
                        LineCount = 3
                    })
                </div>
            </div>
            <div class="col-lg-4 mb-6">
                <div class="cb-section h-100">
                    <div class="cb-section-title mb-4">Freshness empty</div>
                    @await Html.PartialAsync("Foundation/_EmptyState", new UiStateViewModel
                    {
                        Title = "Henüz senkron yok",
                        Message = "İlk bağlantı testi ve ilk account sync sonrası meta satırları bu alanda dolacaktır.",
                        IconText = "FX",
                        ActionText = "Test bağlantısı",
                        ActionHref = "#"
                    })
                </div>
            </div>
            <div class="col-lg-4 mb-6">
                <div class="cb-section h-100">
                    <div class="cb-section-title mb-4">Result error</div>
                    @await Html.PartialAsync("Foundation/_ErrorState", new UiStateViewModel
                    {
                        Title = "Bağlantı doğrulanamadı",
                        Message = "Credential veya izin seti yeniden gözden geçirilmeli. Kullanıcı çıkmaza girmeden tekrar deneyebilmelidir.",
                        IconText = "!",
                        ActionText = "Tekrar dene",
                        ActionHref = "#",
                        SecondaryActionText = "Geri dön",
                        SecondaryActionHref = "#"
                    })
                </div>
            </div>
        </div>
    </div>
</div>
