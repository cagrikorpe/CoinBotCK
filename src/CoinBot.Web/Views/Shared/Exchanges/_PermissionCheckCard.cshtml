<div class="card card-custom gutter-b cb-card cb-dashboard-card">
    <div class="card-header border-0 pt-6">
        <div class="card-title">
            <div>
                <h3 class="card-label font-weight-bolder mb-2">Permission check</h3>
                <div class="cb-dashboard-card-meta">Bağlantı testi sonrası beklenen izinlerin taranabilir görünümü.</div>
            </div>
        </div>
        <div class="card-toolbar">
            <span class="cb-badge cb-badge-neutral" data-cb-permission-summary>Henüz test edilmedi</span>
        </div>
    </div>
    <div class="card-body pt-2">
        <div class="cb-permission-list">
            <div class="cb-permission-row" data-cb-permission="spot">
                <div>
                    <div class="cb-permission-name">Spot Trade izni</div>
                    <div class="cb-permission-text">Spot mod veya hibrit kullanım için beklenen izin.</div>
                </div>
                <span class="cb-badge cb-badge-neutral" data-cb-permission-badge>Doğrulanmadı</span>
            </div>
            <div class="cb-permission-row" data-cb-permission="futures">
                <div>
                    <div class="cb-permission-name">Futures Trade izni</div>
                    <div class="cb-permission-text">Futures seçildiyse gerekli, aksi halde secondary kalabilir.</div>
                </div>
                <span class="cb-badge cb-badge-neutral" data-cb-permission-badge>Pasif</span>
            </div>
            <div class="cb-permission-row" data-cb-permission="read">
                <div>
                    <div class="cb-permission-name">Account Read izni</div>
                    <div class="cb-permission-text">Bakiye ve hesap doğrulama için beklenen read yetkisi.</div>
                </div>
                <span class="cb-badge cb-badge-neutral" data-cb-permission-badge>Doğrulanmadı</span>
            </div>
            <div class="cb-permission-row" data-cb-permission="withdrawal">
                <div>
                    <div class="cb-permission-name">Withdrawal</div>
                    <div class="cb-permission-text">Bu izin kapalı olmalıdır. Açık ise riskli yapı olarak işaretlenir.</div>
                </div>
                <span class="cb-badge cb-badge-warning" data-cb-permission-badge>Kapalı olmalı</span>
            </div>
            <div class="cb-permission-row" data-cb-permission="ip">
                <div>
                    <div class="cb-permission-name">IP Restriction</div>
                    <div class="cb-permission-text">Mümkünse whitelist ile sınırlandırılması önerilir.</div>
                </div>
                <span class="cb-badge cb-badge-info" data-cb-permission-badge>Önerilir</span>
            </div>
            <div class="cb-permission-row" data-cb-permission="secret">
                <div>
                    <div class="cb-permission-name">Secret durumu</div>
                    <div class="cb-permission-text">Secret girildi ancak gerçek test çağrısı yapılmadıysa nötr görünür.</div>
                </div>
                <span class="cb-badge cb-badge-neutral" data-cb-permission-badge>Henüz test edilmedi</span>
            </div>
        </div>

        <div class="cb-section mt-6">
            <div class="cb-section-title">Önerilen ayarlar</div>
            <ul class="cb-guideline-list mt-3 mb-0">
                <li>Paper mode ile ilk test</li>
                <li>Withdrawal kapalı key</li>
                <li>IP whitelist açık</li>
                <li>Futures yalnızca gerçekten gerekiyorsa</li>
            </ul>
        </div>

        <div class="cb-toolbar mt-6">
            <button type="button" class="btn btn-light-primary font-weight-bold" data-cb-drawer-target="#cb_shell_drawer">Permission detayları</button>
        </div>
    </div>
</div>
