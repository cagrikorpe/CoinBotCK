@using CoinBot.Application.Abstractions.Dashboard
@using CoinBot.Domain.Enums
@model UserDashboardPortfolioSnapshot
@{
    var openRows = Model.Positions
        .Where(item => item.IsExchangePosition && item.Plane == ExchangeDataPlane.Futures)
        .OrderBy(item => item.Symbol, StringComparer.Ordinal)
        .ToArray();
}
<div class="card card-custom gutter-b cb-card" data-cb-user-exec-positions>
    <div class="card-header border-0 pt-6">
        <div class="card-title">
            <div>
                <h3 class="card-label font-weight-bolder mb-1">Futures pozisyonlari</h3>
                <div class="text-muted font-size-sm">Yalnizca size ait acik futures pozisyonlari ve reduce-only close aksiyonu.</div>
            </div>
        </div>
        <div class="card-toolbar cb-inline-stack">
            <span class="cb-badge cb-badge-info" id="cb_positions_open_badge" data-cb-open-positions-count>@openRows.Length.ToString(System.Globalization.CultureInfo.InvariantCulture) açık</span>
        </div>
    </div>
    <div class="card-body pt-2">
        <div class="cb-table-wrap @(openRows.Length == 0 ? "d-none" : string.Empty)" data-cb-open-positions-panel="list">
            <table class="table table-borderless cb-table mb-0">
                <thead>
                    <tr>
                        <th>Sembol</th>
                        <th>Yön</th>
                        <th>Boyut</th>
                        <th>Giriş</th>
                        <th>Güncel</th>
                        <th>PnL</th>
                        <th>Ortam</th>
                        <th>Son güncelleme</th>
                        <th>Aksiyon</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in openRows)
                    {
                        var direction = row.PositionSide.Equals("SHORT", StringComparison.OrdinalIgnoreCase) || row.Quantity < 0m ? "Short" : "Long";
                        var directionTone = direction == "Long" ? "cb-badge-success" : "cb-badge-danger";
                        var pnlTone = row.UnrealizedProfit >= 0m ? "cb-text-positive" : "cb-text-negative";
                        var currentPrice = row.MarkPrice ?? row.BreakEvenPrice;
                        var (_, _, _, _, _, _, _, _, _, _, _, _, _, _, _, _, accountScope, _, _, _, _, _, _) = row;
                        var environmentTone = string.Equals(row.EnvironmentTone, "danger", StringComparison.OrdinalIgnoreCase)
                            ? "cb-badge-danger"
                            : string.Equals(row.EnvironmentTone, "success", StringComparison.OrdinalIgnoreCase)
                                ? "cb-badge-success"
                                : "cb-badge-info";
                        <tr data-cb-position-detail="@row.Symbol" data-cb-position-kind="open" data-cb-open-position-row>
                            <td><div class="cb-bot-row-title" data-cb-open-position-symbol>@row.Symbol</div><div class="cb-bot-row-subtitle">@row.Plane</div></td>
                            <td><span class="cb-badge @directionTone cb-direction-badge" data-cb-open-position-side>@direction</span></td>
                            <td class="cb-numeric-cell" data-cb-open-position-qty>@Math.Abs(row.Quantity).ToString("0.####")</td>
                            <td class="cb-numeric-cell" data-cb-open-position-entry>@row.EntryPrice.ToString("0.####")</td>
                            <td class="cb-numeric-cell" data-cb-open-position-current>@currentPrice.ToString("0.####")</td>
                            <td class="cb-numeric-cell @pnlTone" data-cb-open-position-unrealized>@($"{(row.UnrealizedProfit >= 0m ? "+" : string.Empty)}{row.UnrealizedProfit:0.####}")</td>
                            <td><span class="cb-badge @environmentTone" data-cb-open-position-environment>@(row.EnvironmentLabel ?? "n/a")</span></td>
                            <td><div class="cb-numeric-cell" data-cb-open-position-updated>@row.SyncedAtUtc.ToUniversalTime().ToString("dd MMM · HH:mm")</div></td>
                            <td>
                                <div class="cb-inline-stack" data-cb-user-manual-close-panel>
                                    @if (row.CanManualClose && row.ManualCloseBotId.HasValue && accountScope.HasValue)
                                    {
                                        <form asp-controller="Positions" asp-action="ManualClose" method="post" class="w-100" data-cb-user-manual-close-form data-cb-manual-close-form data-cb-manual-close-action="ManualClose">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="botId" value="@row.ManualCloseBotId.Value.ToString("D")" />
                                            <input type="hidden" name="accountScope" value="@accountScope.Value.ToString("D")" />
                                            <input type="hidden" name="symbol" value="@row.Symbol" />
                                            <div class="cb-validation-summary cb-validation-summary-warning mb-2" role="status" data-cb-user-manual-close-warning>
                                                Bu buton borsaya reduce-only close emri gonderir.
                                            </div>
                                            <label class="d-flex align-items-start mb-2" data-cb-user-manual-close-confirm-row>
                                                <input type="checkbox" name="confirmClose" value="true" class="mt-1 mr-2" data-cb-user-manual-close-checkbox data-cb-manual-close-double-confirm required />
                                                <span>Reduce-only close emrini onayliyorum ve pozisyonu kapat komutunu bilerek confirm ediyorum.</span>
                                            </label>
                                            <button type="submit" class="btn btn-sm btn-light-danger" data-cb-user-manual-close-button data-cb-manual-close-submit>
                                                Pozisyonu kapat
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <div class="cb-validation-summary cb-validation-summary-info mb-0" role="status" data-cb-user-manual-close-unavailable>
                                            @(row.ManualCloseUnavailableReason ?? "Manual close hazir degil.")
                                        </div>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="@(openRows.Length == 0 ? string.Empty : "d-none")" data-cb-open-positions-panel="empty">
            <div class="cb-validation-summary cb-validation-summary-info mb-0" role="status">
                Acik futures pozisyonu yok.
            </div>
        </div>

        <div class="d-none" data-cb-open-positions-panel="loading">
            <div class="cb-validation-summary cb-validation-summary-info mb-0" role="status">Pozisyonlar hazırlanıyor.</div>
        </div>

        <div class="d-none" data-cb-open-positions-panel="error">
            <div class="cb-validation-summary cb-validation-summary-danger mb-0" role="alert">Pozisyonlar alınamadı.</div>
        </div>
    </div>
</div>
