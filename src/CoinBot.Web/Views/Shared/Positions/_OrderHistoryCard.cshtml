@using CoinBot.Application.Abstractions.Dashboard
@model UserDashboardPortfolioSnapshot
@{
    var historyRows = Model.TradeHistory.OrderByDescending(item => item.LastUpdatedAtUtc).Take(10).ToArray();
}
<div class="card card-custom gutter-b cb-card" data-cb-user-exec-orders>
    <div class="card-header border-0 pt-6">
        <div class="card-title">
            <div>
                <h3 class="card-label font-weight-bolder mb-1">Emirler</h3>
                <div class="text-muted font-size-sm">Son emir durumları.</div>
            </div>
        </div>
    </div>
    <div class="card-body pt-2">
        <div class="cb-table-wrap @(historyRows.Length == 0 ? "d-none" : string.Empty)" data-cb-order-history-panel="list">
            <table class="table table-borderless cb-table mb-0">
                <thead>
                    <tr>
                        <th>Zaman</th>
                        <th>Sembol</th>
                        <th>Yön</th>
                        <th>Miktar</th>
                        <th>Durum</th>
                        <th>Kâr / Zarar</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in historyRows)
                    {
                        var sideTone = row.Side.Equals("Buy", StringComparison.OrdinalIgnoreCase) ? "cb-badge-success" : "cb-badge-danger";
                        var statusTone = row.ExecutionResultCategory switch
                        {
                            "Filled" => "cb-badge-success",
                            "Partial" => "cb-badge-warning",
                            "Canceled" => "cb-badge-neutral",
                            "Rejected" or "Failed" => "cb-badge-danger",
                            _ => "cb-badge-info"
                        };
                        var statusLabel = row.ExecutionResultCategory switch
                        {
                            "Filled" => "Tamamlandı",
                            "Partial" => "Kısmi",
                            "Canceled" => "İptal",
                            "Rejected" or "Failed" => "Başarısız",
                            _ => "Bekliyor"
                        };
                        var pnlTone = row.RealizedPnl >= 0m ? "cb-text-positive" : "cb-text-negative";
                        <tr data-cb-order-history-row="@row.OrderId.ToString("N")">
                            <td>
                                <div class="cb-bot-row-title cb-numeric" data-cb-history-opened-date>@row.OpenedAtUtc.ToUniversalTime().ToString("dd MMM")</div>
                                <div class="cb-bot-row-subtitle" data-cb-history-opened-time>@row.OpenedAtUtc.ToUniversalTime().ToString("HH:mm")</div>
                            </td>
                            <td>
                                <div class="cb-bot-row-title" data-cb-history-symbol>@row.Symbol</div>
                                <div class="cb-bot-row-subtitle">@row.Plane</div>
                            </td>
                            <td><span class="cb-badge @sideTone" data-cb-history-side>@row.Side</span></td>
                            <td class="cb-numeric-cell" data-cb-history-quantity>@row.Quantity.ToString("0.####")</td>
                            <td>
                                <span class="cb-badge @statusTone" data-cb-history-result-category>@statusLabel</span>
                                <div class="cb-bot-inline-help" data-cb-history-result-code>@statusLabel</div>
                                <div class="cb-bot-inline-help" data-cb-history-result-summary>@(string.IsNullOrWhiteSpace(row.ExecutionResultSummary) ? "Sonuç hazır" : statusLabel)</div>
                            </td>
                            <td class="cb-numeric-cell @pnlTone" data-cb-history-pnl>@($"{(row.RealizedPnl >= 0m ? "+" : string.Empty)}{row.RealizedPnl:0.####}")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="@(historyRows.Length == 0 ? string.Empty : "d-none")" data-cb-order-history-panel="empty">
            <div class="cb-validation-summary cb-validation-summary-info mb-0" role="status">Henüz emir yok.</div>
        </div>

        <div class="d-none" data-cb-order-history-panel="loading">
            <div class="cb-validation-summary cb-validation-summary-info mb-0" role="status">Emirler hazırlanıyor.</div>
        </div>

        <div class="d-none" data-cb-order-history-panel="error">
            <div class="cb-validation-summary cb-validation-summary-danger mb-0" role="alert">Emirler alınamadı.</div>
        </div>
    </div>
</div>
