@using CoinBot.Application.Abstractions.Dashboard
@model UserDashboardPortfolioSnapshot
@{
    var closedRows = Model.TradeHistory
        .Where(item => item.FinalState is "Filled" or "Cancelled" or "Rejected" or "Failed")
        .OrderByDescending(item => item.LastUpdatedAtUtc)
        .Take(8)
        .ToArray();
}
<div class="card card-custom gutter-b cb-card" data-cb-user-exec-history>
    <div class="card-header border-0 pt-6">
        <div class="card-title">
            <div>
                <h3 class="card-label font-weight-bolder mb-1">İşlem Geçmişi</h3>
                <div class="text-muted font-size-sm">Kapanan veya tamamlanan işlemler.</div>
            </div>
        </div>
    </div>
    <div class="card-body pt-2">
        <div class="cb-table-wrap @(closedRows.Length == 0 ? "d-none" : string.Empty)" data-cb-closed-positions-panel="list">
            <table class="table table-borderless cb-table mb-0">
                <thead>
                    <tr>
                        <th>Sembol</th>
                        <th>Yön</th>
                        <th>Sonuç</th>
                        <th>Kâr / Zarar</th>
                        <th>Kapanış</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in closedRows)
                    {
                        var directionLabel = row.Direction ?? (row.Side.Equals("Buy", StringComparison.OrdinalIgnoreCase) ? "Long" : "Short");
                        var tradeAction = row.TradeAction ?? row.Side;
                        var sideTone = directionLabel.Equals("Long", StringComparison.OrdinalIgnoreCase) ? "cb-badge-success" : "cb-badge-danger";
                        var resultTone = row.ExecutionResultCategory switch
                        {
                            "Filled" => "cb-badge-success",
                            "Partial" => "cb-badge-warning",
                            "Canceled" => "cb-badge-neutral",
                            "Rejected" or "Failed" => "cb-badge-danger",
                            _ => "cb-badge-info"
                        };
                        var pnlTone = row.RealizedPnl >= 0m ? "cb-text-positive" : "cb-text-negative";
                        <tr data-cb-position-detail="@row.OrderId.ToString("N")" data-cb-position-kind="closed" data-cb-closed-position-row>
                            <td><div class="cb-bot-row-title" data-cb-closed-position-symbol>@row.Symbol</div><div class="cb-bot-row-subtitle">@row.Plane</div></td>
                            <td><span class="cb-badge @sideTone cb-direction-badge" data-cb-closed-position-side>@tradeAction</span></td>
                            <td><span class="cb-badge @resultTone" data-cb-closed-position-result>@row.ExecutionResultCategory</span></td>
                            <td class="cb-mono @pnlTone" data-cb-closed-position-realized>@($"{(row.RealizedPnl >= 0m ? "+" : string.Empty)}{row.RealizedPnl:0.####}")</td>
                            <td><div class="cb-mono" data-cb-closed-position-updated>@row.LastUpdatedAtUtc.ToUniversalTime().ToString("dd MMM · HH:mm")</div></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="@(closedRows.Length == 0 ? string.Empty : "d-none")" data-cb-closed-positions-panel="empty">
            <div class="cb-validation-summary cb-validation-summary-info mb-0" role="status">Henüz işlem geçmişi yok.</div>
        </div>

        <div class="d-none" data-cb-closed-positions-panel="loading">
            <div class="cb-validation-summary cb-validation-summary-info mb-0" role="status">İşlem geçmişi hazırlanıyor.</div>
        </div>

        <div class="d-none" data-cb-closed-positions-panel="error">
            <div class="cb-validation-summary cb-validation-summary-danger mb-0" role="alert">İşlem geçmişi alınamadı.</div>
        </div>
    </div>
</div>
