<div class="card card-custom gutter-b cb-card">
    <div class="card-header border-0 pt-6">
        <div class="card-title">
            <div>
                <h3 class="card-label font-weight-bolder mb-1">Kapalı pozisyonlar</h3>
                <div class="text-muted font-size-sm">History review odaklı kapalı pozisyonlar listesi realized PnL ve kapanış nedeni ile birlikte gösterilir.</div>
            </div>
        </div>
    </div>
    <div class="card-body pt-2">
        <div class="cb-table-wrap" data-cb-closed-positions-panel="list">
            <table class="table table-borderless cb-table mb-0">
                <thead>
                    <tr>
                        <th>Sembol</th>
                        <th>Yön</th>
                        <th>Lev.</th>
                        <th>Giriş / Çıkış</th>
                        <th>Realized PnL</th>
                        <th>Kapanış nedeni</th>
                        <th>Süre</th>
                        <th>Bot</th>
                        <th>Kapanış</th>
                        <th class="text-right">Aksiyon</th>
                    </tr>
                </thead>
                <tbody>
                    <tr data-cb-position-detail="eth-closed" data-cb-position-kind="closed">
                        <td><div class="cb-bot-row-title">ETHUSDT</div><div class="cb-bot-row-subtitle">Momentum cycle</div></td>
                        <td><span class="cb-badge cb-badge-success cb-direction-badge">▲ Long</span></td>
                        <td><span class="cb-badge cb-badge-neutral">—</span></td>
                        <td class="cb-mono">3,180 / 3,246</td>
                        <td class="cb-mono cb-text-positive">+$96</td>
                        <td><span class="cb-badge cb-badge-success">Take Profit</span></td>
                        <td><div class="cb-mono">2 sa 11 dk</div><div class="cb-bot-inline-help">Holding time</div></td>
                        <td><span class="cb-badge cb-badge-info">Alpha Spot Pulse</span></td>
                        <td><div class="cb-mono">21 Mar · 08:44</div></td>
                        <td class="text-right"><button type="button" class="btn btn-xs btn-light-primary font-weight-bold" data-cb-position-open-detail="eth-closed" data-cb-drawer-target="#cb_positions_detail_drawer">Detay</button></td>
                    </tr>
                    <tr data-cb-position-detail="btc-closed" data-cb-position-kind="closed">
                        <td><div class="cb-bot-row-title">BTCUSDT</div><div class="cb-bot-row-subtitle">Breakout fade</div></td>
                        <td><span class="cb-badge cb-badge-danger cb-direction-badge">▼ Short</span></td>
                        <td><span class="cb-badge cb-badge-warning">4x</span></td>
                        <td class="cb-mono">62,310 / 62,540</td>
                        <td class="cb-mono cb-text-negative">-$58</td>
                        <td><span class="cb-badge cb-badge-danger">Stop Loss</span></td>
                        <td><div class="cb-mono">36 dk</div><div class="cb-bot-inline-help">Holding time</div></td>
                        <td><span class="cb-badge cb-badge-warning">Beta Hedge Runner</span></td>
                        <td><div class="cb-mono">21 Mar · 07:52</div></td>
                        <td class="text-right"><button type="button" class="btn btn-xs btn-light-primary font-weight-bold" data-cb-position-open-detail="btc-closed" data-cb-drawer-target="#cb_positions_detail_drawer">Detay</button></td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="d-none" data-cb-closed-positions-panel="empty">
            @await Html.PartialAsync("Foundation/_EmptyState", new UiStateViewModel
            {
                IconText = "CP",
                Title = "Kapalı pozisyon yok",
                Message = "History verisi geldiğinde realized PnL ve kapanış nedenleri bu bölümde review odaklı gösterilir.",
                ActionText = "Strategy Builder’ı aç",
                ActionHref = "/StrategyBuilder"
            })
        </div>

        <div class="d-none" data-cb-closed-positions-panel="loading">
            @await Html.PartialAsync("Foundation/_LoadingState", new UiLoadingStateViewModel
            {
                Title = "Kapalı pozisyon history hazırlanıyor",
                Message = "Realized PnL ve kapanış nedeni satırları yükleniyor.",
                CardCount = 2,
                LineCount = 4
            })
        </div>

        <div class="d-none" data-cb-closed-positions-panel="error">
            @await Html.PartialAsync("Foundation/_ErrorState", new UiStateViewModel
            {
                IconText = "!",
                Title = "Kapalı pozisyon history alınamadı",
                Message = "History yüzeyi hata aldığında kullanıcıyı retry ve yardım akışına taşıyan kontrollü UI görünümü gösterilir.",
                ActionText = "Tekrar dene",
                ActionHref = "#",
                SecondaryActionText = "Backtest’e git",
                SecondaryActionHref = "/Backtest"
            })
        </div>
    </div>
</div>
