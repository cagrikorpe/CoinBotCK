@{
    var items = new[]
    {
        new { Label = "Toplam bakiye", Value = "$ 24,860.42", Help = "Başlangıçtan +4.8%", Tone = "positive", Tag = "Equity" },
        new { Label = "Kullanılabilir bakiye", Value = "$ 6,410.15", Help = "Serbest marjin alanı", Tone = "neutral", Tag = "Available" },
        new { Label = "Günlük PnL", Value = "+$ 412.08", Help = "Bugün 7 sinyal işlendi", Tone = "positive", Tag = "+1.7%" },
        new { Label = "Haftalık PnL", Value = "-$ 182.44", Help = "Risk limiti altında", Tone = "negative", Tag = "-0.7%" },
        new { Label = "Açık pozisyon", Value = "4", Help = "2 long • 2 short", Tone = "neutral", Tag = "Positions" },
        new { Label = "Aktif bot", Value = "3", Help = "1 paper • 2 live", Tone = "neutral", Tag = "Bots" }
    };
}
<div class="row">
    @foreach (var item in items)
    {
        <div class="col-sm-6 col-xl-4 col-xxl-2">
            <div class="card card-custom gutter-b cb-card cb-stat-card cb-dashboard-kpi-card">
                <div class="card-body">
                    <div class="cb-stat-top">
                        <span class="cb-stat-label">@item.Label</span>
                        <span class="cb-badge @(item.Tone == "positive" ? "cb-badge-success" : item.Tone == "negative" ? "cb-badge-danger" : "cb-badge-neutral")">@item.Tag</span>
                    </div>
                    <div class="cb-stat-value cb-mono @(item.Tone == "positive" ? "cb-text-positive" : item.Tone == "negative" ? "cb-text-negative" : string.Empty)">@item.Value</div>
                    <div class="cb-dashboard-kpi-footer">
                        <span class="cb-dashboard-kpi-dot @(item.Tone == "positive" ? "is-positive" : item.Tone == "negative" ? "is-negative" : "is-neutral")"></span>
                        <span class="cb-stat-help">@item.Help</span>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
