@model CoinBot.Web.ViewModels.Home.DashboardViewModel

<div class="card card-custom gutter-b cb-card cb-dashboard-card cb-equity-card">
    <div class="card-header border-0 pt-6">
        <div class="card-title d-block">
            <h3 class="card-label font-weight-bolder mb-0">Equity / performance</h3>
            <div class="text-muted mt-2">Gerçek bakiye, realized/unrealized PnL ve kapanan trade etkisi aynı kartta özetlenir.</div>
        </div>
    </div>
    <div class="card-body pt-2">
        <div class="row">
            <div class="col-md-3 mb-4">
                <div class="cb-chart-summary-card">
                    <div class="cb-stat-label">Equity estimate</div>
                    <div class="cb-chart-summary-value cb-mono">@Model.Performance.EquityEstimate</div>
                </div>
            </div>
            <div class="col-md-3 mb-4">
                <div class="cb-chart-summary-card">
                    <div class="cb-stat-label">Günlük PnL</div>
                    <div class="cb-chart-summary-value cb-mono">@Model.Performance.DailyPnl</div>
                </div>
            </div>
            <div class="col-md-3 mb-4">
                <div class="cb-chart-summary-card">
                    <div class="cb-stat-label">Açık pozisyon etkisi</div>
                    <div class="cb-chart-summary-value cb-mono">@Model.Performance.OpenPositionEffect</div>
                </div>
            </div>
            <div class="col-md-3 mb-4">
                <div class="cb-chart-summary-card">
                    <div class="cb-stat-label">Kapanan trade etkisi</div>
                    <div class="cb-chart-summary-value cb-mono">@Model.Performance.ClosedTradeEffect</div>
                </div>
            </div>
        </div>

        <div class="text-muted mb-4">@Model.Performance.Summary</div>

        @if (!Model.Performance.HasSufficientData)
        {
            <div class="alert alert-light mb-0">@Model.Performance.EmptyStateMessage</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-borderless table-striped mb-0">
                    <thead>
                        <tr>
                            <th>Zaman</th>
                            <th>Equity</th>
                            <th>Kaynak</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var point in Model.Performance.Points)
                        {
                            <tr>
                                <td class="cb-mono">@point.Time</td>
                                <td class="cb-mono">@point.Equity</td>
                                <td>@point.Source</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
