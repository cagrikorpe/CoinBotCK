@model CoinBot.Web.ViewModels.Home.DashboardViewModel
<div class="card card-custom gutter-b cb-card cb-dashboard-card cb-positions-card">
    <div class="card-header border-0 pt-6">
        <div class="card-title d-block">
            <div class="d-flex align-items-center flex-wrap gap-2">
                <h3 class="card-label font-weight-bolder mb-0">Açık Pozisyonlar</h3>
                <span class="cb-badge cb-badge-neutral">@Model.OpenPositions.Count satır</span>
            </div>
            <div class="text-muted mt-2">Exchange private sync ile yazılan gerçek futures pozisyonları burada listelenir.</div>
        </div>
    </div>
    <div class="card-body pt-2">
        @if (Model.OpenPositions.Count == 0)
        {
            <div class="cb-auth-summary-card cb-auth-summary-card-stacked">
                <div class="cb-auth-summary-label">Aktif futures pozisyonu yok</div>
                <div class="cb-auth-summary-text">Exchange private sync yazmaya başladığında gerçek açık pozisyonlar bu tabloda görünür.</div>
            </div>
        }
        else
        {
            <div class="cb-table-wrap">
                <table class="table table-borderless cb-table mb-0">
                    <thead>
                        <tr>
                            <th>Sembol</th>
                            <th>Yön</th>
                            <th>Miktar</th>
                            <th>Giriş</th>
                            <th>Güncel</th>
                            <th>Unrealized PnL</th>
                            <th>Margin</th>
                            <th>Durum</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.OpenPositions)
                        {
                            <tr>
                                <td>
                                    <div class="cb-position-symbol">@row.Symbol</div>
                                    <div class="cb-dashboard-card-meta">Futures sync</div>
                                </td>
                                <td><span class="cb-badge @(row.DirectionTone == "success" ? "cb-badge-success" : "cb-badge-danger")">@row.Direction</span></td>
                                <td class="cb-numeric-cell">@row.Leverage</td>
                                <td class="cb-numeric-cell">@row.Entry</td>
                                <td class="cb-numeric-cell">@row.Current</td>
                                <td class="cb-numeric-cell @(row.PnlTone == "positive" ? "cb-text-positive" : "cb-text-negative")">@row.Pnl</td>
                                <td><span class="cb-badge @(row.RiskTone == "success" ? "cb-badge-success" : row.RiskTone == "warning" ? "cb-badge-warning" : "cb-badge-danger")">@row.Risk</span></td>
                                <td>
                                    <div>@row.Updated</div>
                                    <div class="cb-dashboard-card-meta">İzleniyor</div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="cb-positions-footer mt-5">
                <span class="cb-dashboard-card-meta">Pozisyon satırları `ExchangePositions` ve anlık fiyat cache’i üzerinden üretilir.</span>
                <a asp-controller="Exchanges" asp-action="Index" class="btn btn-light-primary font-weight-bold">Command Center</a>
            </div>
        }
    </div>
</div>
