@model CoinBot.Web.ViewModels.Home.DashboardViewModel
<div class="card card-custom gutter-b cb-card cb-dashboard-card cb-positions-card" data-cb-open-positions-table="true">
    <div class="card-header border-0 pt-6">
        <div class="card-title d-block">
            <div class="d-flex align-items-center flex-wrap gap-2">
                <h3 class="card-label font-weight-bolder mb-0">Açık Pozisyonlar</h3>
                <span class="cb-badge cb-badge-neutral">@Model.OpenPositions.Count satır</span>
            </div>
            <div class="text-muted mt-2">Exchange private sync ile yazılan gerçek futures veya spot exposure satırları burada listelenir.</div>
        </div>
    </div>
    <div class="card-body pt-2">
        @if (Model.OpenPositions.Count == 0)
        {
            <div class="cb-auth-summary-card cb-auth-summary-card-stacked" data-cb-open-positions-empty>
                <div class="cb-auth-summary-label">Aktif pozisyon yok</div>
                <div class="cb-auth-summary-text">Exchange private sync yazmaya başladığında gerçek açık pozisyonlar, break-even ve PnL detayları bu tabloda görünür.</div>
            </div>
        }
        else
        {
            <div class="cb-table-wrap">
                <table class="table table-borderless cb-table mb-0">
                    <thead>
                        <tr data-cb-open-position-row>
                            <th>Sembol</th>
                            <th>Yön</th>
                            <th>Miktar</th>
                            <th>Entry / Break-even</th>
                            <th>Güncel</th>
                            <th>Unrealized PnL</th>
                            <th>Realized PnL</th>
                            <th>Margin</th>
                            <th>Sync</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.OpenPositions)
                        {
                            <tr data-cb-open-position-row>
                                <td>
                                    <div class="cb-position-symbol" data-cb-open-position-symbol>@row.Symbol</div>
                                    <div class="cb-dashboard-card-meta" data-cb-open-position-sync>@row.Reconciliation</div>
                                </td>
                                <td><span class="cb-badge @(row.DirectionTone == "success" ? "cb-badge-success" : "cb-badge-danger")" data-cb-open-position-direction>@row.Direction</span></td>
                                <td class="cb-numeric-cell" data-cb-open-position-quantity>@row.Quantity</td>
                                <td>
                                    <div class="cb-numeric-cell" data-cb-open-position-entry>@row.Entry</div>
                                    <div class="cb-dashboard-card-meta" data-cb-open-position-break-even>Break-even @row.BreakEven</div>
                                </td>
                                <td class="cb-numeric-cell" data-cb-open-position-current>@row.Current</td>
                                <td class="cb-numeric-cell @(row.UnrealizedPnlTone == "positive" ? "cb-text-positive" : "cb-text-negative")" data-cb-open-position-unrealized>@row.UnrealizedPnl</td>
                                <td class="cb-numeric-cell @(row.RealizedPnlTone == "positive" ? "cb-text-positive" : "cb-text-negative")" data-cb-open-position-realized>@row.RealizedPnl</td>
                                <td><span class="cb-badge @(row.MarginTone == "success" ? "cb-badge-success" : row.MarginTone == "warning" ? "cb-badge-warning" : "cb-badge-neutral")" data-cb-open-position-margin>@row.Margin</span></td>
                                <td>
                                    <div data-cb-open-position-updated>@row.Updated</div>
                                    <div class="cb-dashboard-card-meta" data-cb-open-position-sync>@row.Reconciliation</div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="cb-positions-footer mt-5">
                <span class="cb-dashboard-card-meta">Pozisyon satırları `ExchangePositions`, `DemoPositions`, `SpotPortfolioFills` ve anlık fiyat cache’i üzerinden üretilir.</span>
                <a asp-controller="Positions" asp-action="Index" class="btn btn-light-primary font-weight-bold">Pozisyon Detayı</a>
            </div>
        }
    </div>
</div>















