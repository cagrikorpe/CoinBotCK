<div class="card card-custom gutter-b cb-card" id="toolbox">
    <div class="card-header border-0 pt-6">
        <div class="card-title">
            <div>
                <h3 class="card-label font-weight-bolder mb-1">Rule toolbox</h3>
                <div class="text-muted font-size-sm">Indicator, filter ve action bloklarını builder içine eklemek için sade ama genişlemeye açık picker alanı.</div>
            </div>
        </div>
        <div class="card-toolbar">
            <button type="button" class="btn btn-light-primary btn-sm font-weight-bolder" data-cb-drawer-target="#cb_strategy_template_drawer">Kütüphaneyi aç</button>
        </div>
    </div>
    <div class="card-body pt-2">
        <div class="cb-bot-toolbar">
            <div class="position-relative">
                <span class="cb-bot-search-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="none">
                        <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.8"></circle>
                        <path d="M20 20l-3.5-3.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path>
                    </svg>
                </span>
                <input type="text" class="form-control cb-form-control pl-12" placeholder="Blok ara (placeholder)" />
            </div>
        </div>

        <div class="cb-toolbox-group mt-5">
            <span class="cb-toolbox-label">Indicator blocks</span>
            <div class="cb-chip-group cb-chip-group-sm mt-3">
                <button type="button" class="cb-chip">RSI</button>
                <button type="button" class="cb-chip">EMA</button>
                <button type="button" class="cb-chip">MACD</button>
                <button type="button" class="cb-chip">ATR</button>
                <button type="button" class="cb-chip">Volume</button>
            </div>
        </div>
        <div class="cb-toolbox-group mt-5">
            <span class="cb-toolbox-label">Filter blocks</span>
            <div class="cb-chip-group cb-chip-group-sm mt-3">
                <button type="button" class="cb-chip">Trend Filter</button>
                <button type="button" class="cb-chip">Time Window</button>
                <button type="button" class="cb-chip">Cooldown</button>
                <button type="button" class="cb-chip">Market Regime</button>
            </div>
        </div>
        <div class="cb-toolbox-group mt-5">
            <span class="cb-toolbox-label">Action blocks</span>
            <div class="cb-chip-group cb-chip-group-sm mt-3">
                <button type="button" class="cb-chip">Long aç</button>
                <button type="button" class="cb-chip">Short aç</button>
                <button type="button" class="cb-chip">Watch</button>
                <button type="button" class="cb-chip">Pozisyonu azalt</button>
                <button type="button" class="cb-chip">Pozisyonu kapat</button>
            </div>
        </div>
        <div class="cb-toolbox-group mt-5">
            <span class="cb-toolbox-label">Saved snippet</span>
            <div class="cb-mini-helper-card mt-3">Önceki fazlarda oluşturulan bot/strategy akışlarından snippet kaydetme özelliği sonraki faz için placeholder bırakıldı.</div>
        </div>
    </div>
</div>
