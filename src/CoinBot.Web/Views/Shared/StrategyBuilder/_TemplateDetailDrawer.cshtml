<aside class="cb-drawer cb-strategy-drawer" id="cb_strategy_template_drawer" aria-hidden="true">
    <div class="cb-drawer-header">
        <div>
            <div class="cb-drawer-eyebrow" id="cb_strategy_drawer_eyebrow">Template detail</div>
            <h5 class="cb-drawer-title mb-0" id="cb_strategy_drawer_title">Sıfırdan Başla</h5>
        </div>
        <button type="button" class="btn btn-xs btn-icon btn-light" data-cb-drawer-close>
            <span>&times;</span>
        </button>
    </div>
    <div class="cb-drawer-body">
        <div class="cb-mini-helper-card" id="cb_strategy_drawer_description">Hazır template seçmeden kendi condition ve action bloklarını ekleyebileceğin boş canvas başlangıcı.</div>
        <div class="cb-section mt-6">
            <div class="cb-section-title">Uygun market</div>
            <div class="cb-inline-stack mt-3">
                <span class="cb-badge cb-badge-info" id="cb_strategy_drawer_market">Spot / Futures</span>
                <span class="cb-badge cb-badge-warning" id="cb_strategy_drawer_risk">Esnek</span>
                <span class="cb-badge cb-badge-neutral" id="cb_strategy_drawer_tag">Blank</span>
            </div>
        </div>
        <div class="cb-section mt-6">
            <div class="cb-section-title">Builder foundation neyi doldurur?</div>
            <ul class="mb-0 pl-5 text-muted">
                <li>Örnek entry blokları</li>
                <li>Exit / risk section varsayılanları</li>
                <li>Summary açıklama alanı</li>
            </ul>
        </div>
    </div>
    <div class="cb-drawer-footer">
        <button type="button" class="btn btn-light-primary font-weight-bold" data-cb-drawer-close>Kapat</button>
        <button type="button" class="btn btn-primary font-weight-bolder" id="cb_strategy_drawer_apply" data-cb-strategy-apply-template data-cb-drawer-close>Template uygula</button>
    </div>
</aside>
