@using CoinBot.Application.Abstractions.Strategies
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    var templateSnapshots = ViewData["StrategyTemplateCatalog"] as IReadOnlyCollection<StrategyTemplateSnapshot>
        ?? Array.Empty<StrategyTemplateSnapshot>();
    var draftTargets = ViewData["StrategyBuilderDraftTargets"] as IReadOnlyCollection<SelectListItem>
        ?? Array.Empty<SelectListItem>();
    var templates = templateSnapshots.Select(template => new
    {
        Key = template.TemplateKey,
        Name = template.TemplateName,
        Description = template.Description,
        Category = template.Category,
        Validation = template.Validation.StatusCode,
        SchemaVersion = template.SchemaVersion,
        Source = template.TemplateSource,
        CurrentRevision = template.ActiveRevisionNumber,
        LatestRevision = template.LatestRevisionNumber,
        PublishedRevision = template.PublishedRevisionNumber,
        DefinitionJson = template.DefinitionJson
    }).ToArray();
}

<div class="card card-custom gutter-b cb-card" data-cb-strategy-template-panel>
    <div class="card-body">
        <div class="cb-section-title">Şablondan başla</div>
        <p class="cb-page-description mt-2">Hazır bir şablon seçin. Sistem sizin için kullanıcıya ait yeni bir strateji taslağı oluşturur.</p>

        @if (templates.Length == 0)
        {
            <div class="cb-validation-summary cb-validation-summary-info mt-6">Kullanılabilir şablon yok.</div>
        }
        else
        {
            <div class="cb-strategy-template-grid mt-6" data-cb-strategy-template-grid>
                @foreach (var template in templates)
                {
                    <button type="button"
                            class="cb-template-card"
                            data-cb-template-card
                            data-cb-template-key="@template.Key"
                            data-cb-template-name="@template.Name"
                            data-cb-template-risk="Orta"
                            data-cb-template-market="Spot / Futures"
                            data-cb-template-tag="@template.Category"
                            data-cb-template-validation="@template.Validation"
                            data-cb-template-schema="@template.SchemaVersion"
                            data-cb-template-source="@template.Source"
                            data-cb-template-current-revision="@template.CurrentRevision"
                            data-cb-template-latest-revision="@template.LatestRevision"
                            data-cb-template-published-revision="@template.PublishedRevision"
                            data-cb-template-lifecycle="Active"
                            data-cb-template-description="@template.Description"
                            data-cb-template-definition="@template.DefinitionJson">
                        <div class="cb-template-title-row">
                            <strong>@template.Name</strong>
                        </div>
                        <p>@template.Description</p>
                    </button>
                }
            </div>
        }

        <div class="separator separator-dashed my-6"></div>
        <div class="row align-items-start">
            <div class="col-lg-7">
                <div class="cb-section-title">Builder foundation</div>
                <p class="cb-page-description mt-2">Seçilen şablon JSON’u form alanlarına açılır. Form girdileri validation sonrası canonical JSON olarak mevcut strategy version zincirine kaydedilir.</p>

                <form asp-controller="StrategyBuilder"
                      asp-action="StartFromTemplate"
                      method="post"
                      class="mt-6"
                      data-cb-template-start-form>
                    @Html.AntiForgeryToken()
                    <input type="hidden"
                           name="templateKey"
                           value=""
                           data-cb-template-start-template />
                    <input type="hidden"
                           name="definitionJson"
                           value=""
                           data-cb-builder-definition-json />
                    <div class="form-row">
                        <div class="form-group col-md-6">
                            <label class="text-muted font-size-sm mb-2" for="cb_strategy_start_name">Strateji adı</label>
                            <input class="form-control"
                                   id="cb_strategy_start_name"
                                   name="strategyName"
                                   maxlength="128"
                                   placeholder="Örn. BTC ana strateji"
                                   data-cb-template-strategy-name />
                        </div>
                        <div class="form-group col-md-6">
                            <label class="text-muted font-size-sm mb-2" for="cb_strategy_template_name">Preview template adı</label>
                            <input class="form-control"
                                   id="cb_strategy_template_name"
                                   maxlength="128"
                                   placeholder="Şablon adı"
                                   data-cb-builder-template-name />
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group col-md-4">
                            <label class="text-muted font-size-sm mb-2" for="cb_strategy_schema_version">Schema</label>
                            <input class="form-control"
                                   id="cb_strategy_schema_version"
                                   readonly
                                   data-cb-builder-schema-version />
                        </div>
                        <div class="form-group col-md-4">
                            <label class="text-muted font-size-sm mb-2" for="cb_strategy_template_key">Template key</label>
                            <input class="form-control"
                                   id="cb_strategy_template_key"
                                   readonly
                                   data-cb-builder-template-key />
                        </div>
                        <div class="form-group col-md-4">
                            <label class="text-muted font-size-sm mb-2" for="cb_strategy_section_count">Section</label>
                            <input class="form-control"
                                   id="cb_strategy_section_count"
                                   readonly
                                   data-cb-builder-section-count />
                        </div>
                    </div>

                    <div data-cb-builder-form-root></div>

                    <div class="cb-validation-summary cb-validation-summary-info mt-4" role="status" data-cb-builder-preview-status>
                        Bir şablon seçtiğinizde form alanları mevcut JSON ile doldurulur.
                    </div>
                    <div class="cb-validation-summary cb-validation-summary-warning mt-4 d-none" role="alert" data-cb-builder-validation-summary>
                        <div class="font-weight-bolder mb-2" data-cb-builder-validation-badge>Validation bekleniyor</div>
                        <ul class="mb-0 pl-5" data-cb-builder-validation-list></ul>
                    </div>

                    <div class="cb-validation-summary cb-validation-summary-info mt-4" role="status" data-cb-builder-explainability-summary>
                        <div class="font-weight-bolder mb-2" data-cb-builder-explainability-badge>Neden entry yok / neden blocked?</div>
                        <ul class="mb-0 pl-5" data-cb-builder-explainability-list>
                            <li>Bir şablon seçtiğinizde strategy input ve runtime gate parity özeti burada görünür.</li>
                        </ul>
                    </div>

                    <div class="table-responsive mt-4">
                        <table class="table table-borderless table-sm mb-0">
                            <thead>
                                <tr>
                                    <th>Metric</th>
                                    <th>Strategy input</th>
                                    <th>Runtime gate</th>
                                    <th>Parity</th>
                                </tr>
                            </thead>
                            <tbody data-cb-builder-parity-body>
                                <tr>
                                    <td colspan="4" class="text-muted font-size-sm">Parity tablosu şablon seçilince dolar.</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <button type="submit"
                            class="btn btn-primary font-weight-bolder mt-5"
                            data-cb-template-start-submit
                            disabled>
                        Strateji taslağı oluştur
                    </button>
                </form>
            </div>
            <div class="col-lg-5 mt-8 mt-lg-0">
                <div class="d-flex align-items-center justify-content-between flex-wrap" style="gap:12px;">
                    <div class="cb-section-title">Canlı preview JSON</div>
                    <button type="button" class="btn btn-light-primary btn-sm font-weight-bolder" data-cb-builder-advanced-toggle>Advanced mode</button>
                </div>
                <p class="cb-page-description mt-2">Form alanları değiştikçe preview JSON güncellenir. Geçerli durumda save sırasında aynı içerik canonical JSON olarak persist edilir.</p>
                <div class="text-muted font-size-sm mt-2" data-cb-builder-runtime-threshold-summary>Runtime gate threshold özeti şablon seçilince görünür.</div>
                <div class="cb-code-block mt-4" style="max-height: 420px; overflow:auto;">
                    <pre class="mb-0 font-size-sm" data-cb-builder-json-preview>{ }</pre>
                </div>
                <div class="cb-validation-summary cb-validation-summary-info mt-4 d-none" data-cb-builder-advanced-panel>
                    <div class="d-flex align-items-start justify-content-between flex-wrap" style="gap:12px;">
                        <div>
                            <div class="font-weight-bolder">Advanced mode JSON editörü</div>
                            <div class="text-muted font-size-sm mt-1">JSON’u burada düzenleyip forma kontrollü şekilde geri uygulayabilirsiniz.</div>
                        </div>
                        <button type="button" class="btn btn-light-primary btn-sm font-weight-bolder" data-cb-builder-advanced-apply>JSON’u forma uygula</button>
                    </div>
                    <textarea class="form-control font-size-sm mt-4" rows="18" data-cb-builder-advanced-json spellcheck="false"></textarea>
                    <div class="text-muted font-size-sm mt-3" data-cb-builder-advanced-status>Advanced mode pasif.</div>
                </div>
            </div>
        </div>

        @if (draftTargets.Count > 0)
        {
            <div class="separator separator-dashed my-6"></div>
            <form asp-controller="StrategyBuilder"
                  asp-action="CreateDraftFromTemplate"
                  method="post"
                  class="d-flex flex-wrap align-items-end"
                  style="gap: 12px;"
                  data-cb-template-draft-form>
                @Html.AntiForgeryToken()
                <input type="hidden"
                       name="templateKey"
                       value=""
                       data-cb-template-draft-template />
                <input type="hidden"
                       name="definitionJson"
                       value=""
                       data-cb-builder-definition-json />
                <div class="flex-grow-1" style="min-width: 240px;">
                    <label class="text-muted font-size-sm mb-2" for="cb_strategy_template_draft_target">Mevcut strateji</label>
                    <select class="form-control"
                            id="cb_strategy_template_draft_target"
                            name="strategyId"
                            data-cb-template-draft-target>
                        @foreach (var target in draftTargets)
                        {
                            <option value="@target.Value">@target.Text</option>
                        }
                    </select>
                </div>
                <button type="submit"
                        class="btn btn-light-primary font-weight-bolder"
                        data-cb-template-draft-submit
                        disabled>
                    Seçili stratejiye taslak ekle
                </button>
            </form>
        }
        else
        {
            <div class="cb-validation-summary cb-validation-summary-info mt-6" role="status" data-cb-strategy-empty-state>
                Henüz strateji yok. Bir şablon seçip ilk strateji taslağını oluşturun.
            </div>
        }

        <div class="text-muted font-size-sm mt-4" data-cb-template-selection-summary>Önce bir şablon seçin.</div>
        <div class="text-muted font-size-sm mt-2" data-cb-template-target-summary>Bot oluştururken strateji seçimi bu listeden yapılır.</div>
    </div>
</div>
