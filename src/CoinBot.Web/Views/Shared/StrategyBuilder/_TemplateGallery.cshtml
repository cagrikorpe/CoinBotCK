@using CoinBot.Application.Abstractions.Strategies
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    var templateSnapshots = ViewData["StrategyTemplateCatalog"] as IReadOnlyCollection<StrategyTemplateSnapshot>
        ?? Array.Empty<StrategyTemplateSnapshot>();
    var draftTargets = ViewData["StrategyBuilderDraftTargets"] as IReadOnlyCollection<SelectListItem>
        ?? Array.Empty<SelectListItem>();
    var templates = templateSnapshots.Select((template, index) => new
    {
        Key = template.TemplateKey,
        Name = template.TemplateName,
        Description = template.Description,
        Risk = template.Category == "Momentum" ? "Yüksek" : template.Category == "MeanReversion" ? "Orta" : "Orta",
        Market = "Spot / Futures",
        Tag = template.Category,
        Validation = template.Validation.StatusCode,
        SchemaVersion = template.SchemaVersion,
        Selected = index == 0
    }).ToArray();
}

<div class="card card-custom gutter-b cb-card">
    <div class="card-header border-0 pt-6">
        <div class="card-title">
            <div>
                <h3 class="card-label font-weight-bolder mb-1">Template seçimi</h3>
                <div class="text-muted font-size-sm">Hazır strategy şablonları backend catalog servisinden gelir ve publish öncesi validator ile kontrol edilir.</div>
            </div>
        </div>
        <div class="card-toolbar">
            <button type="button" class="btn btn-light-primary btn-sm font-weight-bolder" data-cb-drawer-target="#cb_strategy_template_drawer">Template detayları</button>
        </div>
    </div>
    <div class="card-body pt-2">
        <div class="cb-strategy-template-grid" data-cb-strategy-template-grid>
            @foreach (var template in templates)
            {
                <button type="button"
                        class="cb-template-card @(template.Selected ? "is-selected" : string.Empty)"
                        data-cb-template-card
                        data-cb-template-key="@template.Key"
                        data-cb-template-name="@template.Name"
                        data-cb-template-risk="@template.Risk"
                        data-cb-template-market="@template.Market"
                        data-cb-template-tag="@template.Tag"
                        data-cb-template-validation="@template.Validation"
                        data-cb-template-schema="@template.SchemaVersion"
                        data-cb-template-description="@template.Description">
                    <span class="cb-template-tag">@template.Tag</span>
                    <div class="cb-template-title-row">
                        <strong>@template.Name</strong>
                        <span class="cb-badge @(template.Risk == "Yüksek" ? "cb-badge-danger" : template.Risk == "Düşük" ? "cb-badge-success" : "cb-badge-warning")">@template.Risk</span>
                    </div>
                    <p>@template.Description</p>
                    <div class="cb-template-meta">
                        <span>Schema v@template.SchemaVersion · @template.Validation</span>
                        <span>Uygula</span>
                    </div>
                </button>
            }
        </div>
        <form asp-controller="StrategyBuilder"
              asp-action="CreateDraftFromTemplate"
              method="post"
              class="mt-6 d-flex flex-wrap align-items-end"
              style="gap: 12px;"
              data-cb-template-draft-form>
            <input type="hidden"
                   id="cb_strategy_template_draft_key"
                   name="templateKey"
                   value="@(templates.FirstOrDefault()?.Key ?? string.Empty)"
                   data-cb-template-draft-template />
            <div class="flex-grow-1" style="min-width: 240px;">
                <label class="text-muted font-size-sm mb-2" for="cb_strategy_template_draft_target">Hedef strategy</label>
                <select class="form-control"
                        id="cb_strategy_template_draft_target"
                        name="strategyId"
                        data-cb-template-draft-target
                        disabled="@(draftTargets.Count == 0)">
                    @if (draftTargets.Count == 0)
                    {
                        <option value="">Kullanıcıya ait strategy bulunamadı</option>
                    }
                    else
                    {
                        @foreach (var target in draftTargets)
                        {
                            <option value="@target.Value">@target.Text</option>
                        }
                    }
                </select>
            </div>
            <button type="submit"
                    class="btn btn-primary font-weight-bolder"
                    data-cb-template-draft-submit
                    disabled="@(draftTargets.Count == 0 || templates.Length == 0)">
                Seçili template’ten draft oluştur
            </button>
        </form>
    </div>
</div>

