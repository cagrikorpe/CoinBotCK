<div class="card card-custom gutter-b cb-card">
    <div class="card-header border-0 pt-6">
        <div class="card-title">
            <div>
                <h3 class="card-label font-weight-bolder mb-1">Son paper işlemler</h3>
                <div class="text-muted font-size-sm">Paper işlem geçmişi Backtest’ten ayrı olarak canlı akış simülasyonu hissi verir.</div>
            </div>
        </div>
        <div class="card-toolbar cb-inline-stack">
            <div class="cb-filter-bar cb-filter-bar-compact">
                <div class="cb-chip-group cb-chip-group-sm" data-cb-toggle-group>
                    <button type="button" class="cb-chip is-active" data-cb-toggle-active data-cb-paper-trade-filter="all">Tümü</button>
                    <button type="button" class="cb-chip" data-cb-toggle-active data-cb-paper-trade-filter="open">Açıldı</button>
                    <button type="button" class="cb-chip" data-cb-toggle-active data-cb-paper-trade-filter="closed">Kapandı</button>
                    <button type="button" class="cb-chip" data-cb-toggle-active data-cb-paper-trade-filter="tp">TP/Stop</button>
                </div>
            </div>
        </div>
    </div>
    <div class="card-body pt-2">
        <div class="cb-table-wrap" data-cb-paper-trades-panel="list">
            <table class="table table-borderless cb-table mb-0">
                <thead>
                    <tr>
                        <th>Tarih/Saat</th>
                        <th>Sembol</th>
                        <th>Yön</th>
                        <th>Giriş / Çıkış</th>
                        <th>Sonuç</th>
                        <th>Bot</th>
                        <th>İşlem tipi</th>
                        <th>Setup</th>
                        <th class="text-right">Aksiyon</th>
                    </tr>
                </thead>
                <tbody>
                    <tr data-cb-paper-trade-row data-cb-paper-activity-id="btc-trade" data-cb-paper-trade-kind="closed">
                        <td><div class="cb-bot-row-title cb-mono">21 Mar</div><div class="cb-bot-row-subtitle">09:42</div></td>
                        <td><div class="cb-bot-row-title">BTCUSDT</div><div class="cb-bot-row-subtitle">1h</div></td>
                        <td><span class="cb-badge cb-badge-success">Long</span></td>
                        <td class="cb-mono">61,420 / 62,180</td>
                        <td class="cb-mono cb-text-positive">+$142</td>
                        <td><span class="cb-badge cb-badge-info">Alpha Spot Pulse</span></td>
                        <td><span class="cb-badge cb-badge-success">Kapandı</span></td>
                        <td><span class="cb-badge cb-badge-info">Momentum</span></td>
                        <td class="text-right"><div class="cb-table-actions justify-content-end"><button type="button" class="btn btn-xs btn-light-primary font-weight-bold" data-cb-paper-activity-detail="btc-trade" data-cb-drawer-target="#cb_paper_activity_drawer">Detay</button></div></td>
                    </tr>
                    <tr data-cb-paper-trade-row data-cb-paper-activity-id="eth-trade" data-cb-paper-trade-kind="open">
                        <td><div class="cb-bot-row-title cb-mono">21 Mar</div><div class="cb-bot-row-subtitle">08:58</div></td>
                        <td><div class="cb-bot-row-title">ETHUSDT</div><div class="cb-bot-row-subtitle">15m</div></td>
                        <td><span class="cb-badge cb-badge-danger">Short</span></td>
                        <td class="cb-mono">3,248 / —</td>
                        <td class="cb-mono cb-text-negative">-$24</td>
                        <td><span class="cb-badge cb-badge-warning">Beta Hedge Runner</span></td>
                        <td><span class="cb-badge cb-badge-warning">Açıldı</span></td>
                        <td><span class="cb-badge cb-badge-warning">Breakout</span></td>
                        <td class="text-right"><div class="cb-table-actions justify-content-end"><button type="button" class="btn btn-xs btn-light-primary font-weight-bold" data-cb-paper-activity-detail="eth-trade" data-cb-drawer-target="#cb_paper_activity_drawer">Detay</button></div></td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="d-none" data-cb-paper-trades-panel="empty">
            @await Html.PartialAsync("Foundation/_EmptyState", new UiStateViewModel
            {
                IconText = "TR",
                Title = "Henüz paper işlem yok",
                Message = "Paper botlar sinyal ürettiğinde açıldı, kapandı ve azaltıldı gibi akışlar burada listelenecek.",
                ActionText = "Paper botları incele",
                ActionHref = "#paper-bots"
            })
        </div>

        <div class="d-none" data-cb-paper-trades-panel="loading">
            @await Html.PartialAsync("Foundation/_LoadingState", new UiLoadingStateViewModel
            {
                Title = "Paper işlemler yükleniyor",
                Message = "Canlı akış simülasyonuna yakın işlem satırları skeleton halinde hazırlanıyor.",
                CardCount = 2,
                LineCount = 4
            })
        </div>

        <div class="d-none" data-cb-paper-trades-panel="error">
            @await Html.PartialAsync("Foundation/_ErrorState", new UiStateViewModel
            {
                IconText = "!",
                Title = "Paper işlem geçmişi alınamadı",
                Message = "Hata anında kullanıcıyı retry ve yardım akışına taşıyan kontrollü UI yüzeyi gösterilir.",
                ActionText = "Tekrar dene",
                ActionHref = "#",
                SecondaryActionText = "Yardımı aç",
                SecondaryActionHref = "#paper-help"
            })
        </div>
    </div>
</div>
