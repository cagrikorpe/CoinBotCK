@model CoinBot.Web.Controllers.RiskCenterViewModel

<div class="card card-custom gutter-b cb-card">
    <div class="card-header border-0 pt-6">
        <div class="card-title">
            <div>
                <h3 class="card-label font-weight-bolder mb-1">Risk tercihleri</h3>
                <div class="text-muted font-size-sm">Botların işlem açarken kullanacağı temel limitler.</div>
            </div>
        </div>
        <div class="card-toolbar">
            <span class="cb-badge @(Model.HasProfile ? "cb-badge-success" : "cb-badge-warning")">@Model.StatusText</span>
        </div>
    </div>
    <div class="card-body pt-2">
        <form asp-controller="RiskCenter" asp-action="Index" method="post" data-cb-risk-real-form>
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

            <div class="cb-form-grid">
                <div>
                    <label asp-for="Input.ProfileName" class="cb-form-label">Profil adı</label>
                    <input asp-for="Input.ProfileName" class="form-control cb-form-control" maxlength="64" />
                    <span asp-validation-for="Input.ProfileName" class="text-danger font-size-sm"></span>
                </div>
                <div>
                    <label asp-for="Input.MaxLeverage" class="cb-form-label">Max kaldıraç</label>
                    <input asp-for="Input.MaxLeverage" type="number" min="1" max="25" step="0.1" class="form-control cb-form-control" />
                    <div class="cb-helper-text">İlk testte 1x önerilir.</div>
                    <span asp-validation-for="Input.MaxLeverage" class="text-danger font-size-sm"></span>
                </div>
                <div>
                    <label asp-for="Input.MaxDailyLossPercentage" class="cb-form-label">Günlük max zarar %</label>
                    <input asp-for="Input.MaxDailyLossPercentage" type="number" min="0.1" max="100" step="0.1" class="form-control cb-form-control" />
                    <span asp-validation-for="Input.MaxDailyLossPercentage" class="text-danger font-size-sm"></span>
                </div>
                <div>
                    <label asp-for="Input.MaxWeeklyLossPercentage" class="cb-form-label">Haftalık max zarar %</label>
                    <input asp-for="Input.MaxWeeklyLossPercentage" type="number" min="0.1" max="100" step="0.1" class="form-control cb-form-control" />
                    <span asp-validation-for="Input.MaxWeeklyLossPercentage" class="text-danger font-size-sm"></span>
                </div>
                <div>
                    <label asp-for="Input.MaxPositionSizePercentage" class="cb-form-label">Pozisyon limiti %</label>
                    <input asp-for="Input.MaxPositionSizePercentage" type="number" min="0.1" max="100" step="0.1" class="form-control cb-form-control" />
                    <span asp-validation-for="Input.MaxPositionSizePercentage" class="text-danger font-size-sm"></span>
                </div>
                <div>
                    <label asp-for="Input.MaxSymbolExposurePercentage" class="cb-form-label">Tek sembol limiti %</label>
                    <input asp-for="Input.MaxSymbolExposurePercentage" type="number" min="0.1" max="100" step="0.1" class="form-control cb-form-control" />
                    <span asp-validation-for="Input.MaxSymbolExposurePercentage" class="text-danger font-size-sm"></span>
                </div>
                <div>
                    <label asp-for="Input.MaxConcurrentPositions" class="cb-form-label">Max açık işlem</label>
                    <input asp-for="Input.MaxConcurrentPositions" type="number" min="1" max="50" step="1" class="form-control cb-form-control" />
                    <span asp-validation-for="Input.MaxConcurrentPositions" class="text-danger font-size-sm"></span>
                </div>
                <div>
                    <label class="cb-form-label">Acil durdurma</label>
                    <label class="checkbox checkbox-outline checkbox-outline-2x checkbox-primary d-flex align-items-center mt-3">
                        <input asp-for="Input.KillSwitchEnabled" />
                        <span></span>
                        <strong class="ml-3">İşlem açmayı durdur</strong>
                    </label>
                    <div class="cb-helper-text">Açık kalırsa botlar güvenli şekilde işlem açmaz.</div>
                </div>
            </div>

            <div class="d-flex flex-wrap align-items-center justify-content-between mt-6">
                <div class="text-muted font-size-sm">Kaydetmeden botlar risk kontrolünden geçemez.</div>
                <button type="submit" class="btn btn-primary font-weight-bolder">Kaydet</button>
            </div>
        </form>
    </div>
</div>
