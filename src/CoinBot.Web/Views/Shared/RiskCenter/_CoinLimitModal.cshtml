<div class="modal fade cb-modal" id="cb_coin_limit_modal" tabindex="-1" role="dialog" aria-labelledby="cb_coin_limit_modal_title" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <div class="cb-page-eyebrow mb-2" id="cb_coin_limit_modal_eyebrow">Coin Limit</div>
                    <h5 class="modal-title" id="cb_coin_limit_modal_title">Coin limiti ekle</h5>
                </div>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="cb-notice cb-notice-info mb-5">Gerçek persist akışı sonraki fazda eklenecek; bu modal coin bazlı limit create/edit standardını hazırlar.</div>
                <div class="cb-form-grid">
                    <div>
                        <label class="cb-form-label">Coin</label>
                        <input type="text" class="form-control cb-form-control" id="cb_coin_limit_symbol" value="BTCUSDT" />
                    </div>
                    <div>
                        <label class="cb-form-label">Limit tipi</label>
                        <select class="form-control cb-form-control">
                            <option>Exposure</option>
                            <option>Cooldown</option>
                            <option>Max pozisyon</option>
                        </select>
                    </div>
                    <div>
                        <label class="cb-form-label">Değer</label>
                        <input type="text" class="form-control cb-form-control" value="%12" />
                    </div>
                    <div>
                        <label class="cb-form-label">Kısa not</label>
                        <input type="text" class="form-control cb-form-control" value="Volatil coin için daha sıkı limit" />
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light-primary font-weight-bold" data-dismiss="modal">İptal</button>
                <button type="button" class="btn btn-primary font-weight-bolder" data-dismiss="modal">Kaydet</button>
            </div>
        </div>
    </div>
</div>
