@using System.Text.Json
@using CoinBot.Application.Abstractions.ExchangeCredentials
@model CoinBot.Web.ViewModels.Home.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    ViewData["ActiveNav"] = "Dashboard";
    ViewData["PageDescription"] = "Operasyonel dashboard; realtime market fiyat kutuları, KPI, guard ozeti ve acik pozisyonlari tek yuzeyde toplar.";
    ViewData["BreadcrumbItems"] = new[] { "Control Surface", "Dashboard" };
    var marketSymbolsJson = JsonSerializer.Serialize(Model.MarketTickers.Select(item => item.Symbol));
    var exchangeSnapshot = ViewData["DashboardExchangeSnapshot"] as UserExchangeCommandCenterSnapshot;
    var latestExchangeAccount = exchangeSnapshot?.Accounts.FirstOrDefault();
    var exchangeStatusLabel = latestExchangeAccount?.CredentialStatusLabel ?? "Bagli hesap yok";
    var exchangeStatusTone = latestExchangeAccount?.CredentialStatusTone ?? "neutral";
    var exchangeSummaryText = latestExchangeAccount is null
        ? "Binance API key baglantisi yapilmadi. Kayit ve validation sonucu Command Center'da ve bu kartta gorunur."
        : !string.IsNullOrWhiteSpace(latestExchangeAccount.LastFailureReason)
            ? latestExchangeAccount.LastFailureReason
            : $"{latestExchangeAccount.PermissionSummary} · {latestExchangeAccount.EnvironmentLabel}";
    var exchangeActionText = latestExchangeAccount is null ? "Binance bagla" : "Command Center";
    var exchangeBadgeClass = exchangeStatusTone == "healthy"
        ? "cb-badge-success"
        : exchangeStatusTone == "warning"
            ? "cb-badge-warning"
            : exchangeStatusTone == "critical"
                ? "cb-badge-danger"
                : "cb-badge-neutral";
    var exchangeBannerStyle = exchangeStatusTone switch
    {
        "healthy" => "background:#ecfdf3;border:1px solid #95d5b2;color:#0f5132;padding:14px 16px;border-radius:12px;margin-top:24px;",
        "warning" => "background:#fff8e1;border:1px solid #f5d48a;color:#6b4f00;padding:14px 16px;border-radius:12px;margin-top:24px;",
        "critical" => "background:#fff1f2;border:1px solid #f2a8b5;color:#7a1f2f;padding:14px 16px;border-radius:12px;margin-top:24px;",
        _ => "background:#eef7ff;border:1px solid #a9d4ff;color:#0b4f7a;padding:14px 16px;border-radius:12px;margin-top:24px;"
    };
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/%40microsoft/signalr@9.0.0/dist/browser/signalr.min.js"></script>
    <script src="~/js/dashboard-ui.js" asp-append-version="true"></script>
}

<div class="row"
     data-cb-market-dashboard
     data-cb-market-hub-url="@Model.MarketDataHubPath"
     data-cb-market-symbols='@marketSymbolsJson'
     data-cb-display-timezone-id="@Model.DisplayTimeZoneJavaScriptId"
     data-cb-display-timezone-label="@Model.DisplayTimeZoneLabel">
    <div class="col-12">
        <div class="card card-custom gutter-b cb-card cb-dashboard-hero-card">
            <div class="card-body">
                <div class="cb-page-header">
                    <div>
                        <div class="cb-page-eyebrow">Operations Dashboard</div>
                        <h2 class="cb-page-title">Trading kontrol yüzeyi</h2>
                        <p class="cb-page-description">Merkezi market data hattı ile beslenen fiyat kutuları ve operasyon kartları aynı dashboard yüzeyinde buluşur.</p>
                    </div>
                    <div class="cb-toolbar">
                        <span class="cb-badge @exchangeBadgeClass">@exchangeStatusLabel</span>
                        <button type="button" class="btn btn-light-primary font-weight-bold">Yenile</button>
                        <a asp-controller="Exchanges" asp-action="Index" class="btn btn-primary font-weight-bolder">@exchangeActionText</a>
                    </div>
                </div>

                @await Html.PartialAsync("Dashboard/_FreshnessBar")

                <div data-cb-dashboard-exchange-status="true" style="@exchangeBannerStyle">
                    <div><strong>Son Binance durumu: @exchangeStatusLabel</strong></div>
                    <div class="mt-2">@exchangeSummaryText</div>
                </div>

                <div class="cb-auth-summary-card cb-auth-summary-card-stacked mt-6">
                    <div class="cb-auth-summary-label">Binance baglanti durumu</div>
                    <div class="cb-auth-summary-value">@exchangeStatusLabel</div>
                    <div class="cb-auth-summary-text">@exchangeSummaryText</div>
                    @if (latestExchangeAccount is not null)
                    {
                        <div class="cb-permission-list mt-4">
                            <div class="cb-permission-item">
                                <span>Fingerprint</span>
                                <strong>@latestExchangeAccount.MaskedFingerprint</strong>
                            </div>
                            <div class="cb-permission-item">
                                <span>Son validation</span>
                                <strong>@latestExchangeAccount.LastValidatedLabel</strong>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="col-12">
        @await Html.PartialAsync("Dashboard/_MarketTickerCards", Model.MarketTickers)
    </div>

    <div class="col-12">
        @await Html.PartialAsync("Dashboard/_KpiCards")
    </div>

    <div class="col-12">
        @await Html.PartialAsync("Dashboard/_OperationsSummaryCard", Model)
    </div>

    <div class="col-12">
        @await Html.PartialAsync("Dashboard/_OpenPositionsTable")
    </div>
</div>
