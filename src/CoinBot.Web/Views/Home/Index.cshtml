@{
    ViewData["Title"] = "Dashboard";
    ViewData["ActiveNav"] = "Dashboard";
    ViewData["PageDescription"] = "Operasyonel dashboard foundation; KPI, equity, AI akışı, risk ve hızlı aksiyon alanlarını tek yüzeyde toplar.";
    ViewData["BreadcrumbItems"] = new[] { "Control Surface", "Dashboard" };
}

@section Scripts {
    <script src="~/js/dashboard-foundation.js" asp-append-version="true"></script>
}

<div class="row">
    <div class="col-12">
        <div class="card card-custom gutter-b cb-card cb-dashboard-hero-card">
            <div class="card-body">
                <div class="cb-page-header">
                    <div>
                        <div class="cb-page-eyebrow">Operations Dashboard</div>
                        <h2 class="cb-page-title">Trading kontrol yüzeyi</h2>
                        <p class="cb-page-description">Gerçek veri akışına bağlanmadan önce operasyon, risk ve karar yüzeyinin aynı tasarım diliyle nasıl oturacağını gösteren foundation ekranı.</p>
                    </div>
                    <div class="cb-toolbar">
                        <span class="cb-badge cb-badge-success">Shell ready</span>
                        <button type="button" class="btn btn-light-primary font-weight-bold">Yenile</button>
                        <a asp-controller="Onboarding" asp-action="Index" class="btn btn-primary font-weight-bolder">Kurulumu gözden geçir</a>
                    </div>
                </div>

                @await Html.PartialAsync("Dashboard/_FreshnessBar")
            </div>
        </div>
    </div>

    <div class="col-12">
        @await Html.PartialAsync("Dashboard/_KpiCards")
    </div>

    <div class="col-xl-8">
        @await Html.PartialAsync("Dashboard/_EquityCurveCard")
    </div>

    <div class="col-xl-4">
        @await Html.PartialAsync("Dashboard/_AiFeedCard")
        @await Html.PartialAsync("Dashboard/_RiskPanel")
        @await Html.PartialAsync("Dashboard/_QuickActionsCard")
    </div>

    <div class="col-12">
        @await Html.PartialAsync("Dashboard/_OpenPositionsTable")
    </div>

    <div class="col-12">
        @await Html.PartialAsync("Dashboard/_StatePatternsCard")
    </div>
</div>
