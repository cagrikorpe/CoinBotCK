@using CoinBot.Application.Abstractions.ExchangeCredentials
@model CoinBot.Web.ViewModels.Home.DashboardViewModel
@{
    ViewData["Title"] = "Ana Sayfa";
    ViewData["ActiveNav"] = "Dashboard";
    ViewData["PageDescription"] = "Günlük kullanım için kısa özet.";
    ViewData["BreadcrumbItems"] = new[] { "CoinBot", "Ana Sayfa" };

    var exchangeSnapshot = ViewData["DashboardExchangeSnapshot"] as UserExchangeCommandCenterSnapshot;
    var latestExchangeAccount = exchangeSnapshot?.Accounts.FirstOrDefault();
    var exchangeReady = latestExchangeAccount?.CredentialStatusTone == "healthy";
    var exchangeStatus = exchangeReady ? "Hazır" : "Eksik";
    var exchangeSummary = exchangeReady
        ? "Binance bağlantısı hazır"
        : "Exchange bağlı değil";
    var activeBotCount = Model.OperationsSummary.EnabledBotCount;
    var botStatus = activeBotCount > 0 ? "Aktif" : "Eksik";
    var botSummary = activeBotCount > 0 ? $"{activeBotCount} bot aktif" : "Henüz aktif bot yok";
    var latestOrder = Model.RecentOrders.FirstOrDefault();
    var latestOrderText = latestOrder is null ? "Son işlem yok" : latestOrder.Time;
    var lastErrorText = !string.IsNullOrWhiteSpace(Model.OperationsSummary.LastJobErrorCode)
        ? "Worker çalışmıyor"
        : !string.IsNullOrWhiteSpace(Model.OperationsSummary.LastExecutionFailureCode)
            ? "Sistem hazır değil"
            : "Son hata yok";
    var primaryController = exchangeReady ? "Bots" : "Exchanges";
    var primaryActionText = exchangeReady ? "Botlarımı aç" : "Binance bağlantısını aç";
}

<div class="row" data-cb-user-shell-home>
    <div class="col-xl-7 col-lg-9">
        <div class="card card-custom gutter-b cb-card">
            <div class="card-body">
                <div class="cb-page-header align-items-start">
                    <div>
                        <div class="cb-page-eyebrow">Ana Sayfa</div>
                        <h2 class="cb-page-title">Günlük özet</h2>
                        <p class="cb-page-description">Botlarınızı ve işlemlerinizi buradan takip edin.</p>
                    </div>
                    <div class="cb-toolbar">
                        <a asp-controller="@primaryController" asp-action="Index" class="btn btn-primary font-weight-bolder">@primaryActionText</a>
                        <a asp-controller="Positions" asp-action="Index" class="btn btn-light-primary font-weight-bold">İşlemler</a>
                    </div>
                </div>

                <div class="cb-permission-list mt-8" data-cb-user-shell-summary>
                    <div class="cb-permission-item">
                        <span>Binance</span>
                        <strong>@exchangeStatus</strong>
                    </div>
                    <div class="cb-field-feedback mb-4">@exchangeSummary</div>

                    <div class="cb-permission-item">
                        <span>Botlar</span>
                        <strong>@botStatus</strong>
                    </div>
                    <div class="cb-field-feedback mb-4">@botSummary</div>

                    <div class="cb-permission-item">
                        <span>Son işlem</span>
                        <strong>@latestOrderText</strong>
                    </div>
                    <div class="cb-field-feedback mb-4">İşlem geçmişini İşlemler ekranında görebilirsiniz.</div>

                    <div class="cb-permission-item">
                        <span>Son hata</span>
                        <strong>@lastErrorText</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>