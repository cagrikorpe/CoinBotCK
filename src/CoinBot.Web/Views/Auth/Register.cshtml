@model RegisterViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Register";
    ViewData["AuthTitle"] = "Hesap oluştur";
    ViewData["AuthDescription"] = "Yeni kullanıcıyı kayıt ekranından onboarding wizard akışına taşıyacak sade ve kontrollü foundation ekranı.";
    ViewData["AuthEyebrow"] = "Auth Foundation";
    ViewData["AuthStage"] = "Register";
    ViewData["AuthProgress"] = "2 / 3";
    ViewData["AuthHighlights"] = new[]
    {
        "Trading bağlamına uygun kısa risk onayı",
        "Password strength ve helper text foundation zemini",
        "Kayıt sonrası MFA / onboarding geçişine hazır aksiyon dili"
    };
}

<div class="cb-auth-panel cb-auth-panel-compact">
    <div class="cb-auth-panel-header">
        <div>
            <div class="cb-page-eyebrow">Create Account</div>
            <h2 class="cb-page-title">Yeni hesap oluşturun</h2>
            <p class="cb-page-description">Gerçek kullanıcı oluşturma logic'i olmadan, doğrulama ve kurulum akışına hazır temiz kayıt formu foundation'ı.</p>
        </div>
        <a asp-controller="Auth" asp-action="Login" class="btn btn-light-primary font-weight-bold">Login'e dön</a>
    </div>

    <form class="cb-auth-form-grid" asp-action="Register" asp-controller="Auth" method="post" novalidate>
        <div class="form-group mb-0">
            <label class="cb-form-label">Ad Soyad</label>
            <input asp-for="FullName" class="form-control cb-form-control" placeholder="Ad Soyad" autocomplete="name" />
            <div class="cb-field-feedback">Profil ve onboarding karşılama alanlarında kullanılacak temel kimlik bilgisi.</div>
            <span asp-validation-for="FullName" class="text-danger d-block mt-2"></span>
        </div>

        <div class="form-group mb-0">
            <label class="cb-form-label">E-posta</label>
            <input asp-for="Email" class="form-control cb-form-control" placeholder="E-posta" autocomplete="email" />
            <div class="cb-field-feedback">Bildirim ve olası MFA fallback akışı için foundation alanı.</div>
            <span asp-validation-for="Email" class="text-danger d-block mt-2"></span>
        </div>

        <div class="form-group mb-0">
            <label class="cb-form-label">Şifre</label>
            <div class="cb-auth-password-wrap">
                <input asp-for="Password" id="register_password" class="form-control cb-form-control cb-form-control-with-action" placeholder="Şifre" autocomplete="new-password" />
                <button type="button" class="cb-auth-field-action" data-cb-password-toggle data-cb-password-target="#register_password">Göster</button>
            </div>
            <div class="cb-field-feedback">Kısa helper text alanı: uzun, benzersiz ve tekrar kullanılmayan şifre önerilir.</div>
            <span asp-validation-for="Password" class="text-danger d-block mt-2"></span>
            <div class="cb-password-strength mt-4" aria-label="Password strength foundation">
                <span class="is-active"></span>
                <span class="is-active"></span>
                <span></span>
                <span></span>
            </div>
        </div>

        <div class="form-group mb-0">
            <label class="cb-form-label">Şifre Tekrar</label>
            <div class="cb-auth-password-wrap">
                <input asp-for="ConfirmPassword" id="register_password_repeat" class="form-control cb-form-control cb-form-control-with-action" placeholder="Şifre tekrar" autocomplete="new-password" />
                <button type="button" class="cb-auth-field-action" data-cb-password-toggle data-cb-password-target="#register_password_repeat">Göster</button>
            </div>
            <div class="cb-field-feedback">Input validation ve eşleşme hata alanı foundation bu bölgede gösterilir.</div>
            <span asp-validation-for="ConfirmPassword" class="text-danger d-block mt-2"></span>
        </div>

        <label class="checkbox checkbox-outline checkbox-outline-2x checkbox-primary cb-auth-risk-check">
            <input asp-for="AcceptRiskDisclosure" />
            <span></span>
            Spot / futures işlemlerin piyasa riski taşıdığını ve ilk kurulum adımında risk tercihlerini ayrıca belirleyeceğimi anlıyorum.
        </label>
        <span asp-validation-for="AcceptRiskDisclosure" class="text-danger d-block mt-2"></span>

        @if (ViewContext.ModelState.ErrorCount > 0)
        {
            <div asp-validation-summary="ModelOnly" class="cb-validation-summary cb-validation-summary-warning"></div>
        }
        else
        {
            <div class="cb-validation-summary cb-validation-summary-warning">
                Validation summary foundation: eksik alan, zayıf şifre veya sözleşme onayı hataları bu bölgede toplanır.
            </div>
        }

        <div class="cb-auth-action-row">
            <button type="submit" class="btn btn-primary font-weight-bolder px-10" data-cb-button-loading>
                <span class="cb-btn-label">Hesap oluştur</span>
                <span class="cb-btn-spinner"></span>
            </button>
            <a asp-controller="Auth" asp-action="Login" class="btn btn-clean text-muted font-weight-bold">Zaten hesabım var</a>
        </div>
    </form>

    <div class="cb-auth-alert cb-auth-alert-success mt-8">
        Başarı / sonraki adım placeholder: kayıt tamamlandığında kullanıcı MFA doğrulama veya onboarding wizard akışına yönlendirilir.
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
