@model MfaViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "MFA";
    ViewData["AuthTitle"] = "İkinci doğrulama";
    ViewData["AuthDescription"] = "Login sonrası ikinci güvenlik katmanı için profesyonel görünen, korkutmayan MFA foundation ekranı.";
    ViewData["AuthEyebrow"] = "Security Check";
    ViewData["AuthStage"] = "MFA";
    ViewData["AuthProgress"] = "3 / 3";
    ViewData["AuthHighlights"] = new[]
    {
        "6 haneli OTP input standardı",
        "Authenticator app doğrulaması gerçek backend akışına bağlı",
        "Geçersiz kod ve oturum hataları aynı yüzeyde gösterilir",
        "Login redirect zinciri korunarak sign-in tamamlanır"
    };
}

<div class="cb-auth-panel cb-auth-panel-compact">
    <div class="cb-auth-panel-header">
        <div>
            <div class="cb-page-eyebrow">Multi-Factor Authentication</div>
            <h2 class="cb-page-title">Doğrulama kodunu girin</h2>
            <p class="cb-page-description">Başarılı parola doğrulaması sonrası authenticator uygulamanızdaki 6 haneli kod backend tarafında doğrulanır ve oturum güvenli şekilde tamamlanır.</p>
        </div>
        <a asp-controller="Auth" asp-action="Login" class="btn btn-light-primary font-weight-bold">Başka hesapla giriş</a>
    </div>

    <div class="cb-auth-methods">
        <button type="button" class="cb-auth-method is-active">Authenticator App</button>
        <button type="button" class="cb-auth-method">Email Code</button>
    </div>

    <div class="cb-auth-alert cb-auth-alert-info mt-6">
        Kod doğrulaması başarılı olduğunda kullanıcı hedeflenen auth gerektiren sayfaya yönlendirilir.
    </div>

    <form class="cb-auth-form-grid" asp-action="Mfa" asp-controller="Auth" method="post" novalidate data-cb-mfa-form>
        <input asp-for="Code" type="hidden" data-cb-otp-code />
        <input asp-for="ReturnUrl" type="hidden" />
        <input asp-for="RememberMe" type="hidden" />

        <div class="form-group mb-0">
            <label class="cb-form-label">6 haneli kod</label>
            <div class="cb-otp-group" data-cb-otp-group>
                <input type="text" inputmode="numeric" maxlength="1" class="form-control cb-otp-input" data-cb-otp />
                <input type="text" inputmode="numeric" maxlength="1" class="form-control cb-otp-input" data-cb-otp />
                <input type="text" inputmode="numeric" maxlength="1" class="form-control cb-otp-input" data-cb-otp />
                <input type="text" inputmode="numeric" maxlength="1" class="form-control cb-otp-input" data-cb-otp />
                <input type="text" inputmode="numeric" maxlength="1" class="form-control cb-otp-input" data-cb-otp />
                <input type="text" inputmode="numeric" maxlength="1" class="form-control cb-otp-input" data-cb-otp />
            </div>
            <div class="cb-field-feedback">Kod yalnızca sayısal olarak alınır ve backend'e normalize edilerek gönderilir.</div>
            <span asp-validation-for="Code" class="text-danger d-block mt-2"></span>
        </div>

        <div class="cb-auth-row-between">
            <span class="cb-auth-meta">Authenticator uygulamanizdaki guncel kodu kullanin.</span>
            <span class="cb-auth-inline-link">Email fallback bu patch kapsaminda login ekranina baglanmadi.</span>
        </div>

        @if (ViewContext.ModelState.ErrorCount > 0)
        {
            <div asp-validation-summary="ModelOnly" class="cb-validation-summary cb-validation-summary-danger"></div>
        }
        else
        {
            <div class="cb-validation-summary cb-validation-summary-danger">
                Gecersiz kod veya MFA oturumu bulunamadi durumlari bu bolgede gosterilir.
            </div>
        }

        <div class="cb-auth-action-row">
            <button type="submit" class="btn btn-primary font-weight-bolder px-10" data-cb-button-loading>
                <span class="cb-btn-label">Doğrula</span>
                <span class="cb-btn-spinner"></span>
            </button>
            <a asp-controller="Auth" asp-action="Login" class="btn btn-clean text-muted font-weight-bold">Geri dön</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const form = document.querySelector('[data-cb-mfa-form]');

            if (!form) {
                return;
            }

            const inputs = Array.from(form.querySelectorAll('[data-cb-otp]'));
            const codeInput = form.querySelector('[data-cb-otp-code]');

            if (!codeInput) {
                return;
            }

            const syncCode = () => {
                codeInput.value = inputs
                    .map(input => input.value.replace(/\D/g, '').slice(0, 1))
                    .join('')
                    .slice(0, 6);
            };

            inputs.forEach((input, index) => {
                input.addEventListener('input', () => {
                    input.value = input.value.replace(/\D/g, '').slice(0, 1);
                    syncCode();

                    if (input.value && index < inputs.length - 1) {
                        inputs[index + 1].focus();
                    }
                });

                input.addEventListener('keydown', event => {
                    if (event.key === 'Backspace' && !input.value && index > 0) {
                        inputs[index - 1].focus();
                    }
                });
            });

            syncCode();
        })();
    </script>
}
