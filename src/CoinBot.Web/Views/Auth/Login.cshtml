@model LoginViewModel
@{
    var authSuccess = TempData["AuthSuccess"] as string;
    var authError = TempData["AuthError"] as string;

    Layout = "_AuthLayout";
    ViewData["Title"] = "Login";
    ViewData["AuthTitle"] = "Güvenli giriş";
    ViewData["AuthDescription"] = "Kullanıcıyı güvenli şekilde oturum açtıran ve gerekli olduğunda MFA ile tamamlanan giriş akışı.";
    ViewData["AuthEyebrow"] = "Secure Access";
    ViewData["AuthStage"] = "Login";
    ViewData["AuthProgress"] = "1 / 3";
    ViewData["AuthHighlights"] = new[]
    {
        "Return URL korunarak güvenli redirect uygulanır",
        "Cookie tabanlı oturum ve logout akışı aynı yüzeyle çalışır",
        "Gerekli olduğunda MFA adımı mevcut akışın devamı olarak açılır"
    };
}

<div class="cb-auth-panel cb-auth-panel-compact">
    <div class="cb-auth-panel-header">
        <div>
            <div class="cb-page-eyebrow">Sign In</div>
            <h2 class="cb-page-title">Hesabınıza giriş yapın</h2>
            <p class="cb-page-description">Başarılı girişten sonra oturum çerezi oluşturulur ve yetki gerektiren sayfalara güvenli şekilde yönlendirilirsiniz.</p>
        </div>
        <a asp-controller="Auth" asp-action="Register" class="btn btn-light-primary font-weight-bold">Hesap oluştur</a>
    </div>

    @if (!string.IsNullOrWhiteSpace(authSuccess))
    {
        <div class="cb-auth-alert cb-auth-alert-success">
            @authSuccess
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(authError))
    {
        <div class="cb-auth-alert cb-auth-alert-danger">
            @authError
        </div>
    }
    else
    {
        <div class="cb-auth-alert cb-auth-alert-info">
            E-posta veya kullanıcı adınızla giriş yapın. Korunan bir sayfadan geldiyseniz dönüş yönlendirmesi korunur.
        </div>
    }

    <form class="cb-auth-form-grid" asp-action="Login" asp-controller="Auth" method="post" novalidate>
        <input asp-for="ReturnUrl" type="hidden" />

        <div class="form-group mb-0">
            <label class="cb-form-label">E-posta veya kullanıcı adı</label>
            <input asp-for="EmailOrUserName" class="form-control cb-form-control" placeholder="E-posta veya kullanıcı adı" autocomplete="username" />
            <div class="cb-field-feedback">Kurumsal e-posta veya tanımlı kullanıcı adınızı girin.</div>
            <span asp-validation-for="EmailOrUserName" class="text-danger d-block mt-2"></span>
        </div>

        <div class="form-group mb-0">
            <div class="d-flex align-items-center justify-content-between">
                <label class="cb-form-label mb-0">Şifre</label>
                <a href="#" class="cb-auth-inline-link">Şifremi unuttum</a>
            </div>
            <div class="cb-auth-password-wrap">
                <input asp-for="Password" id="login_password" class="form-control cb-form-control cb-form-control-with-action" placeholder="Şifre" autocomplete="current-password" />
                <button type="button" class="cb-auth-field-action" data-cb-password-toggle data-cb-password-target="#login_password">Göster</button>
            </div>
            <div class="cb-field-feedback">Şifre alanı için show/hide ve helper text standardı hazırlandı.</div>
            <span asp-validation-for="Password" class="text-danger d-block mt-2"></span>
        </div>

        <div class="cb-auth-row-between">
            <label class="checkbox checkbox-outline checkbox-outline-2x checkbox-primary mb-0 cb-auth-check-inline">
                <input asp-for="RememberMe" />
                <span></span>
                Beni hatırla
            </label>
            <span class="cb-auth-meta">Ek doğrulama gerektiğinde MFA adımı gösterilir.</span>
        </div>

        @if (ViewContext.ModelState.ErrorCount > 0)
        {
            <div asp-validation-summary="ModelOnly" class="cb-validation-summary cb-validation-summary-danger"></div>
        }

        <div class="cb-auth-action-row">
            <button type="submit" class="btn btn-primary font-weight-bolder px-10" data-cb-button-loading>
                <span class="cb-btn-label">Giriş yap</span>
                <span class="cb-btn-spinner"></span>
            </button>
            <a asp-controller="Auth" asp-action="Register" class="btn btn-clean text-muted font-weight-bold">Kayıt ekranına geç</a>
        </div>
    </form>

    <div class="cb-auth-footnote">
        Çoklu başarısız denemelerde hesap geçici olarak kilitlenebilir; beklenmeyen girişlerde parolanızı değiştirin.
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
