@using CoinBot.Web.ViewModels.Foundation
@model CoinBot.Web.ViewModels.Exchanges.UserExchangeCommandCenterPageViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Exchange Connect";
    ViewData["AuthTitle"] = "Binance bağlantısını tamamla";
    ViewData["AuthDescription"] = "Kullanıcı Binance API key bilgisini güvenli biçimde gönderir, backend gerçek doğrulamayı yapar ve sonuç geçmişe yazılır.";
    ViewData["AuthEyebrow"] = "Exchange Connect";
    ViewData["AuthStage"] = "Credential Validation";
    ViewData["AuthProgress"] = "6 / 6";
    ViewData["AuthBackHref"] = Url.Action("ExchangeSecurity", "Onboarding");
    ViewData["AuthHighlights"] = new[]
    {
        "Gerçek POST ve validation akışı",
        "Withdraw guard ve demo/live environment kontrolü",
        "Permission summary ve validation history görünürlüğü"
    };

    var steps = new List<UiWizardStepViewModel>
    {
        new() { Number = 1, Title = "Hoş Geldin", Caption = "Tamamlandı", IsCompleted = true },
        new() { Number = 2, Title = "Trade Modu", Caption = "Tamamlandı", IsCompleted = true },
        new() { Number = 3, Title = "Yön", Caption = "Tamamlandı", IsCompleted = true },
        new() { Number = 4, Title = "Risk", Caption = "Tamamlandı", IsCompleted = true },
        new() { Number = 5, Title = "Security", Caption = "Tamamlandı", IsCompleted = true },
        new() { Number = 6, Title = "Connect", Caption = "Aktif", IsCurrent = true }
    };
}

<div class="cb-auth-panel cb-auth-panel-wide">
    <div class="cb-auth-panel-header">
        <div>
            <div class="cb-page-eyebrow">Connection Setup</div>
            <h2 class="cb-page-title">Binance credential doğrulaması</h2>
            <p class="cb-page-description">Gönderilen anahtarlar şifrelenerek saklanır, ardından key geçerliliği, trade izni, withdraw guard ve environment uyumu tek akışta doğrulanır.</p>
        </div>
        <span class="cb-badge cb-badge-warning">Gerçek backend</span>
    </div>

    @await Html.PartialAsync("Foundation/_WizardStepper", steps)

    <div class="mt-8">
        @await Html.PartialAsync("~/Views/Shared/Exchanges/_UserExchangeCommandCenter.cshtml", Model)
    </div>
</div>
