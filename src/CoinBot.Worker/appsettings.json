{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=CoinBotDb;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=True"
  },
  "JobOrchestration": {
    "Enabled": true,
    "SchedulerPollIntervalSeconds": 5,
    "BotExecutionIntervalSeconds": 30,
    "LeaseDurationSeconds": 30,
    "KeepAliveIntervalSeconds": 10,
    "CleanupIntervalSeconds": 60,
    "WatchdogIntervalSeconds": 30,
    "WatchdogTimeoutSeconds": 90,
    "CleanupGracePeriodSeconds": 300,
    "MaxRetryAttempts": 3,
    "InitialRetryDelaySeconds": 5,
    "MaxRetryDelaySeconds": 60,
    "MaxBotsPerCycle": 100,
    "WorkerInstanceId": ""
  },
  "MarketData": {
    "Scanner": {
      "Enabled": true,
      "ScanIntervalSeconds": 30,
      "MaxUniverseSymbols": 100,
      "TopCandidateCount": 10,
      "VolumeLookbackHours": 24,
      "MaxDataAgeSeconds": 120,
      "Min24hQuoteVolume": 1000000,
      "MinPrice": 1e-08,
      "MaxPrice": 1000000,
      "StrategyScoreWeight": 2,
      "HandoffEnabled": true,
      "AllowedQuoteAssets": [
        "USDT"
      ]
    },
    "Binance": {
      "Enabled": true,
      "RestBaseUrl": "https://demo-fapi.binance.com",
      "WebSocketBaseUrl": "wss://fstream.binancefuture.com",
      "ReconciliationIntervalMinutes": 1,
      "SeedSymbols": [
        "BTCUSDT",
        "ETHUSDT",
        "SOLUSDT"
      ]
    },
    "HistoricalGapFiller": {
      "Enabled": true,
      "ScanIntervalMinutes": 5,
      "LookbackCandles": 200,
      "MaxCandlesPerRequest": 500,
      "MaxRetryAttempts": 3,
      "RetryDelaySeconds": 2,
      "Symbols": [
        "BTCUSDT",
        "ETHUSDT",
        "SOLUSDT"
      ]
    }
  },
  "ExecutionSafety": {
    "Runtime": {
      "AllowInternalDemoExecution": false
    },
    "DataLatencyGuard": {
      "StaleDataThresholdSeconds": 60,
      "StopDataThresholdSeconds": 120,
      "ClockDriftThresholdSeconds": 5
    }
  },
  "Alerting": {
    "ApplicationName": "CoinBot Worker",
    "Telegram": {
      "Enabled": false,
      "BotToken": "",
      "ChatId": ""
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "BotExecutionPilot": {
    "Enabled": true,
    "PilotActivationEnabled": true,
    "AllowNonDevelopmentHost": true,
    "AllowGlobalSwitchBypass": true,
    "SignalEvaluationMode": "Live",
    "DefaultSymbol": "BTCUSDT",
    "Timeframe": "1m",
    "DefaultLeverage": 1,
    "DefaultMarginType": "ISOLATED",
    "AllowedSymbols": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "MaxPilotOrderNotional": "250",
    "PerBotCooldownSeconds": 120,
    "PerSymbolCooldownSeconds": 60,
    "MaxOpenPositionsPerUser": 3,
    "PrivatePlaneFreshnessThresholdSeconds": 120,
    "PrimeHistoricalCandleCount": 200,
    "LongRegimeFilterEnabled": false,
    "LongRegimeMaxEntryRsi": 68,
    "LongRegimeMinMacdHistogram": -0.005,
    "LongRegimeMinBollingerWidthPercentage": 0.07
  },
  "ExchangeSync": {
    "Binance": {
      "Enabled": true,
      "RestBaseUrl": "https://demo-fapi.binance.com",
      "WebSocketBaseUrl": "wss://fstream.binancefuture.com",
      "ReconciliationIntervalMinutes": 1
    }
  }
}
